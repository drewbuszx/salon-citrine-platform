{
  "name": "salon-citrine-platform",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "dev:admin": "npm run dev --workspace apps/admin",
    "build": "npm run build --workspaces --if-present",
    "db:generate-seed": "npm run generate-seed --workspace packages/db"
  }
}
