---
/**
 * Stakeholder demo: embed booking in an iframe (same pattern as saloncitrineindy.com).
 * Live at /book/embed-demo after book Worker deploy.
 */
import "@saloncitrine/theme/tokens.css";
import { BUSINESS } from "@saloncitrine/shared";

const bookBase =
  import.meta.env.PUBLIC_BOOK_URL?.replace(/\/$/, "") ??
  `${Astro.url.origin}${import.meta.env.BASE_URL}`.replace(/\/$/, "");

const embedSrc = `${bookBase}?embed=1`;

const iframeSnippet = `<!-- Salon Citrine booking embed — paste on saloncitrineindy.com -->
<iframe
  id="booking-embed"
  src="${embedSrc}"
  title="Book an appointment at ${BUSINESS.name}"
  style="width:100%;min-height:720px;border:0;border-radius:8px;background:var(--color-cream,#f7f2ea);"
  loading="lazy"
  allow="payment *"
></iframe>

<!-- Optional: auto-resize iframe when booking posts height hints (see embed-resize.ts) -->
<script>
  window.addEventListener("message", function (event) {
    if (event.data && event.data.type === "saloncitrine:embed-height") {
      var iframe = document.getElementById("booking-embed");
      if (iframe && typeof event.data.height === "number") {
        iframe.style.height = event.data.height + "px";
        iframe.style.minHeight = "0";
      }
    }
  });
</script>`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Embed demo · {BUSINESS.name}</title>
    <style>
      :root {
        font-family: var(--font-body);
        color: var(--color-stone-700);
        background: var(--color-cream);
      }
      body {
        margin: 0;
        min-height: 100vh;
      }
      .demo {
        max-width: 52rem;
        margin: 0 auto;
        padding: var(--space-8) var(--space-5) var(--space-12);
      }
      .demo__kicker {
        margin: 0 0 var(--space-2);
        font-size: var(--text-xs);
        font-weight: 600;
        letter-spacing: var(--tracking-widest);
        text-transform: uppercase;
        color: var(--color-stone-500);
      }
      .demo__title {
        margin: 0 0 var(--space-3);
        font-family: var(--font-serif);
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        font-weight: 500;
        line-height: var(--leading-tight);
        color: var(--color-text);
      }
      .demo__lead {
        margin: 0 0 var(--space-6);
        font-size: var(--text-sm);
        line-height: var(--leading-relaxed);
        color: var(--color-stone-500);
        max-width: 38rem;
      }
      .demo__frame-wrap {
        border: 1px solid var(--color-stone-200);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        background: var(--color-cream);
      }
      .demo__frame {
        display: block;
        width: 100%;
        min-height: 720px;
        border: 0;
        background: var(--color-cream);
      }
      .demo__notes {
        margin-top: var(--space-5);
        font-size: var(--text-sm);
        line-height: var(--leading-relaxed);
        color: var(--color-stone-500);
      }
      .demo__notes p {
        margin: 0 0 var(--space-3);
      }
      .demo__code {
        margin-top: var(--space-5);
        padding: var(--space-4);
        border-radius: var(--radius-md);
        background: var(--color-cream-deep);
        border: 1px solid var(--color-stone-200);
        font-family: ui-monospace, "Cascadia Code", "Source Code Pro", monospace;
        font-size: var(--text-xs);
        line-height: var(--leading-normal);
        overflow-x: auto;
        white-space: pre-wrap;
        word-break: break-all;
        color: var(--color-stone-700);
      }
    </style>
  </head>
  <body>
    <div class="demo">
      <p class="demo__kicker">Guest booking · embed mode</p>
      <h1 class="demo__title">Book without leaving the salon site</h1>
      <p class="demo__lead">
        This page mirrors how booking embeds on saloncitrineindy.com — minimal chrome, full funnel,
        cream panel. Use it to demo iframe integration to stakeholders today.
      </p>
      <div class="demo__frame-wrap">
        <iframe
          id="booking-embed"
          class="demo__frame"
          src={embedSrc}
          title={`Book an appointment at ${BUSINESS.name}`}
          loading="lazy"
          allow="payment *"
        ></iframe>
      </div>
      <div class="demo__notes">
        <p>
          <strong>Integration notes:</strong> Include <code>allow="payment *"</code> so Stripe
          deposit checkout works inside the iframe. Match the iframe background to
          <code>var(--color-cream)</code> for a seamless edge blend on the marketing site.
        </p>
        <p>
          <strong>Height sync:</strong> Booking posts <code>saloncitrine:embed-height</code> messages
          to the parent page (see snippet below). This demo listens and resizes the iframe so only
          the host page scrolls — no nested scrollbars inside the widget.
        </p>
      </div>
      <pre class="demo__code" aria-label="iframe snippet">{iframeSnippet}</pre>
    </div>
    <script is:inline>
      window.addEventListener("message", function (event) {
        if (event.data && event.data.type === "saloncitrine:embed-height") {
          var iframe = document.getElementById("booking-embed");
          if (iframe && typeof event.data.height === "number") {
            iframe.style.height = event.data.height + "px";
            iframe.style.minHeight = "0";
          }
        }
      });
    </script>
  </body>
</html>
