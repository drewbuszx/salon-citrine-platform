---
export const prerender = false;

import BookingLayout from "../layouts/BookingLayout.astro";
import ReturningClientsModal from "../components/ReturningClientsModal.astro";
import NotAcceptingNewClientsModal from "../components/NotAcceptingNewClientsModal.astro";
import {
  EXISTING_CLIENT_ACK_PARAM,
  fetchReturningOnlyStaffSlugs,
  fetchStaffForService,
  formatDuration,
  formatPrice,
  getServiceById,
  getStaffBySlug,
  hasExistingClientAck,
  isAcceptingNewClients,
  parseServiceIdsFromParams,
  staffFirstName,
} from "../lib/booking-data";
import { datetimeUrl, bookingFlagsFromUrl } from "../lib/booking-flow";
import { withBase } from "../lib/paths";

const serviceParam = Astro.url.searchParams.get("service");
const servicesParam = Astro.url.searchParams.get("services");
const stylistSlug = Astro.url.searchParams.get("stylist");
const returningAck = Astro.url.searchParams.get("returning") === "1";
const existingAck = hasExistingClientAck(Astro.url.searchParams);

const serviceIds = parseServiceIdsFromParams(servicesParam, serviceParam);
const primaryServiceId = serviceIds[0] ?? serviceParam;

const [primaryService, preselectedStylist, returningOnlySlugs] = await Promise.all([
  getServiceById(primaryServiceId),
  getStaffBySlug(stylistSlug),
  primaryServiceId ? fetchReturningOnlyStaffSlugs(primaryServiceId) : Promise.resolve(new Set<string>()),
]);

if (!primaryService) {
  return Astro.redirect(withBase());
}

const resolvedServiceIds =
  serviceIds.length > 0 ? serviceIds : [primaryService.id];

const flowFlags = {
  ...bookingFlagsFromUrl(Astro.url),
  showStylistStep: true,
  returningAck,
  existingAck,
};

if (preselectedStylist) {
  return Astro.redirect(
    datetimeUrl(resolvedServiceIds, preselectedStylist.slug, flowFlags),
  );
}

const staff = await fetchStaffForService(primaryService.id);
const bookBase = withBase();
const returningOnlyJson = JSON.stringify([...returningOnlySlugs]);

function formatStaffRole(role: string): string {
  return role.replace(/_/g, " ").replace(/\b\w/g, (char) => char.toUpperCase());
}
---

<BookingLayout title="Choose a stylist" step="stylist" showStylistStep embed={flowFlags.embed}>
  <header class="stylist-page__header">
    <p class="stylist-page__kicker">Almost there</p>
    <h1>Choose a professional</h1>
    <p class="lead">
      For <strong>{primaryService.name}</strong>
      {resolvedServiceIds.length > 1 && ` + ${resolvedServiceIds.length - 1} more`} — select who you'd like to book with.
    </p>
  </header>

  <ul class="stylist-grid" data-stylist-list role="list" aria-label="Professionals">
    <li class="stylist-grid__item">
      <div
        class="stylist-card stylist-card--any stylist-card--selected"
        aria-current="true"
      >
        <span class="stylist-card__media">
          <span class="stylist-card__avatar stylist-card__avatar--any" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke-linecap="round" stroke-linejoin="round"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
        </span>
        <span class="stylist-card__body">
          <span class="stylist-card__name">Any Professional</span>
          <span class="stylist-card__role">No preference</span>
          <span class="stylist-card__hint">Select a team member below to continue</span>
        </span>
      </div>
    </li>

    {
      staff.map((member) => {
        const isReturningRestricted = returningOnlySlugs.has(member.slug);
        const isNotAcceptingNew = !isAcceptingNewClients(member);
        const isRestricted = isReturningRestricted || isNotAcceptingNew;
        const datetimeHref = datetimeUrl(resolvedServiceIds, member.slug, flowFlags);
        const continueHref = `${datetimeHref}${datetimeHref.includes("?") ? "&" : "?"}returning=1`;
        const existingContinueHref = `${datetimeHref}${datetimeHref.includes("?") ? "&" : "?"}${EXISTING_CLIENT_ACK_PARAM}=1`;
        const cardLabel = isRestricted
          ? `${member.name}, ${formatStaffRole(member.role)} — requires confirmation`
          : `Book with ${member.name}, ${formatStaffRole(member.role)}`;

        return (
          <li class="stylist-grid__item">
            <button
              type="button"
              class="stylist-card"
              aria-label={cardLabel}
              data-stylist-select={isRestricted ? "" : undefined}
              data-stylist-nav={!isRestricted ? datetimeHref : undefined}
              data-stylist-name={member.name}
              data-stylist-first-name={staffFirstName(member.name)}
              data-stylist-slug={member.slug}
              data-continue-href={continueHref}
              data-existing-continue-href={existingContinueHref}
              data-returning-restricted={isReturningRestricted ? "1" : ""}
              data-not-accepting={isNotAcceptingNew ? "1" : ""}
            >
              <span class="stylist-card__media">
                {member.photoUrl ? (
                  <img
                    class="stylist-card__photo"
                    src={member.photoUrl}
                    alt=""
                    width="120"
                    height="120"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <span class="stylist-card__avatar" aria-hidden="true">
                    {member.name.charAt(0)}
                  </span>
                )}
              </span>
              <span class="stylist-card__body">
                <span class="stylist-card__name">{member.name}</span>
                <span class="stylist-card__role">{formatStaffRole(member.role)}</span>
                {
                  isNotAcceptingNew ? (
                    <span class="stylist-card__badge">Not accepting new clients</span>
                  ) : isReturningRestricted ? (
                    <span class="stylist-card__badge">Returning clients only</span>
                  ) : null
                }
                {member.bio && (
                  <span class="stylist-card__bio">{member.bio}</span>
                )}
              </span>
              <span class="stylist-card__footer">
                <span class="stylist-card__action">Select</span>
              </span>
            </button>
          </li>
        );
      })
    }
  </ul>

  {
    staff.length === 0 && (
      <p class="empty">
        No professionals offer this service right now.{" "}
        <a href={bookBase}>Choose another service</a>
      </p>
    )
  }

  <ReturningClientsModal
    serviceName={primaryService.name}
    serviceDescription={primaryService.description}
    stylistName=""
    durationLabel={formatDuration(primaryService.durationMinutes)}
    priceLabel={formatPrice(primaryService)}
    continueHref={bookBase}
    chooseStylistHref={`${withBase("cart/")}?services=${resolvedServiceIds.join(",")}`}
  />

  <NotAcceptingNewClientsModal
    stylistFirstName=""
    stylistSlug=""
    continueHref={bookBase}
    chooseStylistHref={`${withBase("cart/")}?services=${resolvedServiceIds.join(",")}`}
  />

  <p class="back">
    <a href={`${withBase("cart/")}?services=${resolvedServiceIds.join(",")}`}>
      ← Back to cart
    </a>
  </p>
</BookingLayout>

<script
  define:vars={{
    returningOnlyJson,
    serviceDuration: formatDuration(primaryService.durationMinutes),
    servicePrice: formatPrice(primaryService),
  }}
>
  const returningOnly = new Set(JSON.parse(returningOnlyJson));
  const returningModal = document.getElementById("returning-clients-modal");
  const newClientsModal = document.getElementById("not-accepting-new-clients-modal");
  const stylistNameEl = returningModal?.querySelector(".returning-modal__stylist-name");
  const continueBtn = returningModal?.querySelector("[data-returning-continue]");
  const metaEl = returningModal?.querySelector(".returning-modal__meta");
  const newClientsContinueBtn = newClientsModal?.querySelector("[data-new-clients-continue]");
  const newClientsFirstNameEls = newClientsModal?.querySelectorAll(
    ".new-clients-modal__body strong",
  );
  const anyProCard = document.querySelector(".stylist-card--any");
  const staffCards = Array.from(
    document.querySelectorAll(".stylist-card[data-stylist-nav], .stylist-card[data-stylist-select]"),
  );

  function setSelectedCard(card) {
    document.querySelectorAll(".stylist-card--selected").forEach((el) => {
      el.classList.remove("stylist-card--selected");
    });
    card?.classList.add("stylist-card--selected");
  }

  function resetAnyProSelected() {
    anyProCard?.classList.add("stylist-card--selected");
  }

  function openReturningModal(name, href) {
    if (stylistNameEl) stylistNameEl.textContent = name;
    if (metaEl) metaEl.textContent = `${serviceDuration} · ${servicePrice}`;
    if (continueBtn) continueBtn.dataset.continueHref = href;
    returningModal?.removeAttribute("hidden");
    returningModal?.setAttribute("aria-hidden", "false");
    document.body.classList.add("returning-modal-open");
    continueBtn?.focus();
  }

  function openNewClientsModal(firstName, slug, href) {
    if (newClientsFirstNameEls) {
      newClientsFirstNameEls.forEach((el) => {
        el.textContent = firstName;
      });
    }
    if (newClientsContinueBtn) {
      newClientsContinueBtn.dataset.continueHref = href;
      newClientsContinueBtn.dataset.stylistSlug = slug;
    }
    newClientsModal?.removeAttribute("hidden");
    newClientsModal?.setAttribute("aria-hidden", "false");
    document.body.classList.add("new-clients-modal-open");
    newClientsContinueBtn?.focus();
  }

  staffCards.forEach((button, index) => {
    button.addEventListener("focus", () => setSelectedCard(button));
    button.addEventListener("blur", () => {
      if (!staffCards.some((card) => card === document.activeElement)) {
        resetAnyProSelected();
      }
    });

    button.addEventListener("keydown", (event) => {
      if (!["ArrowRight", "ArrowLeft", "ArrowDown", "ArrowUp"].includes(event.key)) {
        return;
      }

      event.preventDefault();
      const columns = window.matchMedia("(min-width: 56rem)").matches
        ? 3
        : window.matchMedia("(min-width: 36rem)").matches
          ? 2
          : 1;
      const delta =
        event.key === "ArrowRight"
          ? 1
          : event.key === "ArrowLeft"
            ? -1
            : event.key === "ArrowDown"
              ? columns
              : -columns;
      const nextIndex = (index + delta + staffCards.length) % staffCards.length;
      staffCards[nextIndex]?.focus();
    });

    button.addEventListener("click", () => {
      setSelectedCard(button);

      const name = button.dataset.stylistName ?? "";
      const firstName = button.dataset.stylistFirstName ?? name;
      const slug = button.dataset.stylistSlug ?? "";
      const notAccepting = button.dataset.notAccepting === "1";
      const returningRestricted = button.dataset.returningRestricted === "1";
      const navigateHref = button.dataset.stylistNav;

      if (notAccepting) {
        openNewClientsModal(
          firstName,
          slug,
          button.dataset.existingContinueHref ?? "",
        );
        return;
      }

      if (returningRestricted) {
        openReturningModal(name, button.dataset.continueHref ?? "");
        return;
      }

      if (navigateHref) {
        window.location.href = navigateHref;
      }
    });
  });
</script>

<style>
  .stylist-page__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .stylist-page__kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-sage);
  }

  .lead {
    color: var(--color-gray);
    margin-bottom: 0;
  }

  .stylist-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 36rem) {
    .stylist-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 56rem) {
    .stylist-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .stylist-grid__item {
    min-width: 0;
  }

  .stylist-card {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    min-height: 100%;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 0.75rem);
    background: var(--color-booking-card-bg);
    text-decoration: none;
    text-align: center;
    color: inherit;
    font: inherit;
    cursor: default;
    overflow: hidden;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease;
  }

  button.stylist-card {
    cursor: pointer;
  }

  .stylist-card--any {
    pointer-events: none;
  }

  .stylist-card--selected,
  button.stylist-card:hover,
  button.stylist-card:focus-visible {
    border-color: var(--color-citrine);
    box-shadow:
      0 0 0 1px var(--color-citrine),
      0 8px 28px var(--color-card-shadow, rgba(60, 61, 60, 0.08));
    outline: none;
  }

  .stylist-card--selected {
    background: var(--color-citrine-muted);
  }

  .stylist-card__media {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-stone-100);
  }

  .stylist-card__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .stylist-card__avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: var(--color-dusty-rose);
    color: var(--color-white);
    font-family: var(--font-sans);
    font-size: 2rem;
    font-weight: 600;
  }

  .stylist-card__avatar--any {
    background: linear-gradient(
      145deg,
      var(--color-citrine-muted),
      var(--color-dusty-rose-muted)
    );
    color: var(--color-citrine-dark);
  }

  .stylist-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1rem 0.5rem;
    flex: 1;
  }

  .stylist-card__name {
    display: block;
    font-weight: 600;
    font-size: 1.1rem;
    line-height: 1.25;
  }

  .stylist-card__role {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .stylist-card__hint {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.85rem;
    color: var(--color-gray);
  }

  .stylist-card__badge {
    display: inline-block;
    align-self: center;
    margin-top: 0.35rem;
    padding: 0.2rem 0.55rem;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(255, 210, 80, 0.35);
    color: var(--color-charcoal);
    border-radius: var(--radius-sm, 0.35rem);
  }

  .stylist-card__bio {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 0.35rem;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--color-gray);
  }

  .stylist-card__footer {
    padding: 0.75rem 1rem 1rem;
  }

  .stylist-card__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    width: 100%;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.65rem 1.25rem;
    border: 1px solid var(--color-text);
    border-radius: var(--radius-pill, 999px);
    background: var(--color-text);
    color: var(--color-bg);
    transition:
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  button.stylist-card:hover .stylist-card__action,
  button.stylist-card:focus-visible .stylist-card__action,
  .stylist-card--selected:not(.stylist-card--any) .stylist-card__action {
    background: var(--color-citrine);
    border-color: var(--color-citrine);
    color: var(--color-black);
  }

  .empty {
    padding: 1.5rem;
    text-align: center;
    background: var(--color-light);
    color: var(--color-gray);
    border-radius: var(--radius-md, 0.75rem);
  }

  .back {
    margin-top: 1.5rem;
    text-align: center;
  }

  [data-theme="dark"] .stylist-card {
    border-color: var(--color-stone-300);
    background: var(--color-booking-card-bg);
  }

  [data-theme="dark"] .stylist-card__media {
    background: var(--color-stone-200);
  }

  [data-theme="dark"] .stylist-card--selected,
  [data-theme="dark"] button.stylist-card:hover,
  [data-theme="dark"] button.stylist-card:focus-visible {
    border-color: var(--color-citrine);
    box-shadow:
      0 0 0 1px var(--color-citrine),
      0 8px 28px var(--color-card-shadow, rgba(0, 0, 0, 0.35));
  }

  [data-theme="dark"] .stylist-card--selected {
    background: var(--color-citrine-muted);
  }

  [data-theme="dark"] .stylist-card__avatar {
    background: var(--color-dusty-rose);
    color: var(--color-white);
  }

  [data-theme="dark"] .stylist-card__avatar--any {
    background: linear-gradient(
      145deg,
      var(--color-citrine-muted),
      rgba(174, 148, 143, 0.2)
    );
    color: var(--color-citrine);
  }

  [data-theme="dark"] .stylist-card__badge {
    background: rgba(231, 172, 70, 0.22);
    color: var(--color-text);
  }

  [data-theme="dark"] .empty {
    background: var(--color-stone-100);
    border: 1px solid var(--color-stone-300);
  }

  [data-theme="dark"] button.stylist-card:hover .stylist-card__action,
  [data-theme="dark"] button.stylist-card:focus-visible .stylist-card__action,
  [data-theme="dark"] .stylist-card--selected:not(.stylist-card--any) .stylist-card__action {
    background: var(--color-citrine);
    border-color: var(--color-citrine);
    color: var(--color-black);
  }
</style>
