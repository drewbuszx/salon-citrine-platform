---
import BookingLayout from "../layouts/BookingLayout.astro";
import {
  fetchBookableStaff,
  filterStaffForService,
  getServiceById,
  getStaffBySlug,
} from "../lib/booking-data";
import { withBase } from "../lib/paths";

const serviceId = Astro.url.searchParams.get("service");
const stylistSlug = Astro.url.searchParams.get("stylist");

const [service, preselectedStylist, allStaff] = await Promise.all([
  getServiceById(serviceId),
  getStaffBySlug(stylistSlug),
  fetchBookableStaff(),
]);

if (!service) {
  return Astro.redirect(`${withBase()}?${stylistSlug ? `stylist=${stylistSlug}` : ""}`);
}

const staff = filterStaffForService(allStaff, service, preselectedStylist);
---

<BookingLayout title="Choose a stylist" step={2}>
  <h1>Choose a stylist</h1>
  <p class="lead">
    For <strong>{service.name}</strong>
  </p>

  <ul class="stylist-list">
    {
      staff.map((member) => (
        <li>
          <a
            class="stylist-card"
            href={`${withBase("datetime/")}?service=${service.id}&stylist=${member.slug}`}
          >
            <span class="stylist-card__avatar" aria-hidden="true">
              {member.name.charAt(0)}
            </span>
            <span class="stylist-card__body">
              <span class="stylist-card__name">{member.name}</span>
              <span class="stylist-card__role">{member.role.replace("_", " ")}</span>
              {member.bio && <span class="stylist-card__bio">{member.bio}</span>}
            </span>
          </a>
        </li>
      ))
    }
  </ul>

  <p>
    <a href={`${withBase()}?${stylistSlug ? `stylist=${stylistSlug}` : ""}`}>
      ← Back to services
    </a>
  </p>
</BookingLayout>

<style>
  .lead {
    color: var(--color-gray);
  }

  .stylist-list {
    list-style: none;
    margin: 1.5rem 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .stylist-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem;
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  .stylist-card:hover,
  .stylist-card:focus-visible {
    border-color: var(--color-citrine);
  }

  .stylist-card__avatar {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-dusty-rose);
    color: var(--color-white);
    font-family: var(--font-sans);
    font-weight: 600;
    border-radius: 50%;
  }

  .stylist-card__name {
    display: block;
    font-weight: 600;
  }

  .stylist-card__role {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .stylist-card__bio {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.95rem;
    color: var(--color-gray);
  }
</style>
