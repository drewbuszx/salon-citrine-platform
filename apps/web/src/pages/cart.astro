---
export const prerender = false;

import BookingLayout from "../layouts/BookingLayout.astro";
import ReturningClientsModal from "../components/ReturningClientsModal.astro";
import NotAcceptingNewClientsModal from "../components/NotAcceptingNewClientsModal.astro";
import Button from "@saloncitrine/theme/components/Button.astro";
import {
  estimateCartPrice,
  EXISTING_CLIENT_ACK_PARAM,
  fetchCartSuggestions,
  fetchReturningClientsOnly,
  fetchServicesByIds,
  formatDuration,
  formatPrice,
  getServiceById,
  getStaffBySlug,
  hasExistingClientAck,
  isAcceptingNewClients,
  parseServiceIdsFromParams,
  staffFirstName,
  sumServiceDuration,
} from "../lib/booking-data";
import { withBase } from "../lib/paths";

const serviceParam = Astro.url.searchParams.get("service");
const servicesParam = Astro.url.searchParams.get("services");
const stylistSlug = Astro.url.searchParams.get("stylist");
const showStylistStep = Astro.url.searchParams.get("flow") === "stylist";
const returningAck = Astro.url.searchParams.get("returning") === "1";
const existingAck = hasExistingClientAck(Astro.url.searchParams);

const serviceIds = parseServiceIdsFromParams(servicesParam, serviceParam);
const primaryServiceId = serviceIds[0] ?? serviceParam;

const [primaryService, stylist, cartServices, suggestions, returningClientsOnly] =
  await Promise.all([
  getServiceById(primaryServiceId),
  getStaffBySlug(stylistSlug),
  fetchServicesByIds(serviceIds.length > 0 ? serviceIds : primaryServiceId ? [primaryServiceId] : [], stylistSlug),
  primaryServiceId && stylistSlug
    ? fetchCartSuggestions(stylistSlug, primaryServiceId)
    : Promise.resolve({
        requiredConsultation: [],
        addons: [],
        consultations: [],
        relatedOptional: [],
      }),
  primaryServiceId && stylistSlug
    ? fetchReturningClientsOnly(stylistSlug, primaryServiceId)
    : Promise.resolve(false),
]);

if (!primaryService || !stylist) {
  return Astro.redirect(withBase());
}

const showReturningModal = returningClientsOnly && !returningAck;
const showNewClientsModal = !isAcceptingNewClients(stylist) && !existingAck;

const cartParams = new URLSearchParams();
cartParams.set("services", serviceIds.length > 0 ? serviceIds.join(",") : primaryService.id);
cartParams.set("stylist", stylist.slug);
if (showStylistStep) cartParams.set("flow", "stylist");
if (returningAck) cartParams.set("returning", "1");
cartParams.set(EXISTING_CLIENT_ACK_PARAM, "1");
const continueHref = `${withBase("cart/")}?${cartParams.toString()}`;

const returningContinueParams = new URLSearchParams(cartParams);
returningContinueParams.set("returning", "1");
const returningContinueHref = `${withBase("cart/")}?${returningContinueParams.toString()}`;

const chooseStylistParams = new URLSearchParams();
chooseStylistParams.set("service", primaryService.id);
const chooseStylistHref = `${withBase("stylist/")}?${chooseStylistParams.toString()}`;

const initialCartIds =
  cartServices.length > 0 ? cartServices.map((svc) => svc.id) : [primaryService.id];

const totalMinutes = sumServiceDuration(
  cartServices.length > 0 ? cartServices : [primaryService],
);
const estimatedPrice = estimateCartPrice(
  cartServices.length > 0 ? cartServices : [primaryService],
);

const sections = [
  suggestions.requiredConsultation.length > 0 && {
    key: "required",
    title: "Consultation required",
    description:
      "This service requires a consultation. Add one before continuing.",
    required: true,
    services: suggestions.requiredConsultation,
  },
  suggestions.addons.length > 0 && {
    key: "addons",
    title: "Add-ons",
    description: "Enhance your appointment with these extras.",
    services: suggestions.addons,
  },
  suggestions.consultations.length > 0 && {
    key: "consultations",
    title: "Consultations",
    description: "Not sure yet? Book a quick consult with your stylist.",
    services: suggestions.consultations,
  },
  suggestions.relatedOptional.length > 0 && {
    key: "related",
    title: "You might also like",
    services: suggestions.relatedOptional,
  },
].filter(Boolean);

const cartJson = JSON.stringify(
  (cartServices.length > 0 ? cartServices : [primaryService]).map((svc) => ({
    id: svc.id,
    name: svc.name,
    durationMinutes: svc.durationMinutes,
    priceLabel: formatPrice(svc),
    isPrimary: svc.id === primaryService.id,
  })),
);

const suggestionsJson = JSON.stringify(
  sections.map((section) => ({
    ...section,
    services: section.services.map((svc) => ({
      id: svc.id,
      name: svc.name,
      description: svc.description,
      durationMinutes: svc.durationMinutes,
      priceLabel: formatPrice(svc),
    })),
  })),
);

const datetimeBase = withBase("datetime/");
const bookBase = withBase();
---

<BookingLayout
  title="Your appointment"
  step="cart"
  showStylistStep={showStylistStep}
>
  {
    showNewClientsModal && (
      <NotAcceptingNewClientsModal
        stylistFirstName={staffFirstName(stylist.name)}
        stylistSlug={stylist.slug}
        continueHref={continueHref}
        chooseStylistHref={withBase()}
        autoOpen={true}
      />
    )
  }

  {
    showReturningModal && (
      <ReturningClientsModal
        serviceName={primaryService.name}
        serviceDescription={primaryService.description}
        stylistName={stylist.name}
        durationLabel={formatDuration(
          sumServiceDuration(
            cartServices.length > 0 ? cartServices : [primaryService],
          ),
        )}
        priceLabel={formatPrice(primaryService)}
        continueHref={returningContinueHref}
        chooseStylistHref={chooseStylistHref}
        autoOpen={!showNewClientsModal}
      />
    )
  }

  <header class="cart-page__header">
    <p class="cart-page__kicker">Build your visit</p>
    <h1>Your appointment</h1>
    <p class="lead">
      with <strong>{stylist.name}</strong> — add extras or continue when ready.
    </p>
  </header>

  <section class="cart" data-service-cart aria-live="polite">
    <div class="cart__primary">
      <h2 class="cart__heading">In your cart</h2>
      <ul class="cart__items" data-cart-items></ul>
    </div>

    {
      sections.length > 0 && (
        <div class="cart__suggestions" data-suggestions>
          {sections.map((section) => (
            <section class="suggestion-section" data-section={section.key}>
              <header class="suggestion-section__header">
                <h3>{section.title}</h3>
                {section.description && <p>{section.description}</p>}
              </header>
              <ul class="suggestion-list" data-section-list={section.key} />
            </section>
          ))}
        </div>
      )
    }

    <footer class="cart__footer">
      <div class="cart__totals" data-cart-totals>
        <p class="cart__duration">
          Total time: <strong data-total-duration>{formatDuration(totalMinutes)}</strong>
        </p>
        {
          estimatedPrice && (
            <p class="cart__price">
              Estimated: <strong data-total-price>{estimatedPrice}</strong>
            </p>
          )
        }
      </div>

      <div class="cart__actions">
        <Button
          type="button"
          variant="primary"
          data-continue-btn
          data-datetime-base={datetimeBase}
        >
          Continue to date & time
        </Button>
      </div>
    </footer>
  </section>

  <p class="back">
    <a href={`${bookBase}?stylist=${stylist.slug}`}>← Back to services</a>
  </p>
</BookingLayout>

<script
  define:vars={{
    cartJson,
    suggestionsJson,
    stylistSlug,
    showStylistStep,
    primaryServiceId,
    existingAck,
    existingClientAckParam: EXISTING_CLIENT_ACK_PARAM,
  }}
>
  /** @type {{ id: string; name: string; durationMinutes: number; priceLabel: string; isPrimary?: boolean }[]} */
  let cart = JSON.parse(cartJson);
  /** @type {{ key: string; title: string; description?: string; required?: boolean; services: { id: string; name: string; description?: string | null; durationMinutes: number; priceLabel: string }[] }[]} */
  const suggestionSections = JSON.parse(suggestionsJson);

  const root = document.querySelector("[data-service-cart]");
  const itemsEl = root?.querySelector("[data-cart-items]");
  const continueBtn = root?.querySelector("[data-continue-btn]");
  const durationEl = root?.querySelector("[data-total-duration]");
  const priceEl = root?.querySelector("[data-total-price]");

  function formatDurationClient(totalMinutes) {
    const hours = Math.floor(totalMinutes / 60);
    const minutes = totalMinutes % 60;
    if (hours === 0) return `${minutes} min`;
    if (minutes === 0) return hours === 1 ? "1 hr" : `${hours} hr`;
    const hrLabel = hours === 1 ? "1 hr" : `${hours} hr`;
    return `${hrLabel} ${minutes} min`;
  }

  function estimatePriceClient(items) {
    let totalCents = 0;
    let hasNull = false;
    let hasVaries = false;

    for (const item of items) {
      const match = item.priceLabel.match(/^\$(\d+(?:\.\d+)?)/);
      if (!match) {
        if (item.priceLabel === "Complimentary") hasNull = true;
        continue;
      }
      totalCents += Math.round(parseFloat(match[1]) * 100);
      if (item.priceLabel.endsWith("+")) hasVaries = true;
    }

    if (totalCents === 0 && hasNull) return null;
    const dollars = totalCents / 100;
    const base = `$${Number.isInteger(dollars) ? dollars : dollars.toFixed(2)}`;
    if (hasVaries || hasNull) return `${base}+`;
    return base;
  }

  function cartHas(id) {
    return cart.some((item) => item.id === id);
  }

  function addToCart(service) {
    if (cartHas(service.id)) return;
    cart.push({ ...service, isPrimary: service.id === primaryServiceId });
    render();
  }

  function removeFromCart(id) {
    if (id === primaryServiceId) return;
    cart = cart.filter((item) => item.id !== id);
    render();
  }

  function renderCartItems() {
    if (!itemsEl) return;
    itemsEl.innerHTML = "";

    for (const item of cart) {
      const li = document.createElement("li");
      li.className = "cart-item";
      li.dataset.cartItem = item.id;

      const body = document.createElement("div");
      body.className = "cart-item__body";

      const name = document.createElement("h3");
      name.className = "cart-item__name";
      name.textContent = item.name;
      body.appendChild(name);

      const meta = document.createElement("p");
      meta.className = "cart-item__meta";
      meta.textContent = `${item.priceLabel} · ${item.durationMinutes} min`;
      body.appendChild(meta);

      li.appendChild(body);

      if (!item.isPrimary && item.id !== primaryServiceId) {
        const removeBtn = document.createElement("button");
        removeBtn.type = "button";
        removeBtn.className = "cart-item__remove";
        removeBtn.textContent = "Remove";
        removeBtn.addEventListener("click", () => removeFromCart(item.id));
        li.appendChild(removeBtn);
      } else {
        const badge = document.createElement("span");
        badge.className = "cart-item__badge";
        badge.textContent = "Primary";
        li.appendChild(badge);
      }

      itemsEl.appendChild(li);
    }
  }

  function renderSuggestions() {
    for (const section of suggestionSections) {
      const list = root?.querySelector(
        `[data-section-list="${section.key}"]`,
      );
      if (!list) continue;
      list.innerHTML = "";

      for (const service of section.services) {
        const inCart = cartHas(service.id);
        const li = document.createElement("li");
        li.className = "suggestion-card";

        const body = document.createElement("div");
        body.className = "suggestion-card__body";

        const name = document.createElement("h4");
        name.className = "suggestion-card__name";
        name.textContent = service.name;
        body.appendChild(name);

        if (service.description) {
          const desc = document.createElement("p");
          desc.className = "suggestion-card__description";
          desc.textContent = service.description;
          body.appendChild(desc);
        }

        const meta = document.createElement("p");
        meta.className = "suggestion-card__meta";
        meta.textContent = `${service.priceLabel} · ${service.durationMinutes} min`;
        body.appendChild(meta);

        li.appendChild(body);

        const action = document.createElement("button");
        action.type = "button";
        action.className = inCart
          ? "suggestion-card__action suggestion-card__action--added"
          : "suggestion-card__action";
        action.textContent = inCart ? "Added" : "Add";
        action.disabled = inCart;
        action.addEventListener("click", () => addToCart(service));
        li.appendChild(action);

        list.appendChild(li);
      }
    }
  }

  function renderTotals() {
    const totalMinutes = cart.reduce(
      (sum, item) => sum + item.durationMinutes,
      0,
    );
    if (durationEl) durationEl.textContent = formatDurationClient(totalMinutes);

    const estimated = estimatePriceClient(cart);
    if (priceEl) {
      if (estimated) {
        priceEl.textContent = estimated;
        priceEl.parentElement.hidden = false;
      } else {
        priceEl.parentElement.hidden = true;
      }
    }
  }

  function syncUrl() {
    const params = new URLSearchParams();
    params.set("services", cart.map((item) => item.id).join(","));
    params.set("stylist", stylistSlug);
    if (showStylistStep) params.set("flow", "stylist");
    if (existingAck) params.set(existingClientAckParam, "1");
    window.history.replaceState({}, "", `?${params.toString()}`);
  }

  function render() {
    renderCartItems();
    renderSuggestions();
    renderTotals();
    syncUrl();
  }

  continueBtn?.addEventListener("click", () => {
    const base = continueBtn.dataset.datetimeBase ?? "";
    const params = new URLSearchParams();
    params.set("services", cart.map((item) => item.id).join(","));
    params.set("stylist", stylistSlug);
    if (showStylistStep) params.set("flow", "stylist");
    if (existingAck) params.set(existingClientAckParam, "1");
    window.location.href = `${base}?${params.toString()}`;
  });

  renderSuggestions();
  renderCartItems();
</script>

<style>
  .cart-page__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .cart-page__kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-sage);
  }

  .lead {
    margin: 0;
    color: var(--color-gray);
  }

  .cart {
    display: grid;
    gap: 2rem;
  }

  .cart__heading {
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .cart__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  :global(.cart-item) {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1rem 1.15rem;
    background: var(--color-booking-card-bg);
    border: 1px solid var(--color-border);
  }

  :global(.cart-item__name) {
    margin: 0 0 0.35rem;
    font-size: 1.1rem;
    font-weight: 600;
  }

  :global(.cart-item__meta) {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-charcoal);
  }

  :global(.cart-item__remove) {
    padding: 0.55rem 1rem;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  :global(.cart-item__remove:hover),
  :global(.cart-item__remove:focus-visible) {
    border-color: var(--color-dusty-rose);
    color: var(--color-dusty-rose);
    outline: none;
  }

  :global(.cart-item__badge) {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.35rem 0.65rem;
    background: var(--color-sage);
    color: var(--color-white);
  }

  .cart__suggestions {
    display: grid;
    gap: 1.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-subtle);
  }

  .suggestion-section__header h3 {
    margin: 0 0 0.35rem;
    font-size: 1.15rem;
    font-weight: 600;
  }

  .suggestion-section__header p {
    margin: 0 0 1rem;
    font-size: 0.95rem;
    color: var(--color-gray);
  }

  .suggestion-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  :global(.suggestion-card) {
    display: grid;
    gap: 1rem;
    padding: 1rem 1.15rem;
    background: var(--color-light);
    border: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    :global(.suggestion-card) {
      grid-template-columns: 1fr auto;
      align-items: center;
    }
  }

  :global(.suggestion-card__name) {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    font-weight: 600;
  }

  :global(.suggestion-card__description) {
    margin: 0 0 0.5rem;
    font-size: 0.92rem;
    color: var(--color-gray);
    line-height: 1.45;
  }

  :global(.suggestion-card__meta) {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-charcoal);
  }

  :global(.suggestion-card__action) {
    padding: 0.65rem 1.25rem;
    border: 1px solid var(--color-text);
    background: var(--color-text);
    color: var(--color-bg);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
  }

  :global(.suggestion-card__action:hover:not(:disabled)),
  :global(.suggestion-card__action:focus-visible:not(:disabled)) {
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
  }

  :global(.suggestion-card__action--added),
  :global(.suggestion-card__action:disabled) {
    opacity: 0.55;
    cursor: default;
    background: var(--color-light);
    color: var(--color-gray);
    border-color: var(--color-border);
  }

  .cart__footer {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-subtle);
    display: grid;
    gap: 1.25rem;
  }

  .cart__totals {
    display: grid;
    gap: 0.35rem;
  }

  .cart__duration,
  .cart__price {
    margin: 0;
    font-size: 1rem;
  }

  .back {
    margin-top: 1.5rem;
    text-align: center;
  }
</style>
