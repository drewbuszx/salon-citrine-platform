---
export const prerender = false;

import BookingLayout from "../layouts/BookingLayout.astro";
import LocationContext from "../components/LocationContext.astro";
import ReturningClientsModal from "../components/ReturningClientsModal.astro";
import NotAcceptingNewClientsModal from "../components/NotAcceptingNewClientsModal.astro";
import {
  estimateCartPrice,
  EXISTING_CLIENT_ACK_PARAM,
  fetchCartSuggestions,
  fetchReturningClientsOnly,
  fetchServicesByIds,
  formatDuration,
  formatPrice,
  getServiceById,
  getStaffBySlug,
  hasExistingClientAck,
  isAcceptingNewClients,
  parseServiceIdsFromParams,
  staffFirstName,
  sumServiceDuration,
} from "../lib/booking-data";
import { datetimeUrl, stylistUrl, bookingFlagsFromUrl, appendFlowFlags, serviceIndexUrl, sessionFlagsFromUrl } from "../lib/booking-flow";
import { withBase } from "../lib/paths";

const serviceParam = Astro.url.searchParams.get("service");
const servicesParam = Astro.url.searchParams.get("services");
const stylistSlug = Astro.url.searchParams.get("stylist");
const returningAck = Astro.url.searchParams.get("returning") === "1";
const existingAck = hasExistingClientAck(Astro.url.searchParams);
/** Show professional step in progress when stylist not chosen yet */
const showStylistStep = !stylistSlug;

const flowFlags = {
  ...bookingFlagsFromUrl(Astro.url),
  showStylistStep,
  returningAck,
  existingAck,
};

const serviceIds = parseServiceIdsFromParams(servicesParam, serviceParam);
const primaryServiceId = serviceIds[0] ?? serviceParam;

const [primaryService, stylist, cartServices, suggestions, returningClientsOnly] =
  await Promise.all([
  getServiceById(primaryServiceId),
  getStaffBySlug(stylistSlug),
  fetchServicesByIds(serviceIds.length > 0 ? serviceIds : primaryServiceId ? [primaryServiceId] : [], stylistSlug),
  primaryServiceId && stylistSlug
    ? fetchCartSuggestions(stylistSlug, primaryServiceId)
    : Promise.resolve({
        requiredConsultation: [],
        addons: [],
        consultations: [],
        relatedOptional: [],
      }),
  primaryServiceId && stylistSlug
    ? fetchReturningClientsOnly(stylistSlug, primaryServiceId)
    : Promise.resolve(false),
]);

if (!primaryService) {
  return Astro.redirect(withBase());
}

const showReturningModal = stylist && returningClientsOnly && !returningAck;
const showNewClientsModal = stylist && !isAcceptingNewClients(stylist) && !existingAck;

const cartParams = new URLSearchParams();
cartParams.set("services", serviceIds.length > 0 ? serviceIds.join(",") : primaryService.id);
if (stylist) cartParams.set("stylist", stylist.slug);
if (returningAck) cartParams.set("returning", "1");
if (existingAck) cartParams.set(EXISTING_CLIENT_ACK_PARAM, "1");
appendFlowFlags(cartParams, flowFlags);
const continueHref = `${withBase("cart/")}?${cartParams.toString()}`;

const returningContinueParams = new URLSearchParams(cartParams);
returningContinueParams.set("returning", "1");
const returningContinueHref = `${withBase("cart/")}?${returningContinueParams.toString()}`;

const chooseStylistHref = stylistUrl(
  serviceIds.length > 0 ? serviceIds : [primaryService.id],
  flowFlags,
);

const continueTargetUrl = stylist
  ? datetimeUrl(
      serviceIds.length > 0 ? serviceIds : [primaryService.id],
      stylist.slug,
      flowFlags,
    )
  : stylistUrl(
      serviceIds.length > 0 ? serviceIds : [primaryService.id],
      flowFlags,
    );
const continueLabel = stylist ? "Continue to date & time" : "Choose a professional";

const initialCartIds =
  cartServices.length > 0 ? cartServices.map((svc) => svc.id) : [primaryService.id];

const totalMinutes = sumServiceDuration(
  cartServices.length > 0 ? cartServices : [primaryService],
);
const estimatedPrice = estimateCartPrice(
  cartServices.length > 0 ? cartServices : [primaryService],
);

const sections = [
  suggestions.requiredConsultation.length > 0 && {
    key: "required",
    title: "Consultation required",
    description:
      "This service requires a consultation. Add one before continuing.",
    required: true,
    services: suggestions.requiredConsultation,
  },
  suggestions.addons.length > 0 && {
    key: "addons",
    title: "Add-ons",
    description: "Enhance your appointment with these extras.",
    services: suggestions.addons,
  },
  suggestions.consultations.length > 0 && {
    key: "consultations",
    title: "Consultations",
    description: "Not sure yet? Book a quick consult with your stylist.",
    services: suggestions.consultations,
  },
  suggestions.relatedOptional.length > 0 && {
    key: "related",
    title: "You might also like",
    services: suggestions.relatedOptional,
  },
].filter(Boolean);

const cartJson = JSON.stringify(
  (cartServices.length > 0 ? cartServices : [primaryService]).map((svc) => ({
    id: svc.id,
    name: svc.name,
    durationMinutes: svc.durationMinutes,
    priceLabel: formatPrice(svc),
    isPrimary: svc.id === primaryService.id,
  })),
);

const suggestionsJson = JSON.stringify(
  sections.map((section) => ({
    ...section,
    services: section.services.map((svc) => ({
      id: svc.id,
      name: svc.name,
      description: svc.description,
      durationMinutes: svc.durationMinutes,
      priceLabel: formatPrice(svc),
    })),
  })),
);

const bookBase = withBase();
const sessionFlags = sessionFlagsFromUrl(Astro.url);
const backHref = serviceIndexUrl(sessionFlags, {
  stylistSlug: stylist?.slug,
});
---

<BookingLayout
  title="Your appointment"
  step="cart"
  showStylistStep={showStylistStep}
  embed={flowFlags.embed}
>
  <LocationContext />
  {
    showNewClientsModal && stylist && (
      <NotAcceptingNewClientsModal
        stylistFirstName={staffFirstName(stylist.name)}
        stylistSlug={stylist.slug}
        continueHref={continueHref}
        chooseStylistHref={chooseStylistHref}
        autoOpen={true}
      />
    )
  }

  {
    showReturningModal && stylist && (
      <ReturningClientsModal
        serviceName={primaryService.name}
        serviceDescription={primaryService.description}
        stylistName={stylist.name}
        durationLabel={formatDuration(
          sumServiceDuration(
            cartServices.length > 0 ? cartServices : [primaryService],
          ),
        )}
        priceLabel={formatPrice(primaryService)}
        continueHref={returningContinueHref}
        chooseStylistHref={chooseStylistHref}
        autoOpen={!showNewClientsModal}
      />
    )
  }

  <header class="cart-page__header">
    <p class="cart-page__kicker">Build your visit</p>
    <h1>Your appointment</h1>
    <p class="lead">
      {
        stylist ? (
          <>
            with <strong>{stylist.name}</strong> — add extras or continue when ready.
          </>
        ) : (
          <>Review your services, then choose who you'd like to book with.</>
        )
      }
    </p>
  </header>

  <div
    class="cart-page"
    data-service-cart
    data-cart-json={cartJson}
    data-suggestions-json={suggestionsJson}
    data-stylist-slug={stylistSlug ?? ""}
    data-primary-service-id={primaryServiceId}
    data-existing-ack={existingAck ? "true" : "false"}
    data-existing-client-ack-param={EXISTING_CLIENT_ACK_PARAM}
    data-continue-url={continueTargetUrl}
    aria-live="polite"
  >
    <section class="cart">
      <div class="cart__primary cart__tray">
        <h2 class="cart__heading">In your cart</h2>
        <ul class="cart__items" data-cart-items></ul>
      </div>

      {
        sections.length > 0 && (
          <div class="cart__suggestions cart__tray" data-suggestions>
            {sections.map((section) => (
              <section
                class:list={[
                  "suggestion-section",
                  section.required && "suggestion-section--required",
                ]}
                data-section={section.key}
              >
                <header class="suggestion-section__header">
                  <h3>{section.title}</h3>
                  {section.description && <p>{section.description}</p>}
                </header>
                <ul class="suggestion-list" data-section-list={section.key} />
              </section>
            ))}
          </div>
        )
      }

      <footer class="cart__footer cart__footer--desktop">
        <div class="cart__totals" data-cart-totals>
          <p class="cart__duration">
            Total time: <strong data-total-duration>{formatDuration(totalMinutes)}</strong>
          </p>
          <p
            class="cart__price"
            data-total-price-row
            hidden={!estimatedPrice}
          >
            Estimated: <strong data-total-price>{estimatedPrice ?? ""}</strong>
          </p>
        </div>

        <div class="cart__actions">
          <button type="button" class="cart-cta" data-continue-btn>
            {continueLabel}
          </button>
        </div>
      </footer>
    </section>

    <aside class="cart-sticky" aria-label="Appointment summary">
      <div class="cart-sticky__inner">
        <div class="cart-sticky__totals">
          <p class="cart-sticky__duration">
            <span class="cart-sticky__label">Time</span>
            <strong data-total-duration>{formatDuration(totalMinutes)}</strong>
          </p>
          <p
            class="cart-sticky__price"
            data-total-price-row
            hidden={!estimatedPrice}
          >
            <span class="cart-sticky__label">Est.</span>
            <strong data-total-price>{estimatedPrice ?? ""}</strong>
          </p>
        </div>
        <button type="button" class="cart-sticky__cta" data-continue-btn>
          {continueLabel}
        </button>
      </div>
    </aside>
  </div>

  <p class="back">
    <a href={backHref}>
      ← Back to services
    </a>
  </p>
</BookingLayout>

<script src="../scripts/booking-cart-client.ts"></script>

<style>
  .cart-page__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .cart-page__kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-sage);
  }

  .lead {
    margin: 0;
    color: var(--color-gray);
  }

  .cart-page {
    position: relative;
    padding-bottom: calc(5.75rem + env(safe-area-inset-bottom, 0px));
  }

  .cart {
    display: grid;
    gap: 1.75rem;
  }

  .cart__tray {
    padding: clamp(1rem, 3vw, 1.35rem);
    background: var(--color-stone-100);
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-lg);
  }

  .cart--busy .cart__items,
  .cart--busy .cart__suggestions {
    opacity: 0.72;
    transition: opacity var(--transition-fast);
  }

  .cart-page[aria-busy="true"]::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: color-mix(in srgb, var(--color-stone-100) 35%, transparent);
    border-radius: var(--radius-lg);
  }

  .cart__heading {
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-stone-600);
  }

  .cart__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  :global(.cart-item) {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1rem 1.15rem;
    background: var(--color-booking-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  :global(.cart-item__name) {
    margin: 0 0 0.35rem;
    font-size: 1.1rem;
    font-weight: 600;
  }

  :global(.cart-item__meta) {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-stone-600);
  }

  :global(.cart-item__price) {
    font-weight: 600;
    color: var(--color-text);
  }

  :global(.cart-item__remove) {
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--color-stone-300);
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      border-color var(--transition-base),
      color var(--transition-base),
      background var(--transition-base);
  }

  :global(.cart-item__remove:hover),
  :global(.cart-item__remove:focus-visible) {
    border-color: var(--color-dusty-rose);
    color: var(--color-dusty-rose);
    outline: none;
  }

  :global(.cart-item__badge) {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-pill);
    background: var(--color-citrine-muted);
    color: var(--color-citrine-dark);
    border: 1px solid color-mix(in srgb, var(--color-citrine) 35%, transparent);
  }

  .cart__suggestions {
    display: grid;
    gap: 1.5rem;
  }

  .suggestion-section--required {
    padding: 0.85rem;
    border-radius: var(--radius-md);
    border: 1px solid color-mix(in srgb, var(--color-citrine) 35%, var(--color-stone-200));
    background: color-mix(in srgb, var(--color-citrine) 6%, var(--color-stone-100));
  }

  .suggestion-section__header h3 {
    margin: 0 0 0.35rem;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .suggestion-section__header p {
    margin: 0 0 1rem;
    font-size: 0.92rem;
    color: var(--color-gray);
    line-height: 1.45;
  }

  .suggestion-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  :global(.suggestion-list--pills) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  :global(.suggestion-pill-wrap) {
    list-style: none;
  }

  :global(.suggestion-pill) {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.55rem;
    min-height: var(--touch-target-min, 2.75rem);
    padding: 0.65rem 0.95rem;
    border: 1px solid var(--color-stone-300);
    border-radius: var(--radius-pill);
    background: var(--color-booking-card-bg);
    color: var(--color-text);
    font: inherit;
    text-align: left;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--transition-base),
      background var(--transition-base),
      box-shadow var(--transition-base);
  }

  :global(.suggestion-pill:hover:not(:disabled)),
  :global(.suggestion-pill:focus-visible:not(:disabled)) {
    border-color: var(--color-citrine);
    box-shadow: var(--shadow-card-hover);
    outline: none;
  }

  :global(.suggestion-pill--selected),
  :global(.suggestion-pill:disabled) {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted);
    cursor: default;
    opacity: 0.85;
  }

  :global(.suggestion-pill__name) {
    font-weight: 600;
    font-size: 0.92rem;
  }

  :global(.suggestion-pill__price) {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-citrine-dark);
  }

  :global(.suggestion-pill__duration) {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  :global(.suggestion-card) {
    display: grid;
    gap: 1rem;
    padding: 1rem 1.15rem;
    background: var(--color-booking-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  :global(.suggestion-card--selected) {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted);
  }

  @media (min-width: 640px) {
    :global(.suggestion-card) {
      grid-template-columns: 1fr auto;
      align-items: center;
    }
  }

  :global(.suggestion-card__name) {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    font-weight: 600;
  }

  :global(.suggestion-card__description) {
    margin: 0 0 0.5rem;
    font-size: 0.92rem;
    color: var(--color-gray);
    line-height: 1.45;
  }

  :global(.suggestion-card__meta) {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-stone-600);
  }

  :global(.suggestion-card__price) {
    font-weight: 600;
    color: var(--color-text);
  }

  :global(.suggestion-card__action) {
    padding: 0.6rem 1.15rem;
    border: 1px solid var(--color-citrine);
    border-radius: var(--radius-pill);
    background: var(--color-citrine);
    color: var(--color-black);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background var(--transition-base),
      border-color var(--transition-base);
  }

  :global(.suggestion-card__action:hover:not(:disabled)),
  :global(.suggestion-card__action:focus-visible:not(:disabled)) {
    background: var(--color-citrine-hover);
    border-color: var(--color-citrine-hover);
    outline: none;
  }

  :global(.suggestion-card__action--added),
  :global(.suggestion-card__action:disabled) {
    opacity: 0.65;
    cursor: default;
    background: var(--color-stone-200);
    color: var(--color-stone-600);
    border-color: var(--color-stone-300);
  }

  .cart__footer {
    padding-top: 0.5rem;
    display: grid;
    gap: 1.25rem;
  }

  .cart__totals {
    display: grid;
    gap: 0.35rem;
  }

  .cart__duration,
  .cart__price {
    margin: 0;
    font-size: 1rem;
  }

  .cart-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.85rem 1.75rem;
    border: 1px solid var(--color-citrine);
    border-radius: var(--radius-pill);
    background: var(--color-citrine);
    color: var(--color-black);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      background var(--transition-base),
      border-color var(--transition-base);
  }

  .cart-cta:hover,
  .cart-cta:focus-visible {
    background: var(--color-citrine-hover);
    border-color: var(--color-citrine-hover);
    outline: none;
  }

  .cart-sticky {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 90;
    padding: 0.75rem clamp(1rem, 4vw, 1.5rem)
      calc(0.75rem + env(safe-area-inset-bottom, 0px));
    background: color-mix(in srgb, var(--color-booking-panel-bg) 92%, transparent);
    border-top: 1px solid var(--color-stone-200);
    box-shadow: 0 -8px 32px var(--color-card-shadow);
    backdrop-filter: blur(12px);
  }

  .cart-sticky__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.85rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .cart-sticky__totals {
    display: grid;
    gap: 0.15rem;
    min-width: 0;
  }

  .cart-sticky__duration,
  .cart-sticky__price {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
    font-size: 0.92rem;
  }

  .cart-sticky__label {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-stone-500);
    flex-shrink: 0;
  }

  .cart-sticky__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    min-height: var(--touch-target-min, 2.75rem);
    padding: 0.75rem 1.25rem;
    border: 1px solid var(--color-citrine);
    border-radius: var(--radius-pill);
    background: var(--color-citrine);
    color: var(--color-black);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
    cursor: pointer;
    transition:
      background var(--transition-base),
      border-color var(--transition-base);
  }

  .cart-sticky__cta:hover,
  .cart-sticky__cta:focus-visible {
    background: var(--color-citrine-hover);
    border-color: var(--color-citrine-hover);
    outline: none;
  }

  .back {
    margin-top: 1.5rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .cart-page {
      padding-bottom: 0;
    }

    .cart-sticky {
      display: none;
    }

    .cart__footer--desktop {
      display: grid;
      padding-top: 1.25rem;
      border-top: 1px solid var(--color-stone-200);
    }

    .cart-cta {
      width: auto;
    }
  }

  @media (max-width: 767px) {
    .cart__footer--desktop {
      display: none;
    }
  }

  /* Dark mode */
  :global([data-theme="dark"]) .cart__tray {
    background: var(--color-stone-100);
    border-color: var(--color-stone-300);
  }

  :global([data-theme="dark"]) .cart-page[aria-busy="true"]::before {
    background: color-mix(in srgb, var(--color-stone-200) 45%, transparent);
  }

  :global([data-theme="dark"]) .cart__heading {
    color: var(--color-stone-500);
  }

  :global([data-theme="dark"]) :global(.cart-item) {
    border-color: var(--color-stone-300);
    box-shadow: 0 4px 16px var(--color-card-shadow);
  }

  :global([data-theme="dark"]) :global(.cart-item__badge) {
    color: var(--color-citrine);
    background: color-mix(in srgb, var(--color-citrine) 18%, transparent);
  }

  :global([data-theme="dark"]) .suggestion-section--required {
    border-color: color-mix(in srgb, var(--color-citrine) 45%, var(--color-stone-300));
    background: color-mix(in srgb, var(--color-citrine) 10%, var(--color-stone-100));
  }

  :global([data-theme="dark"]) :global(.suggestion-pill) {
    border-color: var(--color-stone-300);
    background: var(--color-stone-50);
