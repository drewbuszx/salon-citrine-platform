---
export const prerender = false;

import BookingLayout from "../layouts/BookingLayout.astro";
import Button from "@saloncitrine/theme/components/Button.astro";
import {
  BUSINESS,
  DEFAULT_BOOKING_POLICY,
  formatBookingPolicySummary,
  TIMEZONE,
  type BookingPolicy,
} from "@saloncitrine/shared";
import {
  estimateCartPrice,
  formatDuration,
  formatPrice,
  sumServiceDuration,
} from "../lib/booking-data";
import {
  fetchAppointmentConfirmation,
  formatConfirmationWhen,
} from "../lib/appointment-confirmation";
import { generateIcsFile } from "../lib/calendar-utils";
import { withBase } from "../lib/paths";
import { bookingFlagsFromUrl, rebookUrl } from "../lib/booking-flow";

const appointmentId = Astro.url.searchParams.get("appointment");
const showStylistStep = Astro.url.searchParams.get("flow") === "stylist";
const flowFlags = bookingFlagsFromUrl(Astro.url);

if (!appointmentId) {
  return Astro.redirect(withBase());
}

const appointment = await fetchAppointmentConfirmation(appointmentId);
if (!appointment) {
  return Astro.redirect(withBase());
}

const servicesForEstimate = appointment.services.map((svc) => ({
  id: svc.id,
  category: "",
  name: svc.name,
  description: null,
  basePriceCents: svc.priceCents,
  durationMinutes: svc.durationMinutes,
  priceVaries: false,
  isAddon: false,
  requiresConsultation: false,
  isActive: true,
}));

const serviceSummary =
  appointment.services.length === 1
    ? `${appointment.services[0].name} (${formatPrice(servicesForEstimate[0])})`
    : appointment.services.map((svc) => svc.name).join(", ");
const priceEstimate = estimateCartPrice(servicesForEstimate);
const totalDuration = sumServiceDuration(servicesForEstimate);
const whenLabel = formatConfirmationWhen(appointment.startsAt);
const timezoneLabel =
  new Intl.DateTimeFormat("en-US", {
    timeZone: TIMEZONE,
    timeZoneName: "shortGeneric",
  })
    .formatToParts(new Date(appointment.startsAt))
    .find((part) => part.type === "timeZoneName")?.value ?? "local time";
const shortId = appointment.id.slice(0, 8).toUpperCase();
const policy = {
  ...DEFAULT_BOOKING_POLICY,
  ...(appointment.policySnapshot as Partial<BookingPolicy>),
};
const policySummary = formatBookingPolicySummary(policy);
const depositLabel =
  appointment.depositChargedCents > 0
    ? `$${(appointment.depositChargedCents / 100).toFixed(
        appointment.depositChargedCents % 100 === 0 ? 0 : 2,
      )} paid today`
    : appointment.depositRequiredCents > 0
      ? `$${(appointment.depositRequiredCents / 100).toFixed(
          appointment.depositRequiredCents % 100 === 0 ? 0 : 2,
        )} secured at booking`
      : null;

const businessAddress = `${BUSINESS.address.street}, ${BUSINESS.address.city}, ${BUSINESS.address.state} ${BUSINESS.address.zip}`;
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(businessAddress)}`;
const confirmPageUrl = Astro.url.href.split("#")[0];

const icsSummary = `${appointment.services.map((svc) => svc.name).join(", ")} with ${appointment.staff.name}`;
const icsDescription = [
  `Confirmation #${shortId}`,
  `Guest: ${appointment.client.firstName} ${appointment.client.lastName}`,
  policySummary,
  confirmPageUrl,
].join("\n");
const icsContent = generateIcsFile({
  uid: `${appointment.id}@${BUSINESS.domain}`,
  startsAt: appointment.startsAt,
  endsAt: appointment.endsAt,
  summary: `${BUSINESS.name}: ${icsSummary}`,
  description: icsDescription,
  location: businessAddress,
  organizerEmail: BUSINESS.bookingEmail,
  url: confirmPageUrl,
});
const icsFilename = `salon-citrine-${shortId.toLowerCase()}.ics`;
const icsContentBase64 = Buffer.from(icsContent, "utf-8").toString("base64");

const serviceIds = appointment.services.map((svc) => svc.id).filter(Boolean);
const rebookHref = rebookUrl(serviceIds, appointment.staff.slug, {
  ...flowFlags,
  showStylistStep,
});

const shareTitle = `Booking confirmed at ${BUSINESS.name}`;
const shareText = [
  `Confirmation #${shortId}`,
  `${whenLabel} (${timezoneLabel}) with ${appointment.staff.name}`,
  serviceSummary,
  businessAddress,
].join("\n");
---

<BookingLayout
  title="Booking confirmed"
  step="confirm"
  showStylistStep={showStylistStep}
  embed={flowFlags.embed}
>
  <div
    class="confirm"
    data-confirm-root
    data-share-title={shareTitle}
    data-share-text={shareText}
    data-share-url={confirmPageUrl}
    data-ics-filename={icsFilename}
    data-ics-content-b64={icsContentBase64}
  >
    <header class="confirm__hero">
      <span class="confirm__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1.5" />
          <path
            d="M7.5 12.25 10.5 15.25 16.5 8.75"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
      <p class="confirm__kicker">You're all set</p>
      <h1 class="confirm__title">Confirmation #{shortId}</h1>
      <p class="confirm__subtitle">
        {whenLabel} ({timezoneLabel}) with {appointment.staff.name}. We look forward to seeing you.
      </p>
    </header>

    <dl class="confirm__details confirm__print-summary">
      <div>
        <dt>Services</dt>
        <dd>
          {
            appointment.services.length === 1 ? (
              <>
                {serviceSummary}
                {priceEstimate && ` · ${priceEstimate}`}
              </>
            ) : (
              <ul class="confirm__service-list">
                {appointment.services.map((svc) => (
                  <li>
                    {svc.name}
                    {svc.durationMinutes > 0 && ` · ${formatDuration(svc.durationMinutes)}`}
                  </li>
                ))}
              </ul>
            )
          }
          {
            appointment.services.length > 1 && priceEstimate && (
              <span class="confirm__service-total">
                {priceEstimate} · {formatDuration(totalDuration)} total
              </span>
            )
          }
        </dd>
      </div>
      <div>
        <dt>Stylist</dt>
        <dd>{appointment.staff.name}</dd>
      </div>
      <div>
        <dt>When</dt>
        <dd>
          {whenLabel}
          <span class="confirm__timezone"> ({timezoneLabel})</span>
        </dd>
      </div>
      <div>
        <dt>Location</dt>
        <dd>
          {businessAddress}
          <a class="confirm__directions" href={directionsUrl} target="_blank" rel="noopener noreferrer">
            Get directions
          </a>
        </dd>
      </div>
      <div>
        <dt>Guest</dt>
        <dd>
          {appointment.client.firstName} {appointment.client.lastName}
          {appointment.client.email && ` · ${appointment.client.email}`}
        </dd>
      </div>
      {
        depositLabel && (
          <div>
            <dt>Deposit</dt>
            <dd>{depositLabel}</dd>
          </div>
        )
      }
    </dl>

    <section class="confirm__recap" aria-label="Policy and deposit">
      <h2 class="confirm__recap-title">Before you arrive</h2>
      <p class="confirm__recap-policy">{policySummary}</p>
      {
        depositLabel && (
          <p class="confirm__recap-deposit">
            <span class="confirm__recap-label">Deposit</span>
            {depositLabel}
          </p>
        )
      }
      <p class="confirm__recap-note">
        A confirmation email is on its way. If you opted in, we'll also text a reminder before your appointment.
      </p>
      <p class="confirm__recap-reassure">
        Need to make a change? Reply to your confirmation email or call the salon — we're happy to help.
      </p>
    </section>

    <div class="confirm__actions confirm__screen-actions">
      <Button href={rebookHref} variant="primary">
        Book again with {appointment.staff.name.split(" ")[0]}
      </Button>
      <div class="confirm__utility-row">
        <button class="confirm__utility-link" type="button" data-confirm-calendar>
          Add to calendar
        </button>
        <button class="confirm__utility-link" type="button" data-confirm-share>
          Share details
        </button>
        <button class="confirm__utility-link" type="button" data-confirm-print>
          Print summary
        </button>
      </div>
      <p class="confirm__share-status" data-confirm-share-status hidden role="status" aria-live="polite" />
      <Button href={directionsUrl} variant="secondary" target="_blank" rel="noopener noreferrer">
        Get directions
      </Button>
      {
        flowFlags.embed ? (
          <Button href="https://saloncitrineindy.com/" variant="secondary">
            Close
          </Button>
        ) : (
          <Button href="https://saloncitrineindy.com/" variant="secondary">
            Back to {BUSINESS.name}
          </Button>
        )
      }
    </div>

    <p class="confirm__print-footer confirm__print-only">
      {BUSINESS.name} · {BUSINESS.phone} · {confirmPageUrl}
    </p>
  </div>
</BookingLayout>

<script src="../scripts/confirm-actions.ts"></script>

<style>
  .confirm {
    max-width: 34rem;
    margin: 0 auto;
    text-align: center;
    padding-bottom: var(--safe-area-bottom, env(safe-area-inset-bottom, 0px));
  }

  .confirm__hero {
    margin-bottom: var(--space-5);
  }

  .confirm__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.25rem;
    height: 4.25rem;
    margin-bottom: var(--space-4);
    color: var(--color-citrine-dark);
    background: var(--color-citrine-muted);
    border: 1px solid rgba(231, 172, 70, 0.35);
    border-radius: 50%;
    box-shadow:
      0 0 0 6px rgba(231, 172, 70, 0.08),
      0 12px 28px rgba(231, 172, 70, 0.12);
  }

  .confirm__icon svg {
    width: 2.15rem;
    height: 2.15rem;
  }

  .confirm__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 500;
    margin: 0 0 var(--space-2);
  }

  .confirm__kicker {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-citrine-dark);
    margin: 0 0 var(--space-2);
  }

  .confirm__subtitle {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-gray);
    line-height: var(--leading-relaxed);
  }

  .confirm__details {
    margin: 0 0 var(--space-4);
    padding: var(--space-5);
    display: grid;
    gap: var(--space-4);
    text-align: left;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-stone-50);
  }

  .confirm__details dt {
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-dusty-rose);
  }

  .confirm__details dd {
    margin: 0.15rem 0 0;
    font-family: var(--font-body);
    font-weight: 500;
    line-height: var(--leading-normal);
  }

  .confirm__service-list {
    margin: 0;
    padding-left: 1.1rem;
  }

  .confirm__service-list li + li {
    margin-top: 0.25rem;
  }

  .confirm__service-total {
    display: block;
    margin-top: 0.45rem;
    font-size: 0.88rem;
    color: var(--color-gray);
  }

  .confirm__timezone {
    font-weight: 400;
    color: var(--color-gray);
  }

  .confirm__directions {
    display: inline-block;
    margin-top: 0.35rem;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-citrine-dark);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .confirm__directions:hover,
  .confirm__directions:focus-visible {
    color: var(--color-text);
  }

  .confirm__recap {
    margin: 0 0 var(--space-5);
    padding: var(--space-4);
    text-align: left;
    background: var(--color-citrine-muted);
    border-left: 3px solid var(--color-citrine);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .confirm__recap-title {
    margin: 0 0 var(--space-2);
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-dusty-rose);
  }

  .confirm__recap-policy,
  .confirm__recap-deposit,
  .confirm__recap-note,
  .confirm__recap-reassure {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-gray);
    line-height: var(--leading-relaxed);
  }

  .confirm__recap-deposit {
    margin-top: var(--space-3);
    font-weight: 500;
    color: var(--color-text);
  }

  .confirm__recap-label {
    display: block;
    margin-bottom: 0.15rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-dusty-rose);
  }

  .confirm__recap-note {
    margin-top: var(--space-3);
    font-size: 0.85rem;
  }

  .confirm__recap-reassure {
    margin-top: var(--space-2);
    font-size: 0.85rem;
  }

  .confirm__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .confirm__utility-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-4);
  }

  .confirm__utility-link {
    display: inline-block;
    padding: 0.65rem 0.35rem;
    border: 0;
    background: transparent;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.18em;
    color: var(--color-text);
  }

  .confirm__share-status {
    margin: 0;
    font-size: 0.82rem;
    color: var(--color-gray);
  }

  .confirm__print-only {
    display: none;
  }

  .confirm__utility-link:hover,
  .confirm__utility-link:focus-visible {
    color: var(--color-citrine-dark);
  }

  [data-theme="dark"] .confirm__icon {
    color: var(--color-citrine);
    background: rgba(231, 172, 70, 0.12);
    border-color: rgba(231, 172, 70, 0.28);
    box-shadow:
      0 0 0 6px rgba(231, 172, 70, 0.05),
      0 12px 28px rgba(0, 0, 0, 0.25);
  }

  [data-theme="dark"] .confirm__kicker {
    color: var(--color-citrine);
  }

  [data-theme="dark"] .confirm__details {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
  }

  [data-theme="dark"] .confirm__recap {
    background: rgba(231, 172, 70, 0.1);
    border-left-color: var(--color-citrine);
  }

  [data-theme="dark"] .confirm__recap-deposit {
    color: var(--color-text);
  }

  [data-theme="dark"] .confirm__directions {
    color: var(--color-citrine);
  }

  [data-theme="dark"] .confirm__utility-link {
    color: var(--color-citrine);
  }

  @media print {
    :global(.booking-steps-wrap),
    :global(.site-header),
    :global(.booking-footer),
    .confirm__screen-actions,
    .confirm__directions,
    .confirm__recap {
      display: none !important;
    }

    .confirm {
      max-width: none;
      text-align: left;
      color: #111;
    }

    .confirm__hero {
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid #ddd;
    }

    .confirm__icon {
      display: none;
    }

    .confirm__details {
      border: 1px solid #ddd;
      background: #fff;
      break-inside: avoid;
    }

    .confirm__print-only {
      display: block;
      margin-top: 1.25rem;
      padding-top: 0.75rem;
      border-top: 1px solid #ddd;
      font-size: 0.75rem;
      color: #555;
      word-break: break-all;
    }
  }
</style>
