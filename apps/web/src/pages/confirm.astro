---
export const prerender = false;

import BookingLayout from "../layouts/BookingLayout.astro";
import Button from "@saloncitrine/theme/components/Button.astro";
import { BUSINESS } from "@saloncitrine/shared";
import {
  estimateCartPrice,
  fetchServicesByIds,
  formatDuration,
  formatPrice,
  getStaffBySlug,
  parseServiceIdsFromParams,
  sumServiceDuration,
} from "../lib/booking-data";
import { isBookingSlotAvailable } from "../lib/availability";
import { withBase } from "../lib/paths";

const serviceParam = Astro.url.searchParams.get("service");
const servicesParam = Astro.url.searchParams.get("services");
const stylistSlug = Astro.url.searchParams.get("stylist");
const date = Astro.url.searchParams.get("date");
const time = Astro.url.searchParams.get("time");
const firstName = Astro.url.searchParams.get("firstName");
const lastName = Astro.url.searchParams.get("lastName");
const email = Astro.url.searchParams.get("email");
const policyAck = Astro.url.searchParams.get("policyAck");
const showStylistStep = Astro.url.searchParams.get("flow") === "stylist";

const serviceIds = parseServiceIdsFromParams(servicesParam, serviceParam);

const [services, stylist] = await Promise.all([
  fetchServicesByIds(serviceIds, stylistSlug),
  getStaffBySlug(stylistSlug),
]);

if (
  services.length === 0 ||
  !stylist ||
  !date ||
  !time ||
  !firstName ||
  !lastName ||
  !email ||
  policyAck !== "true"
) {
  return Astro.redirect(`${withBase("details/")}?${Astro.url.searchParams.toString()}`);
}

const slotAvailable = await isBookingSlotAvailable(
  stylist.id,
  serviceIds,
  date,
  time,
);
if (!slotAvailable) {
  const params = new URLSearchParams({
    services: serviceIds.join(","),
    stylist: stylist.slug,
    date,
  });
  if (showStylistStep) params.set("flow", "stylist");
  return Astro.redirect(`${withBase("datetime/")}?${params.toString()}`);
}

const serviceSummary =
  services.length === 1
    ? `${services[0].name} (${formatPrice(services[0])})`
    : services.map((svc) => svc.name).join(", ");
const priceEstimate = estimateCartPrice(services);
const totalDuration = sumServiceDuration(services);

const confirmationId = `SC-${Date.now().toString(36).toUpperCase()}`;
---

<BookingLayout title="Booking confirmed" step="confirm" showStylistStep={showStylistStep}>
  <div class="confirm">
    <p class="confirm__kicker">You're booked!</p>
    <h1>Confirmation {confirmationId}</h1>

    <dl class="confirm__details">
      <div>
        <dt>Services</dt>
        <dd>
          {serviceSummary}
          {priceEstimate && ` · ${priceEstimate}`}
          {services.length > 1 && ` · ${formatDuration(totalDuration)}`}
        </dd>
      </div>
      <div>
        <dt>Stylist</dt>
        <dd>{stylist.name}</dd>
      </div>
      <div>
        <dt>When</dt>
        <dd>
          {date} at {time}
        </dd>
      </div>
      <div>
        <dt>Guest</dt>
        <dd>
          {firstName} {lastName} · {email}
        </dd>
      </div>
    </dl>

    <p class="confirm__note">
      Placeholder confirmation — Resend email + Twilio SMS will fire here once
      Supabase + Stripe are wired up.
    </p>

    <Button href="https://saloncitrineindy.com/" variant="secondary">
      Back to {BUSINESS.name}
    </Button>
  </div>
</BookingLayout>

<style>
  .confirm__kicker {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-sage);
    margin: 0 0 0.5rem;
  }

  .confirm__details {
    margin: 1.5rem 0;
    display: grid;
    gap: 1rem;
  }

  .confirm__details dt {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .confirm__details dd {
    margin: 0.15rem 0 0;
    font-weight: 500;
  }

  .confirm__note {
    padding: 1rem;
    background: var(--color-light);
    font-size: 0.9rem;
    color: var(--color-gray);
  }
</style>
