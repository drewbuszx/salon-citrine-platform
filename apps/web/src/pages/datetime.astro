---
import BookingLayout from "../layouts/BookingLayout.astro";
import Button from "@saloncitrine/theme/components/Button.astro";
import {
  formatAvailableDateLabel,
  getAvailableDates,
  getAvailableSlots,
  resolveSelectedDate,
} from "../lib/availability";
import { getServiceById, getStaffBySlug } from "../lib/booking-data";
import { withBase } from "../lib/paths";

const serviceId = Astro.url.searchParams.get("service");
const stylistSlug = Astro.url.searchParams.get("stylist");
const requestedDate = Astro.url.searchParams.get("date");

const [service, stylist] = await Promise.all([
  getServiceById(serviceId),
  getStaffBySlug(stylistSlug),
]);

if (!service || !stylist) {
  return Astro.redirect(withBase());
}

const availableDates = await getAvailableDates(stylist.id, service.id);
const selectedDate = resolveSelectedDate(availableDates, requestedDate);
const slots = selectedDate
  ? await getAvailableSlots(stylist.id, service.id, selectedDate)
  : [];
---

<BookingLayout title="Choose date & time" step={2}>
  <h1>Choose date & time</h1>
  <p class="lead">
    {service.name} with <strong>{stylist.name}</strong>
  </p>

  {
    availableDates.length === 0 ? (
      <p class="empty">
        No open times in the next few weeks.{" "}
        <a href={`${withBase()}?stylist=${stylist.slug}`}>
          Try another service or professional
        </a>
      </p>
    ) : (
      <>
        <form
          class="date-form"
          method="get"
          action={withBase("datetime/")}
        >
          <input type="hidden" name="service" value={service.id} />
          <input type="hidden" name="stylist" value={stylist.slug} />

          <fieldset class="field">
            <legend>Date</legend>
            <div class="date-grid">
              {
                availableDates.map((date) => (
                  <label class="date-option">
                    <input
                      type="radio"
                      name="date"
                      value={date}
                      checked={date === selectedDate}
                      onchange="this.form.submit()"
                    />
                    <span>{formatAvailableDateLabel(date)}</span>
                  </label>
                ))
              }
            </div>
          </fieldset>
        </form>

        <form
          class="datetime-form"
          method="get"
          action={withBase("details/")}
        >
          <input type="hidden" name="service" value={service.id} />
          <input type="hidden" name="stylist" value={stylist.slug} />
          <input type="hidden" name="date" value={selectedDate} />

          <fieldset class="field">
            <legend>Time</legend>
            {
              slots.length === 0 ? (
                <p class="empty-slots">No times left on this day.</p>
              ) : (
                <div class="time-grid">
                  {
                    slots.map((slot) => (
                      <label class="time-option">
                        <input
                          type="radio"
                          name="time"
                          value={slot.label}
                          required
                        />
                        <span>{slot.label}</span>
                      </label>
                    ))
                  }
                </div>
              )
            }
          </fieldset>

          {
            slots.length > 0 && (
              <Button type="submit" variant="primary">
                Continue
              </Button>
            )
          }
        </form>
      </>
    )
  }

  <p class="back">
    <a href={`${withBase()}?stylist=${stylist.slug}`}>← Back to services</a>
  </p>
</BookingLayout>

<style>
  .lead {
    color: var(--color-gray);
  }

  .field {
    border: none;
    margin: 0 0 1.75rem;
    padding: 0;
  }

  .field legend {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .date-grid,
  .time-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(7rem, 1fr));
    gap: 0.5rem;
  }

  .date-option input,
  .time-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .date-option span,
  .time-option span {
    display: block;
    padding: 0.65rem 0.5rem;
    border: 1px solid var(--color-border);
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .date-option input:checked + span,
  .time-option input:checked + span {
    border-color: var(--color-citrine);
    background: var(--color-citrine);
    color: var(--color-black);
  }

  .empty,
  .empty-slots {
    padding: 1rem;
    background: var(--color-light);
    color: var(--color-gray);
    text-align: center;
  }

  .back {
    margin-top: 1.5rem;
  }
</style>
