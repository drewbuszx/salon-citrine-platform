---
export const prerender = false;

import BookingLayout from "../layouts/BookingLayout.astro";
import Button from "@saloncitrine/theme/components/Button.astro";
import PolicyModal from "../components/PolicyModal.astro";
import {
  estimateCartPrice,
  fetchServicesByIds,
  formatDuration,
  getStaffBySlug,
  parseServiceIdsFromParams,
  sumServiceDuration,
} from "../lib/booking-data";
import { formatConfirmationWhen } from "../lib/appointment-confirmation";
import { resolveBookingSlot } from "../lib/availability";
import { fetchActiveBookingPolicy } from "../lib/booking-policy";
import { bookingApi, bookingFlagsFromUrl, appendFlowFlags } from "../lib/booking-flow";
import { withBase } from "../lib/paths";
import {
  calculateRequiredDepositCents,
  formatCents,
  formatLateCancelMessage,
} from "@saloncitrine/shared";
import {
  INTAKE_REFERRAL_SOURCES,
  NEW_CLIENT_INTAKE_WELCOME,
  PREFERRED_CONTACT_LABELS,
  PREFERRED_CONTACT_METHODS,
  RETURNING_CLIENT_INTAKE_NOTE,
} from "@saloncitrine/shared";

const serviceParam = Astro.url.searchParams.get("service");
const servicesParam = Astro.url.searchParams.get("services");
const stylistSlug = Astro.url.searchParams.get("stylist");
const date = Astro.url.searchParams.get("date");
const time = Astro.url.searchParams.get("time");
const startsAtParam = Astro.url.searchParams.get("startsAt");
const cartId = Astro.url.searchParams.get("cartId");
const showStylistStep = Astro.url.searchParams.get("flow") === "stylist";
const flowFlags = bookingFlagsFromUrl(Astro.url);

const serviceIds = parseServiceIdsFromParams(servicesParam, serviceParam);
const servicesParamValue = serviceIds.join(",");

const [services, stylist, bookingPolicy] = await Promise.all([
  fetchServicesByIds(serviceIds, stylistSlug),
  getStaffBySlug(stylistSlug),
  fetchActiveBookingPolicy(),
]);

if (services.length === 0 || !stylist || !date || (!time && !startsAtParam)) {
  return Astro.redirect(withBase());
}

const slot = await resolveBookingSlot(
  stylist.id,
  serviceIds,
  date,
  time,
  startsAtParam,
);
if (!slot) {
  const params = new URLSearchParams({
    services: serviceIds.join(","),
    stylist: stylist.slug,
    date,
  });
  if (showStylistStep) params.set("flow", "stylist");
  return Astro.redirect(`${withBase("datetime/")}?${params.toString()}`);
}

const servicesLabel =
  services.length === 1
    ? services[0].name
    : services.map((service) => service.name).join(", ");
const totalDuration = sumServiceDuration(services);
const whenLabel = formatConfirmationWhen(slot.startsAt);
const subtotalCents = services.reduce(
  (sum, service) => sum + (service.basePriceCents ?? 0),
  0,
);
const priceLabel = estimateCartPrice(services) ?? formatCents(subtotalCents);
const depositRequiredCents = calculateRequiredDepositCents(
  bookingPolicy,
  subtotalCents,
);
const requiresCardOnFile =
  depositRequiredCents > 0 ||
  bookingPolicy.depositType === "card_on_file" ||
  bookingPolicy.requiresCardOnFile;
const paymentHint =
  depositRequiredCents > 0
    ? `A ${formatCents(depositRequiredCents)} deposit is charged when you confirm. The rest is due at your visit.`
    : requiresCardOnFile
      ? "Your card secures this appointment — no charge today unless noted below."
      : "No payment is collected online today.";
const depositLabel =
  depositRequiredCents > 0
    ? formatCents(depositRequiredCents)
    : bookingPolicy.depositType === "card_on_file" || bookingPolicy.requiresCardOnFile
      ? "Card on file — no charge today"
      : "No charge today";
const cancellationSummary = formatLateCancelMessage(bookingPolicy);
const paymentExplanation =
  depositRequiredCents > 0
    ? "Charged when you confirm. Applied toward your service total."
    : bookingPolicy.depositType === "card_on_file" || bookingPolicy.requiresCardOnFile
      ? "Kept on file to secure your appointment. You won't be charged today."
      : "No card charge today. Review cancellation terms before you book.";

const stripePublishableKey = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY;
const setupIntentUrl = withBase("api/booking/setup-intent");
const appointmentsUrl = withBase("api/booking/appointments");
const confirmUrl = withBase("confirm/");

const backParams = new URLSearchParams({
  services: servicesParamValue,
  stylist: stylist.slug,
  date,
});
if (showStylistStep) backParams.set("flow", "stylist");
appendFlowFlags(backParams, flowFlags);
const backHref = `${withBase("datetime/")}?${backParams.toString()}`;
---

<BookingLayout
  title="Your details"
  step="details"
  showStylistStep={showStylistStep}
  embed={flowFlags.embed}
>
  <h1>Your details</h1>

  <section class="appointment-summary" aria-label="Appointment summary">
    <p class="appointment-summary__kicker">Your appointment</p>
    <dl class="appointment-summary__grid">
      <div>
        <dt>Service{services.length > 1 ? "s" : ""}</dt>
        <dd>{servicesLabel}</dd>
      </div>
      <div>
        <dt>Stylist</dt>
        <dd>{stylist.name}</dd>
      </div>
      <div>
        <dt>When</dt>
        <dd>{whenLabel}</dd>
      </div>
      <div>
        <dt>Duration</dt>
        <dd>{formatDuration(totalDuration)}</dd>
      </div>
      <div>
        <dt>Estimated price</dt>
        <dd>{priceLabel}</dd>
      </div>
    </dl>
  </section>

  {
    cartId && (
      <p class="reservation-hold" data-reservation-hold data-cart-id={cartId} hidden>
        Your time is reserved for <strong data-reservation-countdown>…</strong>. Complete booking before it expires.
      </p>
    )
  }

  <form
    class="details-form"
    data-booking-details-form
    data-stripe-publishable-key={stripePublishableKey}
    data-setup-intent-url={setupIntentUrl}
    data-appointments-url={appointmentsUrl}
    data-confirm-url={confirmUrl}
    data-client-lookup-url={bookingApi.clientLookup}
    data-cart-api-url={bookingApi.cart}
    data-cart-id={cartId ?? ""}
    data-deposit-required-cents={depositRequiredCents}
    data-requires-card-on-file={requiresCardOnFile ? "true" : "false"}
    novalidate
  >
    <input type="hidden" name="services" value={servicesParamValue} />
    <input type="hidden" name="stylist" value={stylist.slug} />
    {showStylistStep && <input type="hidden" name="flow" value="stylist" />}
    {flowFlags.embed && <input type="hidden" name="embed" value="1" />}
    <input type="hidden" name="date" value={date} />
    <input type="hidden" name="time" value={slot.label} />
    <input type="hidden" name="startsAt" value={slot.startsAt} />
    {cartId && <input type="hidden" name="cartId" value={cartId} />}
    <input type="hidden" id="policy-ack" name="policyAck" value="false" />
    <input type="hidden" name="isReturningClient" value="false" data-returning-client-input />

    <p class="lookup-status" data-lookup-status hidden aria-live="polite"></p>

    <div class="intake-welcome" data-new-client-welcome>
      <p class="intake-welcome__text">{NEW_CLIENT_INTAKE_WELCOME}</p>
    </div>

    <div class="intake-welcome intake-welcome--returning" data-returning-client-welcome hidden>
      <p class="intake-welcome__text">{RETURNING_CLIENT_INTAKE_NOTE}</p>
    </div>

    <fieldset class="form-section stone-tray">
      <legend>Contact information</legend>

      <div class="field-row">
        <label class="field">
          <span>First name</span>
          <input type="text" name="firstName" required autocomplete="given-name" />
          <span class="field-error" data-field-error hidden></span>
        </label>

        <label class="field">
          <span>Last name</span>
          <input type="text" name="lastName" required autocomplete="family-name" />
          <span class="field-error" data-field-error hidden></span>
        </label>
      </div>

      <label class="field">
        <span>Email</span>
        <input type="email" name="email" required autocomplete="email" />
        <span class="field-error" data-field-error hidden></span>
      </label>

      <label class="field">
        <span>Mobile phone</span>
        <input type="tel" name="phone" required autocomplete="tel" />
        <span class="field-error" data-field-error hidden></span>
      </label>

      <fieldset class="field field--inline" data-intake-only>
        <legend>Preferred contact method</legend>
        <div class="radio-group">
          {
            PREFERRED_CONTACT_METHODS.map((method) => (
              <label class="radio">
                <input
                  type="radio"
                  name="preferredContactMethod"
                  value={method}
                  required
                  data-intake-required
                />
                <span>{PREFERRED_CONTACT_LABELS[method]}</span>
              </label>
            ))
          }
        </div>
        <span class="field-error" data-field-error hidden></span>
      </fieldset>

      <label class="checkbox">
        <input type="checkbox" name="smsOptIn" value="true" />
        <span>Text me appointment reminders (optional)</span>
      </label>
    </fieldset>

    <fieldset class="form-section form-section--intake stone-tray" data-intake-section>
      <legend>New client intake</legend>
      <p class="form-section__intro">
        A few details help us personalize your first visit. Returning guests can skip this section.
      </p>

      <div class="field-row field-row--intake">
        <label class="field">
          <span>Birthday</span>
          <input
            type="date"
            name="birthday"
            autocomplete="bday"
            data-intake-required
          />
          <span class="field-error" data-field-error hidden></span>
        </label>
      </div>

      <label class="field">
        <span>Street address</span>
        <input
          type="text"
          name="addressLine1"
          autocomplete="address-line1"
          data-intake-required
        />
        <span class="field-error" data-field-error hidden></span>
      </label>

      <label class="field">
        <span>Apartment, suite, etc. (optional)</span>
        <input type="text" name="addressLine2" autocomplete="address-line2" />
      </label>

      <div class="field-row field-row--3">
        <label class="field">
          <span>City</span>
          <input
            type="text"
            name="addressCity"
            autocomplete="address-level2"
            data-intake-required
          />
          <span class="field-error" data-field-error hidden></span>
        </label>

        <label class="field">
          <span>State</span>
          <input
            type="text"
            name="addressState"
            maxlength="2"
            autocomplete="address-level1"
            placeholder="IN"
            data-intake-required
          />
          <span class="field-error" data-field-error hidden></span>
        </label>

        <label class="field">
          <span>ZIP</span>
          <input
            type="text"
            name="addressZip"
            inputmode="numeric"
            autocomplete="postal-code"
            data-intake-required
          />
          <span class="field-error" data-field-error hidden></span>
        </label>
      </div>

      <fieldset class="field">
        <legend>How did you hear about us?</legend>
        <p class="field-hint">Select all that apply.</p>
        <div class="checkbox-grid">
          {
            INTAKE_REFERRAL_SOURCES.map((source) => (
              <label class="checkbox">
                <input
                  type="checkbox"
                  name="referralSources"
                  value={source}
                  data-intake-required-group="referralSources"
                />
                <span>{source}</span>
              </label>
            ))
          }
        </div>
        <span class="field-error" data-field-error data-field-error-group="referralSources" hidden></span>
      </fieldset>
    </fieldset>

    <fieldset class="form-section form-section--optional stone-tray">
      <legend>Appointment notes (optional)</legend>

      <label class="field">
        <span>Must-know details for your visit</span>
        <textarea
          name="intakeNotes"
          rows="3"
          maxlength="1200"
          placeholder="Allergies, accessibility needs, or other details for your stylist."
        />
      </label>

      <label class="field">
        <span>Service preferences</span>
        <textarea
          name="bookingPreferences"
          rows="2"
          maxlength="600"
          placeholder="Tone goals, styling preferences, or products to avoid."
        />
      </label>
    </fieldset>

    <section class="trust-panel stone-tray" aria-labelledby="trust-panel-title">
      <h2 id="trust-panel-title" class="trust-panel__title">Before you confirm</h2>
      <p class="trust-panel__intro">
        Clear terms up front — no surprises at checkout.
      </p>
      <dl class="trust-panel__items">
        <div>
          <dt>Due today</dt>
          <dd>{depositLabel}</dd>
        </div>
        <div>
          <dt>Cancellation</dt>
          <dd>{cancellationSummary}</dd>
        </div>
        <div>
          <dt>Payment</dt>
          <dd>{paymentExplanation}</dd>
        </div>
      </dl>
      <p class="trust-panel__link-wrap">
        <button type="button" class="trust-panel__link" data-open-policy-link>
          Read full booking policy
        </button>
      </p>
    </section>

    <div class="card-section stone-tray">
      <p class="card-section__label">Payment method</p>
      <p class="card-section__hint" data-payment-hint>
        {paymentHint}
      </p>
      <div id="payment-element" class="payment-element" aria-busy="false" aria-live="polite">
        <p class="payment-element__status">Enter your email to securely load the card form.</p>
      </div>
      <p class="form-error" data-form-error hidden role="alert"></p>
    </div>

    <div class="submit-bar">
      <Button type="button" variant="primary" data-open-policy-modal data-submit-button>
        <span data-submit-label>Review policy &amp; book</span>
      </Button>
    </div>
  </form>

  <PolicyModal policy={bookingPolicy} />

  <p class="back">
    <a href={backHref}>
      ← Back to date & time
    </a>
  </p>
</BookingLayout>

<script src="../scripts/details-booking.ts"></script>

<style>
  .appointment-summary {
    margin-top: var(--space-4);
    padding: var(--space-5);
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-stone-50);
  }

  .appointment-summary__kicker {
    margin: 0 0 var(--space-3);
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-sage);
  }

  .appointment-summary__grid {
    margin: 0;
    display: grid;
    gap: var(--space-4);
  }

  .appointment-summary__grid dt {
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-dusty-rose);
  }

  .appointment-summary__grid dd {
    margin: 0.15rem 0 0;
    font-family: var(--font-body);
    font-weight: 500;
    line-height: var(--leading-normal);
  }

  .reservation-hold {
    margin: var(--space-4) 0 0;
    padding: 0.75rem 1rem;
    background: rgba(231, 172, 70, 0.15);
    border: 1px solid var(--color-citrine);
    font-size: 0.95rem;
  }

  .lookup-status {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-sage);
  }

  .intake-welcome {
    margin-top: 0;
    padding: 0.85rem 1rem;
    background: rgba(231, 172, 70, 0.12);
    border-left: 3px solid var(--color-citrine);
  }

  .intake-welcome--returning {
    background: rgba(143, 168, 143, 0.12);
    border-left-color: var(--color-sage);
  }

  .intake-welcome__text {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .details-form {
    display: grid;
    gap: var(--space-5);
    max-width: 36rem;
    margin-top: var(--space-5);
  }

  @media (max-width: 639px) {
    .details-form {
      padding-bottom: calc(5.5rem + var(--safe-area-bottom, env(safe-area-inset-bottom, 0px)));
    }
  }

  .stone-tray {
    margin: 0;
    padding: var(--space-5);
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-stone-50);
  }

  .form-section {
    display: grid;
    gap: 1rem;
    border: 0;
  }

  .form-section--intake {
    gap: 1.1rem;
  }

  .form-section__intro {
    margin: 0 0 0.25rem;
    font-size: 0.9rem;
    color: var(--color-gray);
    line-height: 1.5;
  }

  .form-section legend,
  .field--inline legend,
  .field legend {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-dusty-rose);
    margin-bottom: 0.35rem;
    padding: 0;
  }

  .form-section--optional legend {
    color: var(--color-gray);
  }

  .field-row {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr 1fr;
  }

  .field-row--3 {
    grid-template-columns: 2fr 1fr 1fr;
  }

  @media (max-width: 520px) {
    .field-row,
    .field-row--3 {
      grid-template-columns: 1fr;
    }
  }

  .field {
    display: grid;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .field span,
  .field > legend {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-dusty-rose);
  }

  .field-row--intake {
    grid-template-columns: minmax(12rem, 16rem);
  }

  .field-hint {
    margin: 0 0 0.35rem;
    font-size: 0.85rem;
    color: var(--color-gray);
  }

  .field input,
  .field textarea {
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font: inherit;
    border-radius: var(--radius-sm);
  }

  .field textarea {
    resize: vertical;
  }

  .radio-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
  }

  .radio,
  .checkbox {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    min-height: var(--touch-target-min, 2.75rem);
    font-size: 0.95rem;
  }

  .checkbox-grid {
    display: grid;
    gap: 0.5rem;
  }

  .trust-panel {
    display: grid;
    gap: var(--space-4);
  }

  .trust-panel__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.25;
  }

  .trust-panel__items {
    margin: 0;
    display: grid;
    gap: var(--space-4);
  }

  .trust-panel__items dt {
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-dusty-rose);
  }

  .trust-panel__items dd {
    margin: 0.2rem 0 0;
    font-size: 0.92rem;
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .trust-panel__link-wrap {
    margin: 0;
  }

  .trust-panel__link {
    display: inline-flex;
    align-items: center;
    min-height: var(--touch-target-min, 2.75rem);
    padding: 0;
    border: 0;
    background: none;
    color: var(--color-citrine-dark);
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: underline;
    text-underline-offset: 0.15em;
    cursor: pointer;
  }

  .trust-panel__link:hover,
  .trust-panel__link:focus-visible {
    color: var(--color-citrine);
  }

  .trust-panel__link:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    pointer-events: none;
  }

  .card-section {
    display: grid;
    gap: 0.5rem;
  }

  .card-section__label {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-dusty-rose);
  }

  .card-section__hint {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-gray);
  }

  .payment-element {
    min-height: 2rem;
  }

  .payment-element__status {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-gray);
  }

  .payment-element__error {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-error);
  }

  .form-error {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-error);
  }

  .submit-bar {
    position: sticky;
    bottom: 0;
    z-index: 20;
    margin: 0 calc(-1 * var(--space-4));
    padding: var(--space-4);
    padding-bottom: calc(var(--space-4) + var(--safe-area-bottom, env(safe-area-inset-bottom, 0px)));
    background: linear-gradient(
      to top,
      var(--color-bg) 70%,
      rgba(255, 255, 255, 0)
    );
    border-top: 1px solid var(--color-border-subtle);
  }

  @media (max-width: 639px) {
    .submit-bar {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 90;
      margin: 0;
      background: color-mix(in srgb, var(--color-booking-panel-bg) 92%, transparent);
      backdrop-filter: blur(12px);
      box-shadow: 0 -8px 32px var(--color-card-shadow);
    }
  }

  .submit-bar :global(.sc-button) {
    width: 100%;
    text-align: center;
  }

  .submit-bar :global(.sc-button[disabled]) {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .submit-bar :global(.sc-button[aria-busy="true"]) {
    opacity: 0.75;
  }

  @media (min-width: 640px) {
    .submit-bar {
      position: static;
      margin: 0;
      padding: 0;
      background: transparent;
      border-top: 0;
    }

    .submit-bar :global(.sc-button) {
      width: auto;
    }
  }

  .back {
    margin-top: var(--space-5);
  }

  :global([data-theme="dark"]) .submit-bar {
    background: linear-gradient(
      to top,
      var(--color-bg) 70%,
      rgba(24, 24, 24, 0)
    );
  }

  @media (max-width: 639px) {
    :global([data-theme="dark"]) .submit-bar {
      background: color-mix(in srgb, var(--color-booking-panel-bg) 95%, transparent);
    }
  }
</style>
