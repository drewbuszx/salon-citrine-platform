---
import BookingLayout from "../layouts/BookingLayout.astro";
import Button from "@saloncitrine/theme/components/Button.astro";
import PolicyModal from "../components/PolicyModal.astro";
import { getServiceById, getStaffBySlug } from "../data/mock";

const serviceId = Astro.url.searchParams.get("service");
const stylistSlug = Astro.url.searchParams.get("stylist");
const date = Astro.url.searchParams.get("date");
const time = Astro.url.searchParams.get("time");
const service = getServiceById(serviceId);
const stylist = getStaffBySlug(stylistSlug);

if (!service || !stylist || !date || !time) {
  return Astro.redirect(import.meta.env.BASE_URL);
}
---

<BookingLayout title="Your details" step={4}>
  <h1>Your details</h1>
  <p class="summary">
    {service.name} · {stylist.name}<br />
    {date} at {time}
  </p>

  <form
    class="details-form"
    method="get"
    action={`${import.meta.env.BASE_URL}confirm/`}
    data-booking-details-form
  >
    <input type="hidden" name="service" value={service.id} />
    <input type="hidden" name="stylist" value={stylist.slug} />
    <input type="hidden" name="date" value={date} />
    <input type="hidden" name="time" value={time} />
    <input type="hidden" id="policy-ack" name="policyAck" value="false" />

    <label class="field">
      <span>First name</span>
      <input type="text" name="firstName" required autocomplete="given-name" />
    </label>

    <label class="field">
      <span>Last name</span>
      <input type="text" name="lastName" required autocomplete="family-name" />
    </label>

    <label class="field">
      <span>Email</span>
      <input type="email" name="email" required autocomplete="email" />
    </label>

    <label class="field">
      <span>Phone</span>
      <input type="tel" name="phone" required autocomplete="tel" />
    </label>

    <label class="checkbox">
      <input type="checkbox" name="smsOptIn" value="true" />
      <span>Text me appointment reminders (optional)</span>
    </label>

    <p class="stripe-note">
      Stripe card-on-file collection will appear here in Phase 1 (SetupIntent).
    </p>

    <Button type="button" variant="primary" data-open-policy-modal>
      Review policy & continue
    </Button>
  </form>

  <PolicyModal />

  <p class="back">
    <a
      href={`${import.meta.env.BASE_URL}datetime/?service=${service.id}&stylist=${stylist.slug}`}
    >
      ← Back to date & time
    </a>
  </p>
</BookingLayout>

<style>
  .summary {
    padding: 1rem;
    background: var(--color-light);
    border-left: 3px solid var(--color-sage);
  }

  .details-form {
    display: grid;
    gap: 1rem;
    max-width: 28rem;
    margin-top: 1.5rem;
  }

  .field {
    display: grid;
    gap: 0.35rem;
  }

  .field span {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .field input {
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .checkbox {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    font-size: 0.95rem;
  }

  .stripe-note {
    font-size: 0.85rem;
    color: var(--color-gray);
    padding: 0.75rem;
    border: 1px dashed var(--color-border);
  }

  .back {
    margin-top: 1.5rem;
  }
</style>
