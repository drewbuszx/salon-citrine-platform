---
export const prerender = false;

import BookingLayout from "../layouts/BookingLayout.astro";
import Button from "@saloncitrine/theme/components/Button.astro";
import PolicyModal from "../components/PolicyModal.astro";
import {
  fetchServicesByIds,
  formatDuration,
  getStaffBySlug,
  parseServiceIdsFromParams,
  sumServiceDuration,
} from "../lib/booking-data";
import { resolveBookingSlot } from "../lib/availability";
import { fetchActiveBookingPolicy } from "../lib/booking-policy";
import { bookingApi } from "../lib/booking-flow";
import { withBase } from "../lib/paths";
import { calculateRequiredDepositCents, formatCents } from "@saloncitrine/shared";
import {
  INTAKE_REFERRAL_SOURCES,
  NEW_CLIENT_INTAKE_WELCOME,
  PREFERRED_CONTACT_LABELS,
  PREFERRED_CONTACT_METHODS,
  RETURNING_CLIENT_INTAKE_NOTE,
} from "@saloncitrine/shared";

const serviceParam = Astro.url.searchParams.get("service");
const servicesParam = Astro.url.searchParams.get("services");
const stylistSlug = Astro.url.searchParams.get("stylist");
const date = Astro.url.searchParams.get("date");
const time = Astro.url.searchParams.get("time");
const startsAtParam = Astro.url.searchParams.get("startsAt");
const cartId = Astro.url.searchParams.get("cartId");
const showStylistStep = Astro.url.searchParams.get("flow") === "stylist";

const serviceIds = parseServiceIdsFromParams(servicesParam, serviceParam);
const servicesParamValue = serviceIds.join(",");

const [services, stylist, bookingPolicy] = await Promise.all([
  fetchServicesByIds(serviceIds, stylistSlug),
  getStaffBySlug(stylistSlug),
  fetchActiveBookingPolicy(),
]);

if (services.length === 0 || !stylist || !date || (!time && !startsAtParam)) {
  return Astro.redirect(withBase());
}

const slot = await resolveBookingSlot(
  stylist.id,
  serviceIds,
  date,
  time,
  startsAtParam,
);
if (!slot) {
  const params = new URLSearchParams({
    services: serviceIds.join(","),
    stylist: stylist.slug,
    date,
  });
  if (showStylistStep) params.set("flow", "stylist");
  return Astro.redirect(`${withBase("datetime/")}?${params.toString()}`);
}

const serviceSummary =
  services.length === 1
    ? services[0].name
    : `${services[0].name} + ${services.length - 1} more`;
const totalDuration = sumServiceDuration(services);
const subtotalCents = services.reduce(
  (sum, service) => sum + (service.basePriceCents ?? 0),
  0,
);
const depositRequiredCents = calculateRequiredDepositCents(
  bookingPolicy,
  subtotalCents,
);
const depositLabel =
  depositRequiredCents > 0
    ? formatCents(depositRequiredCents)
    : bookingPolicy.depositType === "card_on_file" || bookingPolicy.requiresCardOnFile
      ? "Card on file only"
      : "None today";

const stripePublishableKey = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY;
const setupIntentUrl = withBase("api/booking/setup-intent");
const appointmentsUrl = withBase("api/booking/appointments");
const confirmUrl = withBase("confirm/");
---

<BookingLayout title="Your details" step="details" showStylistStep={showStylistStep}>
  <h1>Your details</h1>
  <p class="summary">
    {serviceSummary} · {stylist.name}
    {services.length > 1 && ` · ${formatDuration(totalDuration)}`}
    <br />
    {date} at {slot.label}
  </p>

  {
    cartId && (
      <p class="reservation-hold" data-reservation-hold data-cart-id={cartId} hidden>
        Your time is held for <strong data-reservation-countdown>…</strong>.
      </p>
    )
  }

  <form
    class="details-form"
    data-booking-details-form
    data-stripe-publishable-key={stripePublishableKey}
    data-setup-intent-url={setupIntentUrl}
    data-appointments-url={appointmentsUrl}
    data-confirm-url={confirmUrl}
    data-client-lookup-url={bookingApi.clientLookup}
    data-cart-api-url={bookingApi.cart}
    data-cart-id={cartId ?? ""}
    novalidate
  >
    <input type="hidden" name="services" value={servicesParamValue} />
    <input type="hidden" name="stylist" value={stylist.slug} />
    {showStylistStep && <input type="hidden" name="flow" value="stylist" />}
    <input type="hidden" name="date" value={date} />
    <input type="hidden" name="time" value={slot.label} />
    <input type="hidden" name="startsAt" value={slot.startsAt} />
    {cartId && <input type="hidden" name="cartId" value={cartId} />}
    <input type="hidden" id="policy-ack" name="policyAck" value="false" />
    <input type="hidden" name="isReturningClient" value="false" data-returning-client-input />

    <p class="lookup-status" data-lookup-status hidden aria-live="polite"></p>

    <div class="intake-welcome" data-new-client-welcome>
      <p class="intake-welcome__text">{NEW_CLIENT_INTAKE_WELCOME}</p>
    </div>

    <div class="intake-welcome intake-welcome--returning" data-returning-client-welcome hidden>
      <p class="intake-welcome__text">{RETURNING_CLIENT_INTAKE_NOTE}</p>
    </div>

    <fieldset class="form-section">
      <legend>Contact information</legend>

      <div class="field-row">
        <label class="field">
          <span>First name</span>
          <input type="text" name="firstName" required autocomplete="given-name" />
        </label>

        <label class="field">
          <span>Last name</span>
          <input type="text" name="lastName" required autocomplete="family-name" />
        </label>
      </div>

      <label class="field">
        <span>Email</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>

      <label class="field">
        <span>Mobile phone</span>
        <input type="tel" name="phone" required autocomplete="tel" />
      </label>

      <fieldset class="field field--inline" data-intake-only>
        <legend>Preferred contact method</legend>
        <div class="radio-group">
          {
            PREFERRED_CONTACT_METHODS.map((method) => (
              <label class="radio">
                <input
                  type="radio"
                  name="preferredContactMethod"
                  value={method}
                  required
                  data-intake-required
                />
                <span>{PREFERRED_CONTACT_LABELS[method]}</span>
              </label>
            ))
          }
        </div>
      </fieldset>

      <label class="checkbox">
        <input type="checkbox" name="smsOptIn" value="true" />
        <span>Text me appointment reminders (optional)</span>
      </label>
    </fieldset>

    <fieldset class="form-section" data-intake-section>
      <legend>New client intake</legend>

      <label class="field">
        <span>Birthday</span>
        <input
          type="date"
          name="birthday"
          autocomplete="bday"
          data-intake-required
        />
      </label>

      <label class="field">
        <span>Street address</span>
        <input
          type="text"
          name="addressLine1"
          autocomplete="address-line1"
          data-intake-required
        />
      </label>

      <label class="field">
        <span>Apartment, suite, etc. (optional)</span>
        <input type="text" name="addressLine2" autocomplete="address-line2" />
      </label>

      <div class="field-row field-row--3">
        <label class="field">
          <span>City</span>
          <input
            type="text"
            name="addressCity"
            autocomplete="address-level2"
            data-intake-required
          />
        </label>

        <label class="field">
          <span>State</span>
          <input
            type="text"
            name="addressState"
            maxlength="2"
            autocomplete="address-level1"
            placeholder="IN"
            data-intake-required
          />
        </label>

        <label class="field">
          <span>ZIP</span>
          <input
            type="text"
            name="addressZip"
            inputmode="numeric"
            autocomplete="postal-code"
            data-intake-required
          />
        </label>
      </div>

      <fieldset class="field">
        <legend>How did you hear about us?</legend>
        <p class="field-hint">Select all that apply.</p>
        <div class="checkbox-grid">
          {
            INTAKE_REFERRAL_SOURCES.map((source) => (
              <label class="checkbox">
                <input
                  type="checkbox"
                  name="referralSources"
                  value={source}
                  data-intake-required-group="referralSources"
                />
                <span>{source}</span>
              </label>
            ))
          }
        </div>
      </fieldset>
    </fieldset>

    <fieldset class="form-section form-section--optional">
      <legend>Appointment notes (optional)</legend>

      <label class="field">
        <span>Must-know details for your visit</span>
        <textarea
          name="intakeNotes"
          rows="3"
          maxlength="1200"
          placeholder="Allergies, accessibility needs, or other details for your stylist."
        />
      </label>

      <label class="field">
        <span>Service preferences</span>
        <textarea
          name="bookingPreferences"
          rows="2"
          maxlength="600"
          placeholder="Tone goals, styling preferences, or products to avoid."
        />
      </label>
    </fieldset>

    <div class="order-summary" aria-label="Order summary">
      <div class="order-summary__row">
        <span>Services subtotal</span>
        <span>{formatCents(subtotalCents)}</span>
      </div>
      <div class="order-summary__row order-summary__row--deposit">
        <span>Deposit due today</span>
        <span>{depositLabel}</span>
      </div>
      <p class="order-summary__hint">
        {
          depositRequiredCents > 0
            ? "Your deposit is charged when you confirm. The remaining balance is due at your appointment."
            : "Your card secures this appointment. You won't be charged now unless noted in the policy."
        }
      </p>
    </div>

    <div class="card-section">
      <p class="card-section__label">Payment method</p>
      <p class="card-section__hint">
        Secure card on file — required to complete booking.
      </p>
      <div id="payment-element" class="payment-element" aria-busy="false" aria-live="polite">
        <p class="payment-element__status">Enter your email above to load the card form.</p>
      </div>
      <p class="form-error" data-form-error hidden></p>
    </div>

    <Button type="button" variant="primary" data-open-policy-modal>
      Review policy & continue
    </Button>
  </form>

  <PolicyModal policy={bookingPolicy} />

  <p class="back">
    <a
      href={`${withBase("datetime/")}?services=${servicesParamValue}&stylist=${stylist.slug}&date=${date}${showStylistStep ? "&flow=stylist" : ""}`}
    >
      ← Back to date & time
    </a>
  </p>
</BookingLayout>

<script src="../scripts/details-booking.ts"></script>

<style>
  .summary {
    padding: 1rem;
    background: var(--color-light);
    border-left: 3px solid var(--color-sage);
  }

  .reservation-hold {
    margin: 1rem 0 0;
    padding: 0.75rem 1rem;
    background: rgba(231, 172, 70, 0.15);
    border: 1px solid var(--color-citrine);
    font-size: 0.95rem;
  }

  .lookup-status {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-sage);
  }

  .intake-welcome {
    margin-top: 1.25rem;
    padding: 0.85rem 1rem;
    background: rgba(231, 172, 70, 0.12);
    border-left: 3px solid var(--color-citrine);
  }

  .intake-welcome--returning {
    background: rgba(143, 168, 143, 0.12);
    border-left-color: var(--color-sage);
  }

  .intake-welcome__text {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .details-form {
    display: grid;
    gap: 1.25rem;
    max-width: 32rem;
    margin-top: 1.5rem;
  }

  .form-section {
    display: grid;
    gap: 1rem;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .form-section legend,
  .field--inline legend,
  .field legend {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.35rem;
    padding: 0;
  }

  .form-section--optional legend {
    color: var(--color-gray);
  }

  .field-row {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr 1fr;
  }

  .field-row--3 {
    grid-template-columns: 2fr 1fr 1fr;
  }

  @media (max-width: 520px) {
    .field-row,
    .field-row--3 {
      grid-template-columns: 1fr;
    }
  }

  .field {
    display: grid;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .field span,
  .field > legend {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .field-hint {
    margin: 0 0 0.35rem;
    font-size: 0.85rem;
    color: var(--color-gray);
  }

  .field input,
  .field textarea {
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font: inherit;
  }

  .field textarea {
    resize: vertical;
  }

  .radio-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
  }

  .radio,
  .checkbox {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    font-size: 0.95rem;
  }

  .checkbox-grid {
    display: grid;
    gap: 0.5rem;
  }

  .order-summary {
    margin: 0.25rem 0;
    padding: 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    display: grid;
    gap: 0.5rem;
  }

  .order-summary__row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }

  .order-summary__row--deposit {
    font-weight: 600;
    padding-top: 0.35rem;
    border-top: 1px solid var(--color-border-subtle);
  }

  .order-summary__hint {
    margin: 0.25rem 0 0;
    font-size: 0.82rem;
    color: var(--color-gray);
    line-height: 1.45;
  }

  .card-section {
    display: grid;
    gap: 0.5rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .card-section__label {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .card-section__hint {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-gray);
  }

  .payment-element {
    min-height: 2rem;
  }

  .payment-element__status {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-gray);
  }

  .payment-element__error {
    margin: 0;
    font-size: 0.9rem;
    color: #b42318;
  }

  .form-error {
    margin: 0;
    font-size: 0.9rem;
    color: #b42318;
  }

  .back {
    margin-top: 1.5rem;
  }
</style>
