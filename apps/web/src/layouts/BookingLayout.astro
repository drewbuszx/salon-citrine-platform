---
import "../styles/global.css";
import { BUSINESS } from "@saloncitrine/shared";
import BookingSteps from "../components/BookingSteps.astro";
import { withBase } from "../lib/paths";

interface Props {
  title: string;
  step: 1 | 2 | 3 | 4;
}

const { title, step } = Astro.props;
const logoSrc = `${import.meta.env.BASE_URL}images/salon-citrine-logo.png`.replace(
  /\/+/g,
  "/",
);
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title} · Book · {BUSINESS.name}</title>
  </head>
  <body>
    <div class="booking-shell">
      <header class="booking-header">
        <a class="booking-header__brand" href={withBase()}>
          <img
            class="booking-header__logo"
            src={logoSrc}
            alt={BUSINESS.name}
            width="280"
            height="80"
          />
        </a>
        <p class="booking-header__tagline">{BUSINESS.tagline}</p>
      </header>

      <main class="booking-main">
        <BookingSteps current={step} />
        <div class="booking-content">
          <slot />
        </div>
      </main>

      <footer class="booking-footer">
        <p>
          Questions? Call <a href={`tel:${BUSINESS.phoneE164}`}>{BUSINESS.phone}</a>
        </p>
      </footer>
    </div>
  </body>
</html>

<style>
  .booking-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .booking-header {
    padding: 1.5rem var(--section-padding) 1.25rem;
    border-bottom: 1px solid var(--color-border);
    text-align: center;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(8px);
  }

  .booking-header__brand {
    display: inline-block;
    text-decoration: none;
  }

  .booking-header__logo {
    width: min(220px, 58vw);
    height: auto;
    margin-inline: auto;
  }

  .booking-header__tagline {
    margin: 0.5rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .booking-main {
    flex: 1;
    width: min(var(--max-width), 100%);
    margin: 0 auto;
    padding: var(--section-padding);
    padding-bottom: calc(var(--section-padding) + 1rem);
  }

  .booking-content {
    margin-top: 1.5rem;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    background: var(--color-booking-panel-bg);
    border: 1px solid var(--color-border-subtle);
    box-shadow: 0 8px 40px rgba(60, 61, 60, 0.05);
  }

  .booking-footer {
    padding: 1rem var(--section-padding) 2rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-gray);
    background: rgba(255, 255, 255, 0.72);
  }

  .booking-footer a {
    color: var(--color-text);
  }
</style>
