---
import "../styles/global.css";
import "../styles/fonts.css";
import { BUSINESS } from "@saloncitrine/shared";
import BookingSteps, {
  type BookingStepId,
} from "../components/BookingSteps.astro";
import SiteHeader from "../components/SiteHeader.astro";

interface Props {
  title: string;
  step: BookingStepId;
  showStylistStep?: boolean;
  embed?: boolean;
}

const { title, step, showStylistStep = false } = Astro.props;
const embed =
  Astro.props.embed ?? Astro.url.searchParams.get("embed") === "1";
---

<!doctype html>
<html lang="en" data-booking-embed={embed ? "1" : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title} · Book · {BUSINESS.name}</title>
    <script is:inline>
      (function () {
        var storageKey = "theme";
        var stored = localStorage.getItem(storageKey);
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var theme =
          stored === "dark" || stored === "light"
            ? stored
            : prefersDark
              ? "dark"
              : "light";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <div class:list={["booking-shell", embed && "booking-shell--embed"]}>
      {embed ? null : <SiteHeader />}

      <main class="booking-main">
        <BookingSteps current={step} showStylistStep={showStylistStep} compact={embed} />
        <div class="booking-content">
          <slot />
        </div>
      </main>

      {
        embed ? null : (
          <footer class="booking-footer">
            <p>
              Questions? Call <a href={`tel:${BUSINESS.phoneE164}`}>{BUSINESS.phone}</a>
            </p>
          </footer>
        )
      }
    </div>
  </body>
</html>

<style>
  .booking-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding-top: var(--header-height);
  }

  .booking-shell--embed {
    padding-top: 0;
    background: var(--color-cream);
  }

  .booking-main {
    flex: 1;
    width: min(var(--max-width), 100%);
    margin: 0 auto;
    padding: var(--section-padding);
    padding-bottom: calc(var(--section-padding) + 1rem);
  }

  .booking-shell--embed .booking-main {
    padding-top: var(--space-4);
    padding-bottom: var(--space-6);
  }

  .booking-content {
    margin-top: 1.5rem;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    background: var(--color-booking-panel-bg);
    border: 1px solid var(--color-border-subtle);
    box-shadow: 0 8px 40px var(--color-card-shadow);
  }

  .booking-shell--embed .booking-content {
    margin-top: var(--space-3);
    padding: clamp(1rem, 3vw, 1.75rem);
    box-shadow: none;
    border-color: var(--color-stone-200);
  }

  .booking-shell--embed .booking-footer {
    display: none;
  }

  .booking-footer {
    padding: 1rem var(--section-padding) 2rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-gray);
    background: var(--color-booking-panel-bg);
    border-top: 1px solid var(--color-border-subtle);
  }

  .booking-footer a {
    color: var(--color-text);
  }
</style>
