---
import "../styles/global.css";
import "../styles/fonts.css";
import "../styles/booking-mobile.css";
import { BUSINESS } from "@saloncitrine/shared";
import BookingSteps, {
  type BookingStepId,
} from "../components/BookingSteps.astro";
import SiteHeader from "../components/SiteHeader.astro";

interface Props {
  title: string;
  step: BookingStepId;
  showStylistStep?: boolean;
  embed?: boolean;
}

const { title, step, showStylistStep = false } = Astro.props;
const embed =
  Astro.props.embed ?? Astro.url.searchParams.get("embed") === "1";
---

<!doctype html>
<html lang="en" data-booking-embed={embed ? "1" : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <title>{title} · Book · {BUSINESS.name}</title>
    <script is:inline>
      (function () {
        var storageKey = "theme";
        var stored = localStorage.getItem(storageKey);
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var theme =
          stored === "dark" || stored === "light"
            ? stored
            : prefersDark
              ? "dark"
              : "light";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <div class:list={["booking-shell", embed && "booking-shell--embed"]}>
      {embed ? (
        <a class="booking-skip-link" href="#booking-main">
          Skip to main content
        </a>
      ) : null}
      {embed ? null : <SiteHeader />}

      <main id="booking-main" class="booking-main" tabindex="-1">
        <div class="booking-steps-wrap">
          <BookingSteps current={step} showStylistStep={showStylistStep} compact={embed} />
        </div>
        <div class="booking-content">
          <slot />
        </div>
      </main>

      {
        embed ? null : (
          <footer class="booking-footer">
            <p>
              Questions? Call <a href={`tel:${BUSINESS.phoneE164}`}>{BUSINESS.phone}</a>
            </p>
          </footer>
        )
      }
    </div>
    {embed ? <script src="../scripts/embed-resize.ts"></script> : null}
  </body>
</html>

<style>
  /* Flat cream + natural height in iframe — avoids gradient bleed and double scrollbars. */
  :global(html[data-booking-embed="1"]),
  :global(html[data-booking-embed="1"] body) {
    min-height: auto;
    height: auto;
    overflow-x: hidden;
    background: var(--color-cream);
    background-image: none;
  }

  .booking-skip-link {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    z-index: 500;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius-sm);
    background: var(--color-stone-800);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    transform: translateY(-200%);
    transition: transform var(--transition-fast);
  }

  .booking-skip-link:focus {
    transform: translateY(0);
    outline: 2px solid var(--color-citrine);
    outline-offset: 2px;
  }

  .booking-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding-top: var(--header-height);
  }

  .booking-shell--embed {
    min-height: auto;
    padding-top: 0;
    background: var(--color-cream);
    --booking-steps-sticky-top: 0;
  }

  .booking-main {
    flex: 1;
    width: min(var(--max-width), 100%);
    margin: 0 auto;
    padding: var(--section-padding);
    padding-bottom: calc(var(--section-padding) + 1rem);
  }

  .booking-shell--embed .booking-main {
    padding: var(--space-3) var(--space-4) var(--space-4);
  }

  .booking-steps-wrap {
    position: sticky;
    top: var(--booking-steps-sticky-top, var(--header-height));
    z-index: 15;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    background: var(--color-cream);
  }

  .booking-shell--embed .booking-steps-wrap {
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-1);
  }

  .booking-content {
    padding: clamp(1.5rem, 4vw, 2.5rem);
    background: var(--color-booking-panel-bg);
    border: 1px solid var(--color-stone-200);
    box-shadow: 0 8px 40px var(--color-card-shadow);
  }

  .booking-shell--embed .booking-content {
    padding: clamp(0.75rem, 2.5vw, 1.25rem);
    box-shadow: 0 4px 24px var(--color-card-shadow);
  }

  .booking-shell--embed .booking-footer {
    display: none;
  }

  .booking-footer {
    padding: 1rem var(--section-padding) 2rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-gray);
    background: var(--color-booking-panel-bg);
    border-top: 1px solid var(--color-border-subtle);
  }

  .booking-footer a {
    color: var(--color-text);
  }
</style>
