---
import "../styles/global.css";
import { BUSINESS } from "@saloncitrine/shared";
import BookingSteps from "../components/BookingSteps.astro";
import { withBase } from "../lib/paths";

interface Props {
  title: string;
  step: 1 | 2 | 3 | 4;
}

const { title, step } = Astro.props;
const imageBase = `${import.meta.env.BASE_URL}images/`.replace(/\/+/g, "/");
const logoLightSrc = `${imageBase}salon-citrine-logo.png`;
const logoDarkSrc = `${imageBase}salon-citrine-banner-dark.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title} · Book · {BUSINESS.name}</title>
    <script is:inline>
      (function () {
        var storageKey = "theme";
        var stored = localStorage.getItem(storageKey);
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var theme =
          stored === "dark" || stored === "light"
            ? stored
            : prefersDark
              ? "dark"
              : "light";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <div class="booking-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="site-header__logo" href={withBase()} aria-label={BUSINESS.name}>
            <img
              class="site-header__logo-image site-header__logo-image--light"
              src={logoLightSrc}
              alt={BUSINESS.name}
              width="1180"
              height="430"
              fetchpriority="high"
            />
            <img
              class="site-header__logo-image site-header__logo-image--dark"
              src={logoDarkSrc}
              alt=""
              width="1180"
              height="430"
              fetchpriority="high"
              aria-hidden="true"
            />
          </a>

          <button
            class="site-header__theme-toggle"
            type="button"
            aria-label="Switch to dark mode"
            data-theme-toggle
          >
            <svg
              class="theme-toggle__icon theme-toggle__icon--moon"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
            <svg
              class="theme-toggle__icon theme-toggle__icon--sun"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
          </button>
        </div>
      </header>

      <main class="booking-main">
        <BookingSteps current={step} />
        <div class="booking-content">
          <slot />
        </div>
      </main>

      <footer class="booking-footer">
        <p>
          Questions? Call <a href={`tel:${BUSINESS.phoneE164}`}>{BUSINESS.phone}</a>
        </p>
      </footer>
    </div>

    <script>
      const themeToggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");
      const storageKey = "theme";

      function getTheme() {
        return document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
      }

      function updateToggleLabels(theme: "light" | "dark") {
        const label =
          theme === "dark" ? "Switch to light mode" : "Switch to dark mode";
        themeToggles.forEach((toggle) => toggle.setAttribute("aria-label", label));
      }

      function setTheme(theme: "light" | "dark") {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem(storageKey, theme);
        updateToggleLabels(theme);
      }

      updateToggleLabels(getTheme());

      themeToggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          setTheme(getTheme() === "dark" ? "light" : "dark");
        });
      });
    </script>
  </body>
</html>

<style>
  .booking-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding-top: var(--header-height);
  }

  .booking-main {
    flex: 1;
    width: min(var(--max-width), 100%);
    margin: 0 auto;
    padding: var(--section-padding);
    padding-bottom: calc(var(--section-padding) + 1rem);
  }

  .booking-content {
    margin-top: 1.5rem;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    background: var(--color-booking-panel-bg);
    border: 1px solid var(--color-border-subtle);
    box-shadow: 0 8px 40px var(--color-card-shadow);
  }

  .booking-footer {
    padding: 1rem var(--section-padding) 2rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-gray);
    background: var(--color-booking-panel-bg);
    border-top: 1px solid var(--color-border-subtle);
  }

  .booking-footer a {
    color: var(--color-text);
  }
</style>
