---
import Modal from "@saloncitrine/theme/components/Modal.astro";
import Button from "@saloncitrine/theme/components/Button.astro";
import {
  formatBookingPolicySummary,
  formatLateCancelMessage,
  type BookingPolicy,
} from "@saloncitrine/shared";

interface Props {
  policy: BookingPolicy;
}

const { policy } = Astro.props;
const policyText = formatBookingPolicySummary(policy);
const lateCancelMessage = formatLateCancelMessage(policy);
---

<Modal id="policy-modal" labelledBy="policy-modal-title">
  <p class="policy-modal__kicker">One last step</p>
  <h2 id="policy-modal-title" class="policy-modal__title">{policy.title}</h2>

  <dl class="policy-modal__highlights">
    <div>
      <dt>Cancellation window</dt>
      <dd>{policy.cancellationWindowHours} hours</dd>
    </div>
    <div>
      <dt>Late cancel fee</dt>
      <dd>{policy.lateCancelFeePercent}%</dd>
    </div>
    <div>
      <dt>No-show fee</dt>
      <dd>{policy.noShowFeePercent}%</dd>
    </div>
    {
      policy.depositType === "fixed" && typeof policy.depositValue === "number" ? (
        <div>
          <dt>Deposit</dt>
          <dd>
            ${(policy.depositValue / 100).toFixed(policy.depositValue % 100 === 0 ? 0 : 2)}
          </dd>
        </div>
      ) : policy.depositType === "percent" && typeof policy.depositValue === "number" ? (
        <div>
          <dt>Deposit</dt>
          <dd>{policy.depositValue}%</dd>
        </div>
      ) : policy.depositType === "card_on_file" || policy.requiresCardOnFile ? (
        <div>
          <dt>Card on file</dt>
          <dd>Required</dd>
        </div>
      ) : null
    }
  </dl>

  <div class="policy-modal__body">
    <p class="policy-modal__lead">{lateCancelMessage}</p>
    <p class="policy-modal__text">{policyText}</p>
  </div>

  <div class="policy-modal__actions">
    <Button variant="secondary" type="button" data-policy-back>Go back</Button>
    <Button variant="primary" type="button" data-policy-confirm>I agree — book my appointment</Button>
  </div>
</Modal>

<script>
  const modal = document.getElementById("policy-modal");
  const dialog = modal?.querySelector<HTMLElement>('[role="dialog"]');
  const backBtn = modal?.querySelector<HTMLButtonElement>("[data-policy-back]");
  const confirmBtn = modal?.querySelector<HTMLButtonElement>("[data-policy-confirm]");
  const backdrop = modal?.querySelector<HTMLElement>(".sc-modal__backdrop");
  const openTriggers = document.querySelectorAll<HTMLButtonElement>(
    "[data-open-policy-modal], [data-open-policy-link]",
  );

  const focusableSelector =
    'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';

  function getFocusable(container: HTMLElement) {
    return Array.from(container.querySelectorAll<HTMLElement>(focusableSelector)).filter(
      (el) => !el.hasAttribute("disabled"),
    );
  }

  let lastFocused: HTMLElement | null = null;
  let openedForSubmit = false;

  function openModal(trigger?: HTMLElement | null) {
    if (!modal || !dialog) return;
    lastFocused =
      trigger ??
      (document.activeElement instanceof HTMLElement
        ? (document.activeElement as HTMLElement)
        : null);
    modal.removeAttribute("hidden");
    modal.setAttribute("aria-hidden", "false");
    document.body.classList.add("policy-modal-open");
    backBtn?.focus();
  }

  function closeModal() {
    if (!modal) return;
    modal.setAttribute("hidden", "");
    modal.setAttribute("aria-hidden", "true");
    document.body.classList.remove("policy-modal-open");
    lastFocused?.focus();
  }

  function submitForm() {
    document.dispatchEvent(new CustomEvent("policy-confirmed"));
  }

  openTriggers.forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      openedForSubmit = btn.hasAttribute("data-open-policy-modal");
      openModal(btn);
    });
  });

  backBtn?.addEventListener("click", closeModal);
  backdrop?.addEventListener("click", closeModal);

  confirmBtn?.addEventListener("click", () => {
    closeModal();
    if (openedForSubmit) {
      submitForm();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && !modal.hasAttribute("hidden")) {
      e.preventDefault();
      closeModal();
    }

    if (e.key === "Tab" && modal && !modal.hasAttribute("hidden") && dialog) {
      const focusable = getFocusable(dialog);
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });
</script>

<style>
  :global(#policy-modal .sc-modal__dialog) {
    width: min(36rem, 100%);
    max-height: min(88vh, 40rem);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-radius: var(--radius-md);
    background: var(--color-stone-50);
    border-color: var(--color-stone-200);
    box-shadow:
      0 1.5rem 3rem rgba(0, 0, 0, 0.18),
      0 0 0 1px rgba(0, 0, 0, 0.04);
  }

  :global([data-theme="dark"] #policy-modal .sc-modal__dialog) {
    background: var(--color-stone-100);
    border-color: var(--color-stone-300);
    box-shadow:
      0 1.5rem 3rem rgba(0, 0, 0, 0.45),
      0 0 0 1px rgba(255, 255, 255, 0.06);
  }

  :global([data-theme="dark"] #policy-modal .sc-modal__backdrop) {
    background: rgba(0, 0, 0, 0.72);
  }

  .policy-modal__kicker {
    margin: 0 0 var(--space-2);
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-sage);
  }

  .policy-modal__title {
    margin: 0 0 var(--space-4);
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 3vw, 1.65rem);
    font-weight: 500;
    line-height: 1.2;
  }

  .policy-modal__highlights {
    margin: 0 0 var(--space-5);
    padding: var(--space-4);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
  }

  .policy-modal__highlights dt {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-dusty-rose);
  }

  .policy-modal__highlights dd {
    margin: 0.15rem 0 0;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.3;
  }

  .policy-modal__body {
    display: grid;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .policy-modal__lead {
    margin: 0;
    padding: var(--space-3) var(--space-4);
    background: var(--color-citrine-muted);
    border-left: 3px solid var(--color-citrine);
    font-size: 0.95rem;
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .policy-modal__text {
    margin: 0;
    font-size: 0.95rem;
    line-height: var(--leading-relaxed);
    color: var(--color-gray);
  }

  .policy-modal__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: flex-end;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-stone-200);
  }

  :global(body.policy-modal-open) {
    overflow: hidden;
  }

  @media (max-width: 480px) {
    .policy-modal__highlights {
      grid-template-columns: 1fr;
    }
  }
</style>
