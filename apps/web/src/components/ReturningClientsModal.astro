---
import Modal from "@saloncitrine/theme/components/Modal.astro";
import Button from "@saloncitrine/theme/components/Button.astro";

interface Props {
  serviceName: string;
  serviceDescription: string | null;
  stylistName: string;
  durationLabel: string;
  priceLabel: string;
  /** URL when user confirms they are a returning client */
  continueHref: string;
  /** URL when user wants to pick another stylist */
  chooseStylistHref: string;
  autoOpen?: boolean;
}

const {
  serviceName,
  serviceDescription,
  stylistName,
  durationLabel,
  priceLabel,
  continueHref,
  chooseStylistHref,
  autoOpen = false,
} = Astro.props;
---

<Modal id="returning-clients-modal" labelledBy="returning-clients-modal-title">
  <p class="returning-modal__kicker">Returning clients only</p>

  <h2 id="returning-clients-modal-title" class="returning-modal__title">
    {serviceName}
  </h2>

  <p class="returning-modal__warning" role="status">
    <strong>Before you continue</strong>
    This service with <strong>{stylistName}</strong> is reserved for guests who
    have visited them before. If this is your first time, please choose another
    stylist.
    {
      serviceDescription ? (
        <span class="returning-modal__description">{serviceDescription}</span>
      ) : null
    }
  </p>

  <div class="returning-modal__stylist">
    <p class="returning-modal__stylist-name">{stylistName}</p>
    <p class="returning-modal__meta">
      {durationLabel} · {priceLabel}
    </p>
  </div>

  <div class="returning-modal__actions">
    <Button
      variant="primary"
      type="button"
      data-returning-continue
      data-continue-href={continueHref}
    >
      I'm a returning client — Continue
    </Button>
    <Button
      variant="secondary"
      type="button"
      data-returning-choose-stylist
      data-choose-href={chooseStylistHref}
    >
      Choose another stylist
    </Button>
  </div>
</Modal>

<script define:vars={{ autoOpen }}>
  const modal = document.getElementById("returning-clients-modal");
  const dialog = modal?.querySelector('[role="dialog"]');
  const continueBtn = modal?.querySelector("[data-returning-continue]");
  const chooseBtn = modal?.querySelector("[data-returning-choose-stylist]");
  const backdrop = modal?.querySelector(".sc-modal__backdrop");

  const focusableSelector =
    'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';

  function getFocusable(container) {
    return Array.from(container.querySelectorAll(focusableSelector)).filter(
      (el) => !el.hasAttribute("disabled"),
    );
  }

  let lastFocused = null;

  function openModal() {
    if (!modal || !dialog) return;
    lastFocused =
      document.activeElement instanceof HTMLElement
        ? document.activeElement
        : null;
    modal.removeAttribute("hidden");
    modal.setAttribute("aria-hidden", "false");
    document.body.classList.add("returning-modal-open");
    continueBtn?.focus();
  }

  function closeModal() {
    if (!modal) return;
    modal.setAttribute("hidden", "");
    modal.setAttribute("aria-hidden", "true");
    document.body.classList.remove("returning-modal-open");
    lastFocused?.focus();
  }

  continueBtn?.addEventListener("click", () => {
    const href = continueBtn.dataset.continueHref;
    if (href) window.location.href = href;
  });

  chooseBtn?.addEventListener("click", () => {
    const href = chooseBtn.dataset.chooseHref;
    if (href) window.location.href = href;
  });

  backdrop?.addEventListener("click", closeModal);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && !modal.hasAttribute("hidden")) {
      e.preventDefault();
      closeModal();
    }

    if (e.key === "Tab" && modal && !modal.hasAttribute("hidden") && dialog) {
      const focusable = getFocusable(dialog);
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });

  if (autoOpen) {
    openModal();
  }
</script>

<style>
  :global(#returning-clients-modal .sc-modal__dialog) {
    background: var(--color-cream);
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    color: var(--color-text);
  }

  :global([data-theme="dark"] #returning-clients-modal .sc-modal__dialog) {
    background: var(--color-stone-100);
    border-color: var(--color-stone-300);
    box-shadow: 0 1rem 3rem var(--color-card-shadow);
  }

  .returning-modal__kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  .returning-modal__title {
    margin: 0 0 1rem;
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 600;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .returning-modal__warning {
    margin: 0 0 1.25rem;
    padding: 0.85rem 1rem;
    background: var(--color-citrine-muted);
    border: 1px solid var(--color-citrine);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .returning-modal__warning strong:first-of-type {
    display: block;
    margin-bottom: 0.35rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-charcoal);
  }

  .returning-modal__description {
    display: block;
    margin-top: 0.5rem;
    color: var(--color-stone-500);
  }

  .returning-modal__stylist {
    margin: 0 0 1.5rem;
    padding: 1rem 1.1rem;
    background: var(--color-booking-card-bg, var(--color-stone-50));
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
  }

  :global([data-theme="dark"]) .returning-modal__stylist {
    background: var(--color-stone-50);
    border-color: var(--color-stone-300);
  }

  .returning-modal__stylist-name {
    margin: 0 0 0.35rem;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
  }

  .returning-modal__meta {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  .returning-modal__actions {
    display: grid;
    gap: 0.75rem;
  }

  :global(body.returning-modal-open) {
    overflow: hidden;
  }
</style>
