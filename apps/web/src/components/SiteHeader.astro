---
import { BUSINESS } from "@saloncitrine/shared";
import {
  GIFT_CARDS_URL,
  marketingUrl,
  MARKETING_ORIGIN,
  SHOP_URL,
} from "../lib/marketing-urls";
import { withBase } from "../lib/paths";

type NavChild = {
  href: string;
  label: string;
  external?: boolean;
};

type NavLink = {
  label: string;
  href?: string;
  external?: boolean;
  children?: NavChild[];
};

const shopLinks: NavChild[] = [
  { href: SHOP_URL, label: "Shop Citrine", external: true },
  { href: GIFT_CARDS_URL, label: "Gift Cards", external: true },
];

const navLinks: NavLink[] = [
  { href: marketingUrl("/#about"), label: "About" },
  { href: marketingUrl("/#services"), label: "Services" },
  { href: marketingUrl("/#team"), label: "Team" },
  { label: "Shop", children: shopLinks },
  { href: marketingUrl("/#policies"), label: "Policies" },
  { href: marketingUrl("/#connect"), label: "Connect" },
];

const mobileNavLinks: NavLink[] = navLinks.flatMap((link) =>
  link.href === marketingUrl("/#connect")
    ? [link, { href: marketingUrl("/#reviews"), label: "Reviews" }]
    : [link]
);

const externalLinkAttrs = (external?: boolean) =>
  external ? { target: "_blank", rel: "noopener noreferrer" } : {};

const shopMenuId = "shop-submenu";
const mainContentId = "booking-main";
const logoLightSrc = withBase("images/salon-citrine-logo.png");
const logoDarkSrc = withBase("images/salon-citrine-banner-dark.png");
---

<a class="site-header__skip-link" href={`#${mainContentId}`}>Skip to main content</a>

<header class="site-header">
  <div class="site-header__inner">
    <nav class="site-header__nav site-header__nav--left" aria-label="Primary">
      {
        navLinks.slice(0, 3).map((link) => (
          <a class="site-header__link" href={link.href} {...externalLinkAttrs(link.external)}>
            {link.label}
          </a>
        ))
      }
    </nav>

    <a class="site-header__logo" href={MARKETING_ORIGIN} aria-label={BUSINESS.name}>
      <img
        class="site-header__logo-image site-header__logo-image--light"
        src={logoLightSrc}
        alt={BUSINESS.name}
        width="1180"
        height="430"
        fetchpriority="high"
      />
      <img
        class="site-header__logo-image site-header__logo-image--dark"
        src={logoDarkSrc}
        alt=""
        width="1180"
        height="430"
        fetchpriority="high"
        aria-hidden="true"
      />
    </a>

    <nav class="site-header__nav site-header__nav--right" aria-label="Secondary">
      {
        navLinks.slice(3).map((link) =>
          link.children ? (
            <div class="site-header__dropdown" data-nav-dropdown>
              <button
                class="site-header__link site-header__dropdown-trigger"
                type="button"
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls={shopMenuId}
                data-dropdown-trigger
              >
                {link.label}
                <svg
                  class="site-header__dropdown-chevron"
                  viewBox="0 0 12 12"
                  aria-hidden="true"
                >
                  <path d="M2.5 4.5 6 8l3.5-3.5" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </button>
              <ul
                id={shopMenuId}
                class="site-header__dropdown-menu"
                role="menu"
                aria-label="Shop"
                data-dropdown-menu
              >
                {
                  link.children.map((child) => (
                    <li role="none">
                      <a
                        class="site-header__dropdown-item"
                        href={child.href}
                        role="menuitem"
                        {...externalLinkAttrs(child.external)}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          ) : (
            <a
              class="site-header__link"
              href={link.href}
              {...externalLinkAttrs(link.external)}
            >
              {link.label}
            </a>
          )
        )
      }
    </nav>

    <div class="site-header__theme-tray site-header__theme-tray--desktop">
      <button
        class="site-header__theme-toggle site-header__theme-toggle--desktop"
        type="button"
        aria-label="Switch to dark mode"
        data-theme-toggle
      >
        <svg
          class="theme-toggle__icon theme-toggle__icon--moon"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <svg
          class="theme-toggle__icon theme-toggle__icon--sun"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
      </button>
    </div>

    <div class="site-header__controls">
      <button
        class="site-header__menu-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="site-mobile-nav"
        data-menu-toggle
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <div class="site-header__mobile-backdrop" data-mobile-backdrop hidden></div>

    <nav
      id="site-mobile-nav"
      class="site-header__nav site-header__nav--mobile"
      aria-label="Mobile"
      data-mobile-nav
    >
      {
        mobileNavLinks.map((link) =>
          link.children ? (
            <div class="site-header__dropdown site-header__dropdown--mobile" data-nav-dropdown>
              <button
                class="site-header__link site-header__dropdown-trigger"
                type="button"
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls={`${shopMenuId}-mobile`}
                data-dropdown-trigger
              >
                {link.label}
                <svg
                  class="site-header__dropdown-chevron"
                  viewBox="0 0 12 12"
                  aria-hidden="true"
                >
                  <path d="M2.5 4.5 6 8l3.5-3.5" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </button>
              <ul
                id={`${shopMenuId}-mobile`}
                class="site-header__dropdown-menu"
                role="menu"
                aria-label="Shop"
                data-dropdown-menu
              >
                {
                  link.children.map((child) => (
                    <li role="none">
                      <a
                        class="site-header__dropdown-item"
                        href={child.href}
                        role="menuitem"
                        {...externalLinkAttrs(child.external)}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          ) : (
            <a
              class="site-header__link"
              href={link.href}
              {...externalLinkAttrs(link.external)}
            >
              {link.label}
            </a>
          )
        )
      }

      <div class="site-header__theme-tray site-header__theme-tray--mobile">
        <button
          class="site-header__theme-toggle site-header__theme-toggle--mobile"
          type="button"
          aria-label="Switch to dark mode"
          data-theme-toggle
        >
          <svg
            class="theme-toggle__icon theme-toggle__icon--moon"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
          <svg
            class="theme-toggle__icon theme-toggle__icon--sun"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
        </button>
      </div>
      <button
        class="site-header__menu-close"
        type="button"
        aria-label="Close menu"
        data-menu-close
      >
        <span aria-hidden="true">&times;</span>
      </button>
    </nav>
  </div>
</header>

<script>
  const mainContentId = "booking-main";
  const main = document.querySelector<HTMLElement>(".booking-main");
  if (main && !main.id) {
    main.id = mainContentId;
  }

  const themeToggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");
  const storageKey = "theme";

  function getTheme() {
    return document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
  }

  function updateToggleLabels(theme: "light" | "dark") {
    const label =
      theme === "dark" ? "Switch to light mode" : "Switch to dark mode";
    themeToggles.forEach((toggle) => toggle.setAttribute("aria-label", label));
  }

  function setTheme(theme: "light" | "dark") {
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem(storageKey, theme);
    updateToggleLabels(theme);
  }

  updateToggleLabels(getTheme());

  themeToggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      setTheme(getTheme() === "dark" ? "light" : "dark");
    });
  });

  const menuToggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const nav = document.querySelector<HTMLElement>("[data-mobile-nav]");
  const mobileBackdrop = document.querySelector<HTMLElement>("[data-mobile-backdrop]");
  const dropdowns = document.querySelectorAll<HTMLElement>("[data-nav-dropdown]");

  function closeDropdown(dropdown: HTMLElement) {
    const trigger = dropdown.querySelector<HTMLButtonElement>("[data-dropdown-trigger]");
    dropdown.classList.remove("is-open");
    trigger?.setAttribute("aria-expanded", "false");
  }

  function openDropdown(dropdown: HTMLElement) {
    const trigger = dropdown.querySelector<HTMLButtonElement>("[data-dropdown-trigger]");
    dropdown.classList.add("is-open");
    trigger?.setAttribute("aria-expanded", "true");
  }

  function setDropdownOpen(dropdown: HTMLElement, open: boolean) {
    if (open) {
      openDropdown(dropdown);
    } else {
      closeDropdown(dropdown);
    }
  }

  dropdowns.forEach((dropdown) => {
    const trigger = dropdown.querySelector<HTMLButtonElement>("[data-dropdown-trigger]");
    const menu = dropdown.querySelector<HTMLElement>("[data-dropdown-menu]");
    const items = menu
      ? Array.from(menu.querySelectorAll<HTMLAnchorElement>("a[role='menuitem']"))
      : [];

    trigger?.addEventListener("click", (event) => {
      event.stopPropagation();
      const isOpen = dropdown.classList.contains("is-open");

      dropdowns.forEach((other) => {
        if (other !== dropdown) {
          closeDropdown(other);
        }
      });

      setDropdownOpen(dropdown, !isOpen);
    });

    trigger?.addEventListener("keydown", (event) => {
      if (event.key === "ArrowDown") {
        event.preventDefault();
        dropdowns.forEach((other) => {
          if (other !== dropdown) {
            closeDropdown(other);
          }
        });
        openDropdown(dropdown);
        items[0]?.focus();
      }

      if (event.key === "Escape") {
        closeDropdown(dropdown);
      }
    });

    menu?.addEventListener("keydown", (event) => {
      const activeItem = document.activeElement;
      const currentIndex = items.findIndex((item) => item === activeItem);

      if (event.key === "ArrowDown") {
        event.preventDefault();
        items[Math.min(currentIndex + 1, items.length - 1)]?.focus();
      }

      if (event.key === "ArrowUp") {
        event.preventDefault();
        if (currentIndex <= 0) {
          closeDropdown(dropdown);
          trigger?.focus();
        } else {
          items[currentIndex - 1]?.focus();
        }
      }

      if (event.key === "Escape") {
        event.preventDefault();
        closeDropdown(dropdown);
        trigger?.focus();
      }

      if (event.key === "Tab" && !event.shiftKey && currentIndex === items.length - 1) {
        closeDropdown(dropdown);
      }
    });
  });

  document.addEventListener("click", (event) => {
    dropdowns.forEach((dropdown) => {
      if (!dropdown.contains(event.target as Node)) {
        closeDropdown(dropdown);
      }
    });
  });

  function setMobileMenuOpen(open: boolean) {
    nav?.classList.toggle("is-open", open);
    menuToggle?.classList.toggle("is-active", open);
    menuToggle?.setAttribute("aria-expanded", String(open));
    menuToggle?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    document.body.classList.toggle("site-header-menu-open", open);

    if (mobileBackdrop) {
      mobileBackdrop.hidden = !open;
    }

    if (!open) {
      dropdowns.forEach((dropdown) => closeDropdown(dropdown));
    }
  }

  function closeMobileMenu() {
    setMobileMenuOpen(false);
  }

  menuToggle?.addEventListener("click", () => {
    setMobileMenuOpen(!nav?.classList.contains("is-open"));
  });

  mobileBackdrop?.addEventListener("click", closeMobileMenu);

  document
    .querySelector<HTMLButtonElement>("[data-menu-close]")
    ?.addEventListener("click", closeMobileMenu);

  nav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMobileMenu);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && nav?.classList.contains("is-open")) {
      closeMobileMenu();
      menuToggle?.focus();
    }
  });
</script>

<style>
  .site-header__skip-link {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    z-index: 500;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius-sm);
    background: var(--color-stone-800);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    transform: translateY(-200%);
    transition: transform var(--transition-fast);
  }

  .site-header__skip-link:focus {
    transform: translateY(0);
    outline: 2px solid var(--color-citrine);
    outline-offset: 2px;
  }

  .site-header__theme-tray {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.2rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-pill);
    background: var(--color-stone-100);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
  }

  .site-header__theme-tray--desktop {
    position: absolute;
    right: clamp(1rem, 3vw, 2.5rem);
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
  }

  .site-header__theme-tray--mobile {
    display: none;
  }

  .site-header__theme-tray :global(.site-header__theme-toggle) {
    width: 2.15rem;
    height: 2.15rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-pill);
    background: var(--color-cream);
    color: var(--color-stone-700);
    box-shadow:
      0 1px 2px rgba(47, 42, 40, 0.08),
      0 1px 0 rgba(255, 255, 255, 0.65) inset;
    opacity: 1;
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .site-header__theme-tray :global(.site-header__theme-toggle:hover),
  .site-header__theme-tray :global(.site-header__theme-toggle:focus-visible) {
    opacity: 1;
    background: var(--color-cream-deep);
    border-color: var(--color-citrine);
    transform: translateY(-1px);
    box-shadow:
      0 3px 8px rgba(47, 42, 40, 0.1),
      0 1px 0 rgba(255, 255, 255, 0.65) inset;
    outline: none;
  }

  .site-header__theme-tray :global(.site-header__theme-toggle:focus-visible) {
    box-shadow:
      0 0 0 3px var(--color-focus-ring),
      0 1px 2px rgba(47, 42, 40, 0.08);
  }

  [data-theme="dark"] .site-header__theme-tray {
    border-color: var(--color-stone-300);
    background: var(--color-stone-100);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  [data-theme="dark"] .site-header__theme-tray :global(.site-header__theme-toggle) {
    background: var(--color-stone-50);
    border-color: var(--color-stone-300);
    color: var(--color-stone-700);
    box-shadow:
      0 2px 6px rgba(0, 0, 0, 0.28),
      0 1px 0 rgba(255, 255, 255, 0.06) inset;
  }

  [data-theme="dark"] .site-header__theme-tray :global(.site-header__theme-toggle:hover),
  [data-theme="dark"] .site-header__theme-tray :global(.site-header__theme-toggle:focus-visible) {
    background: var(--color-stone-200);
    border-color: var(--color-citrine);
  }

  :global(.site-header__logo-image--dark) {
    display: none;
  }

  :global([data-theme="dark"] .site-header__logo-image--light) {
    display: none;
  }

  :global([data-theme="dark"] .site-header__logo-image--dark) {
    display: block;
  }

  :global(.site-header__mobile-backdrop) {
    display: none;
  }

  :global(.site-header__menu-toggle.is-active span:nth-child(1)) {
    transform: translateY(7px) rotate(45deg);
  }

  :global(.site-header__menu-toggle.is-active span:nth-child(2)) {
    opacity: 0;
    transform: scaleX(0);
  }

  :global(.site-header__menu-toggle.is-active span:nth-child(3)) {
    transform: translateY(-7px) rotate(-45deg);
  }

  :global(.site-header__menu-toggle span) {
    transition:
      transform var(--transition-base),
      opacity var(--transition-fast);
  }

  :global(body.site-header-menu-open) {
    overflow: hidden;
  }

  @media (max-width: 1100px) {
    :global(.site-header__theme-tray--desktop) {
      display: none;
    }

    :global(.site-header__theme-tray--mobile) {
      display: inline-flex;
    }

    :global(.site-header__mobile-backdrop) {
      display: block;
      position: fixed;
      inset: 0;
      top: var(--header-height);
      z-index: 98;
      background: rgba(26, 24, 22, 0.42);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition:
        opacity var(--transition-slow),
        visibility var(--transition-slow);
    }

    :global(.site-header__mobile-backdrop:not([hidden])) {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    :global(.site-header__nav--mobile) {
      z-index: 99;
      transform: translateY(-1.25rem);
      transition:
        opacity var(--transition-slow),
        visibility var(--transition-slow),
        transform var(--transition-slow);
    }

    :global(.site-header__nav--mobile.is-open) {
      transform: translateY(0);
    }

    :global(.site-header__nav--mobile > .site-header__link),
    :global(.site-header__nav--mobile > .site-header__dropdown),
    :global(.site-header__nav--mobile > .site-header__theme-tray),
    :global(.site-header__nav--mobile > .site-header__menu-close) {
      opacity: 0;
      transform: translateY(0.75rem);
      transition:
        opacity var(--transition-base),
        transform var(--transition-base);
    }

    :global(.site-header__nav--mobile.is-open > .site-header__link),
    :global(.site-header__nav--mobile.is-open > .site-header__dropdown),
    :global(.site-header__nav--mobile.is-open > .site-header__theme-tray),
    :global(.site-header__nav--mobile.is-open > .site-header__menu-close) {
      opacity: 1;
      transform: translateY(0);
    }

    :global(.site-header__nav--mobile.is-open > .site-header__link:nth-child(1)),
    :global(.site-header__nav--mobile.is-open > .site-header__dropdown:nth-child(1)) {
      transition-delay: 0.04s;
    }

    :global(.site-header__nav--mobile.is-open > .site-header__link:nth-child(2)),
    :global(.site-header__nav--mobile.is-open > .site-header__dropdown:nth-child(2)) {
      transition-delay: 0.08s;
    }

    :global(.site-header__nav--mobile.is-open > .site-header__link:nth-child(3)),
    :global(.site-header__nav--mobile.is-open > .site-header__dropdown:nth-child(3)) {
      transition-delay: 0.12s;
    }

    :global(.site-header__nav--mobile.is-open > .site-header__link:nth-child(4)),
    :global(.site-header__nav--mobile.is-open > .site-header__dropdown:nth-child(4)) {
      transition-delay: 0.16s;
    }

    :global(.site-header__nav--mobile.is-open > .site-header__link:nth-child(5)),
    :global(.site-header__nav--mobile.is-open > .site-header__dropdown:nth-child(5)) {
      transition-delay: 0.2s;
    }

    :global(.site-header__nav--mobile.is-open > .site-header__link:nth-child(6)),
    :global(.site-header__nav--mobile.is-open > .site-header__dropdown:nth-child(6)) {
      transition-delay: 0.24s;
    }

    :global(.site-header__nav--mobile.is-open > .site-header__theme-tray) {
      transition-delay: 0.28s;
    }

    :global(.site-header__nav--mobile.is-open > .site-header__menu-close) {
      transition-delay: 0.32s;
    }
  }

  @media (min-width: 1101px) {
    :global(.site-header__inner) {
      padding-right: calc(clamp(1rem, 3vw, 2.5rem) + 2.75rem + 0.75rem);
    }

    :global(.site-header__theme-tray--desktop .site-header__theme-toggle--desktop) {
      position: static;
      right: auto;
      top: auto;
      transform: none;
    }
  }
</style>
