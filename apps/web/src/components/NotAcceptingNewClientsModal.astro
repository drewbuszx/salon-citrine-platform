---
import Modal from "@saloncitrine/theme/components/Modal.astro";
import Button from "@saloncitrine/theme/components/Button.astro";

interface Props {
  stylistFirstName: string;
  stylistSlug: string;
  /** URL when user confirms they are an existing client */
  continueHref: string;
  /** URL when user wants to pick another stylist */
  chooseStylistHref: string;
  autoOpen?: boolean;
}

const {
  stylistFirstName,
  stylistSlug,
  continueHref,
  chooseStylistHref,
  autoOpen = false,
} = Astro.props;
---

<Modal
  id="not-accepting-new-clients-modal"
  labelledBy="not-accepting-new-clients-modal-title"
>
  <p class="new-clients-modal__kicker">New clients</p>

  <h2 id="not-accepting-new-clients-modal-title" class="new-clients-modal__title">
    {stylistFirstName} is not accepting new clients
  </h2>

  <div class="new-clients-modal__body">
    <p class="new-clients-modal__lead">
      <strong>{stylistFirstName}</strong> is currently booked for existing clients
      only. Please confirm how you'd like to continue.
    </p>
    <ul class="new-clients-modal__options">
      <li>
        <strong>Never booked with {stylistFirstName}?</strong>
        Select another stylist to find availability.
      </li>
      <li>
        <strong>Already a client?</strong>
        Proceed to book your next appointment.
      </li>
    </ul>
  </div>

  <div class="new-clients-modal__actions">
    <Button
      variant="primary"
      type="button"
      data-new-clients-continue
      data-continue-href={continueHref}
      data-stylist-slug={stylistSlug}
    >
      I'm an existing client — Proceed
    </Button>
    <Button
      variant="secondary"
      type="button"
      data-new-clients-choose-stylist
      data-choose-href={chooseStylistHref}
    >
      Choose another stylist
    </Button>
  </div>
</Modal>

<script define:vars={{ autoOpen }}>
  const modal = document.getElementById("not-accepting-new-clients-modal");
  const dialog = modal?.querySelector('[role="dialog"]');
  const continueBtn = modal?.querySelector("[data-new-clients-continue]");
  const chooseBtn = modal?.querySelector("[data-new-clients-choose-stylist]");
  const backdrop = modal?.querySelector(".sc-modal__backdrop");

  const focusableSelector =
    'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';

  function sessionKeyForSlug(slug) {
    return `booking-existing-client-${slug}`;
  }

  function getFocusable(container) {
    return Array.from(container.querySelectorAll(focusableSelector)).filter(
      (el) => !el.hasAttribute("disabled"),
    );
  }

  function setSessionAck(slug) {
    if (!slug) return;
    try {
      sessionStorage.setItem(sessionKeyForSlug(slug), "1");
    } catch {
      /* ignore */
    }
  }

  function hasSessionAck(slug) {
    if (!slug) return false;
    try {
      return sessionStorage.getItem(sessionKeyForSlug(slug)) === "1";
    } catch {
      return false;
    }
  }

  function openModal() {
    if (!modal || !dialog) return;
    modal.removeAttribute("hidden");
    modal.setAttribute("aria-hidden", "false");
    document.body.classList.add("new-clients-modal-open");
    continueBtn?.focus();
  }

  function closeModal() {
    if (!modal) return;
    modal.setAttribute("hidden", "");
    modal.setAttribute("aria-hidden", "true");
    document.body.classList.remove("new-clients-modal-open");
  }

  continueBtn?.addEventListener("click", () => {
    const slug = continueBtn.dataset.stylistSlug ?? "";
    setSessionAck(slug);
    const href = continueBtn.dataset.continueHref;
    if (href) window.location.href = href;
  });

  chooseBtn?.addEventListener("click", () => {
    const href = chooseBtn.dataset.chooseHref;
    if (href) window.location.href = href;
  });

  backdrop?.addEventListener("click", closeModal);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && !modal.hasAttribute("hidden")) {
      e.preventDefault();
      closeModal();
    }

    if (e.key === "Tab" && modal && !modal.hasAttribute("hidden") && dialog) {
      const focusable = getFocusable(dialog);
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });

  if (autoOpen) {
    const slug = continueBtn?.dataset.stylistSlug ?? "";
    if (!hasSessionAck(slug)) {
      openModal();
    }
  }
</script>

<style>
  :global(#not-accepting-new-clients-modal .sc-modal__dialog) {
    background: var(--color-cream);
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    color: var(--color-text);
  }

  :global([data-theme="dark"] #not-accepting-new-clients-modal .sc-modal__dialog) {
    background: var(--color-stone-100);
    border-color: var(--color-stone-300);
    box-shadow: 0 1rem 3rem var(--color-card-shadow);
  }

  .new-clients-modal__kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  .new-clients-modal__title {
    margin: 0 0 1rem;
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 600;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .new-clients-modal__body {
    margin: 0 0 1.5rem;
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .new-clients-modal__lead {
    margin: 0 0 1rem;
    padding: 0.85rem 1rem;
    background: var(--color-stone-100);
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
  }

  :global([data-theme="dark"]) .new-clients-modal__lead {
    background: var(--color-stone-50);
    border-color: var(--color-stone-300);
  }

  .new-clients-modal__options {
    margin: 0;
    padding: 0 0 0 1.1rem;
    list-style: disc;
  }

  .new-clients-modal__options li {
    margin-bottom: 0.65rem;
  }

  .new-clients-modal__options li:last-child {
    margin-bottom: 0;
  }

  .new-clients-modal__options strong {
    color: var(--color-charcoal);
  }

  .new-clients-modal__actions {
    display: grid;
    gap: 0.75rem;
  }

  :global(body.new-clients-modal-open) {
    overflow: hidden;
  }
</style>
