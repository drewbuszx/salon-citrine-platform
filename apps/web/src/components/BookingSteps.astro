---
import { withBase } from "../lib/paths";

export type BookingStepId =
  | "service"
  | "cart"
  | "stylist"
  | "datetime"
  | "details"
  | "confirm";

interface Props {
  current: BookingStepId;
  /** Show professional step when user chose "Any Professional" */
  showStylistStep?: boolean;
  /** Compact step indicator for embed mode */
  compact?: boolean;
}

const { current, showStylistStep = false, compact = false } = Astro.props;

/** Boulevard SelectServiceFirst: services → cart → staff → time → client → confirm */
const BASE_STEPS: { id: BookingStepId; label: string; href: string }[] = [
  { id: "service", label: "Services", href: withBase() },
  { id: "cart", label: "Cart", href: withBase("cart/") },
  { id: "stylist", label: "Professional", href: withBase("stylist/") },
  { id: "datetime", label: "Date & time", href: withBase("datetime/") },
  { id: "details", label: "Details & pay", href: withBase("details/") },
  { id: "confirm", label: "Confirm", href: withBase("confirm/") },
];

const steps = showStylistStep
  ? BASE_STEPS
  : BASE_STEPS.filter((step) => step.id !== "stylist");

const currentIndex = steps.findIndex((step) => step.id === current);
---

<nav class:list={["steps", compact && "steps--compact"]} aria-label="Booking progress">
  <ol class="steps__list">
    {
      steps.flatMap((step, index) => {
        const items = [
          <li
            class:list={[
              "steps__item",
              index === currentIndex && "steps__item--current",
              index < currentIndex && "steps__item--complete",
            ]}
            aria-current={index === currentIndex ? "step" : undefined}
          >
            <span class="steps__num" aria-hidden="true">
              {index < currentIndex ? (
                <svg class="steps__check" viewBox="0 0 12 12" fill="none">
                  <path
                    d="M2.5 6.25 4.75 8.5 9.5 3.5"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              ) : (
                index + 1
              )}
            </span>
            <span class="steps__label">{step.label}</span>
          </li>,
        ];

        if (index < steps.length - 1) {
          items.push(
            <li
              class:list={[
                "steps__connector",
                index < currentIndex && "steps__connector--complete",
              ]}
              aria-hidden="true"
            />,
          );
        }

        return items;
      })
    }
  </ol>
</nav>

<style>
  .steps {
    padding: var(--space-3) var(--space-4);
    background: var(--color-stone-100);
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    box-shadow: inset 0 1px 3px var(--color-card-shadow);
  }

  .steps__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .steps__item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.22rem 0.6rem 0.22rem 0.22rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-pill);
    background: var(--color-bg);
    box-shadow: var(--shadow-sm);
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-gray);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      color var(--transition-fast);
  }

  @media (min-width: 640px) {
    .steps__item {
      font-size: 0.68rem;
      gap: 0.4rem;
      padding: 0.25rem 0.7rem 0.25rem 0.25rem;
    }
  }

  .steps__item--current {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted);
    box-shadow: inset 0 0 0 1px var(--color-citrine);
    color: var(--color-text);
    font-weight: 600;
  }

  .steps__item--complete {
    border-color: var(--color-sage);
    color: var(--color-sage-dark);
  }

  .steps__item--complete .steps__num {
    background: var(--color-sage);
    border-color: var(--color-sage);
    color: var(--color-white);
  }

  .steps__connector {
    flex: 0 0 auto;
    width: 1.25rem;
    height: 2px;
    background: var(--color-stone-300);
    border-radius: 1px;
    align-self: center;
    transition: background var(--transition-fast);
  }

  @media (min-width: 640px) {
    .steps__connector {
      width: 1.5rem;
    }
  }

  .steps__connector--complete {
    background: var(--color-sage);
    opacity: 0.65;
  }

  .steps__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 1.375rem;
    height: 1.375rem;
    border: 1px solid var(--color-stone-300);
    border-radius: 50%;
    font-size: 0.62rem;
    font-weight: 600;
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .steps__check {
    width: 0.7rem;
    height: 0.7rem;
  }

  .steps__item--current .steps__num {
    background: var(--color-citrine);
    border-color: var(--color-citrine);
    color: var(--color-black);
  }

  .steps__item--complete .steps__label {
    color: var(--color-sage-dark);
  }

  .steps--compact {
    padding: var(--space-2) var(--space-3);
  }

  .steps--compact .steps__list {
    gap: var(--space-1) var(--space-2);
  }

  .steps--compact .steps__item {
    padding: 0.18rem;
  }

  .steps--compact .steps__connector {
    width: 0.85rem;
  }

  .steps--compact .steps__label {
    display: none;
  }

  @media (max-width: 479px) {
    .steps__label {
      display: none;
    }

    .steps__item {
      padding: 0.18rem;
    }

    .steps__connector {
      width: 0.65rem;
    }
  }
</style>
