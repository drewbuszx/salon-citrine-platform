---
import { withBase } from "../lib/paths";

export type BookingStepId =
  | "service"
  | "stylist"
  | "cart"
  | "datetime"
  | "details"
  | "confirm";

interface Props {
  current: BookingStepId;
  /** Include the stylist step when booking started with "Any Professional" */
  showStylist?: boolean;
}

const { current, showStylist = false } = Astro.props;

const BASE_STEPS: { id: BookingStepId; label: string; href: string }[] = [
  { id: "service", label: "Service", href: withBase() },
  { id: "stylist", label: "Stylist", href: withBase("stylist/") },
  { id: "cart", label: "Cart", href: withBase("cart/") },
  { id: "datetime", label: "Date & time", href: withBase("datetime/") },
  { id: "details", label: "Details", href: withBase("details/") },
  { id: "confirm", label: "Confirm", href: withBase("confirm/") },
];

const steps = showStylist
  ? BASE_STEPS
  : BASE_STEPS.filter((step) => step.id !== "stylist");

const currentIndex = steps.findIndex((step) => step.id === current);
---

<nav class="steps" aria-label="Booking progress">
  <ol class="steps__list">
    {
      steps.map((step, index) => (
        <li
          class:list={[
            "steps__item",
            index === currentIndex && "steps__item--current",
            index < currentIndex && "steps__item--complete",
          ]}
        >
          <span class="steps__num">{index + 1}</span>
          <span class="steps__label">{step.label}</span>
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .steps {
    margin-bottom: 0.5rem;
  }

  .steps__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .steps__item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .steps__item--current {
    color: var(--color-text);
    font-weight: 600;
  }

  .steps__item--complete .steps__num {
    background: var(--color-sage);
    border-color: var(--color-sage);
    color: var(--color-white);
  }

  .steps__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    font-size: 0.65rem;
  }

  .steps__item--current .steps__num {
    background: var(--color-citrine);
    border-color: var(--color-citrine);
    color: var(--color-black);
  }
</style>
