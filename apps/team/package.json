    "test:calendar-grid": "node scripts/test-calendar-grid.mjs",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@zxing/browser": "^0.1.5",
    "@astrojs/cloudflare": "^14.1.1",
    "@saloncitrine/shared": "*",
