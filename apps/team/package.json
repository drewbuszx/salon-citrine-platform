{
  "name": "apps-team",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev --port 4322 --strictPort",
    "build": "astro build",
    "check": "astro check",
    "build:alt": "astro build --outDir dist-build",
    "preview": "astro preview",
    "test": "node --experimental-strip-types scripts/test-report-range.mjs && node --experimental-strip-types scripts/test-event-presentation.mjs && node scripts/test-calendar-grid.mjs && node --experimental-strip-types scripts/test-security-hardening.mjs",
    "test:security": "node --experimental-strip-types scripts/test-security-hardening.mjs",
    "test:invite:local": "node scripts/test-invite-flow-local.mjs",
    "test:e2e:role-matrix": "node scripts/test-role-matrix-e2e.mjs",
    "test:report-range": "node --experimental-strip-types scripts/test-report-range.mjs",
    "test:event-presentation": "node --experimental-strip-types scripts/test-event-presentation.mjs",
    "qa:mobile-viewport": "node scripts/mobile-viewport-qa.mjs",
    "qa:desktop-sidebar": "node scripts/desktop-sidebar-qa.mjs",
    "qa:mobile-a11y": "node scripts/mobile-a11y-qa.mjs",
    "qa:mobile": "node scripts/mobile-viewport-qa.mjs && node scripts/mobile-a11y-qa.mjs",
    "test:calendar-grid": "node scripts/test-calendar-grid.mjs",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.1",
    "@saloncitrine/shared": "*",
    "@saloncitrine/theme": "*",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.110.0",
    "@zxing/browser": "^0.1.5",
    "astro": "^7.0.4",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "playwright": "^1.52.0",
    "typescript": "^6.0.3"
  }
}
