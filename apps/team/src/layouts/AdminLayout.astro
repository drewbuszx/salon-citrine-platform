---
import "../styles/global.css";
import { BUSINESS } from "@saloncitrine/shared";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title} · Admin · {BUSINESS.name}</title>
  </head>
  <body>
    <header class="admin-header">
      <div class="admin-header__inner">
        <a class="admin-header__brand" href={import.meta.env.BASE_URL}>
          {BUSINESS.name} Admin
        </a>
        <nav class="admin-nav" aria-label="Admin">
          <a class="admin-nav__link admin-nav__link--active" href={import.meta.env.BASE_URL}>
            Calendar
          </a>
          <span class="admin-nav__link admin-nav__link--disabled">Clients</span>
          <span class="admin-nav__link admin-nav__link--disabled">Settings</span>
        </nav>
        <button class="admin-header__login" type="button" disabled>
          Sign in (Supabase Auth)
        </button>
      </div>
    </header>

    <main class="admin-main">
      <slot />
    </main>
  </body>
</html>

<style>
  .admin-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-charcoal);
    color: var(--color-white);
  }

  .admin-header__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    width: min(var(--max-width), 100%);
    margin: 0 auto;
    padding: 0.85rem var(--section-padding);
  }

  .admin-header__brand {
    font-family: var(--font-nav);
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
  }

  .admin-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    margin-left: auto;
  }

  .admin-nav__link {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.65);
  }

  .admin-nav__link--active {
    color: var(--color-citrine);
  }

  .admin-nav__link--disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .admin-header__login {
    padding: 0.45rem 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: transparent;
    color: inherit;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: not-allowed;
    opacity: 0.6;
  }

  .admin-main {
    width: min(var(--max-width), 100%);
    margin: 0 auto;
    padding: var(--section-padding);
  }
</style>
