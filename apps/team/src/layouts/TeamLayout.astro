---
import "../styles/global.css";
import { BUSINESS } from "@saloncitrine/shared";
import TeamSiteHeader, {
  type TeamActiveNav,
} from "../components/TeamSiteHeader.astro";

interface Props {
  title: string;
  activeNav?: TeamActiveNav;
  wide?: boolean;
  fullBleed?: boolean;
  plain?: boolean;
  loginPage?: boolean;
}

const {
  title,
  activeNav,
  wide = false,
  fullBleed = false,
  plain = false,
  loginPage = false,
} = Astro.props;
const { staff, user } = Astro.locals;
const isAuthenticated = Boolean(user && staff);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title} · Team · {BUSINESS.name}</title>
    <script is:inline>
      (function () {
        var storageKey = "theme";
        var mobileQuery = window.matchMedia("(max-width: 1100px)");

        function resolveTheme() {
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (mobileQuery.matches) {
            var stored = localStorage.getItem(storageKey);
            if (stored === "dark" || stored === "light") {
              return stored;
            }
          }
          return prefersDark ? "dark" : "light";
        }

        function applyTheme() {
          document.documentElement.setAttribute("data-theme", resolveTheme());
        }

        applyTheme();
        mobileQuery.addEventListener("change", applyTheme);
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", applyTheme);
      })();
    </script>
  </head>
  <body>
    <div
      class:list={[
        "team-shell",
        loginPage && "team-shell--login",
        (fullBleed || plain) && "team-shell--book",
      ]}
    >
      <TeamSiteHeader
        activeNav={activeNav}
        staff={staff}
        isAuthenticated={isAuthenticated}
      />

      <main
        class:list={[
          "team-main",
          wide && "team-main--wide",
          fullBleed && "team-main--full-bleed",
        ]}
      >
        {
          fullBleed || plain ? (
            <slot />
          ) : (
            <div class:list={["team-content", loginPage && "team-content--login"]}>
              <slot />
            </div>
          )
        }
      </main>
    </div>

    <script>
      const storageKey = "theme";
      const mobileQuery = window.matchMedia("(max-width: 1100px)");
      const themeToggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");

      function getTheme() {
        return document.documentElement.getAttribute("data-theme") === "dark"
          ? "dark"
          : "light";
      }

      function updateToggleLabels(theme: "light" | "dark") {
        const label =
          theme === "dark" ? "Switch to light mode" : "Switch to dark mode";
        themeToggles.forEach((toggle) => toggle.setAttribute("aria-label", label));
      }

      function applyThemeFromRules() {
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        let theme: "light" | "dark";

        if (mobileQuery.matches) {
          const stored = localStorage.getItem(storageKey);
          theme =
            stored === "dark" || stored === "light"
              ? (stored as "light" | "dark")
              : prefersDark
                ? "dark"
                : "light";
        } else {
          theme = prefersDark ? "dark" : "light";
        }

        document.documentElement.setAttribute("data-theme", theme);
        updateToggleLabels(theme);
      }

      function setMobileTheme(theme: "light" | "dark") {
        if (!mobileQuery.matches) return;
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem(storageKey, theme);
        updateToggleLabels(theme);
      }

      applyThemeFromRules();
      mobileQuery.addEventListener("change", applyThemeFromRules);
      window
        .matchMedia("(prefers-color-scheme: dark)")
        .addEventListener("change", applyThemeFromRules);

      themeToggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          setMobileTheme(getTheme() === "dark" ? "light" : "dark");
        });
      });

      const menuToggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
      const nav = document.querySelector<HTMLElement>("[data-mobile-nav]");
      const profileDropdown = document.querySelector<HTMLElement>("[data-profile-dropdown]");
      const profileTrigger = document.querySelector<HTMLButtonElement>("[data-profile-trigger]");

      function closeProfileMenu() {
        profileDropdown?.classList.remove("is-open");
        profileTrigger?.setAttribute("aria-expanded", "false");
      }

      function openProfileMenu() {
        profileDropdown?.classList.add("is-open");
        profileTrigger?.setAttribute("aria-expanded", "true");
      }

      profileTrigger?.addEventListener("click", (event) => {
        event.stopPropagation();
        const isOpen = profileDropdown?.classList.contains("is-open");
        if (isOpen) {
          closeProfileMenu();
        } else {
          openProfileMenu();
        }
      });

      document.addEventListener("click", (event) => {
        if (
          profileDropdown &&
          !profileDropdown.contains(event.target as Node)
        ) {
          closeProfileMenu();
        }
      });

      profileTrigger?.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeProfileMenu();
        }
      });

      function closeMobileMenu() {
        nav?.classList.remove("is-open");
        menuToggle?.setAttribute("aria-expanded", "false");
      }

      menuToggle?.addEventListener("click", () => {
        const isOpen = nav?.classList.toggle("is-open");
        menuToggle.setAttribute("aria-expanded", String(!!isOpen));
        if (isOpen) {
          closeProfileMenu();
        }
      });

      document
        .querySelector<HTMLButtonElement>("[data-menu-close]")
        ?.addEventListener("click", closeMobileMenu);

      nav?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMobileMenu);
      });
    </script>
  </body>
</html>
