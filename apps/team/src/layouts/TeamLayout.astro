---
import "../styles/global.css";
import { BUSINESS } from "@saloncitrine/shared";
import TeamSiteHeader, {
  type TeamActiveNav,
} from "../components/TeamSiteHeader.astro";

interface Props {
  title: string;
  activeNav?: TeamActiveNav;
  wide?: boolean;
  fullBleed?: boolean;
  plain?: boolean;
  cream?: boolean;
  loginPage?: boolean;
}

const {
  title,
  activeNav,
  wide = false,
  fullBleed = false,
  plain = false,
  cream = false,
  loginPage = false,
} = Astro.props;
const { staff, user } = Astro.locals;
const isAuthenticated = Boolean(user && staff);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title} · Team · {BUSINESS.name}</title>
    <script is:inline>
      (function () {
        var storageKey = "theme";

        function resolveTheme() {
          var stored = localStorage.getItem(storageKey);
          if (stored === "dark" || stored === "light") {
            return stored;
          }
          return "light";
        }

        document.documentElement.setAttribute("data-theme", resolveTheme());
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#team-main-content">Skip to main content</a>
    <div
      class:list={[
        "team-shell",
        loginPage && "team-shell--login",
        (fullBleed || plain) && "team-shell--book",
        cream && "team-shell--editorial",
      ]}
    >
      <TeamSiteHeader
        activeNav={activeNav}
        staff={staff}
        isAuthenticated={isAuthenticated}
      />

      <main
        id="team-main-content"
        class:list={[
          "team-main",
          wide && "team-main--wide",
          fullBleed && "team-main--full-bleed",
        ]}
      >
        {
          fullBleed || plain ? (
            <slot />
          ) : (
            <div class:list={["team-content", loginPage && "team-content--login"]}>
              <slot />
            </div>
          )
        }
      </main>
    </div>

    <script>
      const storageKey = "theme";
      const themeToggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");

      function getTheme() {
        return document.documentElement.getAttribute("data-theme") === "dark"
          ? "dark"
          : "light";
      }

      function updateToggleLabels(theme: "light" | "dark") {
        const label =
          theme === "dark" ? "Switch to light mode" : "Switch to dark mode";
        themeToggles.forEach((toggle) => toggle.setAttribute("aria-label", label));
      }

      function applyThemeFromRules() {
        const stored = localStorage.getItem(storageKey);
        const theme: "light" | "dark" =
          stored === "dark" || stored === "light"
            ? (stored as "light" | "dark")
            : "light";

        document.documentElement.setAttribute("data-theme", theme);
        updateToggleLabels(theme);
      }

      function setTheme(theme: "light" | "dark") {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem(storageKey, theme);
        updateToggleLabels(theme);
      }

      applyThemeFromRules();

      themeToggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          setTheme(getTheme() === "dark" ? "light" : "dark");
        });
      });

      document.querySelectorAll<HTMLImageElement>(".team-bar__logo-img[data-fallback-src]").forEach((img) => {
        if (img.complete && img.naturalWidth === 0) {
          img.dispatchEvent(new Event("error"));
        }
        img.addEventListener("error", () => {
          const logoLink = img.closest<HTMLElement>(".team-bar__logo");
          const fallback = img.getAttribute("data-fallback-src");
          if (fallback && img.dataset.fallbackUsed !== "1") {
            img.dataset.fallbackUsed = "1";
            img.src = fallback;
            img.classList.remove("team-bar__logo-img--fallback");
            return;
          }
          logoLink?.classList.add("is-wordmark");
        });
      });

      const menuToggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
      const nav = document.querySelector<HTMLElement>("[data-mobile-nav]");
      const profileDropdown = document.querySelector<HTMLElement>("[data-profile-dropdown]");
      const profileTrigger = document.querySelector<HTMLButtonElement>("[data-profile-trigger]");
      const profileMenu = document.querySelector<HTMLElement>("[data-profile-menu]");

      function getProfileMenuItems() {
        return profileMenu
          ? Array.from(
              profileMenu.querySelectorAll<HTMLElement>(
                '[role="menuitem"]:not([disabled])',
              ),
            )
          : [];
      }

      function closeProfileMenu(returnFocus = false) {
        profileDropdown?.classList.remove("is-open");
        profileTrigger?.setAttribute("aria-expanded", "false");
        profileMenu?.setAttribute("hidden", "");
        if (returnFocus) {
          profileTrigger?.focus();
        }
      }

      function openProfileMenu(focusFirst = true) {
        profileDropdown?.classList.add("is-open");
        profileTrigger?.setAttribute("aria-expanded", "true");
        profileMenu?.removeAttribute("hidden");
        if (focusFirst) {
          getProfileMenuItems()[0]?.focus();
        }
      }

      function focusProfileMenuItem(direction: 1 | -1) {
        const items = getProfileMenuItems();
        if (!items.length) return;
        const active = document.activeElement;
        const index = items.findIndex((item) => item === active);
        const nextIndex =
          index === -1
            ? direction === 1
              ? 0
              : items.length - 1
            : (index + direction + items.length) % items.length;
        items[nextIndex]?.focus();
      }

      profileTrigger?.addEventListener("click", (event) => {
        event.stopPropagation();
        const isOpen = profileDropdown?.classList.contains("is-open");
        if (isOpen) {
          closeProfileMenu();
        } else {
          openProfileMenu();
        }
      });

      document.addEventListener("click", (event) => {
        if (
          profileDropdown &&
          !profileDropdown.contains(event.target as Node)
        ) {
          closeProfileMenu();
        }
      });

      profileTrigger?.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeProfileMenu(true);
          return;
        }
        if (event.key === "ArrowDown" || event.key === "ArrowUp") {
          event.preventDefault();
          if (!profileDropdown?.classList.contains("is-open")) {
            openProfileMenu(event.key === "ArrowUp");
          } else {
            focusProfileMenuItem(event.key === "ArrowDown" ? 1 : -1);
          }
        }
      });

      profileMenu?.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          event.preventDefault();
          closeProfileMenu(true);
          return;
        }
        if (event.key === "ArrowDown") {
          event.preventDefault();
          focusProfileMenuItem(1);
        }
        if (event.key === "ArrowUp") {
          event.preventDefault();
          focusProfileMenuItem(-1);
        }
        if (event.key === "Tab") {
          closeProfileMenu();
        }
      });

      function closeMobileMenu() {
        nav?.classList.remove("is-open");
        menuToggle?.setAttribute("aria-expanded", "false");
      }

      menuToggle?.addEventListener("click", () => {
        const isOpen = nav?.classList.toggle("is-open");
        menuToggle.setAttribute("aria-expanded", String(!!isOpen));
        if (isOpen) {
          closeProfileMenu();
        }
      });

      document
        .querySelector<HTMLButtonElement>("[data-menu-close]")
        ?.addEventListener("click", closeMobileMenu);

      nav?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMobileMenu);
      });
    </script>
  </body>
</html>
