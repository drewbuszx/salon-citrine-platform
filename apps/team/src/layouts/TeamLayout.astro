---
import "../styles/global.css";
import { BUSINESS } from "@saloncitrine/shared";
import TeamSiteHeader, {
  type TeamActiveNav,
} from "../components/TeamSiteHeader.astro";
import { withBase } from "../lib/paths";

const faviconUrl = withBase("favicon.png");

interface Props {
  title: string;
  activeNav?: TeamActiveNav;
  wide?: boolean;
  fullBleed?: boolean;
  plain?: boolean;
  cream?: boolean;
  loginPage?: boolean;
}

const {
  title,
  activeNav,
  wide = false,
  fullBleed = false,
  plain = false,
  cream = false,
  loginPage = false,
} = Astro.props;
const { staff, user } = Astro.locals;
const isAuthenticated = Boolean(user && staff);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/png" href={faviconUrl} />
    <link rel="apple-touch-icon" href={faviconUrl} />
    <title>{title} · Team · {BUSINESS.name}</title>
    <script is:inline>
      (function () {
        var storageKey = "theme";

        function resolveTheme() {
          var stored = localStorage.getItem(storageKey);
          if (stored === "dark" || stored === "light") {
            return stored;
          }
          return "light";
        }

        document.documentElement.setAttribute("data-theme", resolveTheme());
      })();
    </script>
  </head>
  <body class:list={[loginPage && "body--login"]}>
    <a class="skip-link" href="#team-main-content">Skip to main content</a>
    <div
      class:list={[
        "team-shell",
        loginPage && "team-shell--login",
        (fullBleed || plain) && "team-shell--book",
        cream && "team-shell--editorial",
      ]}
    >
      {
        !loginPage ? (
          <TeamSiteHeader
            activeNav={activeNav}
            staff={staff}
            isAuthenticated={isAuthenticated}
            pageTitle={title}
          />
        ) : null
      }

      <main
        id="team-main-content"
        class:list={[
          "team-main",
          wide && "team-main--wide",
          (fullBleed || loginPage) && "team-main--full-bleed",
        ]}
      >
        {
          fullBleed || plain ? (
            <slot />
          ) : (
            <div class:list={["team-content", loginPage && "team-content--login"]}>
              <slot />
            </div>
          )
        }
      </main>
    </div>

    {
      isAuthenticated && !loginPage ? (
        <script src="../scripts/session-guard.ts"></script>
      ) : null
    }

    <script>
      import "../scripts/nav-state.ts";
      import "../scripts/team-header.ts";

      const storageKey = "theme";
      const themeToggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");

      function getTheme() {
        return document.documentElement.getAttribute("data-theme") === "dark"
          ? "dark"
          : "light";
      }

      function updateToggleLabels(theme: "light" | "dark") {
        const isDark = theme === "dark";
        // In dark mode the button offers to switch to light (sun); in light
        // mode it offers to switch to dark (moon).
        const ariaLabel = isDark ? "Switch to light mode" : "Switch to dark mode";
        const visibleLabel = isDark ? "Light mode" : "Dark mode";

        themeToggles.forEach((toggle) => {
          toggle.setAttribute("aria-label", ariaLabel);
          toggle.setAttribute("aria-pressed", isDark ? "true" : "false");

          const labelEl = toggle.querySelector<HTMLElement>(
            "[data-theme-toggle-label]",
          );
          if (labelEl) labelEl.textContent = visibleLabel;

          const moonIcon = toggle.querySelector<SVGElement>(
            '[data-theme-icon="moon"]',
          );
          const sunIcon = toggle.querySelector<SVGElement>(
            '[data-theme-icon="sun"]',
          );
          if (moonIcon) moonIcon.toggleAttribute("hidden", isDark);
          if (sunIcon) sunIcon.toggleAttribute("hidden", !isDark);
        });
      }

      function applyThemeFromRules() {
        const stored = localStorage.getItem(storageKey);
        const theme: "light" | "dark" =
          stored === "dark" || stored === "light"
            ? (stored as "light" | "dark")
            : "light";

        document.documentElement.setAttribute("data-theme", theme);
        updateToggleLabels(theme);
      }

      function setTheme(theme: "light" | "dark") {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem(storageKey, theme);
        updateToggleLabels(theme);
      }

      applyThemeFromRules();

      themeToggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          setTheme(getTheme() === "dark" ? "light" : "dark");
        });
      });

      document.querySelectorAll<HTMLImageElement>(".team-bar__logo-img[data-fallback-src]").forEach((img) => {
        if (img.complete && img.naturalWidth === 0) {
          img.dispatchEvent(new Event("error"));
        }
        img.addEventListener("error", () => {
          const logoLink = img.closest<HTMLElement>(".team-bar__logo");
          const fallback = img.getAttribute("data-fallback-src");
          if (fallback && img.dataset.fallbackUsed !== "1") {
            img.dataset.fallbackUsed = "1";
            img.src = fallback;
            img.classList.add("team-bar__logo-img--fallback");
            return;
          }
          logoLink?.classList.add("is-wordmark");
        });
      });
    </script>
  </body>
</html>
