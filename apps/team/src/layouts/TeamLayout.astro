---
import "../styles/global.css";
import { BUSINESS } from "@saloncitrine/shared";
import SiteHeaderMinimal from "../components/SiteHeaderMinimal.astro";
import TeamHeader from "../components/TeamHeader.astro";

interface Props {
  title: string;
  activeNav?: "calendar" | "block-time" | "services" | "my-services";
  wide?: boolean;
}

const { title, activeNav = "calendar", wide = false } = Astro.props;
const { staff, user } = Astro.locals;
const isAuthenticated = Boolean(user && staff);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title} · Team · {BUSINESS.name}</title>
    <script is:inline>
      (function () {
        var storageKey = "theme";
        var stored = localStorage.getItem(storageKey);
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var theme =
          stored === "dark" || stored === "light"
            ? stored
            : prefersDark
              ? "dark"
              : "light";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body class:list={[{ "team-shell--authenticated": isAuthenticated }]}>
    <div class="team-shell">
      <SiteHeaderMinimal />

      {
        isAuthenticated ? (
          <TeamHeader
            activeNav={activeNav}
            staffName={staff.name}
            staffRole={staff.role}
          />
        ) : null
      }

      <main class:list={["team-main", wide && "team-main--wide"]}>
        <div class="team-content">
          <slot />
        </div>
      </main>
    </div>

    <script>
      const themeToggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");
      const storageKey = "theme";

      function getTheme() {
        return document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
      }

      function updateToggleLabels(theme: "light" | "dark") {
        const label =
          theme === "dark" ? "Switch to light mode" : "Switch to dark mode";
        themeToggles.forEach((toggle) => toggle.setAttribute("aria-label", label));
      }

      function setTheme(theme: "light" | "dark") {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem(storageKey, theme);
        updateToggleLabels(theme);
      }

      updateToggleLabels(getTheme());

      themeToggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          setTheme(getTheme() === "dark" ? "light" : "dark");
        });
      });
    </script>
  </body>
</html>
