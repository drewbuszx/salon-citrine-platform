---
import {
  createSupabaseAdminClient,
  createSupabaseServerClient,
  teamUrl,
} from "../../lib/supabase-server";
import { isPendingInvite } from "../../lib/staff-access-admin";
import { grantPasswordSetupContext } from "../../lib/password-setup-context";

const tokenHash = Astro.url.searchParams.get("token_hash");
const type = Astro.url.searchParams.get("type");
const code = Astro.url.searchParams.get("code");
const cspNonce = Astro.locals.cspNonce;

// Recovery and invite callbacks only verify the one-time token here. Staff access is
// NOT activated at this point; activation happens atomically after the password is
// set (see /api/auth/reset-password). On any failure the session is cleared so a
// partial callback cannot leave an authenticated cookie behind.
async function completeVerifiedSession(
  supabase: ReturnType<typeof createSupabaseServerClient>,
) {
  const { data: { user } } = await supabase.auth.getUser();
  if (!user) {
    await supabase.auth.signOut();
    return null;
  }
  let pending = false;
  try {
    pending = await isPendingInvite(createSupabaseAdminClient(), user.id);
  } catch {
    pending = false;
  }
  grantPasswordSetupContext(Astro.cookies, pending ? "invite" : "recovery");
  return pending;
}

if (code) {
  try {
    const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
    const { error } = await supabase.auth.exchangeCodeForSession(code);
    if (!error) {
      const pending = await completeVerifiedSession(supabase);
      if (pending !== null) {
        return Astro.redirect(
          teamUrl(pending ? "/reset-password?flow=invite" : "/reset-password"),
        );
      }
    } else {
      await supabase.auth.signOut();
    }
  } catch {
    // fall through to client hash handler / error state
  }
}

if (tokenHash && (type === "recovery" || type === "invite" || type === "magiclink")) {
  try {
    const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
    const { error } = await supabase.auth.verifyOtp({ token_hash: tokenHash, type });
    if (!error) {
      const pending = await completeVerifiedSession(supabase);
      if (pending !== null) {
        return Astro.redirect(
          teamUrl(
            type === "recovery" && !pending
              ? "/reset-password"
              : "/reset-password?flow=invite",
          ),
        );
      }
    } else {
      await supabase.auth.signOut();
    }
  } catch {
    // fall through to client hash handler / error state
  }
}

Astro.response.headers.set("Cache-Control", "no-store");
Astro.response.headers.set("Referrer-Policy", "no-referrer");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Confirming sign-in · Salon Citrine Team</title>
    <script is:inline nonce={cspNonce}>
      (function () {
        var storageKey = "theme";
        var stored = localStorage.getItem(storageKey);
        var theme = stored === "dark" || stored === "light" ? stored : "light";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <style>
      @import "@saloncitrine/theme/tokens.css";

      body {
        margin: 0;
        min-height: 100dvh;
        display: grid;
        place-items: center;
        font-family: var(--font-body, system-ui, sans-serif);
        background: var(--color-cream, #f3ede3);
        color: var(--color-text, #3d3832);
      }

      .confirm-card {
        max-width: 24rem;
        padding: 1.5rem;
        text-align: center;
      }

      .confirm-card p {
        margin: 0 0 0.75rem;
        line-height: 1.5;
      }

      .confirm-card a {
        color: var(--color-link, #8a6f2c);
      }

      [data-confirm-status="error"] {
        display: none;
      }

      [data-theme="dark"] body {
        background: var(--color-cream);
        color: var(--color-text);
      }
    </style>
  </head>
  <body>
    <div class="confirm-card">
      <p data-confirm-status="loading">Confirming your secure link…</p>
      <p data-confirm-status="error">
        This reset link is invalid or has expired.
        <a href={teamUrl("/forgot-password")}>Request a new link</a>
        or <a href={teamUrl("/login")}>return to sign in</a>.
      </p>
    </div>

    <script nonce={cspNonce} define:vars={{ exchangeUrl: teamUrl("/api/auth/exchange"), resetUrl: teamUrl("/reset-password") }}>
      async function finishRecovery() {
        const hash = new URLSearchParams(window.location.hash.replace(/^#/, ""));
        const accessToken = hash.get("access_token");
        const refreshToken = hash.get("refresh_token");
        const type = hash.get("type");

        if (!accessToken || !refreshToken || !["recovery", "invite", "magiclink"].includes(type ?? "")) {
          showError();
          return;
        }

        const response = await fetch(exchangeUrl, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            access_token: accessToken,
            refresh_token: refreshToken,
          }),
        });

        if (!response.ok) {
          showError();
          return;
        }

        const result = await response.json();
        window.location.replace(result.redirect ?? (type === "recovery" ? resetUrl : `${resetUrl}?flow=invite`));
      }

      function showError() {
        document.querySelector('[data-confirm-status="loading"]')?.remove();
        const errorEl = document.querySelector('[data-confirm-status="error"]');
        if (errorEl instanceof HTMLElement) {
          errorEl.style.display = "block";
        }
      }

      finishRecovery().catch(showError);
    </script>
  </body>
</html>
