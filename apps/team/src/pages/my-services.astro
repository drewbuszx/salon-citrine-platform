---
import TeamLayout from "../layouts/TeamLayout.astro";
import { teamUrl } from "../lib/supabase-server";

const { supabase, staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login"));
}

const { data: staffServices, error } = await supabase
  .from("staff_services")
  .select("service_id, returning_clients_only, services(id, category, name, duration_minutes)")
  .eq("staff_id", staff.id)
  .order("services(category)", { ascending: true });

type StaffServiceRow = {
  service_id: string;
  returning_clients_only: boolean;
  services:
    | {
        id: string;
        category: string;
        name: string;
        duration_minutes: number;
      }
    | {
        id: string;
        category: string;
        name: string;
        duration_minutes: number;
      }[]
    | null;
};

const rows = (staffServices ?? []) as StaffServiceRow[];
const services = rows
  .map((row) => {
    const raw = row.services;
    const svc = Array.isArray(raw) ? raw[0] : raw;
    if (!svc) return null;
    return {
      id: svc.id,
      category: svc.category,
      name: svc.name,
      durationMinutes: svc.duration_minutes,
      returningClientsOnly: row.returning_clients_only,
    };
  })
  .filter(Boolean);

const saved = Astro.url.searchParams.get("saved") === "1";
const updateError = Astro.url.searchParams.get("error") === "update";
const returnTo = teamUrl("/my-services");
---

<TeamLayout title="My services">
  <h1 class="page-title">My services</h1>
  <p class="page-lead">
    Choose which services you offer are for returning clients only. New clients
    will see a notice before booking those services with you.
  </p>

  {saved ? <p class="notice notice--success">Settings saved.</p> : null}
  {
    updateError ? (
      <p class="notice notice--error" role="alert">
        Could not update service. Try again.
      </p>
    ) : null
  }

  {
    error ? (
      <p class="notice notice--error" role="alert">
        Failed to load your services.
      </p>
    ) : services.length === 0 ? (
      <p class="empty-state">No services are assigned to your profile yet.</p>
    ) : (
      <div class="card-grid my-services">
        {
          services.map((service) => (
            <form
              class="card-row card-row--2 my-services__row"
              method="post"
              action={teamUrl("/api/staff-services")}
            >
              <input type="hidden" name="service_id" value={service.id} />
              <input type="hidden" name="staff_id" value={staff.id} />
              <input type="hidden" name="return_to" value={returnTo} />

              <div class="my-services__info">
                <span class="label-meta">{service.category}</span>
                <span class="my-services__name">{service.name}</span>
                <span class="my-services__meta">{service.durationMinutes} min</span>
              </div>

              <label class="my-services__toggle">
                <input
                  type="checkbox"
                  name="returning_clients_only"
                  value="1"
                  checked={service.returningClientsOnly}
                  onchange="this.form.requestSubmit()"
                />
                <span>Returning clients only</span>
              </label>
            </form>
          ))
        }
      </div>
    )
  }
</TeamLayout>

<style>
  .my-services {
    margin-top: 1.5rem;
  }

  .my-services__info {
    display: grid;
    gap: 0.15rem;
  }

  .my-services__name {
    font-size: 1rem;
  }

  .my-services__meta {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--color-gray);
  }

  .my-services__toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    cursor: pointer;
    white-space: nowrap;
  }

  .my-services__toggle input {
    width: 1rem;
    height: 1rem;
    accent-color: var(--color-citrine);
  }
</style>
