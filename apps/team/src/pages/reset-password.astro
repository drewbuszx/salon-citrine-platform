---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamPage from "../components/TeamPage.astro";
import { teamUrl } from "../lib/supabase-server";

const error = Astro.url.searchParams.get("error");
const flow = Astro.url.searchParams.get("flow");
const isInvite = flow === "invite";

const message =
  error === "mismatch"
    ? "Those passwords don’t match. Try again."
    : error === "weak"
      ? "Use at least 8 characters for your password."
      : error === "update"
        ? "We couldn’t save your password. Please try again."
        : error === "invalid"
          ? "Fill in both password fields to continue."
          : error === "invite_activation"
            ? "Your password was saved, but we couldn’t finish activating your account. Contact an owner."
            : null;

const { user } = Astro.locals;
if (!user) {
  return Astro.redirect(teamUrl("/login?error=reset_expired"));
}

const title = isInvite ? "Set your password" : "Choose a new password";
const lead = isInvite
  ? "Step 2 of 2 — create a password, then you’ll sign in to the team app."
  : "Your reset link is confirmed. Set a new password to continue.";
---

<TeamLayout title={title} loginPage plain>
  <TeamPage title={title} lead={lead}>
    <section class="form-stack form-stack--narrow">
      {
        isInvite ? (
          <ol class="invite-steps" aria-label="Invite steps">
            <li class="invite-steps__item invite-steps__item--done">Email invite opened</li>
            <li class="invite-steps__item invite-steps__item--current">Set your password</li>
            <li class="invite-steps__item">Sign in to the team app</li>
          </ol>
        ) : null
      }

      {message ? <p class="notice notice--error" role="alert">{message}</p> : null}

      <form class="form-stack" method="post" action={teamUrl("/api/auth/reset-password")}>
        {isInvite ? <input type="hidden" name="flow" value="invite" /> : null}
        <label class="form-label">
          {isInvite ? "Create password" : "New password"}
          <input
            class="form-input"
            name="new_password"
            type="password"
            autocomplete="new-password"
            minlength="8"
            required
          />
          <span class="label-meta">At least 8 characters.</span>
        </label>
        <label class="form-label">
          Confirm password
          <input
            class="form-input"
            name="confirm_password"
            type="password"
            autocomplete="new-password"
            minlength="8"
            required
          />
        </label>
        <button class="btn-primary" type="submit">
          {isInvite ? "Save password & continue" : "Update password"}
        </button>
      </form>

      {
        isInvite ? (
          <p class="label-meta">
            After this you’ll land on the team dashboard. If anything looks off, ask an owner to resend your invite.
          </p>
        ) : null
      }
    </section>
  </TeamPage>
</TeamLayout>

<style>
  .invite-steps {
    margin: 0 0 1rem;
    padding: 0.75rem 1rem;
    list-style: none;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-stone-50);
  }

  .invite-steps__item {
    position: relative;
    padding: 0.35rem 0 0.35rem 1.25rem;
    font-size: 0.85rem;
    color: var(--color-stone-500);
  }

  .invite-steps__item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7rem;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--color-stone-300);
  }

  .invite-steps__item--done {
    color: var(--color-stone-600);
  }

  .invite-steps__item--done::before {
    background: var(--color-sage, #6b8f71);
  }

  .invite-steps__item--current {
    color: var(--color-stone-800);
    font-weight: 600;
  }

  .invite-steps__item--current::before {
    background: var(--color-citrine, #c4a35a);
  }
</style>
