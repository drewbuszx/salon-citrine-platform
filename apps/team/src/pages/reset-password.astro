---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamPage from "../components/TeamPage.astro";
import { teamUrl } from "../lib/supabase-server";

const error = Astro.url.searchParams.get("error");
const message =
  error === "mismatch"
    ? "New passwords do not match."
    : error === "weak"
      ? "New password must be at least 8 characters."
      : error === "update"
        ? "Could not update password. Try again."
        : error === "invalid"
          ? "Fill in all fields correctly."
          : null;

const { user } = Astro.locals;
if (!user) {
  return Astro.redirect(teamUrl("/login?error=reset_expired"));
}
---

<TeamLayout title="Reset password" loginPage plain>
  <TeamPage title="Choose a new password" lead="Your reset link is confirmed. Set a new password to continue.">
    <section class="form-stack form-stack--narrow">
      {message ? <p class="notice notice--error" role="alert">{message}</p> : null}

      <form class="form-stack" method="post" action={teamUrl("/api/auth/reset-password")}>
        <label class="form-label">
          New password
          <input
            class="form-input"
            name="new_password"
            type="password"
            autocomplete="new-password"
            minlength="8"
            required
          />
        </label>
        <label class="form-label">
          Confirm new password
          <input
            class="form-input"
            name="confirm_password"
            type="password"
            autocomplete="new-password"
            minlength="8"
            required
          />
        </label>
        <button class="btn-primary" type="submit">Save password</button>
      </form>
    </section>
  </TeamPage>
</TeamLayout>
