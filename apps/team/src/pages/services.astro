---
import TeamLayout from "../layouts/TeamLayout.astro";
import { teamUrl } from "../lib/supabase-server";

const { supabase } = Astro.locals;

const [
  { data: services, error: servicesError },
  { data: staff, error: staffError },
  { data: staffServices, error: staffServicesError },
] = await Promise.all([
  supabase
    .from("services")
    .select("id, category, name, duration_minutes")
    .eq("is_active", true)
    .order("category")
    .order("sort_order")
    .order("name"),
  supabase
    .from("staff")
    .select("id, name, role")
    .in("role", ["owner", "stylist", "esthetician"])
    .order("name"),
  supabase
    .from("staff_services")
    .select("staff_id, service_id, returning_clients_only"),
]);

const error = servicesError ?? staffError ?? staffServicesError;
const saved = Astro.url.searchParams.get("saved") === "1";
const updateError = Astro.url.searchParams.get("error") === "update";
const returnTo = teamUrl("/services");

const returningByPair = new Map<string, boolean>();
for (const row of staffServices ?? []) {
  const key = `${row.staff_id}:${row.service_id}`;
  returningByPair.set(key, row.returning_clients_only === true);
}

const staffServiceIds = new Map<string, Set<string>>();
for (const row of staffServices ?? []) {
  const set = staffServiceIds.get(row.staff_id) ?? new Set<string>();
  set.add(row.service_id);
  staffServiceIds.set(row.staff_id, set);
}
---

<TeamLayout title="Services" activeNav="services">
  <h1>Services</h1>
  <p class="lead">
    Update service durations and returning-clients-only settings per stylist.
  </p>

  {saved ? <p class="notice notice--success">Settings saved.</p> : null}
  {
    updateError ? (
      <p class="notice notice--error" role="alert">
        Could not update. Check the value and try again.
      </p>
    ) : null
  }

  {
    error ? (
      <p class="notice notice--error" role="alert">
        Failed to load services.
      </p>
    ) : (
      <>
        <section class="section">
          <h2>Service durations</h2>
          <div class="services">
            {
              (services ?? []).map((service) => (
                <form
                  class="services__row"
                  method="post"
                  action={teamUrl(`/api/services/${service.id}`)}
                >
                  <div class="services__info">
                    <span class="services__category">{service.category}</span>
                    <span class="services__name">{service.name}</span>
                  </div>
                  <label class="services__duration">
                    Minutes
                    <input
                      name="duration_minutes"
                      type="number"
                      min="15"
                      step="15"
                      value={service.duration_minutes}
                      required
                    />
                  </label>
                  <button type="submit">Save</button>
                </form>
              ))
            }
          </div>
        </section>

        <section class="section">
          <h2>Returning clients only</h2>
          <p class="section__lead">
            Per stylist and service. When enabled, online booking shows a
            returning-clients notice before the cart.
          </p>

          <div class="matrix">
            {
              (staff ?? []).map((member) => {
                const offered = staffServiceIds.get(member.id);
                const memberServices = (services ?? []).filter((svc) =>
                  offered?.has(svc.id),
                );
                if (memberServices.length === 0) return null;

                return (
                  <div class="matrix__group">
                    <h3 class="matrix__staff">{member.name}</h3>
                    <div class="matrix__rows">
                      {
                        memberServices.map((service) => {
                          const key = `${member.id}:${service.id}`;
                          const returningOnly =
                            returningByPair.get(key) ?? false;

                          return (
                            <form
                              class="matrix__row"
                              method="post"
                              action={teamUrl("/api/staff-services")}
                            >
                              <input
                                type="hidden"
                                name="service_id"
                                value={service.id}
                              />
                              <input
                                type="hidden"
                                name="staff_id"
                                value={member.id}
                              />
                              <input
                                type="hidden"
                                name="return_to"
                                value={returnTo}
                              />

                              <div class="matrix__service">
                                <span class="matrix__category">
                                  {service.category}
                                </span>
                                <span class="matrix__name">{service.name}</span>
                              </div>

                              <label class="matrix__toggle">
                                <input
                                  type="checkbox"
                                  name="returning_clients_only"
                                  value="1"
                                  checked={returningOnly}
                                  onchange="this.form.requestSubmit()"
                                />
                                <span>Returning clients only</span>
                              </label>
                            </form>
                          );
                        })
                      }
                    </div>
                  </div>
                );
              })
            }
          </div>
        </section>
      </>
    )
  }
</TeamLayout>

<style>
  h1 {
    font-size: 1.75rem;
  }

  .lead {
    color: var(--color-gray);
  }

  .section {
    margin-top: 2rem;
  }

  .section h2 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
  }

  .section__lead {
    margin: 0 0 1rem;
    color: var(--color-gray);
    font-size: 0.95rem;
  }

  .notice {
    padding: 0.65rem 0.75rem;
    font-size: 0.9rem;
    margin: 1rem 0;
  }

  .notice--success {
    border: 1px solid var(--color-citrine);
    background: rgba(255, 210, 80, 0.15);
  }

  .notice--error {
    border: 1px solid #c44;
    background: rgba(200, 60, 60, 0.08);
    color: #922;
  }

  .services,
  .matrix__rows {
    display: grid;
    gap: 0.75rem;
  }

  .services__row,
  .matrix__row {
    display: grid;
    gap: 0.75rem;
    align-items: end;
    padding: 0.85rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  @media (min-width: 40rem) {
    .services__row {
      grid-template-columns: 1fr auto auto;
    }

    .matrix__row {
      grid-template-columns: 1fr auto;
      align-items: center;
    }
  }

  .services__info,
  .matrix__service {
    display: grid;
    gap: 0.15rem;
  }

  .services__category,
  .matrix__category {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .services__name,
  .matrix__name {
    font-size: 1rem;
  }

  .services__duration {
    display: grid;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .services__duration input {
    width: 6rem;
    padding: 0.5rem 0.65rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    font-size: 1rem;
    text-transform: none;
    letter-spacing: normal;
  }

  .services__row button {
    padding: 0.55rem 0.85rem;
    border: none;
    background: var(--color-charcoal);
    color: var(--color-white);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .matrix {
    display: grid;
    gap: 1.5rem;
  }

  .matrix__group {
    border: 1px solid var(--color-border);
    padding: 1rem;
    background: var(--color-bg);
  }

  .matrix__staff {
    margin: 0 0 0.85rem;
    font-size: 1rem;
    font-weight: 600;
  }

  .matrix__toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    cursor: pointer;
    white-space: nowrap;
  }

  .matrix__toggle input {
    width: 1rem;
    height: 1rem;
    accent-color: var(--color-citrine);
  }
</style>
