---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamListLayout from "../components/TeamListLayout.astro";
import TeamListFilter from "../components/TeamListFilter.astro";
import { teamUrl } from "../lib/supabase-server";

const { supabase } = Astro.locals;

const [
  { data: services, error: servicesError },
  { data: staff, error: staffError },
  { data: staffServices, error: staffServicesError },
] = await Promise.all([
  supabase
    .from("services")
    .select("id, category, name, duration_minutes")
    .eq("is_active", true)
    .order("category")
    .order("sort_order")
    .order("name"),
  supabase
    .from("staff")
    .select("id, name, role")
    .in("role", ["owner", "stylist", "esthetician"])
    .order("name"),
  supabase
    .from("staff_services")
    .select("staff_id, service_id, returning_clients_only"),
]);

const error = servicesError ?? staffError ?? staffServicesError;
const saved = Astro.url.searchParams.get("saved") === "1";
const updateError = Astro.url.searchParams.get("error") === "update";
const returnTo = teamUrl("/services");

const returningByPair = new Map<string, boolean>();
for (const row of staffServices ?? []) {
  const key = `${row.staff_id}:${row.service_id}`;
  returningByPair.set(key, row.returning_clients_only === true);
}

const staffServiceIds = new Map<string, Set<string>>();
for (const row of staffServices ?? []) {
  const set = staffServiceIds.get(row.staff_id) ?? new Set<string>();
  set.add(row.service_id);
  staffServiceIds.set(row.staff_id, set);
}

const categories = [...new Set((services ?? []).map((s) => s.category).filter(Boolean))].sort();
---

<TeamLayout title="Services" activeNav="manage" plain wide fullBleed>
  <TeamListLayout title="Services" mainTitle="Manage services" sidebarTitle="Filters">
    <a slot="headerActions" class="team-list-layout__btn-secondary" href={teamUrl("/booking-policy")}>Booking policy</a>

    <TeamListFilter slot="sidebarFilters" label="Category" count={categories.length} open={categories.length > 0}>
      {
        categories.length > 0 ? (
          <div class="team-list-layout__filter-options">
            <label class="team-list-layout__filter-option">
              <input type="radio" name="svc-category" value="" data-svc-filter-category checked />
              <span>All categories</span>
            </label>
            {
              categories.map((category) => (
                <label class="team-list-layout__filter-option">
                  <input type="radio" name="svc-category" value={category} data-svc-filter-category />
                  <span>{category}</span>
                </label>
              ))
            }
          </div>
        ) : (
          <p class="team-list-layout__filter-placeholder">No services loaded.</p>
        )
      }
    </TeamListFilter>

    <TeamListFilter slot="sidebarFilters" label="Staff" count={(staff ?? []).length} open>
      <div class="team-list-layout__filter-options">
        <label class="team-list-layout__filter-option">
          <input type="radio" name="svc-staff" value="" data-svc-filter-staff checked />
          <span>All stylists</span>
        </label>
        {
          (staff ?? []).map((member) => (
            <label class="team-list-layout__filter-option">
              <input type="radio" name="svc-staff" value={member.id} data-svc-filter-staff />
              <span>{member.name}</span>
            </label>
          ))
        }
      </div>
    </TeamListFilter>

    <TeamListFilter slot="sidebarFilters" label="Status">
      <p class="team-list-layout__filter-placeholder">All listed services are active.</p>
    </TeamListFilter>

    <Fragment slot="mainLead">
      Update service durations and returning-clients-only settings per stylist.
    </Fragment>

    {saved ? <p class="notice notice--success">Settings saved.</p> : null}
  {
    updateError ? (
      <p class="notice notice--error" role="alert">
        Could not update. Check the value and try again.
      </p>
    ) : null
  }

  {
    error ? (
      <p class="notice notice--error" role="alert">
        Failed to load services.
      </p>
    ) : (
      <>
        <section class="page-section" data-svc-section="durations">
          <h2>Service durations</h2>
          <div class="card-grid">
            {
              (services ?? []).map((service) => (
                <form
                  class="card-row card-row--3"
                  method="post"
                  action={teamUrl(`/api/services/${service.id}`)}
                  data-svc-category={service.category}
                >
                  <div class="services__info">
                    <span class="label-meta">{service.category}</span>
                    <span class="services__name">{service.name}</span>
                  </div>
                  <label class="form-label services__duration">
                    Minutes
                    <input
                      class="form-input services__duration-input"
                      name="duration_minutes"
                      type="number"
                      min="15"
                      step="15"
                      value={service.duration_minutes}
                      required
                    />
                  </label>
                  <button class="btn-primary btn-primary--compact" type="submit">
                    Save
                  </button>
                </form>
              ))
            }
          </div>
        </section>

        <section class="page-section" data-svc-section="returning">
          <h2>Returning clients only</h2>
          <p class="page-section__lead">
            Per stylist and service. When enabled, online booking shows a
            returning-clients notice before the cart.
          </p>

          <div class="matrix">
            {
              (staff ?? []).map((member) => {
                const offered = staffServiceIds.get(member.id);
                const memberServices = (services ?? []).filter((svc) =>
                  offered?.has(svc.id),
                );
                if (memberServices.length === 0) return null;

                return (
                  <div class="matrix__group" data-svc-staff={member.id}>
                    <h3 class="matrix__staff">{member.name}</h3>
                    <div class="card-grid">
                      {
                        memberServices.map((service) => {
                          const key = `${member.id}:${service.id}`;
                          const returningOnly =
                            returningByPair.get(key) ?? false;

                          return (
                            <form
                              class="card-row card-row--2"
                              method="post"
                              action={teamUrl("/api/staff-services")}
                              data-svc-category={service.category}
                            >
                              <input
                                type="hidden"
                                name="service_id"
                                value={service.id}
                              />
                              <input
                                type="hidden"
                                name="staff_id"
                                value={member.id}
                              />
                              <input
                                type="hidden"
                                name="return_to"
                                value={returnTo}
                              />

                              <div class="services__info">
                                <span class="label-meta">{service.category}</span>
                                <span class="services__name">{service.name}</span>
                              </div>

                              <label class="matrix__toggle">
                                <input
                                  type="checkbox"
                                  name="returning_clients_only"
                                  value="1"
                                  checked={returningOnly}
                                  onchange="this.form.requestSubmit()"
                                />
                                <span>Returning clients only</span>
                              </label>
                            </form>
                          );
                        })
                      }
                    </div>
                  </div>
                );
              })
            }
          </div>
        </section>
      </>
    )
  }
  </TeamListLayout>
</TeamLayout>

<script>
  function applyServiceFilters() {
    const category =
      document.querySelector<HTMLInputElement>("[data-svc-filter-category]:checked")?.value ?? "";
    const staffId =
      document.querySelector<HTMLInputElement>("[data-svc-filter-staff]:checked")?.value ?? "";

    document.querySelectorAll<HTMLElement>("[data-svc-category]").forEach((el) => {
      const matchCategory = !category || el.dataset.svcCategory === category;
      el.hidden = !matchCategory;
    });

    document.querySelectorAll<HTMLElement>("[data-svc-staff]").forEach((el) => {
      const matchStaff = !staffId || el.dataset.svcStaff === staffId;
      el.hidden = !matchStaff;
    });
  }

  document.querySelectorAll("[data-svc-filter-category], [data-svc-filter-staff]").forEach((el) => {
    el.addEventListener("change", applyServiceFilters);
  });
</script>

<style>
  .services__info {
    display: grid;
    gap: 0.15rem;
  }

  .services__name {
    font-size: 1rem;
  }

  .services__duration {
    margin: 0;
  }

  .services__duration-input {
    width: 6rem;
    padding: 0.5rem 0.65rem;
  }

  .btn-primary--compact {
    padding: 0.55rem 0.85rem;
    font-size: 0.72rem;
  }

  .matrix {
    display: grid;
    gap: 1.5rem;
  }

  .matrix__group {
    border: 1px solid var(--color-border);
    padding: 1rem;
    background: var(--color-booking-card-bg);
  }

  .matrix__group[hidden] {
    display: none;
  }

  [data-svc-category][hidden] {
    display: none;
  }

  .matrix__staff {
    margin: 0 0 0.85rem;
    font-size: 1rem;
    font-weight: 600;
  }

  .matrix__toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    cursor: pointer;
    white-space: nowrap;
  }

  .matrix__toggle input {
    width: 1rem;
    height: 1rem;
    accent-color: var(--color-citrine);
  }
</style>
