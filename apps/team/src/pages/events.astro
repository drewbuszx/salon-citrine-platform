---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamListLayout from "../components/TeamListLayout.astro";
import TeamListFilter from "../components/TeamListFilter.astro";
import { isSalonManager } from "../lib/auth";
import { PAGE_CONTEXT } from "../lib/page-context";
import { teamUrl } from "../lib/supabase-server";
import { staffAccentColor } from "../lib/staff-colors";

const { supabase, staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

const managerView = isSalonManager(staff);

const { data: staffRows } = await supabase
  .from("staff")
  .select("id, name")
  .order("name");

const staffOptions = staffRows ?? [];

const typeFilters: { type: string; label: string }[] = [
  { type: "closure", label: "Holiday / closure" },
  { type: "community", label: "Community event" },
  { type: "announcement", label: "Announcement" },
  { type: "birthday", label: "Birthday" },
  { type: "time_off", label: "Time off" },
];
---

<TeamLayout title="Events" activeNav="events" plain wide fullBleed>
  <div
    class="events-page"
    data-events-app
    data-api-base={teamUrl("/api/events")}
    data-holidays-base={teamUrl("/images/holidays/")}
    data-manager={managerView ? "1" : "0"}
    data-current-staff-id={staff.id}
  >
    <TeamListLayout
      title={PAGE_CONTEXT.events.nav}
      contextTitle={PAGE_CONTEXT.events.title}
      contextSubtitle={PAGE_CONTEXT.events.subtitle}
      sidebarTitle="Filters"
      filterKey="events"
      rootClass="events-list-layout"
      contentWidth="operational"
    >
      <button slot="headerActions" class="team-list-layout__btn-primary" type="button" data-event-create>
        {managerView ? "Add event" : "Request time off"}
      </button>

      <TeamListFilter slot="sidebarFilters" label="Event type" open>
        <div class="team-list-layout__filter-options">
          {
            typeFilters.map(({ type, label }) => (
              <label class="team-list-layout__filter-option events-filter-option">
                <input type="checkbox" data-filter-type={type} checked />
                <span class="events-filter-option__icon" data-type-icon={type} aria-hidden="true" />
                <span class="events-filter-option__label">{label}</span>
              </label>
            ))
          }
        </div>
      </TeamListFilter>

      {
        managerView ? (
          <TeamListFilter slot="sidebarFilters" label="Staff" count={staffOptions.length} open>
            <div class="events-staff-filter">
              <div class="events-staff-filter__toolbar">
                <span class="events-staff-filter__count">
                  <span data-staff-selected-count>All</span> selected
                </span>
                <div class="events-staff-filter__actions">
                  <button class="events-staff-filter__link" type="button" data-staff-select-all>
                    All
                  </button>
                  <button class="events-staff-filter__link" type="button" data-staff-clear>
                    Clear
                  </button>
                </div>
              </div>
              <div class="team-list-layout__filter-options team-list-layout__filter-options--scroll events-staff-filter__list">
                {
                  staffOptions.map((member) => (
                    <label class="team-list-layout__filter-option events-staff-option">
                      <input type="checkbox" value={member.id} data-filter-staff />
                      <span
                        class="events-staff-option__swatch"
                        style={`--ec-accent: ${staffAccentColor(member.id)}`}
                        aria-hidden="true"
                      />
                      <span class="events-staff-option__name">{member.name}</span>
                    </label>
                  ))
                }
              </div>
            </div>
          </TeamListFilter>
        ) : null
      }

      <div slot="sidebarFooter" class="events-sidebar-footer">
        <button class="team-list-layout__btn-secondary events-reset-btn" type="button" data-events-reset-filters hidden>
          Reset filters
        </button>
      </div>

      <div slot="toolbar" class="events-toolbar" aria-label="Calendar controls">
        <div class="events-toolbar__chips" data-events-active-filters hidden />
        <button class="events-toolbar__reset" type="button" data-events-reset-filters hidden>
          Reset filters
        </button>
      </div>

      <p class="notice notice--error events-page__error" data-events-error hidden role="alert" />

      <section class="events-calendar-panel" aria-label="Month calendar">
        <div class="events-calendar-panel__sticky" data-events-sticky>
          <header class="events-calendar-panel__header">
            <div class="events-calendar-panel__nav">
              <button
                class="events-calendar-panel__nav-btn ui-btn ui-btn--ghost ui-btn--icon"
                type="button"
                data-month-prev
                aria-label="Previous month"
              >
                ‹
              </button>
              <h3 class="events-calendar-panel__title" data-month-header />
              <button
                class="events-calendar-panel__nav-btn ui-btn ui-btn--ghost ui-btn--icon"
                type="button"
                data-month-next
                aria-label="Next month"
              >
                ›
              </button>
            </div>
            <button
              class="events-calendar-panel__today ui-btn ui-btn--secondary ui-btn--compact"
              type="button"
              data-month-today
            >
              Today
            </button>
          </header>
          <div class="events-calendar-panel__weekdays" aria-hidden="true">
            <span>Sun</span>
            <span>Mon</span>
            <span>Tue</span>
            <span>Wed</span>
            <span>Thu</span>
            <span>Fri</span>
            <span>Sat</span>
          </div>
        </div>

        <div class="events-calendar" data-events-calendar role="grid" aria-label="Calendar days" />

        <div class="events-calendar-legend" data-events-legend aria-label="Event type legend" />
      </section>

      <section class="events-upcoming team-panel" aria-labelledby="events-list-heading">
        <div class="events-upcoming__header">
          <div class="events-upcoming__title-wrap">
            <h3 class="team-panel__title" id="events-list-heading" data-events-list-title>
              Upcoming events
            </h3>
            <span class="events-upcoming__count" data-events-list-count />
          </div>
          <button class="events-upcoming__clear" type="button" data-events-clear-day hidden>
            Show all upcoming
          </button>
        </div>
        <div class="events-list" data-events-list aria-live="polite">
          <p class="events-loading">Loading events…</p>
        </div>
      </section>
    </TeamListLayout>

    <div class="ec-visually-hidden" aria-live="polite" aria-atomic="true" data-events-sr-status />
  </div>

  <dialog class="events-modal" data-event-modal aria-labelledby="event-modal-title">
    <form class="events-modal__form" method="dialog" data-event-form>
      <header class="events-modal__header">
        <h2 id="event-modal-title" data-event-modal-title>Add event</h2>
        <button class="events-modal__close ui-btn ui-btn--ghost ui-btn--icon" type="button" data-event-modal-close aria-label="Close">
          ×
        </button>
      </header>

      <div class="form-stack">
        <label class="form-label">
          Event type
          <select class="form-input" name="event_type" data-event-type required>
            {
              managerView ? (
                <>
                  <option value="event">Community event</option>
                  <option value="announcement">Salon announcement</option>
                  <option value="closure">Holiday / closure</option>
                  <option value="time_off">Time off</option>
                </>
              ) : (
                <option value="time_off">Time off (my schedule)</option>
              )
            }
          </select>
        </label>

        <label class="form-label">
          Title
          <input class="form-input" name="title" type="text" maxlength="200" required />
        </label>

        <div class="events-modal__staff" data-staff-picker hidden>
          <label class="form-label">
            Team member
            <select class="form-input" name="staff_id">
              {
                staffOptions.map((member) => (
                  <option value={member.id} selected={member.id === staff.id}>
                    {member.name}
                  </option>
                ))
              }
            </select>
          </label>
          <div class="events-modal__color-preview" data-staff-color-preview hidden aria-hidden="true">
            <span class="events-modal__color-swatch" />
            <span>Staff color preview</span>
          </div>
        </div>

        <label class="events-modal__checkbox" data-all-day-row>
          <input type="checkbox" name="all_day" data-all-day checked />
          All day
        </label>

        <label class="form-label" data-start-label>
          Start date
          <input class="form-input" name="starts_at" type="date" required />
        </label>

        <label class="form-label" data-end-label>
          End date (optional)
          <input class="form-input" name="ends_at" type="date" />
        </label>

        <label class="form-label">
          Description (optional)
          <textarea class="form-input" name="description" rows="3" maxlength="2000" />
        </label>

        <p class="events-modal__privacy" data-time-off-privacy hidden>
          Time-off notes are visible only to you and managers.
        </p>
      </div>

      <footer class="events-modal__footer">
        <p class="events-modal__delete-hint" data-event-delete-hint hidden>Tap again to confirm removal.</p>
        <button class="team-list-layout__btn-secondary" type="button" data-event-modal-close>Cancel</button>
        {
          managerView ? (
            <button class="team-list-layout__btn-destructive" type="button" data-event-delete hidden>
              Delete
            </button>
          ) : (
            <button class="team-list-layout__btn-destructive" type="button" data-event-delete hidden>
              Remove
            </button>
          )
        }
        <button class="team-list-layout__btn-primary" type="submit" data-event-submit>Save</button>
      </footer>
    </form>
  </dialog>
</TeamLayout>

<script src="../scripts/events.ts"></script>

<style>
  /* ── Page shell (scoped to .events-page only) ─────────────────────────── */
  .events-page {
    --ec-cell-pad: 0.35rem;
    --ec-lane-h: 1.35rem;
    --ec-accent: var(--color-sage);
    min-width: 0;
    overflow-x: clip;
  }

  .events-page :global(.ec-visually-hidden) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .events-page [data-event-create].team-list-layout__btn-primary {
    background: var(--color-citrine);
    color: var(--color-black);
    border: none;
  }

  .events-page [data-event-create].team-list-layout__btn-primary:hover,
  .events-page [data-event-create].team-list-layout__btn-primary:focus-visible {
    background: var(--color-citrine-dark);
    outline: none;
    box-shadow: var(--shadow-sm);
  }

  /* Tighter sidebar↔main gap on desktop (page-scoped only). */
  .events-page :global(.events-list-layout .team-list-layout__body) {
    grid-template-columns: minmax(240px, 260px) minmax(0, 1fr);
  }

  .events-page :global(.events-list-layout .team-list-layout__main) {
    padding: var(--space-4) var(--space-5) var(--space-8);
  }

  @media (min-width: 901px) {
    .events-page :global(.events-list-layout .team-list-layout__sidebar) {
      position: sticky;
      top: var(--team-bar-height, 3.25rem);
      align-self: start;
      max-height: calc(100vh - var(--team-bar-height, 3.25rem));
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .events-page :global(.events-list-layout .team-list-layout__filters) {
      flex: 1 1 auto;
      min-height: 0;
      overflow-y: auto;
      overscroll-behavior: contain;
    }
  }

  /* ── Sidebar filters ─────────────────────────────────────────────────── */
  .events-staff-filter {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-height: 0;
  }

  .events-staff-filter__toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0 0.15rem 0.25rem;
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

  .events-staff-filter__actions {
    display: flex;
    gap: 0.5rem;
  }

  .events-staff-filter__link {
    border: none;
    background: none;
    padding: 0.35rem 0.25rem;
    min-height: var(--touch-target-min, 2.75rem);
    font: inherit;
    font-size: var(--text-xs);
    color: var(--color-link);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .events-staff-filter__list {
    max-height: min(16rem, 40vh);
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .events-page :global(.events-staff-option) {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    gap: 0.45rem;
  }

  .events-page :global(.events-staff-option__swatch) {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--ec-accent);
    flex-shrink: 0;
  }

  .events-page :global(.events-staff-option__name) {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .events-page :global(.events-filter-option) {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    gap: 0.45rem;
  }

  .events-page :global(.events-filter-option__icon) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    color: var(--ec-accent, var(--color-stone-500));
  }

  .events-page :global(.events-filter-option__icon .ec-filter__icon) {
    width: 0.85rem;
    height: 0.85rem;
  }

  .events-sidebar-footer {
    padding: 0.5rem var(--team-sidebar-inset-x) 0;
  }

  .events-reset-btn {
    width: 100%;
    justify-content: center;
  }

  /* ── Toolbar chips ───────────────────────────────────────────────────── */
  .events-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .events-toolbar__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    min-width: 0;
  }

  .events-toolbar__reset {
    border: none;
    background: none;
    padding: 0.35rem 0.5rem;
    font: inherit;
    font-size: var(--text-xs);
    color: var(--color-link);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .events-page :global(.ec-chip) {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.2rem 0.45rem;
    border: 1px solid color-mix(in srgb, var(--ec-accent, var(--color-stone-400)) 45%, var(--color-border-subtle));
    border-radius: 999px;
    background: color-mix(in srgb, var(--ec-accent, var(--color-stone-400)) 10%, var(--color-bg));
    font-size: var(--text-xs);
    color: var(--color-text);
    cursor: pointer;
  }

  .events-page :global(.ec-chip--info) {
    cursor: default;
    border-color: var(--color-stone-300);
    background: var(--color-stone-50);
  }

  .events-page :global(.ec-chip__icon) {
    width: 0.75rem;
    height: 0.75rem;
  }

  .events-page :global(.ec-chip__x) {
    opacity: 0.7;
    font-weight: 700;
  }

  /* ── Calendar panel ──────────────────────────────────────────────────── */
  .events-page__error {
    margin: 0 0 1rem;
  }

  .events-loading {
    margin: 0;
    padding: var(--mobile-space-md);
    font-size: var(--text-sm);
    color: var(--color-stone-500);
  }

  .events-calendar-panel {
    margin-bottom: 1rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: 10px;
    background: var(--color-bg);
    box-shadow: 0 2px 16px color-mix(in srgb, var(--color-charcoal) 6%, transparent);
  }

  .events-calendar-panel__sticky {
    position: sticky;
    top: var(--team-bar-height, 3.25rem);
    z-index: 20;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border-subtle);
    border-radius: 10px 10px 0 0;
  }

  .events-calendar-panel__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 0.75rem;
    padding: 0.65rem 0.85rem 0.45rem;
  }

  .events-calendar-panel__nav {
    display: flex;
    flex: 1 1 auto;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    min-width: 0;
  }

  .events-calendar-panel__title {
    margin: 0;
    min-width: 9rem;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-text);
  }

  .events-calendar-panel__weekdays {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0;
    padding: 0.35rem 0 0.45rem;
    border-top: 1px solid var(--color-border-subtle);
    background: color-mix(in srgb, var(--color-cream) 55%, var(--color-bg));
  }

  .events-calendar-panel__weekdays span {
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .events-calendar {
    display: flex;
    flex-direction: column;
    background: var(--color-border-subtle);
    overflow: hidden;
    border-radius: 0 0 10px 10px;
  }

  /* ── Week row + cells ──────────────────────────────────────────────────── */
  .events-page :global(.ec-week) {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0;
    min-height: 5.5rem;
  }

  .events-page :global(.ec-cell) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-height: 5.5rem;
    padding: var(--ec-cell-pad);
    border-right: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
    background: var(--color-bg);
    cursor: default;
    text-align: left;
    font: inherit;
    color: inherit;
    transition: background 0.15s ease, box-shadow 0.15s ease;
  }

  .events-page :global(.ec-cell:nth-child(7n)) {
    border-right: none;
  }

  .events-page :global(.ec-cell--outside) {
    background: color-mix(in srgb, var(--color-cream) 50%, var(--color-bg));
    opacity: 0.55;
  }

  .events-page :global(.ec-cell--weekend:not(.ec-cell--outside)) {
    background: color-mix(in srgb, var(--color-cream) 28%, var(--color-bg));
  }

  .events-page :global(.ec-cell--pride:not(.ec-cell--outside)) {
    background: var(--pride-bg, transparent);
  }

  .events-page :global(.ec-cell--holiday:not(.ec-cell--outside)) {
    background-image: var(--holiday-image, none);
    background-repeat: no-repeat;
    background-position: bottom 0.15rem right 0.15rem;
    background-size: 1.75rem 1.75rem;
    background-color: color-mix(in srgb, var(--holiday-bg, transparent) 72%, var(--color-bg));
  }

  .events-page :global(.ec-cell--today:not(.ec-cell--selected)) {
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-dusty-rose) 50%, transparent);
  }

  .events-page :global(.ec-cell--selected) {
    background: var(--color-selection-bg, rgba(141, 158, 136, 0.12));
    box-shadow: inset 0 0 0 2px var(--color-selection-border, var(--color-sage));
  }

  .events-page :global(.ec-cell:focus-visible) {
    outline: 2px solid var(--color-selection-border, var(--color-sage));
    outline-offset: -2px;
    z-index: 2;
  }

  .events-page :global(.ec-cell__head) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.15rem;
    min-height: 1.1rem;
  }

  .events-page :global(.ec-cell__day) {
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-text);
  }

  .events-page :global(.ec-cell--today .ec-cell__day) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.35rem;
    height: 1.35rem;
    padding: 0 0.15rem;
    border-radius: 999px;
    background: var(--color-dusty-rose);
    color: #fff;
    font-weight: 700;
  }

  .events-page :global(.ec-cell__today) {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-dusty-rose);
  }

  .events-page :global(.ec-cell__lanes) {
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
    margin-top: auto;
    min-height: calc(var(--ec-lane-h) * 3 + 0.24rem);
  }

  .events-page :global(.ec-lane) {
    display: block;
    min-height: var(--ec-lane-h);
    max-height: var(--ec-lane-h);
    overflow: hidden;
  }

  .events-page :global(.ec-lane--empty) {
    visibility: hidden;
  }

  /* ── Event segments (pills + multi-day bars) ─────────────────────────── */
  .events-page :global(.ec-seg) {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    width: 100%;
    height: 100%;
    max-height: var(--ec-lane-h);
    padding: 0 0.28rem;
    border: none;
    border-left: 3px solid var(--ec-accent);
    border-radius: 3px;
    background: color-mix(in srgb, var(--ec-accent) 14%, var(--color-bg));
    color: var(--color-text);
    font: inherit;
    font-size: 0.625rem;
    font-weight: 600;
    line-height: 1.1;
    text-align: left;
    cursor: pointer;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .events-page :global(.ec-seg--bar) {
    border-radius: 0;
  }

  .events-page :global(.ec-seg--start) {
    border-top-left-radius: 4px;
    border-bottom-left-radius: 4px;
  }

  .events-page :global(.ec-seg--end) {
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
  }

  .events-page :global(.ec-seg--bleed-left) {
    border-left-color: transparent;
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
    margin-left: calc(-1 * var(--ec-cell-pad));
    padding-left: calc(0.28rem + var(--ec-cell-pad));
  }

  .events-page :global(.ec-seg--bleed-right) {
    margin-right: calc(-1 * var(--ec-cell-pad));
    padding-right: calc(0.28rem + var(--ec-cell-pad));
  }

  .events-page :global(.ec-seg--birthday) {
    border-left-color: var(--ec-accent);
    background: color-mix(in srgb, var(--ec-accent) 18%, var(--color-bg));
  }

  .events-page :global(.ec-seg__icon) {
    width: 0.7rem;
    height: 0.7rem;
    flex-shrink: 0;
    color: var(--ec-accent);
  }

  .events-page :global(.ec-seg__title) {
