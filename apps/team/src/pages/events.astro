---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamPage from "../components/TeamPage.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";

const { supabase, staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

const managerView = isSalonManager(staff);

const { data: staffRows } = await supabase
  .from("staff")
  .select("id, name")
  .order("name");

const staffOptions = staffRows ?? [];
---

<TeamLayout title="Events" activeNav="events" plain>
  <div
    class="events-page"
    data-events-app
    data-api-base={teamUrl("/api/events")}
    data-manager={managerView ? "1" : "0"}
    data-current-staff-id={staff.id}
  >
    <TeamPage
      title="Team calendar"
      lead="Birthdays, time off, closures, and salon announcements — not the appointment book."
      toolbar
    >
      <button slot="actions" class="btn-primary" type="button" data-event-create>
        Add event
      </button>

      <div slot="toolbar" class="events-page__toolbar">
        <button class="btn-secondary events-page__nav-btn" type="button" data-month-prev aria-label="Previous month">
          ‹
        </button>
        <h2 class="events-page__month" data-month-label></h2>
        <button class="btn-secondary events-page__nav-btn" type="button" data-month-next aria-label="Next month">
          ›
        </button>
        <button class="btn-secondary events-page__today" type="button" data-month-today>
          Today
        </button>
      </div>

      <p class="notice notice--error events-page__error" data-events-error hidden role="alert"></p>

      <section class="events-calendar-panel" aria-label="Month calendar">
        <div class="events-calendar" data-events-calendar></div>
        <div class="events-calendar-legend" aria-hidden="true">
          <span class="events-calendar-legend__item events-calendar-legend__item--closure">Holiday / closure</span>
          <span class="events-calendar-legend__item events-calendar-legend__item--event">Community</span>
          <span class="events-calendar-legend__item events-calendar-legend__item--announcement">Announcement</span>
          <span class="events-calendar-legend__item events-calendar-legend__item--time_off">Time off (staff color)</span>
        </div>
      </section>

      <section class="events-upcoming team-panel">
        <h3 class="team-panel__title">Upcoming</h3>
        <div class="events-list" data-events-list aria-live="polite">
          <p class="empty-state">Loading events…</p>
        </div>
      </section>
    </TeamPage>
  </div>

  <dialog class="events-modal" data-event-modal aria-labelledby="event-modal-title">
    <form class="events-modal__form" method="dialog" data-event-form>
      <header class="events-modal__header">
        <h2 id="event-modal-title" data-event-modal-title>Add event</h2>
        <button class="events-modal__close" type="button" data-event-modal-close aria-label="Close">
          ×
        </button>
      </header>

      <div class="form-stack">
        <label class="form-label">
          Title
          <input class="form-input" name="title" type="text" maxlength="200" required />
        </label>

        <label class="form-label">
          Description (optional)
          <textarea class="form-input" name="description" rows="3" maxlength="2000"></textarea>
        </label>

        <label class="form-label">
          Type
          <select class="form-input" name="event_type" data-event-type>
            {
              managerView ? (
                <>
                  <option value="event">Community event</option>
                  <option value="announcement">Salon announcement</option>
                  <option value="closure">Holiday / closure</option>
                  <option value="time_off">Time off</option>
                </>
              ) : (
                <option value="time_off">Time off (my schedule)</option>
              )
            }
          </select>
        </label>

        <div class="events-modal__staff" data-staff-picker hidden>
          <label class="form-label">
            Team member
            <select class="form-input" name="staff_id">
              {
                staffOptions.map((member) => (
                  <option value={member.id} selected={member.id === staff.id}>
                    {member.name}
                  </option>
                ))
              }
            </select>
          </label>
        </div>

        <label class="events-modal__checkbox">
          <input type="checkbox" name="all_day" data-all-day />
          All day
        </label>

        <label class="form-label" data-start-label>
          Starts
          <input class="form-input" name="starts_at" type="datetime-local" required />
        </label>

        <label class="form-label" data-end-label>
          Ends (optional)
          <input class="form-input" name="ends_at" type="datetime-local" />
        </label>
      </div>

      <footer class="events-modal__footer">
        <button class="btn-secondary" type="button" data-event-modal-close>Cancel</button>
        {
          managerView ? (
            <button class="btn-secondary" type="button" data-event-delete hidden>
              Delete
            </button>
          ) : (
            <button class="btn-secondary" type="button" data-event-delete hidden>
              Remove
            </button>
          )
        }
        <button class="btn-primary" type="submit" data-event-submit>Save</button>
      </footer>
    </form>
  </dialog>
</TeamLayout>

<script src="../scripts/events.ts"></script>

<style>
  .events-page__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
  }

  .events-page__nav-btn {
    min-width: 2.25rem;
    padding-inline: 0.65rem;
    font-size: 1.1rem;
    line-height: 1;
  }

  .events-page__month {
    margin: 0;
    flex: 1;
    min-width: 10rem;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .events-page__today {
    margin-left: auto;
  }

  .events-page__error {
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .events-calendar-panel {
    margin-bottom: 1.25rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    overflow: hidden;
  }

  .events-calendar {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 1px;
    background: var(--color-border-subtle);
  }

  .events-calendar__head,
  .events-calendar__cell {
    background: var(--color-booking-card-bg);
    font-family: var(--font-sans);
  }

  .events-calendar__head {
    padding: 0.55rem 0.35rem;
    text-align: center;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gray);
    background: var(--color-booking-panel-bg);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .events-calendar__cell {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-height: 5.25rem;
    padding: 0.4rem 0.45rem 0.35rem;
    cursor: default;
    transition: background 0.15s ease;
  }

  .events-calendar__cell--pad {
    background: var(--color-booking-panel-bg);
    opacity: 0.45;
  }

  .events-calendar__cell--today .events-calendar__day {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.55rem;
    height: 1.55rem;
    border-radius: 50%;
    background: var(--color-dusty-rose);
    color: #fff;
  }

  .events-calendar__cell--closure {
    background: rgba(200, 60, 60, 0.1);
    box-shadow: inset 0 0 0 1px rgba(200, 60, 60, 0.22);
  }

  .events-calendar__cell--event {
    background: rgba(196, 168, 106, 0.14);
    box-shadow: inset 0 0 0 1px rgba(196, 168, 106, 0.28);
  }

  .events-calendar__cell--announcement {
    background: rgba(138, 115, 85, 0.12);
    box-shadow: inset 0 0 0 1px rgba(138, 115, 85, 0.24);
  }

  .events-calendar__day {
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1;
  }

  .events-calendar__markers {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    min-height: 0;
    flex: 1;
  }

  .events-calendar__chip {
    display: block;
    padding: 0.12rem 0.3rem;
    border-left: 3px solid var(--event-staff-color, var(--color-dusty-rose));
    background: color-mix(in srgb, var(--event-staff-color, var(--color-dusty-rose)) 14%, transparent);
    font-size: 0.58rem;
    font-weight: 500;
    line-height: 1.25;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .events-calendar__chip--closure {
    border-left-color: #c83c3c;
    background: rgba(200, 60, 60, 0.12);
  }

  .events-calendar__chip--announcement {
    border-left-color: #8a7355;
    background: rgba(138, 115, 85, 0.12);
  }

  .events-calendar__bar {
    display: block;
    height: 0.28rem;
    border-radius: 999px;
    background: var(--event-staff-color, var(--color-dusty-rose));
  }

  .events-calendar__more {
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .events-calendar-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    padding: 0.55rem 0.85rem;
    border-top: 1px solid var(--color-border-subtle);
    background: var(--color-booking-panel-bg);
  }

  .events-calendar-legend__item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .events-calendar-legend__item::before {
    content: "";
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .events-calendar-legend__item--closure::before {
    background: rgba(200, 60, 60, 0.35);
    border: 1px solid rgba(200, 60, 60, 0.5);
  }

  .events-calendar-legend__item--event::before {
    background: rgba(196, 168, 106, 0.35);
    border: 1px solid rgba(196, 168, 106, 0.5);
  }

  .events-calendar-legend__item--announcement::before {
    background: rgba(138, 115, 85, 0.3);
    border: 1px solid rgba(138, 115, 85, 0.45);
  }

  .events-calendar-legend__item--time_off::before {
    background: linear-gradient(
      90deg,
      var(--color-citrine) 0 33%,
      var(--color-sage) 33% 66%,
      #d4a5a5 66% 100%
    );
    border-radius: 999px;
  }

  .events-upcoming {
    margin-top: 0;
  }

  .events-list {
    display: grid;
    gap: 0.65rem;
  }

  .event-card {
    position: relative;
    display: flex;
    align-items: stretch;
    width: 100%;
    padding: 0;
    border: 1px solid var(--color-border);
    background: var(--color-booking-card-bg);
    cursor: pointer;
    text-align: left;
    font: inherit;
    color: inherit;
    overflow: hidden;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .event-card:hover,
  .event-card:focus-visible {
    border-color: var(--color-sage);
    box-shadow: 0 2px 12px var(--color-card-shadow);
    outline: none;
  }

  .event-card__accent {
    width: 4px;
    flex-shrink: 0;
    background: var(--event-staff-color, var(--color-dusty-rose));
  }

  .event-card--closure .event-card__accent {
    background: #c83c3c;
  }

  .event-card--announcement .event-card__accent {
    background: #8a7355;
  }

  .event-card__body {
    display: grid;
    gap: 0.45rem;
    flex: 1;
    min-width: 0;
    padding: 0.85rem 1rem;
  }

  .event-card__top {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .event-card__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .event-card__description {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.45;
    color: var(--color-gray);
  }

  .event-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: var(--color-gray);
  }

  .event-card__staff {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .event-card__staff::before {
    content: "";
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--event-staff-color, var(--color-dusty-rose));
  }

  .event-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.18rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .event-badge--time_off {
    border-color: color-mix(in srgb, var(--event-staff-color, #7a8f6e) 55%, var(--color-border));
    color: var(--color-text);
    background: color-mix(in srgb, var(--event-staff-color, #7a8f6e) 12%, transparent);
  }

  .event-badge--closure {
    border-color: #c83c3c;
    color: #922;
    background: rgba(200, 60, 60, 0.1);
  }

  .event-badge--announcement {
    border-color: #8a7355;
    color: #8a7355;
    background: rgba(138, 115, 85, 0.1);
  }

  .event-badge--event {
    border-color: var(--color-citrine);
    color: var(--color-text);
    background: rgba(196, 168, 106, 0.14);
  }

  .events-modal {
    width: min(32rem, calc(100vw - 2rem));
    max-height: calc(100vh - 2rem);
    padding: 0;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    box-shadow: 0 12px 48px var(--color-card-shadow);
  }

  .events-modal::backdrop {
    background: rgba(0, 0, 0, 0.35);
  }

  .events-modal__form {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    margin: 0;
  }

  .events-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .events-modal__header h2 {
    margin: 0;
    font-size: 1.15rem;
  }

  .events-modal__close {
    border: none;
    background: none;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-gray);
    cursor: pointer;
  }

  .events-modal__checkbox {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    text-transform: none;
    letter-spacing: normal;
    cursor: pointer;
  }

  .events-modal__footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
    padding-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .events-calendar__cell {
      min-height: 3.75rem;
      padding: 0.25rem;
    }

    .events-calendar__chip {
      display: none;
    }

    .events-calendar__head {
      font-size: 0.58rem;
      padding: 0.4rem 0.15rem;
    }

    .events-calendar-legend {
      gap: 0.45rem 0.65rem;
      padding: 0.45rem 0.65rem;
    }

    .events-calendar-legend__item {
      font-size: 0.55rem;
    }
  }
</style>
