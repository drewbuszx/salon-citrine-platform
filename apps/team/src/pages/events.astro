---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamListLayout from "../components/TeamListLayout.astro";
import TeamListFilter from "../components/TeamListFilter.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";

const { supabase, staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

const managerView = isSalonManager(staff);

const { data: staffRows } = await supabase
  .from("staff")
  .select("id, name")
  .order("name");

const staffOptions = staffRows ?? [];
---

<TeamLayout title="Events" activeNav="events" plain wide fullBleed>
  <div
    class="events-page"
    data-events-app
    data-api-base={teamUrl("/api/events")}
    data-manager={managerView ? "1" : "0"}
    data-current-staff-id={staff.id}
  >
    <TeamListLayout title="Events" mainTitle="Team calendar" sidebarTitle="Filters">
      <button slot="headerActions" class="team-list-layout__btn-primary" type="button" data-event-create>
        Add event
      </button>

      <TeamListFilter slot="sidebarFilters" label="Event type" open>
        <div class="team-list-layout__filter-options">
          <label class="team-list-layout__filter-option">
            <input type="checkbox" data-filter-type="closure" checked />
            <span>Holiday / closure</span>
          </label>
          <label class="team-list-layout__filter-option">
            <input type="checkbox" data-filter-type="event" checked />
            <span>Community event</span>
          </label>
          <label class="team-list-layout__filter-option">
            <input type="checkbox" data-filter-type="announcement" checked />
            <span>Announcement</span>
          </label>
          <label class="team-list-layout__filter-option">
            <input type="checkbox" data-filter-type="time_off" checked />
            <span>Time off</span>
          </label>
        </div>
      </TeamListFilter>

      {
        managerView ? (
          <TeamListFilter slot="sidebarFilters" label="Staff" count={staffOptions.length} open>
            <div class="team-list-layout__filter-options">
              <label class="team-list-layout__filter-option">
                <input type="radio" name="events-staff" value="" data-filter-staff checked />
                <span>All staff</span>
              </label>
              {
                staffOptions.map((member) => (
                  <label class="team-list-layout__filter-option">
                    <input type="radio" name="events-staff" value={member.id} data-filter-staff />
                    <span>{member.name}</span>
                  </label>
                ))
              }
            </div>
          </TeamListFilter>
        ) : null
      }

      <div slot="sidebarExtra">
        <h3 class="team-list-layout__sidebar-title">Month</h3>
        <div class="team-list-layout__sidebar-shortcuts">
          <button class="team-list-layout__sidebar-shortcut" type="button" data-month-today>Today</button>
          <button class="team-list-layout__sidebar-shortcut" type="button" data-month-prev>Previous month</button>
          <button class="team-list-layout__sidebar-shortcut" type="button" data-month-next>Next month</button>
        </div>
        <p class="team-list-layout__filter-placeholder" data-month-label></p>
      </div>

      <Fragment slot="mainLead">
        Birthdays, time off, closures, and salon announcements — not the appointment book.
      </Fragment>

      <p class="notice notice--error events-page__error" data-events-error hidden role="alert"></p>

      <section class="events-calendar-panel" aria-label="Month calendar">
        <header class="events-calendar-panel__header">
          <h3 class="events-calendar-panel__title" data-month-header></h3>
        </header>
        <div class="events-calendar" data-events-calendar></div>
        <div class="events-calendar-legend" aria-hidden="true">
          <span class="events-calendar-legend__item events-calendar-legend__item--closure">Holiday / closure</span>
          <span class="events-calendar-legend__item events-calendar-legend__item--event">Community</span>
          <span class="events-calendar-legend__item events-calendar-legend__item--announcement">Announcement</span>
          <span class="events-calendar-legend__item events-calendar-legend__item--time_off">Time off (staff color)</span>
        </div>
      </section>

      <section class="events-upcoming team-panel">
        <div class="events-upcoming__header">
          <h3 class="team-panel__title" data-events-list-title>Upcoming</h3>
          <button class="events-upcoming__clear" type="button" data-events-clear-day hidden>
            Show all upcoming
          </button>
        </div>
        <div class="events-list" data-events-list aria-live="polite">
          <p class="empty-state">Loading events…</p>
        </div>
      </section>
    </TeamListLayout>
  </div>

  <dialog class="events-modal" data-event-modal aria-labelledby="event-modal-title">
    <form class="events-modal__form" method="dialog" data-event-form>
      <header class="events-modal__header">
        <h2 id="event-modal-title" data-event-modal-title>Add event</h2>
        <button class="events-modal__close" type="button" data-event-modal-close aria-label="Close">
          ×
        </button>
      </header>

      <div class="form-stack">
        <label class="form-label">
          Title
          <input class="form-input" name="title" type="text" maxlength="200" required />
        </label>

        <label class="form-label">
          Description (optional)
          <textarea class="form-input" name="description" rows="3" maxlength="2000"></textarea>
        </label>

        <label class="form-label">
          Type
          <select class="form-input" name="event_type" data-event-type>
            {
              managerView ? (
                <>
                  <option value="event">Community event</option>
                  <option value="announcement">Salon announcement</option>
                  <option value="closure">Holiday / closure</option>
                  <option value="time_off">Time off</option>
                </>
              ) : (
                <option value="time_off">Time off (my schedule)</option>
              )
            }
          </select>
        </label>

        <div class="events-modal__staff" data-staff-picker hidden>
          <label class="form-label">
            Team member
            <select class="form-input" name="staff_id">
              {
                staffOptions.map((member) => (
                  <option value={member.id} selected={member.id === staff.id}>
                    {member.name}
                  </option>
                ))
              }
            </select>
          </label>
        </div>

        <label class="events-modal__checkbox">
          <input type="checkbox" name="all_day" data-all-day />
          All day
        </label>

        <label class="form-label" data-start-label>
          Starts
          <input class="form-input" name="starts_at" type="datetime-local" required />
        </label>

        <label class="form-label" data-end-label>
          Ends (optional)
          <input class="form-input" name="ends_at" type="datetime-local" />
        </label>
      </div>

      <footer class="events-modal__footer">
        <button class="btn-secondary" type="button" data-event-modal-close>Cancel</button>
        {
          managerView ? (
            <button class="btn-secondary" type="button" data-event-delete hidden>
              Delete
            </button>
          ) : (
            <button class="btn-secondary" type="button" data-event-delete hidden>
              Remove
            </button>
          )
        }
        <button class="btn-primary" type="submit" data-event-submit>Save</button>
      </footer>
    </form>
  </dialog>
</TeamLayout>

<script src="../scripts/events.ts"></script>

<style>
  .events-page {
    --event-color-closure: var(--color-error);
    --event-color-event: var(--color-citrine);
    --event-color-announcement: var(--color-stone-600);
    --event-color-time-off: var(--color-dusty-rose);
    --event-marker-size: 0.5rem;
    --event-marker-gap: 0.2rem;
  }

  .events-page__toolbar {
    display: none;
  }

  .events-page__nav-btn {
    min-width: 2.25rem;
    padding-inline: 0.65rem;
    font-size: 1.1rem;
    line-height: 1;
  }

  .events-page__month {
    margin: 0;
    flex: 1;
    min-width: 10rem;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .events-page__today {
    margin-left: auto;
  }

  .events-page__error {
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .events-calendar-panel {
    margin-bottom: 1rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: 10px;
    background: var(--color-bg);
    box-shadow: 0 2px 16px color-mix(in srgb, var(--color-charcoal) 6%, transparent);
    overflow: hidden;
  }

  .events-calendar-panel__header {
    padding: 0.75rem 1rem 0.5rem;
    border-bottom: 1px solid var(--color-border-subtle);
    background: color-mix(in srgb, var(--color-cream) 45%, var(--color-bg));
  }

  .events-calendar-panel__title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-align: center;
    color: var(--color-text);
  }

  .events-calendar {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0;
    background: var(--color-border-subtle);
  }

  .events-calendar__head,
  .events-calendar__cell {
    background: var(--color-bg);
    font-family: var(--font-sans);
  }

  .events-calendar__head {
    padding: 0.55rem 0.25rem;
    text-align: center;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gray);
    background: color-mix(in srgb, var(--color-cream) 65%, var(--color-bg));
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .events-calendar__cell {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.25rem;
    min-height: 5rem;
    padding: 0.4rem 0.45rem 0.35rem;
    margin: 0;
    border: none;
    border-right: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
    cursor: pointer;
    text-align: left;
    font: inherit;
    color: inherit;
    transition:
      background 0.15s ease,
      box-shadow 0.15s ease;
  }

  .events-calendar__cell:nth-child(7n) {
    border-right: none;
  }

  .events-calendar__cell:hover:not(.events-calendar__cell--pad) {
    background: color-mix(in srgb, var(--color-citrine) 6%, var(--color-bg));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-citrine) 30%, transparent);
    z-index: 1;
  }

  .events-calendar__cell:focus-visible {
    outline: 2px solid var(--color-citrine);
    outline-offset: -2px;
    z-index: 2;
  }

  .events-calendar__cell--pad {
    background: color-mix(in srgb, var(--color-cream) 50%, var(--color-bg));
    opacity: 0.55;
    cursor: default;
  }

  .events-calendar__cell--weekend:not(.events-calendar__cell--pad) {
    background: color-mix(in srgb, var(--color-cream) 28%, var(--color-bg));
  }

  .events-calendar__cell--today {
    background: color-mix(in srgb, var(--color-dusty-rose) 6%, var(--color-bg));
    box-shadow: inset 0 0 0 2px color-mix(in srgb, var(--color-dusty-rose) 45%, transparent);
  }

  .events-calendar__cell--today:hover {
    background: color-mix(in srgb, var(--color-dusty-rose) 10%, var(--color-bg));
  }

  .events-calendar__cell--selected {
    background: var(--color-citrine-muted);
    box-shadow: inset 0 0 0 2px var(--color-citrine);
  }

  .events-calendar__cell--selected.events-calendar__cell--today {
    background: color-mix(in srgb, var(--color-citrine-muted) 70%, color-mix(in srgb, var(--color-dusty-rose) 6%, var(--color-bg)));
    box-shadow: inset 0 0 0 2px var(--color-citrine);
  }

  .events-calendar__cell--today .events-calendar__day {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.45rem;
    height: 1.45rem;
    padding: 0 0.2rem;
    border-radius: 999px;
    background: var(--color-dusty-rose);
    color: #fff;
    font-weight: 700;
  }

  .events-calendar__day {
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-text);
  }

  .events-calendar__cell--pad .events-calendar__day {
    visibility: hidden;
  }

  .events-calendar__markers {
    display: flex;
    flex-wrap: wrap;
    gap: var(--event-marker-gap);
    align-items: center;
    align-content: flex-start;
    margin-top: auto;
    min-height: var(--event-marker-size);
    padding-top: 0.1rem;
  }

  .events-calendar__marker {
    display: block;
    width: var(--event-marker-size);
    height: var(--event-marker-size);
    flex-shrink: 0;
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-bg) 80%, transparent);
  }

  .events-calendar__marker--closure {
    border-radius: 2px;
    background: var(--event-color-closure);
  }

  .events-calendar__marker--event {
    border-radius: 2px;
    background: var(--event-color-event);
  }

  .events-calendar__marker--announcement {
    border-radius: 2px;
    background: var(--event-color-announcement);
  }

  .events-calendar__marker--time_off {
    border-radius: 999px;
    background: var(--event-staff-color, var(--event-color-time-off));
  }

  .events-calendar__more {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-stone-500);
    line-height: 1;
  }

  .events-calendar-legend {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-5);
    padding: var(--space-2) var(--space-4);
    border-top: 1px solid var(--color-stone-200);
    background: var(--color-stone-50);
  }

  .events-calendar-legend__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  .events-calendar-legend__item::before {
    content: "";
    width: var(--event-marker-size);
    height: var(--event-marker-size);
    flex-shrink: 0;
  }

  .events-calendar-legend__item--closure::before {
    border-radius: 2px;
    background: var(--event-color-closure);
  }

  .events-calendar-legend__item--event::before {
    border-radius: 2px;
    background: var(--event-color-event);
  }

  .events-calendar-legend__item--announcement::before {
    border-radius: 2px;
    background: var(--event-color-announcement);
  }

  .events-calendar-legend__item--time_off::before {
    border-radius: 999px;
    background: var(--event-color-time-off);
  }

  .events-upcoming {
    margin-top: 0;
  }

  .events-upcoming__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .events-upcoming .team-panel__title {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin: 0;
  }

  .events-upcoming__clear {
    border: none;
    background: none;
    padding: 0;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-link);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .events-upcoming__clear:hover {
    color: var(--color-link-hover);
  }

  .events-upcoming__clear:focus-visible {
    outline: 2px solid var(--color-citrine);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .events-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border-subtle);
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-bg);
  }

  .event-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    grid-template-areas:
      "dot title badge"
      "dot meta meta";
    align-items: center;
    column-gap: var(--space-2);
    row-gap: 0.05rem;
    width: 100%;
    padding: var(--space-2) var(--space-3);
    border: none;
    border-bottom: 1px solid var(--color-stone-200);
    background: var(--color-bg);
    cursor: pointer;
    text-align: left;
    font: inherit;
    color: inherit;
    transition: background var(--transition-fast);
  }

  .event-row:nth-child(even) {
    background: var(--color-stone-50);
  }

  .event-row:last-child {
    border-bottom: none;
  }

  .event-row:hover,
  .event-row:focus-visible {
    background: color-mix(in srgb, var(--color-citrine) 8%, var(--color-bg));
    outline: none;
  }

  .event-row__dot {
    grid-area: dot;
    align-self: center;
    width: var(--event-marker-size);
    height: var(--event-marker-size);
    flex-shrink: 0;
  }

  .event-row--closure .event-row__dot {
    border-radius: 2px;
    background: var(--event-color-closure);
  }

  .event-row--event .event-row__dot {
    border-radius: 2px;
    background: var(--event-color-event);
  }

  .event-row--announcement .event-row__dot {
    border-radius: 2px;
    background: var(--event-color-announcement);
  }

  .event-row--time_off .event-row__dot {
    border-radius: 999px;
    background: var(--event-staff-color, var(--event-color-time-off));
  }

  .event-row__title {
    grid-area: title;
    min-width: 0;
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: 1.25;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .event-row__meta {
    grid-area: meta;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    line-height: 1.2;
    color: var(--color-stone-500);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .event-row .event-badge {
    grid-area: badge;
    justify-self: end;
    align-self: center;
    padding: 0.08rem 0.38rem;
    font-size: 0.5625rem;
    letter-spacing: var(--tracking-wide);
  }

  .event-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.12rem 0.45rem;
    border: 1px solid var(--color-stone-300);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .event-badge--time_off {
    border-color: color-mix(in srgb, var(--event-staff-color, var(--event-color-time-off)) 55%, var(--color-stone-300));
    color: var(--color-text);
    background: color-mix(in srgb, var(--event-staff-color, var(--event-color-time-off)) 12%, transparent);
  }

  .event-badge--closure {
    border-color: var(--event-color-closure);
    color: var(--event-color-closure);
    background: var(--color-error-muted);
  }

  .event-badge--announcement {
    border-color: var(--event-color-announcement);
    color: var(--event-color-announcement);
    background: color-mix(in srgb, var(--event-color-announcement) 10%, transparent);
  }

  .event-badge--event {
    border-color: var(--event-color-event);
    color: var(--color-text);
    background: var(--color-citrine-muted);
  }

  .events-modal {
    width: min(32rem, calc(100vw - 2rem));
    max-height: calc(100vh - 2rem);
    padding: 0;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-lg);
  }

  .events-modal::backdrop {
    background: rgba(47, 42, 40, 0.4);
  }

  .events-modal__form {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 0;
  }

  .events-modal__form .form-stack {
    margin-top: 0;
    padding: var(--space-4) var(--space-5);
    gap: var(--space-4);
  }

  .events-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--color-stone-200);
    background: var(--color-stone-50);
  }

  .events-modal__header h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .events-modal__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: none;
    border-radius: var(--radius-sm);
    background: none;
    font-size: 1.35rem;
    line-height: 1;
    color: var(--color-stone-500);
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .events-modal__close:hover {
    background: var(--color-stone-100);
    color: var(--color-text);
  }

  .events-modal__close:focus-visible {
    outline: 2px solid var(--color-citrine);
    outline-offset: 2px;
  }

  .events-modal__checkbox {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    text-transform: none;
    letter-spacing: normal;
    cursor: pointer;
  }

  .events-modal__footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-5);
    border-top: 1px solid var(--color-stone-200);
    background: var(--color-stone-50);
  }

  .events-modal__footer [data-event-delete] {
    margin-right: auto;
    border-color: var(--color-error);
    color: var(--color-error);
  }

  .events-modal__footer [data-event-delete]:hover {
    background: var(--color-error-muted);
  }

  @media (max-width: 640px) {
    .events-calendar__cell {
      min-height: 3.75rem;
      padding: 0.28rem 0.22rem 0.22rem;
    }

    .events-calendar__day {
      font-size: 0.68rem;
    }

    .events-calendar__cell--today .events-calendar__day {
      min-width: 1.25rem;
      height: 1.25rem;
    }

    .events-calendar__marker {
      width: 0.4375rem;
      height: 0.4375rem;
    }

    .events-page {
      --event-marker-size: 0.4375rem;
    }

    .events-calendar__head {
      font-size: 0.5625rem;
      padding: 0.35rem 0.1rem;
    }

    .events-calendar-panel__header {
      padding: 0.55rem 0.75rem 0.4rem;
