---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamListLayout from "../components/TeamListLayout.astro";
import TeamSidebarNav from "../components/TeamSidebarNav.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";

const { staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

const managerView = isSalonManager(staff);
---

<TeamLayout title="Docs" activeNav="docs" plain wide fullBleed>
  <div
    class="docs-page"
    data-docs-app
    data-api-base={teamUrl("/api/documents")}
    data-manager={managerView ? "1" : "0"}
  >
    <TeamListLayout title="Docs" mainTitle="Your documents" sidebarTitle="Categories">
      {
        managerView ? (
          <button slot="headerActions" class="team-list-layout__btn-primary" type="button" data-doc-upload-open>
            Upload
          </button>
        ) : null
      }

      <TeamSidebarNav slot="sidebarFilters" label="Document categories">
        <button class="team-list-layout__sidebar-nav-btn is-active" type="button" data-doc-category="all">All categories</button>
        <button class="team-list-layout__sidebar-nav-btn" type="button" data-doc-category="policies">Policies</button>
        <button class="team-list-layout__sidebar-nav-btn" type="button" data-doc-category="training">Training</button>
        <button class="team-list-layout__sidebar-nav-btn" type="button" data-doc-category="forms">Forms</button>
        <button class="team-list-layout__sidebar-nav-btn" type="button" data-doc-category="other">Other</button>
      </TeamSidebarNav>

      <Fragment slot="mainLead">Employee handbook, procedures, and salon resources.</Fragment>

      <label slot="searchBar" class="team-list-layout__search">
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="none">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.75"></circle>
          <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
        </svg>
        <input
          class="team-list-layout__search-input"
          type="search"
          placeholder="Title or description…"
          autocomplete="off"
          data-doc-search
        />
      </label>

      <p class="notice notice--error docs-page__error" data-docs-error hidden role="alert"></p>

      <div class="docs-list" data-docs-list aria-live="polite">
        <p class="docs-loading">Loading documents…</p>
      </div>
    </TeamListLayout>
  </div>

  <dialog class="docs-modal" data-doc-modal aria-labelledby="doc-modal-title">
    <form class="docs-modal__form" method="dialog" data-doc-form enctype="multipart/form-data">
      <header class="docs-modal__header">
        <h2 id="doc-modal-title">Upload document</h2>
        <button class="docs-modal__close ui-btn ui-btn--ghost ui-btn--icon" type="button" data-doc-modal-close aria-label="Close">
          ×
        </button>
      </header>

      <div class="form-stack">
        <label class="form-label">
          Title
          <input class="form-input" name="title" type="text" maxlength="200" required />
        </label>

        <label class="form-label">
          Description (optional)
          <textarea class="form-input" name="description" rows="3" maxlength="2000"></textarea>
        </label>

        <label class="form-label">
          Category
          <select class="form-input" name="category">
            <option value="">Uncategorized</option>
            <option value="policies">Policies</option>
            <option value="training">Training</option>
            <option value="forms">Forms</option>
            <option value="other">Other</option>
          </select>
        </label>

        <label class="form-label">
          File
          <input
            class="form-input"
            name="file"
            type="file"
            accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.webp,application/pdf,image/*"
            required
          />
        </label>
      </div>

      <footer class="docs-modal__footer">
        <button class="team-list-layout__btn-secondary" type="button" data-doc-modal-close>Cancel</button>
        <button class="team-list-layout__btn-primary" type="submit" data-doc-submit>Upload</button>
      </footer>
    </form>
  </dialog>
</TeamLayout>

<script src="../scripts/docs.ts"></script>

<!--
  is:global — docs.ts injects cards via innerHTML; scoped selectors would not match.
-->
<style is:global>
  .docs-page {
    min-width: 0;
    overflow-x: clip;
  }

  .docs-page__error {
    margin-top: 0;
  }

  .docs-list {
    display: grid;
    gap: var(--mobile-space-sm, 0.75rem);
  }

  .docs-loading {
    margin: 0;
    padding: var(--mobile-space-sm) 0;
    font-size: var(--text-sm);
    color: var(--color-stone-500);
  }

  .docs-loading--error {
    color: var(--color-error, #b42318);
  }

  .docs-page .docs-empty.ui-empty {
    justify-items: start;
    text-align: left;
    border: none;
    background: transparent;
    padding: var(--mobile-space-md) 0;
  }

  .docs-page .docs-empty .ui-empty__title {
    font-size: var(--text-sm);
  }

  .docs-page .docs-empty .ui-empty__hint {
    font-size: var(--text-xs);
    max-width: none;
  }

  .docs-page .docs-empty .ui-empty__actions {
    justify-content: flex-start;
  }

  .doc-card {
    display: grid;
    gap: var(--mobile-space-sm);
    padding: var(--mobile-space-md);
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-sm);
  }

  .doc-card--skeleton {
    pointer-events: none;
  }

  .doc-card__skeleton-title {
    display: block;
    width: 55%;
    height: 1rem;
    border-radius: var(--radius-sm);
  }

  .doc-card__skeleton-badge {
    display: block;
    width: 4rem;
    height: 1.25rem;
    border-radius: 999px;
  }

  .doc-card__skeleton-line {
    display: block;
    width: 85%;
    height: 0.75rem;
    border-radius: var(--radius-sm);
  }

  .doc-card__skeleton-meta {
    display: block;
    width: 60%;
    height: 0.65rem;
    border-radius: var(--radius-sm);
  }

  .doc-card__top {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--mobile-space-xs) var(--mobile-space-sm);
  }

  .doc-card__title {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--ui-card-title-size, var(--text-base));
    font-weight: 600;
    line-height: var(--leading-tight);
    color: var(--color-stone-800);
  }

  .doc-card__description {
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-stone-500);
  }

  .doc-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.65rem;
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

  .doc-card__meta-sep {
    color: var(--color-stone-400);
    user-select: none;
  }

  .doc-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--mobile-space-xs);
    padding-top: 0.15rem;
  }

  .doc-card__confirm {
    display: grid;
    gap: 0.35rem;
    width: 100%;
  }

  .doc-card__confirm-text {
    font-size: var(--text-xs);
    color: var(--color-stone-600);
  }

  .doc-card__confirm-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--mobile-space-xs);
  }

  .doc-badge--policies {
    border-color: var(--color-dusty-rose);
    color: var(--color-dusty-rose);
  }

  .doc-badge--training {
    border-color: var(--color-sage);
    color: var(--color-sage);
  }

  .doc-badge--forms,
  .doc-badge--other {
    border-color: var(--color-stone-300);
    color: var(--color-stone-600);
  }

  .docs-modal {
    width: min(32rem, calc(100vw - 2rem));
    max-height: calc(100vh - 2rem);
    padding: 0;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-lg);
  }

  .docs-modal::backdrop {
    background: rgba(0, 0, 0, 0.35);
  }

  .docs-modal__form {
    display: grid;
    gap: 0;
    margin: 0;
  }

  .docs-modal__form .form-stack {
    padding: var(--space-4) var(--space-5);
    gap: var(--space-4);
  }

  .docs-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--color-stone-200);
    background: var(--color-stone-50);
  }

  .docs-modal__header h2 {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .docs-modal__footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: var(--space-4) var(--space-5);
    border-top: 1px solid var(--color-stone-200);
    background: var(--color-stone-50);
  }

  @media (max-width: 640px) {
    .doc-card__actions {
      flex-direction: column;
    }

    .doc-card__actions .ui-btn {
      width: 100%;
      min-height: var(--touch-target-min);
    }

    .doc-card__confirm-actions {
      flex-direction: column;
    }

    .doc-card__confirm-actions .ui-btn {
      width: 100%;
      min-height: var(--touch-target-min);
    }
  }

  @media (max-width: 900px) {
    .docs-modal {
      width: 100%;
      max-width: none;
      max-height: var(--ui-bottom-sheet-max-height, 85vh);
      margin: 0;
      border-radius: var(--radius-xl) var(--radius-xl) 0 0;
      align-self: flex-end;
    }

    .docs-modal__footer {
      padding-bottom: calc(var(--space-4) + var(--safe-area-bottom, env(safe-area-inset-bottom, 0px)));
    }
  }
</style>

<style>
  dialog.docs-modal {
    padding: 0;
  }

  @media (max-width: 900px) {
    dialog.docs-modal {
      inset: auto 0 0 0;
      position: fixed;
      width: 100%;
      max-height: var(--ui-bottom-sheet-max-height, 85vh);
    }
  }
</style>
