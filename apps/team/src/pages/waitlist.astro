---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamListLayout from "../components/TeamListLayout.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";

const { staff, supabase } = Astro.locals;
if (!staff) {
  return Astro.redirect(`${import.meta.env.BASE_URL}login?error=unlinked`);
}

const managerView = isSalonManager(staff);

const [{ data: staffRows }, { data: serviceRows }] = await Promise.all([
  supabase
    .from("staff")
    .select("id, name")
    .in("role", ["owner", "stylist", "esthetician"])
    .order("name"),
  supabase.from("services").select("id, name").eq("is_active", true).order("name"),
]);

const providers = staffRows ?? [];
const services = serviceRows ?? [];
---

<TeamLayout title="Waitlist" activeNav="book" plain wide fullBleed>
  <div
    class="waitlist-page"
    data-waitlist-root
    data-api-base={teamUrl("/api/waitlist")}
    data-clients-base={teamUrl("/clients")}
    data-manager={managerView ? "1" : "0"}
  >
    <TeamListLayout title="Waitlist" mainTitle="Waitlist" showSidebar={false}>
      {
        managerView ? (
          <button slot="headerActions" class="team-list-layout__btn-accent" type="button" data-waitlist-add-open>
            Add To Waitlist
          </button>
        ) : null
      }

      <Fragment slot="stats">
        <span data-waitlist-count>0</span> on waitlist
      </Fragment>

      <div slot="searchBar" class="waitlist-page__search-row" data-search-wrap>
        <label class="team-list-layout__search waitlist-page__search">
          <svg
            class="waitlist-page__search-icon"
            data-search-icon
            width="18"
            height="18"
            viewBox="0 0 24 24"
            aria-hidden="true"
            fill="none"
          >
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.75"></circle>
            <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
          </svg>
          <input
            class="team-list-layout__search-input"
            type="search"
            placeholder="Search by name, phone, email, staff, or service"
            autocomplete="off"
            aria-label="Filter waitlist"
            data-waitlist-filter
          />
          <button
            class="waitlist-page__search-clear"
            type="button"
            aria-label="Clear search"
            data-waitlist-filter-clear
            hidden
          >
            ×
          </button>
        </label>
        <p class="waitlist-page__filter-hint" data-waitlist-filter-hint hidden></p>
      </div>

      <p class="team-list-layout__notice" data-waitlist-status hidden aria-live="polite"></p>

      <div class="team-list-layout__table-wrap">
        <table class="team-list-layout__data-table waitlist-table">
          <thead>
            <tr>
              <th scope="col">Client</th>
              <th scope="col">Phone</th>
              <th scope="col">Requested Staff</th>
              <th scope="col">Service(s)</th>
              <th scope="col">Preferred Time</th>
              <th scope="col">Date Added</th>
            </tr>
          </thead>
          <tbody data-waitlist-results></tbody>
        </table>
        <div class="waitlist-page__empty" data-waitlist-empty hidden>
          <svg
            class="waitlist-page__empty-art"
            width="88"
            height="72"
            viewBox="0 0 88 72"
            aria-hidden="true"
            fill="none"
          >
            <rect x="12" y="10" width="64" height="52" rx="6" stroke="currentColor" stroke-width="1.5"></rect>
            <path d="M12 24h64" stroke="currentColor" stroke-width="1.5"></path>
            <circle cx="24" cy="17" r="2" fill="currentColor"></circle>
            <circle cx="32" cy="17" r="2" fill="currentColor"></circle>
            <circle cx="40" cy="17" r="2" fill="currentColor"></circle>
            <rect x="22" y="32" width="10" height="8" rx="2" fill="currentColor" opacity="0.35"></rect>
            <rect x="38" y="32" width="10" height="8" rx="2" fill="currentColor" opacity="0.2"></rect>
            <rect x="54" y="32" width="10" height="8" rx="2" fill="currentColor" opacity="0.2"></rect>
            <rect x="22" y="46" width="10" height="8" rx="2" fill="currentColor" opacity="0.2"></rect>
            <rect x="38" y="46" width="10" height="8" rx="2" fill="currentColor" opacity="0.35"></rect>
            <path
              d="M58 58c6-8 12-8 18 0"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              opacity="0.45"
            ></path>
          </svg>
          <strong data-waitlist-empty-title>No one on the waitlist</strong>
          <span class="waitlist-page__empty-hint" data-waitlist-empty-hint>
            When clients request a spot, they'll appear here so you can fit them in.
          </span>
        </div>
      </div>
    </TeamListLayout>
  </div>

  {
    managerView ? (
      <div class="waitlist-modal" data-waitlist-add-modal hidden>
        <div class="waitlist-modal__backdrop" data-waitlist-add-close></div>
        <div class="waitlist-modal__panel" role="dialog" aria-modal="true" aria-labelledby="waitlist-add-title">
          <div class="waitlist-modal__head">
            <h2 id="waitlist-add-title">Add To Waitlist</h2>
            <button class="waitlist-modal__close" type="button" data-waitlist-add-close aria-label="Close">×</button>
          </div>
          <form class="waitlist-modal__form" data-waitlist-add-form>
            <label class="waitlist-modal__label">
              First name
              <input class="waitlist-modal__input" name="firstName" required autocomplete="given-name" />
            </label>
            <label class="waitlist-modal__label">
              Last name
              <input class="waitlist-modal__input" name="lastName" required autocomplete="family-name" />
            </label>
            <label class="waitlist-modal__label">
              Email
              <input class="waitlist-modal__input" name="email" type="email" required autocomplete="email" />
            </label>
            <label class="waitlist-modal__label">
              Phone
              <input class="waitlist-modal__input" name="phone" type="tel" autocomplete="tel" />
            </label>
            <label class="waitlist-modal__label">
              Requested staff
              <select class="waitlist-modal__input" name="staffId">
                <option value="">Any professional</option>
                {
                  providers.map((member) => (
                    <option value={member.id}>{member.name}</option>
                  ))
                }
              </select>
            </label>
            <label class="waitlist-modal__label">
              Service
              <select class="waitlist-modal__input" name="serviceId" required>
                <option value="" disabled selected>
                  Select a service
                </option>
                {
                  services.map((service) => (
                    <option value={service.id}>{service.name}</option>
                  ))
                }
              </select>
            </label>
            <label class="waitlist-modal__label">
              Preferred date
              <input class="waitlist-modal__input" name="preferredDate" type="date" />
            </label>
            <fieldset class="waitlist-modal__fieldset">
              <legend class="waitlist-modal__legend">Preferred time (optional)</legend>
              <div class="waitlist-modal__chip-row">
                <button class="waitlist-modal__chip" type="button" data-time-chip="morning" aria-pressed="false">
                  Morning
                </button>
                <button class="waitlist-modal__chip" type="button" data-time-chip="afternoon" aria-pressed="false">
                  Afternoon
                </button>
                <button class="waitlist-modal__chip" type="button" data-time-chip="evening" aria-pressed="false">
                  Evening
                </button>
              </div>
              <input type="hidden" name="preferredTimeSlot" value="" data-waitlist-time-slot />
            </fieldset>
            <label class="waitlist-modal__label">
              Notes
              <textarea class="waitlist-modal__input waitlist-modal__textarea" name="clientMessage" rows="2"></textarea>
            </label>
            <p class="team-list-layout__notice team-list-layout__notice--error" data-waitlist-add-error hidden></p>
            <div class="waitlist-modal__actions">
              <button class="team-list-layout__btn-secondary" type="button" data-waitlist-add-close>Cancel</button>
              <button class="team-list-layout__btn-accent" type="submit">Add To Waitlist</button>
            </div>
          </form>
        </div>
      </div>
    ) : null
  }

  <script src="../scripts/waitlist.ts"></script>
</TeamLayout>

<style>
  .waitlist-page__search-row {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .waitlist-page__search {
    margin-bottom: 0;
    max-width: 26rem;
  }

  .waitlist-page__search-clear {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    border: none;
    border-radius: 50%;
    background: var(--color-stone-100);
    color: var(--color-stone-500);
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    transition:
      background var(--transition-fast),
      color var(--transition-fast);
  }

  .waitlist-page__search-clear:hover,
  .waitlist-page__search-clear:focus-visible {
    background: var(--color-stone-200);
    color: var(--color-stone-700);
    outline: none;
  }

  .waitlist-page__filter-hint {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

  .waitlist-page__filter-hint[hidden] {
    display: none;
  }

  .waitlist-page__empty {
    display: grid;
    gap: 0.5rem;
    justify-items: center;
    margin: 2.5rem auto 0;
    max-width: 20rem;
    padding: 2rem 1rem;
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-stone-500);
  }

  .waitlist-page__empty[hidden] {
    display: none;
  }

  .waitlist-page__empty-art {
    color: var(--color-stone-300);
    margin-bottom: 0.25rem;
  }

  .waitlist-page__empty strong {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-stone-700);
  }

  .waitlist-page__empty-hint {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-stone-500);
  }

  .waitlist-page :global(.waitlist-table tbody tr[data-waitlist-row]) {
    cursor: default;
  }

  .waitlist-page :global(.waitlist-table th:nth-child(1)),
  .waitlist-page :global(.waitlist-table td:nth-child(1)) {
    min-width: 9rem;
  }

  .waitlist-page :global(.waitlist-table th:nth-child(2)),
  .waitlist-page :global(.waitlist-table td:nth-child(2)) {
    min-width: 7.5rem;
    white-space: nowrap;
  }

  .waitlist-page :global(.waitlist-table th:nth-child(4)),
  .waitlist-page :global(.waitlist-table td:nth-child(4)) {
    min-width: 10rem;
  }

  .waitlist-page :global(.waitlist-table td) {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  .waitlist-page :global(.waitlist-table .waitlist-table__services),
  .waitlist-page :global(.waitlist-table .waitlist-table__preferred) {
    color: var(--color-stone-500);
  }

  .waitlist-page :global(.waitlist-table .waitlist-table__date) {
    white-space: nowrap;
    color: var(--color-stone-500);
  }

  .waitlist-page :global(.waitlist-table .waitlist-table__loading td) {
    padding: 2.5rem 1rem;
    text-align: center;
    color: var(--color-stone-500);
    font-size: var(--text-sm);
    background: transparent;
  }

  .waitlist-modal[hidden] {
    display: none;
  }

  .waitlist-modal {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: grid;
    place-items: center;
    padding: 1rem;
  }

  .waitlist-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(17, 24, 39, 0.45);
  }

  .waitlist-modal__panel {
    position: relative;
    z-index: 1;
    width: min(100%, 28rem);
    max-height: 90vh;
    overflow: auto;
    padding: 1.25rem;
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-lg);
  }

  .waitlist-modal__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .waitlist-modal__head h2 {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 600;
  }

  .waitlist-modal__close {
    border: none;
    background: none;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-stone-500);
    cursor: pointer;
  }

  .waitlist-modal__form {
    display: grid;
    gap: 0.85rem;
  }

  .waitlist-modal__label {
    display: grid;
    gap: 0.35rem;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-stone-700);
  }

  .waitlist-modal__input {
    padding: 0.55rem 0.65rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    background: var(--color-bg);
  }

  .waitlist-modal__textarea {
    resize: vertical;
    min-height: 4rem;
  }

  .waitlist-modal__input:focus-visible {
    outline: none;
    border-color: var(--color-citrine);
    box-shadow: 0 0 0 3px var(--color-focus-ring);
  }

  .waitlist-modal__fieldset {
    margin: 0;
    padding: 0;
    border: none;
  }

  .waitlist-modal__legend {
    margin-bottom: 0.45rem;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-stone-700);
  }

  .waitlist-modal__chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .waitlist-modal__chip {
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--color-stone-200);
    border-radius: 999px;
    background: var(--color-bg);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-stone-700);
    cursor: pointer;
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast),
      color var(--transition-fast);
  }

  .waitlist-modal__chip:hover,
  .waitlist-modal__chip:focus-visible {
    border-color: var(--color-citrine);
    outline: none;
  }

  .waitlist-modal__chip--active {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted);
    color: var(--color-stone-800);
  }

  .waitlist-modal__actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }
</style>
