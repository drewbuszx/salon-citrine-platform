---
import { BUSINESS, TIMEZONE } from "@saloncitrine/shared";
import TeamLayout from "../layouts/TeamLayout.astro";
import StaffAvatar from "../components/StaffAvatar.astro";
import TeamOps from "../components/TeamOps.astro";
import { staffInitials, staffPhotoSrc } from "../lib/staff-display";
import { normalizePhotoCrop, parsePhotoCrop } from "../lib/staff-photo";
import { isSalonManager } from "../lib/auth";
import { loadTaskSummary, type TaskSummaryCounts } from "../lib/api-tasks";
import { loadSalonRoutines, type RoutinePayload } from "../lib/api-routines";
import { loadUpcomingTeamEvents, loadManagerDashboardCounts } from "../lib/team-ops";
import {
  EVENT_TOKENS,
  eventIconMarkup,
  normalizeEventType,
} from "../lib/event-presentation";
import { teamUrl } from "../lib/supabase-server";

const { supabase, staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

const manager = isSalonManager(staff);

const photoSrc = staffPhotoSrc(staff.photo_url, staff.slug);
const photoCrop = normalizePhotoCrop(parsePhotoCrop(staff.photo_crop));
const initials = staffInitials(staff.name);
const firstName = staff.name.split(/\s+/)[0] ?? staff.name;

const EMPTY_COUNTS: TaskSummaryCounts = {
  assignedToMe: 0,
  openToEveryone: 0,
  needsAttention: 0,
  dueToday: 0,
  completedThisWeek: 0,
};

let counts: TaskSummaryCounts = EMPTY_COUNTS;
let dashboardDegraded = false;
try {
  const summary = await loadTaskSummary(supabase, staff.id, manager);
  counts = summary.counts;
} catch (error) {
  dashboardDegraded = true;
  console.error("Failed to load task summary", error);
}

let routines: RoutinePayload[] = [];
try {
  routines = await loadSalonRoutines(supabase);
} catch (error) {
  dashboardDegraded = true;
  console.error("Failed to load salon routines", error);
}

const upcomingEvents = await loadUpcomingTeamEvents(supabase, staff, 14, 6);

const managerCounts = manager
  ? await loadManagerDashboardCounts(supabase, staff, counts.needsAttention)
  : null;

const showWelcome = Astro.url.searchParams.get("welcome") === "1";

const salonHour = Number(
  new Intl.DateTimeFormat("en-US", {
    timeZone: TIMEZONE,
    hour: "numeric",
    hour12: false,
  }).format(new Date()),
);
const greeting =
  salonHour < 12
    ? "Good morning"
    : salonHour < 17
      ? "Good afternoon"
      : "Good evening";

const eventDateFmt = new Intl.DateTimeFormat("en-US", {
  timeZone: TIMEZONE,
  weekday: "short",
  month: "short",
  day: "numeric",
});
const eventTimeFmt = new Intl.DateTimeFormat("en-US", {
  timeZone: TIMEZONE,
  hour: "numeric",
  minute: "2-digit",
});
const todaySalon = new Intl.DateTimeFormat("en-CA", {
  timeZone: TIMEZONE,
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(new Date());

function formatEventWhen(startsAt: string, allDay: boolean) {
  const date = new Date(startsAt);
  const dayKey = new Intl.DateTimeFormat("en-CA", {
    timeZone: TIMEZONE,
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(date);
  const dayLabel = dayKey === todaySalon ? "Today" : eventDateFmt.format(date);
  if (allDay) return dayLabel;
  return `${dayLabel} · ${eventTimeFmt.format(date)}`;
}

const quickLinks: { label: string; href: string; desc: string; icon: string }[] = [
  {
    label: "Tasks",
    href: teamUrl("/tasks"),
    desc: "Assignments, open pool, and salon checklists",
    icon: `<path d="M9 11l3 3 8-8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/><path d="M20 12v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h9" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    label: "Docs",
    href: teamUrl("/docs"),
    desc: "Policies, guides, and salon references",
    icon: `<path d="M7 3h7l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M14 3v5h5M9 13h6M9 17h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    label: "Calendar",
    href: teamUrl("/events"),
    desc: "Birthdays, time off, closures, and meetings",
    icon: `<rect x="4" y="5" width="16" height="15" rx="1.5" stroke="currentColor" stroke-width="1.6"/><path d="M8 3v4M16 3v4M4 10h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    label: "Manage",
    href: teamUrl("/manage"),
    desc: "Employees, roles, and access",
    icon: `<circle cx="9" cy="8" r="3" stroke="currentColor" stroke-width="1.6"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6M16 11l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
];
---

<TeamLayout title="Dashboard" activeNav="dashboard" plain cream>
  <section class="dashboard">
    {
      dashboardDegraded ? (
        <p class="notice notice--error" role="alert">
          Some dashboard data could not be loaded. Counts may be incomplete; try refreshing.
        </p>
      ) : null
    }
    {
      showWelcome ? (
        <p class="notice notice--success" role="status">
          You’re in — welcome to the {BUSINESS.name} team app. Tasks, Calendar, and Docs are ready when you are.
        </p>
      ) : null
    }
    <header class="dashboard__hero">
      <div class="dashboard__avatar-wrap">
        {
          photoSrc ? (
            <StaffAvatar
              src={photoSrc}
              alt=""
              crop={photoCrop}
              size="hero"
              class="dashboard__avatar"
            />
          ) : (
            <span class="dashboard__avatar dashboard__avatar--initials" aria-hidden="true">
              {initials}
            </span>
          )
        }
      </div>
      <p class="dashboard__greeting">{greeting},</p>
      <h1 class="dashboard__name">{firstName}</h1>
      <p class="dashboard__salon">{BUSINESS.name}</p>
    </header>

    {
      manager && managerCounts ? (
        <section class="dashboard__manager" aria-label="Manager attention">
          <header class="dashboard__manager-head">
            <h2 class="dashboard__manager-title">Needs your attention</h2>
            <p class="dashboard__manager-sub">Real queues from Calendar and Manage</p>
          </header>
          <div class="dashboard__manager-grid">
            <a
              class:list={[
                "dashboard__manager-chip",
                managerCounts.pendingTimeOff > 0 && "dashboard__manager-chip--hot",
              ]}
              href={teamUrl("/events#pending")}
            >
              <span class="dashboard__manager-value">{managerCounts.pendingTimeOff}</span>
              <span class="dashboard__manager-label">Pending time off</span>
            </a>
            <a
              class:list={[
                "dashboard__manager-chip",
                managerCounts.pendingInvites > 0 && "dashboard__manager-chip--hot",
              ]}
              href={teamUrl("/manage/employees?access=invited")}
            >
              <span class="dashboard__manager-value">{managerCounts.pendingInvites}</span>
              <span class="dashboard__manager-label">Pending invites</span>
            </a>
            <a
              class:list={[
                "dashboard__manager-chip",
                managerCounts.pendingBios > 0 && "dashboard__manager-chip--hot",
              ]}
              href={teamUrl("/manage/bios")}
            >
              <span class="dashboard__manager-value">{managerCounts.pendingBios}</span>
              <span class="dashboard__manager-label">Pending bios</span>
            </a>
            <a
              class:list={[
                "dashboard__manager-chip",
                managerCounts.needsAttention > 0 && "dashboard__manager-chip--hot",
              ]}
              href={teamUrl("/tasks?view=attention")}
            >
              <span class="dashboard__manager-value">{managerCounts.needsAttention}</span>
              <span class="dashboard__manager-label">Tasks needing attention</span>
            </a>
          </div>
        </section>
      ) : null
    }

    <div class="dashboard__ops">
      <TeamOps counts={counts} routines={routines} />
    </div>

    <nav class="dashboard__links" aria-label="Quick links">
      <p class="dashboard__links-title">Quick links</p>
      {
        quickLinks.map((link) => (
          <a class="dashboard__link" href={link.href}>
            <span class="dashboard__link-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" set:html={link.icon} />
            </span>
            <span class="dashboard__link-copy">
              <span class="dashboard__link-label">{link.label}</span>
              <span class="dashboard__link-desc">{link.desc}</span>
            </span>
          </a>
        ))
      }
    </nav>

    <section class="dashboard__upcoming" aria-labelledby="dashboard-upcoming-title">
      <div class="dashboard__upcoming-head">
        <h2 id="dashboard-upcoming-title" class="dashboard__section-title">Upcoming</h2>
        <a class="dashboard__upcoming-link" href={teamUrl("/events")}>View Calendar</a>
      </div>

      {
        upcomingEvents.length === 0 ? (
          <div class="dashboard__empty">
            <span class="dashboard__empty-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <rect x="4" y="5" width="16" height="15" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M8 3v4M16 3v4M4 10h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </span>
            <p class="dashboard__empty-title">Nothing on the calendar</p>
            <p class="dashboard__empty-copy">
              No team events in the next two weeks. Open Calendar to add one.
            </p>
            <a class="dashboard__empty-cta" href={teamUrl("/events")}>Open Calendar</a>
          </div>
        ) : (
          <ul class="dashboard__list">
            {upcomingEvents.map((event) => {
              const token = EVENT_TOKENS[normalizeEventType(event.eventType)];
              return (
                <li>
                  <a class="dashboard__card" href={teamUrl("/events")}>
                    <span
                      class="dashboard__card-icon"
                      style={`--event-color: ${token.baseColor}`}
                      aria-hidden="true"
                      set:html={eventIconMarkup(token.icon, {
                        className: "dashboard__card-icon-svg",
                      })}
                    />
                    <span class="dashboard__card-main">
                      <span class="dashboard__card-title">{event.title}</span>
                      <span class="dashboard__card-meta">
                        <span class="dashboard__card-type">{token.label}</span>
                        <span class="dashboard__card-when">
                          {formatEventWhen(event.startsAt, event.allDay)}
                        </span>
                      </span>
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        )
      }
    </section>
  </section>
</TeamLayout>

<style>
  .dashboard {
    max-width: 34rem;
    margin: 0 auto;
    padding: var(--space-6) var(--space-4) var(--space-10);
  }

  .dashboard__hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-2) 0 var(--space-6);
    border-bottom: 1px solid var(--color-stone-200);
    margin-bottom: var(--space-6);
  }

  .dashboard__avatar-wrap {
    margin-bottom: 1rem;
    padding: 4px;
    border-radius: 50%;
    background: linear-gradient(
      145deg,
      var(--color-citrine-light),
      var(--color-citrine) 45%,
      var(--color-citrine-dark)
    );
    box-shadow:
      0 8px 24px rgba(231, 172, 70, 0.22),
      0 0 0 1px rgba(231, 172, 70, 0.15);
  }

  .dashboard__avatar {
    width: 7.5rem;
    height: 7.5rem;
    border-radius: 50%;
    box-shadow:
      inset 0 0 0 3px var(--color-cream),
      var(--shadow-md);
  }

  .dashboard__avatar--initials {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-dusty-rose);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .dashboard__greeting {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--color-stone-500);
  }

  .dashboard__name {
    margin: 0.1rem 0 var(--space-1);
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: var(--leading-tight);
    color: var(--color-stone-800);
  }

  .dashboard__salon {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  .dashboard__ops {
    margin-bottom: var(--space-6);
  }

  .dashboard__manager {
    margin-bottom: var(--space-6);
    padding: 1rem 1rem 1.1rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-lg);
    background: var(--color-bg);
  }

  .dashboard__manager-head {
    margin-bottom: 0.75rem;
    padding: 0 0.15rem;
  }

  .dashboard__manager-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-stone-700);
  }

  .dashboard__manager-sub {
    margin: 0.2rem 0 0;
    font-size: 0.75rem;
    color: var(--color-stone-500);
  }

  .dashboard__manager-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .dashboard__manager-chip {
    display: grid;
    justify-items: center;
    gap: 0.2rem;
    min-height: 2.75rem;
    padding: 0.75rem 0.4rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-stone-50);
    text-align: center;
    color: inherit;
    text-decoration: none;
  }

  .dashboard__manager-chip:hover,
  .dashboard__manager-chip:focus-visible {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted);
    outline: none;
  }

  .dashboard__manager-chip--hot {
    border-color: rgba(196, 90, 78, 0.4);
    background: rgba(196, 90, 78, 0.06);
  }

  .dashboard__manager-value {
    font-family: var(--font-display);
    font-size: 1.65rem;
    font-weight: 500;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    color: var(--color-stone-800);
  }

  .dashboard__manager-label {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-stone-600);
  }

  @media (max-width: 640px) {
    .dashboard__manager-grid {
      grid-template-columns: 1fr;
    }
  }

  .dashboard__links {
    display: grid;
    gap: 0.55rem;
    margin-bottom: var(--space-8);
  }

  .dashboard__links-title {
    margin: 0 0 0.1rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  .dashboard__link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-stone-50);
    color: inherit;
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .dashboard__link:hover,
  .dashboard__link:focus-visible {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
    outline: none;
  }

  .dashboard__link-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--color-stone-100);
    color: var(--color-stone-700);
  }

  .dashboard__link:hover .dashboard__link-icon,
  .dashboard__link:focus-visible .dashboard__link-icon {
    background: rgba(231, 172, 70, 0.22);
    color: var(--color-citrine-dark);
  }

  .dashboard__link-icon svg {
    width: 1.15rem;
    height: 1.15rem;
  }

  .dashboard__link-copy {
    display: grid;
    gap: 0.1rem;
    min-width: 0;
  }

  .dashboard__link-label {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-stone-800);
  }

  .dashboard__link-desc {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    line-height: 1.35;
    color: var(--color-stone-500);
  }

  .dashboard__upcoming-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .dashboard__section-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--color-stone-800);
  }

  .dashboard__upcoming-link {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-link, var(--color-gray));
    transition: color var(--transition-fast);
  }

  .dashboard__upcoming-link:hover,
  .dashboard__upcoming-link:focus-visible {
    color: var(--color-link-hover, var(--color-citrine-dark));
  }

  .dashboard__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    padding: 1.5rem 1.25rem;
    border: 1px dashed var(--color-stone-200, var(--color-border));
    border-radius: 0.75rem;
    background: var(--color-stone-50, rgba(243, 241, 236, 0.5));
    text-align: center;
  }

  .dashboard__empty-icon {
    display: inline-flex;
    width: 2rem;
    height: 2rem;
    margin-bottom: 0.15rem;
    color: var(--color-stone-500, var(--color-gray));
  }

  .dashboard__empty-icon svg {
    width: 100%;
    height: 100%;
  }

  .dashboard__empty-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-stone-700, var(--color-text));
  }

  .dashboard__empty-copy {
    margin: 0;
    max-width: 16rem;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--color-stone-500, var(--color-gray));
  }

  .dashboard__empty-cta {
    margin-top: 0.35rem;
    padding: 0.45rem 0.9rem;
    border-radius: var(--radius-sm, 0.35rem);
    background: var(--color-citrine);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background var(--transition-fast);
  }

  .dashboard__empty-cta:hover,
  .dashboard__empty-cta:focus-visible {
    background: var(--color-citrine-hover);
    outline: none;
  }

  .dashboard__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .dashboard__card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.65rem;
    background: var(--color-bg);
    color: inherit;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .dashboard__card:hover,
  .dashboard__card:focus-visible {
    border-color: var(--color-citrine);
    box-shadow: 0 4px 16px rgba(47, 42, 40, 0.08);
    outline: none;
  }

  .dashboard__card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.85rem;
    height: 1.85rem;
    flex-shrink: 0;
    border-radius: 999px;
    background: color-mix(in srgb, var(--event-color, var(--color-stone-400)) 16%, var(--color-bg));
    border: 1px solid color-mix(in srgb, var(--event-color, var(--color-stone-400)) 40%, transparent);
    color: var(--event-color, var(--color-stone-500));
  }

  .dashboard__card-icon :global(.dashboard__card-icon-svg) {
    width: 0.95rem;
    height: 0.95rem;
  }

  .dashboard__card-main {
    display: grid;
    gap: 0.15rem;
    min-width: 0;
  }

  .dashboard__card-title {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-stone-800);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .dashboard__card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-stone-500);
  }

  .dashboard__card-type {
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    font-size: 0.66rem;
    color: var(--color-stone-600);
  }

  :global([data-theme="dark"]) .dashboard__name {
    color: var(--color-stone-800);
  }

  :global([data-theme="dark"]) .dashboard__salon,
  :global([data-theme="dark"]) .dashboard__greeting {
    color: var(--color-stone-500);
  }

  :global([data-theme="dark"]) .dashboard__link,
  :global([data-theme="dark"]) .dashboard__link-label {
    color: var(--color-stone-800);
  }

  :global([data-theme="dark"]) .dashboard__link-desc,
  :global([data-theme="dark"]) .dashboard__empty-copy {
    color: var(--color-stone-500);
  }

  /* ============================================================= */
  /* DESKTOP ENHANCED LAYOUT (>= 1100px). Mobile/tablet untouched.  */
  /* ============================================================= */
  @media (min-width: 1100px) {
    /* Allow the app shell to breathe into a wide, centered content
       column. Only loaded on this page, so other routes are unaffected. */
    :global(.team-main) {
      --team-max-width: 1320px;
    }

    .dashboard {
      max-width: 1240px;
