---
import { BUSINESS } from "@saloncitrine/shared";
import TeamLayout from "../layouts/TeamLayout.astro";
import StaffAvatar from "../components/StaffAvatar.astro";
import TeamPulse from "../components/TeamPulse.astro";
import { staffInitials, staffPhotoSrc } from "../lib/staff-display";
import { normalizePhotoCrop, parsePhotoCrop } from "../lib/staff-photo";
import {
  formatAppointmentStatusLabel,
  formatTimeRangeInSalon,
  loadUpcomingAppointments,
  salonDateString,
} from "../lib/calendar";
import { loadTeamPulseMetrics } from "../lib/team-pulse";
import { teamUrl } from "../lib/supabase-server";

const { supabase, staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

const bookOrigin =
  import.meta.env.PUBLIC_BOOK_URL ?? "https://book.saloncitrineindy.com/book";
const bookingLink = `${bookOrigin.replace(/\/$/, "")}?staff=${staff.slug}`;

const photoSrc = staffPhotoSrc(staff.photo_url, staff.slug);
const photoCrop = normalizePhotoCrop(parsePhotoCrop(staff.photo_crop));
const initials = staffInitials(staff.name);

let upcoming: Awaited<ReturnType<typeof loadUpcomingAppointments>> = [];

try {
  upcoming = await loadUpcomingAppointments(supabase, staff.id);
} catch (error) {
  console.error("Failed to load upcoming appointments", error);
}

const todaySalon = salonDateString(new Date());
const pulseMetrics = await loadTeamPulseMetrics(supabase, staff);

const checkoutHref =
  upcoming.length > 0
    ? teamUrl(`/checkout/${upcoming[0]!.id}`)
    : teamUrl("/book");

function minutesUntil(iso: string) {
  const diffMs = new Date(iso).getTime() - Date.now();
  if (diffMs < 0) return null;
  const mins = Math.round(diffMs / 60_000);
  if (mins < 1) return "Starting now";
  if (mins < 60) return `In ${mins} min`;
  const hours = Math.floor(mins / 60);
  const rem = mins % 60;
  return rem > 0 ? `In ${hours}h ${rem}m` : `In ${hours}h`;
}

function formatUpcomingWhen(startsAt: string, endsAt: string) {
  const dateLabel = salonDateString(new Date(startsAt));
  const timeRange = formatTimeRangeInSalon(startsAt, endsAt);
  if (dateLabel === todaySalon) {
    return { day: "Today", time: timeRange };
  }
  const tomorrow = new Date();
  tomorrow.setDate(tomorrow.getDate() + 1);
  if (dateLabel === salonDateString(tomorrow)) {
    return { day: "Tomorrow", time: timeRange };
  }
  const dayPart = new Intl.DateTimeFormat("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
  }).format(new Date(startsAt));
  return { day: dayPart, time: timeRange };
}
---

<TeamLayout title="Dashboard" activeNav="dashboard" plain>
  <section class="dashboard">
    <header class="dashboard__hero">
      <div class="dashboard__avatar-wrap">
        {
          photoSrc ? (
            <StaffAvatar
              src={photoSrc}
              alt=""
              crop={photoCrop}
              size="hero"
              class="dashboard__avatar"
            />
          ) : (
            <span class="dashboard__avatar dashboard__avatar--initials" aria-hidden="true">
              {initials}
            </span>
          )
        }
      </div>
      <h1 class="dashboard__name">{staff.name}</h1>
      <p class="dashboard__salon">{BUSINESS.name}</p>
      <div class="dashboard__booking-row">
        <a class="dashboard__booking-link" href={bookingLink} target="_blank" rel="noopener noreferrer">
          Your booking link
        </a>
        <button class="dashboard__copy-link" type="button" data-copy-booking-link data-booking-url={bookingLink}>
          Copy link
        </button>
      </div>
    </header>

    <TeamPulse metrics={pulseMetrics} />

    <nav class="dashboard__actions" aria-label="Quick actions">
      <a class="dashboard__action dashboard__action--primary" href={teamUrl("/book")}>
        <span class="dashboard__action-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
        </span>
        Book appointment
      </a>
      <a class="dashboard__action" href={checkoutHref}>
        <span class="dashboard__action-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M6 8h12M6 12h8M6 16h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <rect x="4" y="5" width="16" height="14" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </span>
        Sale / Checkout
      </a>
      <a class="dashboard__action" href={teamUrl("/inventory")}>
        <span class="dashboard__action-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M4 8h4l2-3h4l2 3h4v11H4V8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="12" cy="13" r="3" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </span>
        Scan
      </a>
    </nav>

    <section class="dashboard__upcoming" aria-labelledby="dashboard-upcoming-title">
      <div class="dashboard__upcoming-head">
        <h2 id="dashboard-upcoming-title" class="dashboard__section-title">Upcoming</h2>
        <a class="dashboard__upcoming-link" href={teamUrl("/book")}>View book</a>
      </div>

      {
        upcoming.length === 0 ? (
          <div class="dashboard__empty">
            <span class="dashboard__empty-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <rect x="4" y="5" width="16" height="15" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M8 3v4M16 3v4M4 10h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </span>
            <p class="dashboard__empty-title">Your schedule is clear</p>
            <p class="dashboard__empty-copy">
              No upcoming appointments yet. Open book to add a guest or block time.
            </p>
            <a class="dashboard__empty-cta" href={teamUrl("/book")}>Open book</a>
          </div>
        ) : (
          <ul class="dashboard__list">
            {upcoming.map((appt, index) => {
              const when = formatUpcomingWhen(appt.startsAt, appt.endsAt);
              const isTodayAppt = salonDateString(new Date(appt.startsAt)) === todaySalon;
              const urgency = isTodayAppt ? minutesUntil(appt.startsAt) : null;
              return (
              <li>
                <a
                  class:list={[
                    "dashboard__card",
                    index === 0 && urgency && "dashboard__card--next",
                  ]}
                  href={teamUrl(`/checkout/${appt.id}`)}
                >
                  <div class="dashboard__card-main">
                    <p class="dashboard__card-client">
                      {index === 0 && urgency ? (
                        <span class="dashboard__live-dot" aria-hidden="true" />
                      ) : null}
                      {appt.clientName}
                    </p>
                    <p class="dashboard__card-service">
                      {appt.serviceLabel ?? "Appointment"}
                    </p>
                    <p class="dashboard__card-time">
                      <span class="dashboard__card-day">{when.day}</span>
                      <span class="dashboard__card-range">{when.time}</span>
                      {urgency ? (
                        <span class="dashboard__card-urgency">{urgency}</span>
                      ) : null}
                    </p>
                  </div>
                  <span
                    class:list={[
                      "dashboard__badge",
                      `dashboard__badge--${appt.status.replace(/_/g, "-")}`,
                    ]}
                  >
                    {formatAppointmentStatusLabel(appt.status)}
                  </span>
                </a>
              </li>
              );
            })}
          </ul>
        )
      }
    </section>
  </section>
</TeamLayout>

<script>
  const copyBtn = document.querySelector("[data-copy-booking-link]");
  copyBtn?.addEventListener("click", async () => {
    const url = copyBtn.getAttribute("data-booking-url");
    if (!url) return;
    try {
      await navigator.clipboard.writeText(url);
      const prev = copyBtn.textContent;
      copyBtn.textContent = "Copied!";
      setTimeout(() => {
        copyBtn.textContent = prev;
      }, 2000);
    } catch {
      window.prompt("Copy your booking link:", url);
    }
  });
</script>

<style>
  .dashboard {
    max-width: 34rem;
    margin: 0 auto;
    padding: var(--space-6) var(--space-4) var(--space-10);
  }

  .dashboard__hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-2) 0 var(--space-8);
    border-bottom: 1px solid var(--color-stone-200);
    margin-bottom: var(--space-6);
  }

  .dashboard__avatar-wrap {
    margin-bottom: 1rem;
    padding: 4px;
    border-radius: 50%;
    background: linear-gradient(
      145deg,
      var(--color-citrine-light),
      var(--color-citrine) 45%,
      var(--color-citrine-dark)
    );
    box-shadow:
      0 8px 24px rgba(231, 172, 70, 0.22),
      0 0 0 1px rgba(231, 172, 70, 0.15);
  }

  .dashboard__avatar {
    width: 7.5rem;
    height: 7.5rem;
    border-radius: 50%;
    box-shadow:
      inset 0 0 0 3px var(--color-cream),
      var(--shadow-md);
  }

  .dashboard__avatar--initials {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-dusty-rose);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .dashboard__name {
    margin: 0 0 var(--space-1);
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: var(--leading-tight);
    color: var(--color-stone-800);
  }

  .dashboard__salon {
    margin: 0 0 var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  .dashboard__booking-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
  }

  .dashboard__booking-link {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--color-sage-dark, var(--color-sage));
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .dashboard__copy-link {
    padding: 0.35rem 0.65rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-stone-50);
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-stone-700);
    cursor: pointer;
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .dashboard__copy-link:hover,
  .dashboard__copy-link:focus-visible {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted);
    outline: none;
  }

  .dashboard__actions {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .dashboard__action {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    min-height: 5rem;
    padding: var(--space-4) var(--space-3);
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    text-align: center;
    line-height: 1.25;
    color: inherit;
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .dashboard__action:hover,
  .dashboard__action:focus-visible {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted, rgba(231, 172, 70, 0.12));
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
    outline: none;
  }

  .dashboard__action--primary {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted, rgba(231, 172, 70, 0.12));
  }

  .dashboard__action--primary:hover,
  .dashboard__action--primary:focus-visible {
    background: rgba(231, 172, 70, 0.18);
  }

  .dashboard__action-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.85rem;
    height: 1.85rem;
    border-radius: 50%;
    background: var(--color-stone-100, var(--color-light));
    color: var(--color-stone-700, var(--color-text));
    transition:
      background var(--transition-fast),
      color var(--transition-fast);
  }

  .dashboard__action-icon svg {
    width: 1rem;
    height: 1rem;
  }

  .dashboard__action:hover .dashboard__action-icon,
  .dashboard__action:focus-visible .dashboard__action-icon {
    background: rgba(231, 172, 70, 0.22);
    color: var(--color-citrine-dark);
  }

  .dashboard__upcoming-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .dashboard__section-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--color-stone-800);
  }

  .dashboard__upcoming-link {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-link, var(--color-gray));
    transition: color var(--transition-fast);
  }

  .dashboard__upcoming-link:hover,
  .dashboard__upcoming-link:focus-visible {
    color: var(--color-link-hover, var(--color-citrine-dark));
  }

  .dashboard__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    padding: 1.5rem 1.25rem;
    border: 1px dashed var(--color-stone-200, var(--color-border));
    border-radius: 0.75rem;
    background: var(--color-stone-50, rgba(243, 241, 236, 0.5));
    text-align: center;
  }

  .dashboard__empty-icon {
    display: inline-flex;
    width: 2rem;
    height: 2rem;
    margin-bottom: 0.15rem;
    color: var(--color-stone-500, var(--color-gray));
  }

  .dashboard__empty-icon svg {
    width: 100%;
    height: 100%;
  }

  .dashboard__empty-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-stone-700, var(--color-text));
  }

  .dashboard__empty-copy {
    margin: 0;
    max-width: 16rem;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--color-stone-500, var(--color-gray));
  }

  .dashboard__empty-cta {
    margin-top: 0.35rem;
    padding: 0.45rem 0.9rem;
    border-radius: var(--radius-sm, 0.35rem);
    background: var(--color-citrine);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background var(--transition-fast);
  }

  .dashboard__empty-cta:hover,
  .dashboard__empty-cta:focus-visible {
    background: var(--color-citrine-dark);
    outline: none;
  }

  .dashboard__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .dashboard__card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.65rem;
    background: var(--color-bg);
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .dashboard__card:hover,
  .dashboard__card:focus-visible {
    border-color: var(--color-citrine);
    box-shadow: 0 4px 16px rgba(47, 42, 40, 0.08);
    outline: none;
  }

  .dashboard__card-main {
    min-width: 0;
  }

  .dashboard__card--next {
    border-color: rgba(231, 172, 70, 0.45);
    background: rgba(231, 172, 70, 0.06);
  }

  .dashboard__live-dot {
    display: inline-block;
    width: 0.45rem;
    height: 0.45rem;
    margin-right: 0.35rem;
    border-radius: 50%;
    background: var(--color-sage);
    vertical-align: middle;
    box-shadow: 0 0 0 0 rgba(141, 158, 136, 0.45);
    animation: dashboard-live-pulse 2.4s ease-in-out infinite;
  }

  @keyframes dashboard-live-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(141, 158, 136, 0.45);
    }
    50% {
      box-shadow: 0 0 0 5px rgba(141, 158, 136, 0);
    }
  }

  .dashboard__card-urgency {
    font-weight: 600;
    color: var(--color-citrine-dark);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.68rem;
  }

  .dashboard__card-client {
    margin: 0 0 0.15rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .dashboard__card-service {
    margin: 0 0 0.2rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--color-gray);
  }

  .dashboard__card-time {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem;
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    color: var(--color-gray);
  }

  .dashboard__card-day {
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-stone-700, var(--color-text));
  }

  .dashboard__card-range {
    color: var(--color-stone-500, var(--color-gray));
  }

  .dashboard__badge {
    flex: 0 0 auto;
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--color-light);
    color: var(--color-text);
  }

  .dashboard__badge--confirmed,
  .dashboard__badge--booked {
    background: rgba(231, 172, 70, 0.18);
    color: var(--color-text);
  }

  .dashboard__badge--arrived {
    background: rgba(141, 158, 136, 0.22);
  }

  .dashboard__badge--completed {
    background: var(--color-light);
    opacity: 0.85;
  }

  .dashboard__badge--pending {
    background: rgba(174, 148, 143, 0.2);
  }

  .dashboard__badge--no-show {
    background: rgba(47, 42, 40, 0.08);
    text-decoration: line-through;
  }

  @media (max-width: 420px) {
    .dashboard__actions {
      grid-template-columns: 1fr;
    }

    .dashboard__action {
      flex-direction: row;
      min-height: auto;
      padding: 0.75rem 1rem;
      text-align: left;
    }
  }
</style>
