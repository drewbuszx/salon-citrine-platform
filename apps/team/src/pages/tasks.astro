---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamListLayout from "../components/TeamListLayout.astro";
import TeamSidebarNav from "../components/TeamSidebarNav.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";

const { supabase, staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

const managerView = isSalonManager(staff);

const { data: staffRows } = await supabase
  .from("staff")
  .select("id, name")
  .order("name");

const staffOptions = staffRows ?? [];
---

<TeamLayout title="Tasks" activeNav="tasks" plain wide fullBleed>
  <div
    class="tasks-page"
    data-tasks-app
    data-api-base={teamUrl("/api/tasks")}
    data-manager={managerView ? "1" : "0"}
    data-current-staff-id={staff.id}
  >
    <TeamListLayout title="Tasks" sidebarTitle="Views">
      {
        managerView ? (
          <button slot="headerActions" class="team-list-layout__btn-primary" type="button" data-task-create>
            + New entry
          </button>
        ) : null
      }

      <TeamSidebarNav slot="sidebarFilters" label="Task views">
        <button class="team-list-layout__sidebar-nav-btn is-active" type="button" data-view="my" aria-selected="true">
          <span>Assigned to me</span>
        </button>
        <button class="team-list-layout__sidebar-nav-btn" type="button" data-view="available" aria-selected="false">
          <span>For everyone</span>
        </button>
        <button
          class="team-list-layout__sidebar-nav-btn"
          type="button"
          data-view="attention"
          aria-selected="false"
          title="Active tasks already overdue or due within 24 hours"
        >
          <span>Needs attention</span>
          <span
            class="team-list-layout__sidebar-badge team-list-layout__sidebar-badge--attention"
            data-attention-badge
            hidden
            aria-label="Tasks needing attention"
          >0</span>
        </button>
        <button class="team-list-layout__sidebar-nav-btn" type="button" data-view="completed" aria-selected="false">
          <span>Completed</span>
        </button>
        {
          managerView ? (
            <button class="team-list-layout__sidebar-nav-btn" type="button" data-view="all" aria-selected="false">
              <span>All active</span>
            </button>
          ) : null
        }
      </TeamSidebarNav>

      <Fragment slot="mainLead">Team to-dos and salon checklists.</Fragment>

      <div class="notebook" aria-label="Task notebook">
        <div class="notebook__binding" aria-hidden="true">
          <span class="notebook__hole"></span>
          <span class="notebook__hole"></span>
          <span class="notebook__hole"></span>
        </div>

        <div class="notebook__paper">
          <p class="notice notice--error tasks-page__error" data-tasks-error hidden role="alert"></p>

          <div class="tasks-list" data-tasks-list aria-live="polite">
            <p class="notebook-empty">Loading tasks…</p>
          </div>
        </div>
      </div>
    </TeamListLayout>
  </div>

  <dialog class="tasks-modal" data-task-modal aria-labelledby="task-modal-title">
    <form class="tasks-modal__form" method="dialog" data-task-form>
      <header class="tasks-modal__header">
        <h2 id="task-modal-title" data-task-modal-title>New entry</h2>
        <button class="tasks-modal__close" type="button" data-task-modal-close aria-label="Close">
          ×
        </button>
      </header>

      <div class="form-stack">
        <label class="form-label">
          Title
          <input
            class="form-input"
            name="title"
            type="text"
            maxlength="200"
            required
            placeholder="e.g. Restock towels at the color station"
          />
        </label>

        <label class="form-label">
          Description (optional)
          <textarea
            class="form-input"
            name="description"
            rows="3"
            maxlength="2000"
            placeholder="What done looks like — where, how many, anything to watch for"></textarea>
        </label>

        <label class="form-label">
          Due date (optional)
          <input class="form-input" name="due_at" type="datetime-local" />
          <span class="tasks-modal__hint">Salon time (Indianapolis). Due or overdue within 24 hours lands in Needs attention.</span>
        </label>

        <label class="form-label">
          Priority
          <select class="form-input" name="priority">
            <option value="low">Low — when there's a lull</option>
            <option value="normal" selected>Normal — today's flow</option>
            <option value="high">High — before it affects clients</option>
          </select>
        </label>

        <fieldset class="tasks-modal__fieldset">
          <legend class="label-meta">Assignment</legend>
          <label class="tasks-modal__radio">
            <input type="radio" name="assignment_type" value="open" checked />
            <span>Open to team — shows in <strong>For everyone</strong>, first to claim it owns it</span>
          </label>
          <label class="tasks-modal__radio">
            <input type="radio" name="assignment_type" value="assigned" />
            <span>Assign to specific team member(s)</span>
          </label>
        </fieldset>

        <div class="tasks-modal__assignees" data-assignee-picker hidden>
          <span class="label-meta">Team members</span>
          <div class="tasks-modal__staff-list">
            {
              staffOptions.map((member) => (
                <label class="tasks-modal__staff-option">
                  <input type="checkbox" name="assignee_ids" value={member.id} />
                  <span>{member.name}</span>
                </label>
              ))
            }
          </div>
        </div>
      </div>

      <footer class="tasks-modal__footer">
        <button class="team-list-layout__btn-secondary" type="button" data-task-modal-close>Discard</button>
        <button class="team-list-layout__btn-primary" type="submit" data-task-submit>Save entry</button>
      </footer>
    </form>
  </dialog>

  <dialog class="tasks-modal tasks-modal--narrow" data-complete-modal aria-labelledby="complete-modal-title">
    <form class="tasks-modal__form" method="dialog" data-complete-form>
      <header class="tasks-modal__header">
        <h2 id="complete-modal-title">Mark complete</h2>
        <button class="tasks-modal__close" type="button" data-complete-modal-close aria-label="Close">
          ×
        </button>
      </header>

      <div class="form-stack">
        <p class="tasks-modal__lead" data-complete-task-title></p>
        <p class="tasks-modal__hint">
          This records you as the one who finished it, with the time, under Completed.
        </p>

        <label class="form-label">
          Completion notes (optional)
          <textarea
            class="form-input"
            name="completion_notes"
            rows="3"
            maxlength="1000"
            placeholder="e.g. Used the last case — added towels to the supply order"></textarea>
        </label>
      </div>

      <footer class="tasks-modal__footer">
        <button class="team-list-layout__btn-secondary" type="button" data-complete-modal-close>Not yet</button>
        <button class="team-list-layout__btn-primary" type="submit">Mark done</button>
      </footer>
    </form>
  </dialog>
</TeamLayout>

<script src="../scripts/tasks.ts"></script>

<style>
  .tasks-page {
    --notebook-line: clamp(2rem, 1.7rem + 0.6vw, 2.25rem);
    --notebook-margin: clamp(2.25rem, 1.9rem + 1vw, 2.75rem);
    --notebook-paper: #fdfaf4;
    --notebook-paper-dark: #1e1c19;
    --notebook-rule: rgba(174, 148, 143, 0.32);
    --notebook-margin-line: rgba(196, 90, 78, 0.42);
    --notebook-glow-1: rgba(231, 172, 70, 0.06);
    --notebook-glow-2: rgba(141, 158, 136, 0.05);
  }

  /*
    The notebook is a single clipped shell: the binding strip and the ruled
    paper are painted as one continuous surface, so the rule lines and the
    margin line are guaranteed to reach every edge no matter how much task
    content stretches the container's height.
  */
  .notebook {
    position: relative;
    max-width: 56rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 6px 24px var(--color-card-shadow);
  }

  .notebook__binding {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(2.5rem, 12vw, 5rem);
    height: 1.35rem;
    padding: 0 1rem;
    background: var(--color-cream-deep);
    box-shadow: inset 0 -3px 5px -2px rgba(60, 45, 40, 0.12);
  }

  .notebook__hole {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--notebook-paper);
    box-shadow:
      inset 0 1px 2px rgba(0, 0, 0, 0.22),
      0 1px 0 rgba(255, 255, 255, 0.4);
  }

  [data-theme="dark"] .notebook__hole {
    background: var(--notebook-paper-dark);
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.5);
  }

  .notebook__paper {
    position: relative;
    min-height: 18rem;
    padding: 1.25rem 1.5rem 2rem calc(var(--notebook-margin) + 1.25rem);
    background-color: var(--notebook-paper);
    background-repeat: repeat-y, no-repeat, no-repeat, no-repeat;
    background-size:
      100% var(--notebook-line),
      1.5px 100%,
      100% 100%,
      100% 100%;
    background-position:
      0 0,
      var(--notebook-margin) 0,
      0 0,
      0 0;
    background-image:
      linear-gradient(
        to bottom,
        transparent calc(var(--notebook-line) - 1px),
        var(--notebook-rule) calc(var(--notebook-line) - 1px),
        var(--notebook-rule) var(--notebook-line)
      ),
      linear-gradient(var(--notebook-margin-line), var(--notebook-margin-line)),
      radial-gradient(ellipse 80% 50% at 15% 0%, var(--notebook-glow-1) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 90% 100%, var(--notebook-glow-2) 0%, transparent 55%);
  }

  [data-theme="dark"] .notebook__paper {
    background-color: var(--notebook-paper-dark);
    --notebook-rule: rgba(174, 148, 143, 0.18);
    --notebook-margin-line: rgba(196, 90, 78, 0.35);
    --notebook-glow-1: rgba(231, 172, 70, 0.04);
    --notebook-glow-2: rgba(141, 158, 136, 0.03);
  }

  .notebook__paper::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.45;
    pointer-events: none;
    mix-blend-mode: multiply;
  }

  [data-theme="dark"] .notebook__paper::after {
    opacity: 0.2;
    mix-blend-mode: soft-light;
  }

  .tasks-tabs {
    display: none;
  }

  .tasks-tabs__btn {
    padding: 0.35rem 0.65rem;
    border: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    color: var(--color-gray);
    font-family: var(--font-basic-title);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .tasks-tabs__btn:hover,
  .tasks-tabs__btn:focus-visible {
    color: var(--color-text);
    outline: none;
  }

  .tasks-tabs__btn.is-active {
    color: var(--color-text);
    border-bottom-color: var(--color-citrine);
  }

  .tasks-page__error {
    position: relative;
    z-index: 1;
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .tasks-list {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
  }

  .tasks-page :global(.notebook-empty) {
    margin: 0;
    padding: var(--notebook-line) 0;
    min-height: calc(var(--notebook-line) * 3);
    font-family: var(--font-display);
    color: var(--color-stone-500);
    line-height: var(--notebook-line);
  }

  .tasks-page :global(.notebook-empty--filter) {
    display: grid;
    gap: 0;
    align-content: center;
    min-height: calc(var(--notebook-line) * 4);
    padding: calc(var(--notebook-line) * 0.5) 0;
  }

  .tasks-page :global(.notebook-empty__title) {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    font-style: normal;
    line-height: var(--notebook-line);
    color: var(--color-stone-700);
  }

  .tasks-page :global(.notebook-empty__hint) {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: normal;
    line-height: var(--notebook-line);
    color: var(--color-stone-500);
  }

  .tasks-page :global(.notebook-entry) {
    position: relative;
    padding: 0.4rem 0.5rem 0.4rem 0.6rem;
    border-radius: 4px;
    border-bottom: none;
    transition: background var(--transition-fast);
  }

  .tasks-page :global(.notebook-entry:hover) {
    background: rgba(231, 172, 70, 0.06);
  }

  /* High-priority tasks get a left accent bar for instant triage. */
  .tasks-page :global(.notebook-entry.is-high)::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.45rem;
    bottom: 0.45rem;
    width: 3px;
    border-radius: 999px;
    background: #c47070;
  }

  .tasks-page :global(.notebook-entry.is-active) {
    border-radius: 4px;
  }

  .tasks-page :global(.notebook-entry.is-active .notebook-entry__title) {
    color: var(--color-stone-800);
  }

  .tasks-page :global(.notebook-entry.is-active .notebook-entry__check) {
    border-color: var(--color-citrine-dark);
    box-shadow: 0 1px 0 rgba(231, 172, 70, 0.2);
  }

  .tasks-page :global(.notebook-entry.is-done) {
    opacity: 0.82;
  }

  .tasks-page :global(.notebook-entry.is-done .notebook-entry__body) {
    background: linear-gradient(
      90deg,
      var(--color-sage-muted) 0%,
      transparent 55%
    );
    border-radius: 2px;
  }

  .tasks-page :global(.notebook-entry + .notebook-entry) {
    margin-top: 0.15rem;
    border-top: 1px solid var(--notebook-rule);
  }

  .tasks-page :global(.notebook-entry__row) {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    min-height: var(--notebook-line);
    line-height: var(--notebook-line);
  }

  .tasks-page :global(.notebook-entry__check) {
    flex-shrink: 0;
    width: 1.15rem;
    height: 1.15rem;
    margin-top: calc((var(--notebook-line) - 1.15rem) / 2);
    border: 1.5px solid var(--color-dusty-rose);
    border-radius: 3px 4px 3px 2px;
    background: transparent;
    position: relative;
    transform: rotate(-1.5deg);
    transition: border-color 0.2s ease;
  }

  .tasks-page :global(.notebook-entry.is-done .notebook-entry__check) {
    border-color: var(--color-sage);
    background: rgba(141, 158, 136, 0.12);
  }

  .tasks-page :global(.notebook-entry.is-done .notebook-entry__check::after) {
    content: "";
    position: absolute;
    left: 0.22rem;
    top: 0.05rem;
    width: 0.45rem;
    height: 0.7rem;
    border: solid 2px var(--color-sage);
    border-width: 0 2px 2px 0;
    transform: rotate(38deg);
  }

  .tasks-page :global(.notebook-entry.is-high .notebook-entry__check) {
    border-color: #c47070;
  }

  .tasks-page :global(.notebook-entry__body) {
    flex: 1;
    min-width: 0;
    padding-bottom: calc(var(--notebook-line) * 0.1);
  }

  .tasks-page :global(.notebook-entry__main) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.6rem;
    min-height: var(--notebook-line);
  }

  .tasks-page :global(.notebook-entry__title) {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    line-height: var(--notebook-line);
    letter-spacing: 0.01em;
  }

  .tasks-page :global(.notebook-entry.is-done .notebook-entry__title) {
    text-decoration: line-through;
    text-decoration-color: var(--color-sage);
    text-decoration-thickness: 1px;
    color: var(--color-stone-500);
  }

  .tasks-page :global(.notebook-entry.is-low .notebook-entry__title) {
    color: var(--color-stone-500);
  }

  .tasks-page :global(.notebook-entry__tags) {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    line-height: 1;
  }

  /* Priority + status read as compact chips, not body copy. */
  .tasks-page :global(.task-badge) {
    display: inline-flex;
    align-items: center;
    padding: 0.05rem 0.45rem;
    border: 1px solid transparent;
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    font-style: normal;
    line-height: 1.5;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--color-stone-500);
    background: var(--color-stone-100);
  }

  .tasks-page :global(.task-badge--high) {
    color: #8f2a2a;
    background: rgba(196, 90, 78, 0.14);
    border-color: rgba(196, 90, 78, 0.35);
  }

  .tasks-page :global(.task-badge--high::before) {
    content: "★";
    margin-right: 0.25rem;
  }

  .tasks-page :global(.task-badge--low) {
    color: var(--color-stone-500);
    background: transparent;
    border-color: var(--color-stone-200);
  }

  .tasks-page :global(.task-badge--open) {
    color: #4f6b4a;
    background: rgba(141, 158, 136, 0.18);
    border-color: rgba(141, 158, 136, 0.4);
  }

  .tasks-page :global(.task-badge--claimed) {
    color: var(--color-stone-600, var(--color-stone-500));
    background: var(--color-stone-100);
    border-color: var(--color-stone-200);
  }

  .tasks-page :global(.task-badge--done) {
    color: #4f6b4a;
    background: rgba(141, 158, 136, 0.14);
    border-color: rgba(141, 158, 136, 0.3);
  }

  .tasks-page :global(.task-badge--muted) {
    opacity: 0.7;
  }

  /* Due date is a first-class, colour-coded chip so overdue/soon pop. */
  .tasks-page :global(.task-due) {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.05rem 0.5rem;
    border: 1px solid var(--color-stone-200);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.64rem;
    font-weight: 600;
    line-height: 1.5;
    letter-spacing: 0.02em;
    white-space: nowrap;
    color: var(--color-stone-600, var(--color-stone-500));
    background: var(--color-bg);
  }

  .tasks-page :global(.task-due::before) {
    content: "◷";
    font-size: 0.72rem;
    line-height: 1;
  }

  .tasks-page :global(.task-due--soon) {
    color: #8a6314;
    background: rgba(231, 172, 70, 0.16);
    border-color: var(--color-citrine);
  }

  .tasks-page :global(.task-due--overdue) {
    color: #8f2a2a;
    background: rgba(196, 90, 78, 0.16);
    border-color: rgba(196, 90, 78, 0.5);
  }

  .tasks-page :global(.task-due--overdue::before) {
    content: "⚠";
  }

  .tasks-page :global(.notebook-entry__description) {
    margin: 0.1rem 0 0;
    padding-left: 0.05rem;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: normal;
    line-height: 1.5;
    color: var(--color-stone-600, var(--color-stone-500));
  }

  .tasks-page :global(.notebook-entry__meta) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.15rem 0.6rem;
    margin-top: 0.25rem;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    line-height: 1.5;
    color: var(--color-stone-500);
  }

  .tasks-page :global(.notebook-entry__meta span:not(:first-child)::before) {
    content: "·";
    margin-right: 0.6rem;
    opacity: 0.65;
  }

  .tasks-page :global(.notebook-entry__actions) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.5rem;
    margin-top: 0.55rem;
    padding-bottom: 0.15rem;
  }

  /* Push destructive Cancel to the far right, away from primary actions. */
  .tasks-page :global(.notebook-entry__actions .task-action--danger) {
    margin-left: auto;
  }

  .tasks-page :global(.task-action) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.42rem 0.85rem;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    line-height: 1;
    cursor: pointer;
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      color var(--transition-fast);
  }

  /* Primary = citrine (CLAIM / COMPLETE) — the fast, forward action. */
  .tasks-page :global(.task-action--primary) {
    background: var(--color-citrine);
    border-color: var(--color-citrine);
    color: var(--color-black);
  }

  .tasks-page :global(.task-action--primary:hover),
  .tasks-page :global(.task-action--primary:focus-visible) {
    background: var(--color-citrine-hover);
    border-color: var(--color-citrine-hover);
    outline: none;
    box-shadow: var(--shadow-sm), 0 0 0 3px var(--color-focus-ring);
  }

  /* Ghost = neutral outline (EDIT) — available but recessive. */
  .tasks-page :global(.task-action--ghost) {
    background: var(--color-bg);
    border-color: var(--color-stone-300);
    color: var(--color-stone-700);
  }

  .tasks-page :global(.task-action--ghost:hover),
  .tasks-page :global(.task-action--ghost:focus-visible) {
    background: var(--color-stone-50);
    border-color: var(--color-stone-400);
    outline: none;
    box-shadow: 0 0 0 3px var(--color-focus-ring);
  }

  /* Danger = quiet outline that reveals intent on hover (CANCEL). */
  .tasks-page :global(.task-action--danger) {
    background: transparent;
    border-color: var(--color-stone-300);
    color: var(--color-stone-500);
  }

  .tasks-page :global(.task-action--danger:hover),
  .tasks-page :global(.task-action--danger:focus-visible) {
    background: rgba(196, 90, 78, 0.1);
    border-color: rgba(196, 90, 78, 0.55);
