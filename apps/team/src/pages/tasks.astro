---
import TeamLayout from "../layouts/TeamLayout.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";

const { supabase, staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

const managerView = isSalonManager(staff);

const { data: staffRows } = await supabase
  .from("staff")
  .select("id, name")
  .order("name");

const staffOptions = staffRows ?? [];
---

<TeamLayout title="Tasks" activeNav="tasks">
  <div
    class="tasks-page"
    data-tasks-app
    data-api-base={teamUrl("/api/tasks")}
    data-manager={managerView ? "1" : "0"}
    data-current-staff-id={staff.id}
  >
    <header class="tasks-page__header">
      <div>
        <h1 class="tasks-page__title">Tasks</h1>
        <p class="tasks-page__subtitle">Team to-dos &amp; salon checklists</p>
      </div>
      {
        managerView ? (
          <button class="tasks-page__create" type="button" data-task-create>
            + New entry
          </button>
        ) : null
      }
    </header>

    <div class="notebook" aria-label="Task notebook">
      <div class="notebook__binding" aria-hidden="true">
        <span class="notebook__hole"></span>
        <span class="notebook__hole"></span>
        <span class="notebook__hole"></span>
      </div>

      <div class="notebook__paper">
        <div class="tasks-tabs" role="tablist" aria-label="Task views">
          <button class="tasks-tabs__btn is-active" type="button" role="tab" data-view="my" aria-selected="true">
            My tasks
          </button>
          <button class="tasks-tabs__btn" type="button" role="tab" data-view="available" aria-selected="false">
            Available
          </button>
          <button class="tasks-tabs__btn" type="button" role="tab" data-view="completed" aria-selected="false">
            Completed
          </button>
          {
            managerView ? (
              <button class="tasks-tabs__btn" type="button" role="tab" data-view="all" aria-selected="false">
                All
              </button>
            ) : null
          }
        </div>

        <p class="notice notice--error tasks-page__error" data-tasks-error hidden role="alert"></p>

        <div class="tasks-list" data-tasks-list aria-live="polite">
          <p class="notebook-empty">Loading tasks…</p>
        </div>
      </div>
    </div>
  </div>

  <dialog class="tasks-modal" data-task-modal aria-labelledby="task-modal-title">
    <form class="tasks-modal__form" method="dialog" data-task-form>
      <header class="tasks-modal__header">
        <h2 id="task-modal-title" data-task-modal-title>New task</h2>
        <button class="tasks-modal__close" type="button" data-task-modal-close aria-label="Close">
          ×
        </button>
      </header>

      <div class="form-stack">
        <label class="form-label">
          Title
          <input class="form-input" name="title" type="text" maxlength="200" required />
        </label>

        <label class="form-label">
          Description (optional)
          <textarea class="form-input" name="description" rows="3" maxlength="2000"></textarea>
        </label>

        <label class="form-label">
          Due date (optional)
          <input class="form-input" name="due_at" type="datetime-local" />
        </label>

        <label class="form-label">
          Priority
          <select class="form-input" name="priority">
            <option value="low">Low</option>
            <option value="normal" selected>Normal</option>
            <option value="high">High</option>
          </select>
        </label>

        <fieldset class="tasks-modal__fieldset">
          <legend class="label-meta">Assignment</legend>
          <label class="tasks-modal__radio">
            <input type="radio" name="assignment_type" value="open" checked />
            Anyone can claim
          </label>
          <label class="tasks-modal__radio">
            <input type="radio" name="assignment_type" value="assigned" />
            Assign to team member(s)
          </label>
        </fieldset>

        <div class="tasks-modal__assignees" data-assignee-picker hidden>
          <span class="label-meta">Team members</span>
          <div class="tasks-modal__staff-list">
            {
              staffOptions.map((member) => (
                <label class="tasks-modal__staff-option">
                  <input type="checkbox" name="assignee_ids" value={member.id} />
                  <span>{member.name}</span>
                </label>
              ))
            }
          </div>
        </div>
      </div>

      <footer class="tasks-modal__footer">
        <button class="btn-secondary" type="button" data-task-modal-close>Cancel</button>
        <button class="btn-primary" type="submit" data-task-submit>Save task</button>
      </footer>
    </form>
  </dialog>

  <dialog class="tasks-modal tasks-modal--narrow" data-complete-modal aria-labelledby="complete-modal-title">
    <form class="tasks-modal__form" method="dialog" data-complete-form>
      <header class="tasks-modal__header">
        <h2 id="complete-modal-title">Mark complete</h2>
        <button class="tasks-modal__close" type="button" data-complete-modal-close aria-label="Close">
          ×
        </button>
      </header>

      <p class="tasks-modal__lead" data-complete-task-title></p>

      <label class="form-label">
        Completion notes (optional)
        <textarea class="form-input" name="completion_notes" rows="3" maxlength="1000"></textarea>
      </label>

      <footer class="tasks-modal__footer">
        <button class="btn-secondary" type="button" data-complete-modal-close>Cancel</button>
        <button class="btn-primary" type="submit">Mark done</button>
      </footer>
    </form>
  </dialog>
</TeamLayout>

<script src="../scripts/tasks.ts"></script>

<style>
  .tasks-page {
    --notebook-line: 2.25rem;
    --notebook-margin: 2.75rem;
    --notebook-paper: #fdfaf4;
    --notebook-paper-dark: #1e1c19;
    --notebook-rule: rgba(174, 148, 143, 0.32);
    --notebook-margin-line: rgba(196, 90, 78, 0.42);
  }

  .tasks-page__header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .tasks-page__title {
    margin: 0 0 0.25rem;
    font-family: var(--font-nav);
    font-size: clamp(1.75rem, 4.5vw, 2.25rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.1;
  }

  .tasks-page__subtitle {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-style: italic;
    color: var(--color-gray);
  }

  .tasks-page__create {
    flex-shrink: 0;
    padding: 0.55rem 1rem;
    border: 1px solid var(--color-dusty-rose);
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-basic-title);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .tasks-page__create:hover,
  .tasks-page__create:focus-visible {
    background: var(--color-dusty-rose);
    color: var(--color-on-brand-section);
    outline: none;
  }

  /* Notebook shell */
  .notebook {
    position: relative;
    filter: drop-shadow(0 6px 24px var(--color-card-shadow));
  }

  .notebook__binding {
    display: flex;
    justify-content: center;
    gap: clamp(2.5rem, 12vw, 5rem);
    padding: 0.65rem 1rem 0;
    background: linear-gradient(
      180deg,
      var(--color-cream-deep) 0%,
      var(--color-dusty-rose) 100%
    );
    border-radius: 6px 6px 0 0;
    border: 1px solid var(--color-border);
    border-bottom: none;
  }

  .notebook__hole {
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 50%;
    background: var(--color-cream);
    box-shadow:
      inset 0 1px 3px rgba(0, 0, 0, 0.18),
      0 1px 0 rgba(255, 255, 255, 0.35);
  }

  [data-theme="dark"] .notebook__hole {
    background: var(--color-bg);
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.45);
  }

  .notebook__paper {
    position: relative;
    min-height: 18rem;
    padding: 1.25rem 1.5rem 2rem calc(var(--notebook-margin) + 1.25rem);
    background-color: var(--notebook-paper);
    background-image:
      repeating-linear-gradient(
        transparent,
        transparent calc(var(--notebook-line) - 1px),
        var(--notebook-rule) calc(var(--notebook-line) - 1px),
        var(--notebook-rule) var(--notebook-line)
      ),
      radial-gradient(ellipse 80% 50% at 15% 0%, rgba(231, 172, 70, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 90% 100%, rgba(141, 158, 136, 0.05) 0%, transparent 55%);
    border: 1px solid var(--color-border);
    border-top: none;
    border-radius: 0 0 4px 4px;
  }

  [data-theme="dark"] .notebook__paper {
    background-color: var(--notebook-paper-dark);
    --notebook-rule: rgba(174, 148, 143, 0.18);
    --notebook-margin-line: rgba(196, 90, 78, 0.35);
    background-image:
      repeating-linear-gradient(
        transparent,
        transparent calc(var(--notebook-line) - 1px),
        var(--notebook-rule) calc(var(--notebook-line) - 1px),
        var(--notebook-rule) var(--notebook-line)
      ),
      radial-gradient(ellipse 80% 50% at 15% 0%, rgba(231, 172, 70, 0.04) 0%, transparent 60%);
  }

  .notebook__paper::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--notebook-margin);
    width: 1.5px;
    background: var(--notebook-margin-line);
    pointer-events: none;
  }

  .notebook__paper::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.45;
    pointer-events: none;
    mix-blend-mode: multiply;
  }

  [data-theme="dark"] .notebook__paper::after {
    opacity: 0.2;
    mix-blend-mode: soft-light;
  }

  .tasks-tabs {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: calc(var(--notebook-line) * 0.5);
    padding-bottom: 0.5rem;
  }

  .tasks-tabs__btn {
    padding: 0.35rem 0.65rem;
    border: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    color: var(--color-gray);
    font-family: var(--font-basic-title);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .tasks-tabs__btn:hover,
  .tasks-tabs__btn:focus-visible {
    color: var(--color-text);
    outline: none;
  }

  .tasks-tabs__btn.is-active {
    color: var(--color-text);
    border-bottom-color: var(--color-citrine);
  }

  .tasks-page__error {
    position: relative;
    z-index: 1;
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .tasks-list {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
  }

  .notebook-empty {
    margin: 0;
    padding: var(--notebook-line) 0;
    min-height: var(--notebook-line);
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-gray);
    line-height: var(--notebook-line);
  }

  /* Task rows — aligned to ruled lines */
  .notebook-entry {
    position: relative;
    border-bottom: none;
  }

  .notebook-entry + .notebook-entry {
    margin-top: calc(var(--notebook-line) * 0.15);
  }

  .notebook-entry__row {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    min-height: var(--notebook-line);
    line-height: var(--notebook-line);
  }

  .notebook-entry__check {
    flex-shrink: 0;
    width: 1.15rem;
    height: 1.15rem;
    margin-top: calc((var(--notebook-line) - 1.15rem) / 2);
    border: 1.5px solid var(--color-dusty-rose);
    border-radius: 3px 4px 3px 2px;
    background: transparent;
    position: relative;
    transform: rotate(-1.5deg);
    transition: border-color 0.2s ease;
  }

  .notebook-entry.is-done .notebook-entry__check {
    border-color: var(--color-sage);
    background: rgba(141, 158, 136, 0.12);
  }

  .notebook-entry.is-done .notebook-entry__check::after {
    content: "";
    position: absolute;
    left: 0.22rem;
    top: 0.05rem;
    width: 0.45rem;
    height: 0.7rem;
    border: solid 2px var(--color-sage);
    border-width: 0 2px 2px 0;
    transform: rotate(38deg);
  }

  .notebook-entry.is-high .notebook-entry__check {
    border-color: #c47070;
  }

  .notebook-entry__body {
    flex: 1;
    min-width: 0;
    padding-bottom: calc(var(--notebook-line) * 0.1);
  }

  .notebook-entry__main {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 0.75rem;
    min-height: var(--notebook-line);
  }

  .notebook-entry__title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 500;
    line-height: var(--notebook-line);
    letter-spacing: 0.01em;
  }

  .notebook-entry.is-done .notebook-entry__title {
    text-decoration: line-through;
    text-decoration-color: var(--color-dusty-rose);
    text-decoration-thickness: 1px;
    color: var(--color-gray);
  }

  .notebook-entry.is-low .notebook-entry__title {
    color: var(--color-gray);
  }

  .notebook-entry__tags {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    line-height: 1;
  }

  .task-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.1rem 0.35rem;
    font-family: var(--font-serif);
    font-size: 0.72rem;
    font-style: italic;
    letter-spacing: 0.02em;
    color: var(--color-gray);
  }

  .task-badge--high {
    color: #922;
    font-style: normal;
    font-weight: 600;
  }

  .task-badge--high::before {
    content: "★ ";
  }

  .task-badge--low {
    opacity: 0.7;
  }

  .task-badge--open {
    color: var(--color-sage);
    font-style: normal;
  }

  .notebook-entry__description {
    margin: 0;
    padding-left: 0.15rem;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-style: italic;
    line-height: var(--notebook-line);
    color: var(--color-gray);
  }

  .notebook-entry__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    min-height: var(--notebook-line);
    font-family: var(--font-serif);
    font-size: 0.82rem;
    line-height: var(--notebook-line);
    color: var(--color-gray);
  }

  .notebook-entry__meta span::before {
    content: "— ";
    opacity: 0.5;
  }

  .notebook-entry__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    padding: calc(var(--notebook-line) * 0.15) 0 calc(var(--notebook-line) * 0.25);
  }

  .notebook-entry__actions .btn-primary,
  .notebook-entry__actions .btn-secondary {
    padding: 0.4rem 0.65rem;
    font-size: 0.68rem;
  }

  .notebook-entry__actions .btn-primary {
    background: var(--color-dusty-rose);
    color: var(--color-on-brand-section);
  }

  .notebook-entry__actions .btn-primary:hover,
  .notebook-entry__actions .btn-primary:focus-visible {
    background: var(--color-charcoal);
  }

  .notebook-entry__actions .btn-secondary {
    border-color: var(--color-dusty-rose);
    font-family: var(--font-serif);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    text-transform: none;
  }

  @media (min-width: 48rem) {
    .notebook__paper {
      padding-right: 2.5rem;
    }

    .notebook-entry__main {
      flex-wrap: nowrap;
    }

    .notebook-entry__tags {
      margin-left: auto;
    }
  }

  @media (max-width: 36rem) {
    .tasks-page {
      --notebook-margin: 2rem;
    }

    .notebook__paper {
      padding-left: calc(var(--notebook-margin) + 0.85rem);
      padding-right: 1rem;
    }
  }

  .tasks-modal {
    width: min(32rem, calc(100vw - 2rem));
    max-height: calc(100vh - 2rem);
    padding: 0;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    box-shadow: 0 12px 48px var(--color-card-shadow);
  }

  .tasks-modal--narrow {
    width: min(26rem, calc(100vw - 2rem));
  }

  .tasks-modal::backdrop {
    background: rgba(0, 0, 0, 0.35);
  }

  .tasks-modal__form {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    margin: 0;
  }

  .tasks-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .tasks-modal__header h2 {
    margin: 0;
    font-size: 1.15rem;
  }

  .tasks-modal__close {
    border: none;
    background: none;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-gray);
    cursor: pointer;
  }

  .tasks-modal__fieldset {
    margin: 0;
    padding: 0;
    border: none;
    display: grid;
    gap: 0.5rem;
  }

  .tasks-modal__radio {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    text-transform: none;
    letter-spacing: normal;
    cursor: pointer;
  }

  .tasks-modal__assignees {
    display: grid;
    gap: 0.5rem;
  }

  .tasks-modal__staff-list {
    display: grid;
    gap: 0.35rem;
    max-height: 10rem;
    overflow-y: auto;
    padding: 0.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-booking-card-bg);
  }

  .tasks-modal__staff-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.92rem;
    text-transform: none;
    letter-spacing: normal;
    cursor: pointer;
  }

  .tasks-modal__footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
    padding-top: 0.25rem;
  }

  .tasks-modal__lead {
    margin: 0;
    font-size: 0.95rem;
  }
</style>
