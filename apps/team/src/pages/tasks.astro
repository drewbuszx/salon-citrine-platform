---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamListLayout from "../components/TeamListLayout.astro";
import TeamSidebarNav from "../components/TeamSidebarNav.astro";
import UiScrollRow from "../components/ui/UiScrollRow.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";

const { supabase, staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

const managerView = isSalonManager(staff);

const { data: staffRows } = await supabase
  .from("staff")
  .select("id, name")
  .order("name");

const staffOptions = staffRows ?? [];
---

<TeamLayout title="Tasks" activeNav="tasks" plain wide fullBleed>
  <div
    class="tasks-page"
    data-tasks-app
    data-api-base={teamUrl("/api/tasks")}
    data-manager={managerView ? "1" : "0"}
    data-current-staff-id={staff.id}
  >
    <TeamListLayout title="Tasks" sidebarTitle="Views">
      {
        managerView ? (
          <button slot="headerActions" class="team-list-layout__btn-primary" type="button" data-task-create>
            + New entry
          </button>
        ) : null
      }

      <div class="tasks-page__sidebar-nav" data-tasks-nav slot="sidebarFilters">
      <TeamSidebarNav label="Task views">
        <button class="team-list-layout__sidebar-nav-btn is-active" type="button" data-view="my" aria-selected="true">
          <span>Assigned to me</span>
        </button>
        <button class="team-list-layout__sidebar-nav-btn" type="button" data-view="available" aria-selected="false">
          <span>For everyone</span>
        </button>
        <button
          class="team-list-layout__sidebar-nav-btn"
          type="button"
          data-view="attention"
          aria-selected="false"
          title="Active tasks already overdue or due within 24 hours"
        >
          <span>Needs attention</span>
          <span
            class="team-list-layout__sidebar-badge team-list-layout__sidebar-badge--attention"
            data-attention-badge
            hidden
            aria-label="Tasks needing attention"
          >0</span>
        </button>
        <button class="team-list-layout__sidebar-nav-btn" type="button" data-view="completed" aria-selected="false">
          <span>Completed</span>
        </button>
        {
          managerView ? (
            <button class="team-list-layout__sidebar-nav-btn" type="button" data-view="all" aria-selected="false">
              <span>All active</span>
            </button>
          ) : null
        }
      </TeamSidebarNav>
      </div>

      <Fragment slot="mainLead">Team to-dos and salon checklists.</Fragment>

      <div class="tasks-tabs" data-tasks-nav>
        <UiScrollRow label="Task views">
          <button class="tasks-tabs__btn is-active" type="button" data-view="my" aria-selected="true">
            <span class="tasks-tabs__long">Assigned to me</span>
            <span class="tasks-tabs__short">Mine</span>
          </button>
          <button class="tasks-tabs__btn" type="button" data-view="available" aria-selected="false">
            <span class="tasks-tabs__long">For everyone</span>
            <span class="tasks-tabs__short">Open</span>
          </button>
          <button
            class="tasks-tabs__btn"
            type="button"
            data-view="attention"
            aria-selected="false"
            title="Active tasks already overdue or due within 24 hours"
          >
            <span class="tasks-tabs__long">Needs attention</span>
            <span class="tasks-tabs__short">Urgent</span>
            <span
              class="tasks-tabs__badge"
              data-attention-badge
              hidden
              aria-label="Tasks needing attention"
            >0</span>
          </button>
          <button class="tasks-tabs__btn" type="button" data-view="completed" aria-selected="false">
            <span class="tasks-tabs__long">Completed</span>
            <span class="tasks-tabs__short">Done</span>
          </button>
          {
            managerView ? (
              <button class="tasks-tabs__btn" type="button" data-view="all" aria-selected="false">
                <span class="tasks-tabs__long">All active</span>
                <span class="tasks-tabs__short">All</span>
              </button>
            ) : null
          }
        </UiScrollRow>
      </div>

      <div class="notebook" aria-label="Task notebook">
        <div class="notebook__binding" aria-hidden="true">
          <span class="notebook__hole"></span>
          <span class="notebook__hole"></span>
          <span class="notebook__hole"></span>
        </div>

        <div class="notebook__paper">
          <p class="notice notice--error tasks-page__error" data-tasks-error hidden role="alert"></p>

          <div class="tasks-list" data-tasks-list aria-live="polite">
            <p class="notebook-empty">Loading tasks…</p>
          </div>
        </div>
      </div>
    </TeamListLayout>
  </div>

  <dialog class="tasks-modal" data-task-modal aria-labelledby="task-modal-title">
    <form class="tasks-modal__form" method="dialog" data-task-form>
      <header class="tasks-modal__header">
        <h2 id="task-modal-title" data-task-modal-title>New entry</h2>
        <button class="tasks-modal__close" type="button" data-task-modal-close aria-label="Close">
          ×
        </button>
      </header>

      <div class="form-stack">
        <label class="form-label">
          Title
          <input
            class="form-input"
            name="title"
            type="text"
            maxlength="200"
            required
            placeholder="e.g. Restock towels at the color station"
          />
        </label>

        <label class="form-label">
          Description (optional)
          <textarea
            class="form-input"
            name="description"
            rows="3"
            maxlength="2000"
            placeholder="What done looks like — where, how many, anything to watch for"></textarea>
        </label>

        <label class="form-label">
          Due date (optional)
          <input class="form-input" name="due_at" type="datetime-local" />
          <span class="tasks-modal__hint">Salon time (Indianapolis). Due or overdue within 24 hours lands in Needs attention.</span>
        </label>

        <label class="form-label">
          Priority
          <select class="form-input" name="priority">
            <option value="low">Low — when there's a lull</option>
            <option value="normal" selected>Normal — today's flow</option>
            <option value="high">High — before it affects clients</option>
          </select>
        </label>

        <fieldset class="tasks-modal__fieldset">
          <legend class="label-meta">Assignment</legend>
          <label class="tasks-modal__radio">
            <input type="radio" name="assignment_type" value="open" checked />
            <span>Open to team — shows in <strong>For everyone</strong>, first to claim it owns it</span>
          </label>
          <label class="tasks-modal__radio">
            <input type="radio" name="assignment_type" value="assigned" />
            <span>Assign to specific team member(s)</span>
          </label>
        </fieldset>

        <div class="tasks-modal__assignees" data-assignee-picker hidden>
          <span class="label-meta">Team members</span>
          <div class="tasks-modal__staff-list">
            {
              staffOptions.map((member) => (
                <label class="tasks-modal__staff-option">
                  <input type="checkbox" name="assignee_ids" value={member.id} />
                  <span>{member.name}</span>
                </label>
              ))
            }
          </div>
        </div>
      </div>

      <footer class="tasks-modal__footer">
        <button class="team-list-layout__btn-secondary" type="button" data-task-modal-close>Discard</button>
        <button class="team-list-layout__btn-primary" type="submit" data-task-submit>Save entry</button>
      </footer>
    </form>
  </dialog>

  <dialog class="tasks-modal tasks-modal--narrow" data-complete-modal aria-labelledby="complete-modal-title">
    <form class="tasks-modal__form" method="dialog" data-complete-form>
      <header class="tasks-modal__header">
        <h2 id="complete-modal-title">Mark complete</h2>
        <button class="tasks-modal__close" type="button" data-complete-modal-close aria-label="Close">
          ×
        </button>
      </header>

      <div class="form-stack">
        <p class="tasks-modal__lead" data-complete-task-title></p>
        <p class="tasks-modal__hint">
          This records you as the one who finished it, with the time, under Completed.
        </p>

        <label class="form-label">
          Completion notes (optional)
          <textarea
            class="form-input"
            name="completion_notes"
            rows="3"
            maxlength="1000"
            placeholder="e.g. Used the last case — added towels to the supply order"></textarea>
        </label>
      </div>

      <footer class="tasks-modal__footer">
        <button class="team-list-layout__btn-secondary" type="button" data-complete-modal-close>Not yet</button>
        <button class="team-list-layout__btn-primary" type="submit">Mark done</button>
      </footer>
    </form>
  </dialog>
</TeamLayout>

<script src="../scripts/tasks.ts"></script>

<style>
  .tasks-page {
    --notebook-line: clamp(2rem, 1.7rem + 0.6vw, 2.25rem);
    --notebook-margin: clamp(2.25rem, 1.9rem + 1vw, 2.75rem);
    --notebook-paper: #fdfaf4;
    --notebook-paper-dark: #1e1c19;
    --notebook-rule: rgba(174, 148, 143, 0.32);
    --notebook-margin-line: rgba(196, 90, 78, 0.42);
    --notebook-glow-1: rgba(231, 172, 70, 0.06);
    --notebook-glow-2: rgba(141, 158, 136, 0.05);
    /*
      Sketch palette (final rendered alpha = this shared opacity × each
      path's own opacity attribute, since background layers can't be
      dimmed individually): warm grey-brown #8a7f72 pencil linework reads
      at ~0.09, dusty-rose #c4a5a5 stardust at ~0.08, citrine #c9a227
      facet hints at ~0.06 — all inside the 0.05–0.12 discipline.
    */
    --notebook-sketch-opacity: 0.09;
    --notebook-sketch-moon: url("data:image/svg+xml,%3Csvg viewBox='0 0 48 48' xmlns='http://www.w3.org/2000/svg' fill='none'%3E%3Cpath d='M30 7c-10 1-17 10-17 19 0 9 7 16 16 17-7-4-10-10-10-17 0-8 5-15 11-19z' stroke='%238a7f72' stroke-width='1.15' stroke-linecap='round' stroke-linejoin='round'/%3E%3Ccircle cx='35' cy='11' r='0.9' fill='%23c9a227' opacity='0.67'/%3E%3C/svg%3E");
    --notebook-sketch-moon-sm: url("data:image/svg+xml,%3Csvg viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg' fill='none'%3E%3Cpath d='M26 6c-8 1-13 8-13 15 0 7 5 13 12 14-6-3-8-8-8-14 0-6 4-11 9-15z' stroke='%238a7f72' stroke-width='1' stroke-linecap='round'/%3E%3Ccircle cx='31' cy='9' r='0.7' fill='%23c9a227' opacity='0.6'/%3E%3C/svg%3E");
    --notebook-sketch-crystal: url("data:image/svg+xml,%3Csvg viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg' fill='none'%3E%3Cpath d='M40 6l10 24-10 44-10-44z' stroke='%238a7f72' stroke-width='1.05' stroke-linejoin='round'/%3E%3Cpath d='M24 34l8-12 8 16 8-12 8 8' stroke='%23c9a227' stroke-width='0.9' stroke-linecap='round' stroke-linejoin='round' opacity='0.67'/%3E%3Cpath d='M18 54l10-10 12 14 10-10 12 10' stroke='%23c9a227' stroke-width='0.85' stroke-linecap='round' stroke-linejoin='round' opacity='0.5'/%3E%3Cpath d='M34 22l6 8-6 8-6-8z' stroke='%23c4a5a5' stroke-width='0.75' opacity='0.89'/%3E%3C/svg%3E");
    --notebook-sketch-stars: url("data:image/svg+xml,%3Csvg viewBox='0 0 28 56' xmlns='http://www.w3.org/2000/svg' fill='none'%3E%3Cpath d='M9 10l.6 1.8 1.8.6-1.8.6-.6 1.8-.6-1.8-1.8-.6 1.8-.6z' stroke='%23c4a5a5' stroke-width='0.55' stroke-linejoin='round' opacity='0.89'/%3E%3Cpath d='M17 30l.5 1.5 1.5.5-1.5.5-.5 1.5-.5-1.5-1.5-.5 1.5-.5z' stroke='%23c4a5a5' stroke-width='0.5' stroke-linejoin='round' opacity='0.6'/%3E%3Ccircle cx='11' cy='46' r='0.75' fill='%238a7f72' opacity='1'/%3E%3Cpath d='M20 48l.4 1.2 1.2.4-1.2.4-.4 1.2-.4-1.2-1.2-.4 1.2-.4z' stroke='%23c9a227' stroke-width='0.45' opacity='0.67'/%3E%3C/svg%3E");
    --notebook-sketch-herb: url("data:image/svg+xml,%3Csvg viewBox='0 0 60 100' xmlns='http://www.w3.org/2000/svg' fill='none'%3E%3Cpath d='M30 94c-1-20 2-38-1-58-1.3-8 .5-16 3-24' stroke='%238a7f72' stroke-width='1' stroke-linecap='round'/%3E%3Cpath d='M29 70c-6-2-11 1-14 6 5-1 10-3 14-6z' stroke='%238a7f72' stroke-width='0.9' stroke-linejoin='round'/%3E%3Cpath d='M30 68c6-3 11 0 14 5-5-1-10-2-14-5z' stroke='%238a7f72' stroke-width='0.9' stroke-linejoin='round'/%3E%3Cpath d='M27 46c-6-2-10 1-13 6 5-1 9-3 13-6z' stroke='%238a7f72' stroke-width='0.85' stroke-linejoin='round'/%3E%3Cpath d='M28 44c5-3 10 0 13 5-5-1-9-2-13-5z' stroke='%238a7f72' stroke-width='0.85' stroke-linejoin='round'/%3E%3Cpath d='M26 24c-5-2-9 1-11 5 4-1 8-2 11-5z' stroke='%238a7f72' stroke-width='0.75' stroke-linejoin='round'/%3E%3Cpath d='M27 22c4-3 8 0 11 4-4-1-8-1-11-4z' stroke='%238a7f72' stroke-width='0.75' stroke-linejoin='round'/%3E%3Ccircle cx='31' cy='6' r='1.4' fill='%238a7f72' opacity='0.9'/%3E%3Ccircle cx='27' cy='9' r='1.1' fill='%238a7f72' opacity='0.7'/%3E%3Ccircle cx='34' cy='9' r='1.1' fill='%238a7f72' opacity='0.7'/%3E%3C/svg%3E");
  }

  /*
    One sheet of paper for the whole list. The paper grows vertically with the
    task list — its bottom edge only appears after the final task. Centered and
    constrained to a natural page proportion so it never spans the full viewport.
  */
  .notebook {
    position: relative;
    display: flex;
    flex-direction: column;
    max-width: 52rem;
    margin: clamp(0.75rem, 0.4rem + 1vw, 1.5rem) auto 0;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 6px 24px var(--color-card-shadow);
  }

  .notebook__binding {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(2.5rem, 12vw, 5rem);
    height: 1.35rem;
    padding: 0 1rem;
    background: var(--color-cream-deep);
    box-shadow: inset 0 -3px 5px -2px rgba(60, 45, 40, 0.12);
  }

  .notebook__hole {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--notebook-paper);
    box-shadow:
      inset 0 1px 2px rgba(0, 0, 0, 0.22),
      0 1px 0 rgba(255, 255, 255, 0.4);
  }

  [data-theme="dark"] .notebook__hole {
    background: var(--notebook-paper-dark);
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.5);
  }

  /*
    The ONE paper layer for the whole list: base cream, horizontal ruled lines
    on the --notebook-line grid, and a single red margin line. No stacked raster
    textures — task rows sit transparently on top of this single surface.
  */
  .notebook__paper {
    position: relative;
    flex: 1 1 auto;
    min-height: 16rem;
    padding:
      calc(var(--notebook-line) * 1.15)
      2rem
      calc(var(--notebook-line) * 0.75)
      calc(var(--notebook-margin) + 1.75rem);
    background-color: var(--notebook-paper);
    background-repeat: repeat-y, no-repeat;
    background-size: 100% var(--notebook-line), 1.5px 100%;
    background-position: 0 0, var(--notebook-margin) 0;
    background-image:
      linear-gradient(
        to bottom,
        transparent calc(var(--notebook-line) - 1px),
        var(--notebook-rule) calc(var(--notebook-line) - 1px),
        var(--notebook-rule) var(--notebook-line)
      ),
      linear-gradient(var(--notebook-margin-line), var(--notebook-margin-line));
    isolation: isolate;
  }

  /*
    The single decorative layer — sketch motifs live only on the paper
    container, never on individual task rows. Corner/margin-anchored (no
    full-cover tiling) so nothing bands or reads as a second stacked sheet.
  */
  .notebook__paper::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: var(--notebook-sketch-opacity);
    background-repeat: no-repeat;
    background-size:
      3.25rem 3.25rem,
      5.5rem 5.5rem,
      3.75rem 6.25rem,
      1.75rem 3.5rem;
    background-position:
      calc(var(--notebook-margin) * 0.5) 0.75rem,
      right 0.85rem bottom 1rem,
      left 0.2rem bottom 0.75rem,
      right 0.6rem top 2.5rem;
    background-image:
      var(--notebook-sketch-moon),
      var(--notebook-sketch-crystal),
      var(--notebook-sketch-herb),
      var(--notebook-sketch-stars);
  }

  [data-theme="dark"] .notebook__paper {
    background-color: var(--notebook-paper-dark);
    --notebook-rule: rgba(90, 78, 68, 0.24);
    --notebook-margin-line: rgba(160, 72, 62, 0.44);
    --notebook-sketch-opacity: 0.08;
  }

  /*
    Dark shell + cream paper island: global stone tokens invert for the dark
    chrome, but ink on paper must stay dark. Scoped paper palette keeps the
    notebook aesthetic without pale-gold / light-gray-on-cream contrast fails.
  */
  [data-theme="dark"] .tasks-page {
    --notebook-paper-dark: #e8e0d2;
    --notebook-ink: #2f2a28;
    --notebook-ink-muted: #5c554e;
    --notebook-ink-faint: #787068;
    --notebook-surface: #f3f0ea;
    --notebook-surface-muted: #f3f1ec;
    --notebook-border: #d4cfc4;
    --notebook-border-strong: #a8a093;
  }

  [data-theme="dark"] .tasks-page :global(.notebook-empty),
  [data-theme="dark"] .tasks-page :global(.tasks-loading) {
    color: var(--notebook-ink-faint);
  }

  [data-theme="dark"] .tasks-page :global(.notebook-entry.is-active .notebook-entry__title) {
    color: var(--notebook-ink);
  }

  [data-theme="dark"] .tasks-page :global(.notebook-entry__title) {
    color: var(--notebook-ink);
  }

  [data-theme="dark"] .tasks-page :global(.notebook-entry.is-done .notebook-entry__title) {
    color: var(--notebook-ink-faint);
  }

  [data-theme="dark"] .tasks-page :global(.notebook-entry.is-low .notebook-entry__title) {
    color: var(--notebook-ink-faint);
  }

  [data-theme="dark"] .tasks-page :global(.notebook-entry__description) {
    color: var(--notebook-ink-muted);
  }

  [data-theme="dark"] .tasks-page :global(.notebook-entry__meta) {
    color: var(--notebook-ink-faint);
  }

  [data-theme="dark"] .tasks-page :global(.task-badge) {
    color: var(--notebook-ink-faint);
    background: var(--notebook-surface-muted);
    border-color: var(--notebook-border);
  }

  [data-theme="dark"] .tasks-page :global(.task-badge--high) {
    color: #8f3a32;
    background: rgba(196, 90, 78, 0.14);
    border-color: rgba(196, 90, 78, 0.38);
  }

  [data-theme="dark"] .tasks-page :global(.task-badge--low) {
    color: var(--notebook-ink-faint);
    background: transparent;
    border-color: var(--notebook-border);
  }

  [data-theme="dark"] .tasks-page :global(.task-badge--open) {
    color: #3f5a3a;
    background: rgba(141, 158, 136, 0.2);
    border-color: rgba(141, 158, 136, 0.45);
  }

  [data-theme="dark"] .tasks-page :global(.task-badge--claimed) {
    color: var(--notebook-ink-muted);
    background: var(--notebook-surface-muted);
    border-color: var(--notebook-border);
  }

  [data-theme="dark"] .tasks-page :global(.task-badge--done) {
    color: #3f5a3a;
    background: rgba(141, 158, 136, 0.16);
    border-color: rgba(141, 158, 136, 0.35);
  }

  [data-theme="dark"] .tasks-page :global(.task-due) {
    color: var(--notebook-ink-muted);
    background: var(--notebook-surface);
    border-color: var(--notebook-border);
  }

  [data-theme="dark"] .tasks-page :global(.task-due--soon) {
    color: #7a5610;
    background: rgba(231, 172, 70, 0.2);
    border-color: #c9952e;
  }

  [data-theme="dark"] .tasks-page :global(.task-due--overdue) {
    color: #7a2222;
    background: rgba(196, 90, 78, 0.18);
    border-color: rgba(196, 90, 78, 0.55);
  }

  [data-theme="dark"] .tasks-page :global(.task-action--primary) {
    background: var(--color-citrine);
    border-color: var(--color-citrine);
    color: var(--color-black);
  }

  [data-theme="dark"] .tasks-page :global(.task-action--ghost) {
    background: var(--notebook-surface);
    border-color: var(--notebook-border-strong);
    color: var(--notebook-ink);
  }

  [data-theme="dark"] .tasks-page :global(.task-action--ghost:hover),
  [data-theme="dark"] .tasks-page :global(.task-action--ghost:focus-visible) {
    background: #faf9f7;
    border-color: #787068;
    color: var(--notebook-ink);
  }

  [data-theme="dark"] .tasks-page :global(.task-action--danger) {
    background: transparent;
    border-color: var(--notebook-border-strong);
    color: var(--notebook-ink-muted);
  }

  [data-theme="dark"] .tasks-page :global(.task-action--danger:hover),
  [data-theme="dark"] .tasks-page :global(.task-action--danger:focus-visible) {
    background: rgba(196, 90, 78, 0.12);
    border-color: rgba(196, 90, 78, 0.6);
    color: #7a2222;
  }

  [data-theme="dark"] .tasks-page :global(.tasks-empty .ui-empty__title) {
    color: var(--notebook-ink);
  }

  [data-theme="dark"] .tasks-page :global(.tasks-empty .ui-empty__hint) {
    color: var(--notebook-ink-faint);
  }

  .notebook__paper::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image:
      radial-gradient(ellipse 80% 45% at 12% 0%, var(--notebook-glow-1) 0%, transparent 60%),
      radial-gradient(ellipse 55% 35% at 92% 100%, var(--notebook-glow-2) 0%, transparent 55%);
    opacity: 0.6;
    pointer-events: none;
  }

  [data-theme="dark"] .notebook__paper::after {
    --notebook-glow-1: rgba(231, 172, 70, 0.05);
    --notebook-glow-2: rgba(141, 158, 136, 0.04);
    opacity: 0.4;
  }

  .tasks-tabs {
    display: none;
    max-width: 52rem;
    margin: 0 auto 0.65rem;
    min-width: 0;
  }

  .tasks-tabs__btn {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 0.35rem;
    min-height: 2.25rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-stone-200);
    border-radius: 999px;
    background: var(--color-bg);
