---
import TeamLayout from "../../layouts/TeamLayout.astro";
import TeamManageLayout from "../../components/TeamManageLayout.astro";
import { teamUrl } from "../../lib/supabase-server";
import { isLockedOnGrant } from "../../lib/capabilities";
import { STAFF_ROLE_LABELS } from "../../lib/staff-manage";
import type { StaffRole } from "../../env.d.ts";

const { staff, supabase } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

// Soft deny for non-owners (page still renders an explanation — no silent redirect).
const isOwner = staff.role !== "owner" ? false : true;

const [capsResult, grantsResult] = isOwner
  ? await Promise.all([
      supabase
        .from("capabilities")
        .select("key, label, description, sort_order")
        .order("sort_order"),
      supabase.from("role_capabilities").select("role, capability"),
    ])
  : [{ data: null, error: null }, { data: null, error: null }];

const loadError = Boolean(capsResult.error || grantsResult.error);
const capabilities = (capsResult.data ?? []) as {
  key: string;
  label: string;
  description: string;
}[];
const grantSet = new Set(
  (grantsResult.data ?? []).map((g) => `${g.role}:${g.capability}`),
);
const roles: StaffRole[] = ["owner", "stylist", "esthetician", "front_desk"];
const apiBase = teamUrl("/api/staff/capabilities");

const CAP_HELP: Record<string, string> = {
  manage_team:
    "Invite employees, edit profiles, and change login access. Owners always keep this.",
  view_activity: "Open the Activity Log of invites, role changes, and access actions.",
};
---

<TeamLayout title="Roles & permissions" activeNav="manage" plain wide fullBleed>
  <TeamManageLayout
    title="Roles & permissions"
    contextSubtitle="Control who can manage the team and view activity."
    activeSection="roles"
    managerView
  >
    <a slot="headerActions" class="team-list-layout__btn-secondary" href={teamUrl("/manage")}>&larr; Manage</a>

    {
      !isOwner ? (
        <div class="manage-roles__denied" role="status">
          <h2 class="manage-roles__denied-title">Owner access only</h2>
          <p class="manage-roles__denied-copy">
            Role permissions can only be changed by an owner. You can still manage day-to-day
            employee profiles from Employees if you have Manage team access.
          </p>
          <a class="ui-btn ui-btn--secondary" href={teamUrl("/manage/employees")}>Go to Employees</a>
        </div>
      ) : (
        <>
          <p class="manage-page__lead">
            <strong>Manage team</strong> covers invites and employee access.
            <strong> View activity</strong> covers the Activity Log. Changes apply immediately
            and are enforced by the database. Owners always keep Manage team.
          </p>

          {
            loadError ? (
              <p class="notice notice--error" role="alert">
                Failed to load permissions. Refresh the page or try again shortly.
              </p>
            ) : capabilities.length === 0 ? (
              <p class="empty-state">
                No capabilities are defined yet. Ask a developer to seed role permissions.
              </p>
            ) : (
              <section class="manage-roles" data-manage-roles data-api-base={apiBase}>
                <p class="notice notice--success" data-roles-success hidden role="status">Saved.</p>
                <p class="notice notice--error" data-roles-error hidden role="alert"></p>

                <div class="manage-roles__list">
                  {capabilities.map((cap) => (
                    <article class="manage-roles__cap">
                      <div class="manage-roles__cap-head">
                        <h2 class="manage-roles__cap-title">{cap.label}</h2>
                        <p class="manage-roles__cap-desc">
                          {CAP_HELP[cap.key] ?? cap.description}
                        </p>
                      </div>
                      <fieldset class="manage-roles__roles">
                        <legend class="manage-roles__legend">Roles with this capability</legend>
                        {roles.map((role) => {
                          const locked = isLockedOnGrant(role, cap.key);
                          const granted = grantSet.has(`${role}:${cap.key}`) || locked;
                          return (
                            <label class="manage-roles__toggle">
                              <input
                                type="checkbox"
                                data-role-toggle
                                data-role={role}
                                data-capability={cap.key}
                                checked={granted}
                                disabled={locked}
                              />
                              <span class="manage-roles__toggle-label">{STAFF_ROLE_LABELS[role]}</span>
                              {locked ? <span class="ui-badge ui-badge--info">Always on</span> : null}
                            </label>
                          );
                        })}
                      </fieldset>
                    </article>
                  ))}
                </div>

                <script src="../../scripts/manage-roles.ts"></script>
              </section>
            )
          }
        </>
      )
    }
  </TeamManageLayout>
</TeamLayout>

<style>
  .manage-page__lead {
    margin: 0 0 1rem;
    font-size: 0.875rem;
    line-height: 1.45;
    color: var(--color-stone-500);
  }

  .manage-roles__denied {
    display: grid;
    gap: 0.75rem;
    max-width: 28rem;
    padding: 1.25rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-stone-50);
  }

  .manage-roles__denied-title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .manage-roles__denied-copy {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--color-stone-600);
  }

  .manage-roles__list {
    display: grid;
    gap: 1rem;
  }

  .manage-roles__cap {
    padding: 1rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
  }

  .manage-roles__cap-title {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    font-weight: 600;
  }

  .manage-roles__cap-desc {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-stone-500);
  }

  .manage-roles__roles {
    display: grid;
    gap: 0.5rem;
    margin: 0.85rem 0 0;
    padding: 0;
    border: 0;
  }

  .manage-roles__legend {
    padding: 0;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  .manage-roles__toggle {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-height: 2.75rem;
    cursor: pointer;
  }

  .manage-roles__toggle-label {
    font-size: 0.9rem;
  }
</style>
