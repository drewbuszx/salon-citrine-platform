---
import TeamLayout from "../../layouts/TeamLayout.astro";
import TeamManageLayout from "../../components/TeamManageLayout.astro";
import StaffAvatar from "../../components/StaffAvatar.astro";
import { isSalonManager } from "../../lib/auth";
import {
  ACCESS_STATUS_BADGE_VARIANT,
  ACCESS_STATUS_LABELS,
  mapStaffRow,
  STAFF_MANAGE_SELECT,
  STAFF_ROLE_LABELS,
  type AccessStatus,
  type StaffManageRow,
} from "../../lib/staff-manage";
import { staffPhotoSrc } from "../../lib/staff-display";
import { teamUrl } from "../../lib/supabase-server";
import { isModuleEnabled } from "../../lib/modules";

const { staff, supabase } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

if (!isSalonManager(staff)) {
  return Astro.redirect(teamUrl("/manage"));
}

const { data, error } = await supabase
  .from("staff")
  .select(STAFF_MANAGE_SELECT)
  .order("name");

const employees = (data ?? []).map((row) => mapStaffRow(row as StaffManageRow));
const apiBase = teamUrl("/api/staff");
const bookEnabled = isModuleEnabled("book");
const schedulesApi = bookEnabled ? teamUrl("/api/my-book/schedules") : "";

const FILTERS: Array<{ id: "all" | AccessStatus; label: string }> = [
  { id: "all", label: "All" },
  { id: "active", label: ACCESS_STATUS_LABELS.active },
  { id: "invited", label: ACCESS_STATUS_LABELS.invited },
  { id: "uninvited", label: ACCESS_STATUS_LABELS.uninvited },
  { id: "disabled", label: ACCESS_STATUS_LABELS.disabled },
];

const accessParam = Astro.url.searchParams.get("access");
const initialFilter: "all" | AccessStatus =
  accessParam === "all" ||
  (accessParam !== null && accessParam in ACCESS_STATUS_LABELS)
    ? (accessParam as "all" | AccessStatus)
    : "all";

function badgeClass(status: AccessStatus) {
  const variant = ACCESS_STATUS_BADGE_VARIANT[status];
  return variant === "default" ? "ui-badge" : `ui-badge ui-badge--${variant}`;
}
---

<TeamLayout title="Employees" activeNav="manage" plain wide fullBleed>
  <TeamManageLayout
    title="Employees"
    contextSubtitle="Invite teammates, set roles, and manage who can sign in."
    activeSection="staff"
    managerView
  >
    <a slot="headerActions" class="team-list-layout__btn-secondary" href={teamUrl("/manage")}>← Manage</a>

    <p class="manage-page__lead">
      {
        bookEnabled
          ? "Team profiles, roles, login access, and weekly bookable hours."
          : "Team profiles, roles, and login access."
      }
    </p>

    {
      error ? (
        <p class="notice notice--error" role="alert">
          Failed to load employees.
        </p>
      ) : (
        <div
          class="manage-employees"
          data-manage-employees
          data-api-base={apiBase}
          data-schedules-api={schedulesApi}
          data-book-enabled={bookEnabled ? "true" : "false"}
        >
          <p class="notice notice--success" data-employees-success hidden role="status">
            Saved.
          </p>
          <p class="notice notice--error" data-employees-error hidden role="alert"></p>

          <div class="manage-employees__toolbar">
            <div
              class="manage-employees__filters"
              data-access-filters
              role="group"
              aria-label="Filter by access status"
            >
              {
                FILTERS.map((filter) => (
                  <button
                    class:list={[
                      "manage-employees__filter",
                      { "manage-employees__filter--active": filter.id === initialFilter },
                    ]}
                    type="button"
                    data-access-filter={filter.id}
                    aria-pressed={filter.id === initialFilter ? "true" : "false"}
                  >
                    {filter.label}
                  </button>
                ))
              }
            </div>
            <button class="btn-primary" type="button" data-add-employee>
              Add employee
            </button>
          </div>

          <div class="manage-employees__list" data-employee-list>
            {
              employees.length === 0 ? (
                <p class="empty-state">No employees yet. Add someone to invite them to the team app.</p>
              ) : (
                employees.map((member) => {
                  const photo = staffPhotoSrc(member.photoUrl, member.slug);
                  return (
                    <button
                      class="manage-employees__row"
                      type="button"
                      data-employee-row
                      data-employee-id={member.id}
                      data-access-status={member.accessStatus}
                    >
                      {
                        photo ? (
                          <StaffAvatar
                            src={photo}
                            alt=""
                            crop={member.photoCrop}
                            size="preview"
                          />
                        ) : (
                          <span class="manage-employees__initials" aria-hidden="true">
                            {member.name
                              .split(/\s+/)
                              .map((part) => part[0] ?? "")
                              .join("")
                              .slice(0, 2)
                              .toUpperCase()}
                          </span>
                        )
                      }
                      <span class="manage-employees__copy">
                        <span class="manage-employees__name">{member.name}</span>
                        <span class="manage-employees__meta">
                          {STAFF_ROLE_LABELS[member.role]}
                        </span>
                      </span>
                      <span class={badgeClass(member.accessStatus)}>
                        {ACCESS_STATUS_LABELS[member.accessStatus]}
                      </span>
                    </button>
                  );
                })
              )
            }
          </div>
          <p class="empty-state" data-filter-empty hidden>
            No employees match this filter.
          </p>

          <dialog class="manage-employees__dialog" data-employee-dialog aria-labelledby="employee-dialog-title">
            <form class="manage-employees__form" data-employee-form>
              <header class="manage-employees__dialog-header">
                <h2 id="employee-dialog-title" data-employee-form-title>Edit employee</h2>
                <button class="manage-employees__close" type="button" data-close-dialog aria-label="Close">
                  ×
                </button>
              </header>

              <input type="hidden" name="id" data-employee-id />

              <div class="form-stack form-stack--medium">
                <label class="form-label">
                  Name
                  <input class="form-input" name="name" type="text" required />
                </label>

                <label class="form-label">
                  Slug
                  <input class="form-input" name="slug" type="text" required />
                  <span class="label-meta">Used in URLs and default photo paths.</span>
                </label>

                <label class="form-label">
                  Role
                  <select class="form-input" name="role" required>
                    {
                      Object.entries(STAFF_ROLE_LABELS).map(([value, label]) => (
                        <option value={value}>{label}</option>
                      ))
                    }
                  </select>
                </label>

                <label class="form-label">
                  Email
                  <input class="form-input" name="email" type="email" autocomplete="email" />
                </label>

                <label class="form-label">
                  Phone
                  <input class="form-input" name="phone" type="tel" autocomplete="tel" />
                </label>

                <label class="form-label">
                  Bio
                  <textarea class="form-input" name="bio" rows="4"></textarea>
                </label>

                <label class="form-label">
                  Start date
                  <input class="form-input" name="startDate" type="date" />
                </label>

                <fieldset class="manage-employees__fieldset">
                  <legend>Emergency contact</legend>
                  <label class="form-label">
                    Contact name
                    <input class="form-input" name="emergencyContactName" type="text" autocomplete="off" />
                  </label>
                  <label class="form-label">
                    Contact phone
                    <input class="form-input" name="emergencyContactPhone" type="tel" autocomplete="off" />
                  </label>
                </fieldset>

                {
                  bookEnabled ? (
                    <>
                      <label class="form-label form-label--checkbox">
                        <input type="checkbox" name="isBookable" checked />
                        Active for online booking
                      </label>

                      <label class="form-label form-label--checkbox">
                        <input type="checkbox" name="acceptingNewClients" checked />
                        Accepting new clients
                      </label>
                    </>
                  ) : null
                }

                <section class="manage-employees__access" data-access-section hidden>
                  <h3 class="manage-employees__access-title">Login access</h3>
                  <p class="label-meta" data-link-status></p>
                  <div class="card-row" data-access-actions aria-label="Employee access actions">
                    <button class="ui-btn" type="button" data-access-action="invite" hidden>
                      Invite
                    </button>
                    <button class="ui-btn" type="button" data-access-action="resend" hidden>
                      Resend invite
                    </button>
                    <button class="ui-btn ui-btn--destructive" type="button" data-access-action="deactivate" hidden>
                      Deactivate
                    </button>
                    <button class="ui-btn" type="button" data-access-action="reactivate" hidden>
                      Reactivate
                    </button>
                  </div>
                  <p class="manage-employees__next" data-access-next hidden></p>
                </section>

                {
                  bookEnabled ? (
                    <section class="page-section" data-schedule-section hidden>
                      <h3>Weekly bookable hours</h3>
                      <p class="page-section__lead">
                        These hours feed client availability on the booking site.
                      </p>
                      <div class="manage-employees__schedule" data-schedule-grid></div>
                    </section>
                  ) : null
                }

                <div class="card-row card-row--1">
                  <button class="btn-primary" type="submit">Save employee</button>
                </div>
              </div>
            </form>
          </dialog>
        </div>
      )
    }
  </TeamManageLayout>

  <script src="../../scripts/manage-employees.ts"></script>
</TeamLayout>

<style is:global>
  .confirm-destructive {
    width: min(100%, 24rem);
    padding: 0;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .confirm-destructive::backdrop {
    background: rgb(15 23 42 / 0.45);
  }

  .confirm-destructive__form {
    display: grid;
    gap: 0.85rem;
    padding: 1.25rem;
  }

  .confirm-destructive__title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .confirm-destructive__body {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--color-stone-600);
  }

  .confirm-destructive__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
  }
</style>

<style>
  .manage-page__lead {
    margin: 0 0 1.25rem;
    font-size: 0.875rem;
    line-height: 1.45;
    color: var(--color-stone-500);
  }

  .manage-employees__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .manage-employees__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .manage-employees__filter {
    min-height: 2.75rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-stone-600);
    font: inherit;
    font-size: 0.8rem;
    cursor: pointer;
  }

  .manage-employees__filter--active,
  .manage-employees__filter[aria-pressed="true"] {
    border-color: var(--color-citrine, #c4a35a);
    background: var(--color-citrine-muted, #f7f1e4);
    color: var(--color-stone-800);
    font-weight: 600;
  }

  .manage-employees__filter:focus-visible {
    outline: 2px solid var(--color-citrine, #c4a35a);
    outline-offset: 2px;
  }

  .manage-employees__list {
    display: grid;
    gap: 0;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .manage-employees__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    min-height: 2.75rem;
    padding: 0.75rem 1rem;
    border: 0;
    border-bottom: 1px solid var(--color-stone-200);
    background: var(--color-bg);
    color: inherit;
    text-align: left;
    cursor: pointer;
    font: inherit;
  }

  .manage-employees__row:last-child {
    border-bottom: none;
  }

  .manage-employees__row:hover,
  .manage-employees__row:focus-visible {
    background: var(--color-citrine-muted);
    outline: none;
  }

  .manage-employees__row[hidden] {
    display: none;
  }

  .manage-employees__initials {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background: var(--color-stone-100);
    color: var(--color-stone-600);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .manage-employees__copy {
    display: grid;
    gap: 0.15rem;
    min-width: 0;
  }

  .manage-employees__name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-stone-800);
  }

  .manage-employees__meta {
    font-size: 0.8rem;
    color: var(--color-stone-500);
  }

  .manage-employees__access {
    display: grid;
    gap: 0.65rem;
    padding: 0.85rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-stone-50, #fafaf9);
  }

  .manage-employees__access-title {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .manage-employees__next {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--color-stone-600);
  }

  .manage-employees__dialog {
    width: min(100%, 36rem);
    max-height: 90vh;
    padding: 0;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .manage-employees__dialog::backdrop {
    background: rgb(15 23 42 / 0.45);
  }

  .manage-employees__dialog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-stone-200);
  }

  .manage-employees__dialog-header h2 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .manage-employees__close {
    border: 0;
    background: transparent;
    color: var(--color-stone-500);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
  }

  .manage-employees__form {
    padding: 1.25rem;
    overflow: auto;
    max-height: calc(90vh - 4rem);
  }

  .manage-employees__fieldset {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding: 0.75rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
  }

  .manage-employees__fieldset legend {
    padding: 0 0.35rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-stone-600);
  }

  .form-label--checkbox {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .form-label--checkbox input {
    width: auto;
  }

  .manage-employees__schedule {
    display: grid;
    gap: 0.5rem;
  }

  .manage-employees__day-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    align-items: center;
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-booking-card-bg, var(--color-stone-50));
  }

  .manage-employees__day-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
  }

  .manage-employees__day-times {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .manage-employees__day-times[hidden] {
    display: none;
  }

  .manage-employees__skeleton {
    display: grid;
    gap: 0.75rem;
    padding: 1rem;
  }

  .manage-employees__skeleton-row {
    height: 3rem;
    border-radius: var(--radius-sm);
    background: linear-gradient(
      90deg,
      var(--color-stone-100) 0%,
      var(--color-stone-50) 50%,
      var(--color-stone-100) 100%
    );
    background-size: 200% 100%;
    animation: manage-employees-shimmer 1.2s ease-in-out infinite;
  }

  @keyframes manage-employees-shimmer {
    0% { background-position: 100% 0; }
    100% { background-position: -100% 0; }
  }
</style>
