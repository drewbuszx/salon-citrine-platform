---
import TeamLayout from "../../layouts/TeamLayout.astro";
import TeamManageLayout from "../../components/TeamManageLayout.astro";
import { MANAGE_HUB_ITEMS } from "../../lib/manage-nav";

const hubIcons: Record<string, string> = {
  services: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h10" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
  products: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6h12l1 4H5l1-4zM5 10v8a1 1 0 001 1h12a1 1 0 001-1v-8" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/></svg>`,
  "booking-policy": `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="4" y="5" width="16" height="15" rx="1" stroke="currentColor" stroke-width="1.75"/><path d="M8 3v4M16 3v4M4 10h16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
  staff: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="9" cy="8" r="3" stroke="currentColor" stroke-width="1.75"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6M16 11l2 2 4-4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  tags: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 12V5a1 1 0 011-1h7l8 8-7 7-8-8z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/><circle cx="8.5" cy="8.5" r="1" fill="currentColor"/></svg>`,
  business: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20V9l8-4 8 4v11M9 20v-6h6v6" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/></svg>`,
};
---

<TeamLayout title="Manage" activeNav="manage" plain wide fullBleed>
  <TeamManageLayout title="Manage" activeSection="hub">
    <div class="team-manage-layout__hub-list">
      {
        MANAGE_HUB_ITEMS.map((item) => (
          <article
            class:list={[
              "team-manage-layout__hub-row",
              { "team-manage-layout__hub-row--disabled": item.disabled },
            ]}
            id={item.id}
          >
            <div class="team-manage-layout__hub-icon" set:html={hubIcons[item.id] ?? hubIcons.services} />
            <div class="team-manage-layout__hub-copy">
              <h2 class="team-manage-layout__hub-title">{item.title}</h2>
              <p class="team-manage-layout__hub-desc">{item.description}</p>
            </div>
            {
              item.disabled ? (
                <span class="team-manage-layout__soon-badge" aria-label={`${item.title} — coming soon`}>
                  Soon
                </span>
              ) : (
                <a class="team-list-layout__btn-secondary" href={item.href}>
                  {item.actionLabel ?? "Open"}
                </a>
              )
            }
          </article>
        ))
      }
    </div>
  </TeamManageLayout>
</TeamLayout>
