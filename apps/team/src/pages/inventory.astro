---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamListLayout from "../components/TeamListLayout.astro";
import TeamListFilter from "../components/TeamListFilter.astro";
import TeamListExportButton from "../components/TeamListExportButton.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";

const { staff, supabase } = Astro.locals;
const isManager = isSalonManager(staff);

const { data: productMeta } = await supabase
  .from("products")
  .select("category, brand")
  .eq("is_active", true);

const categorySet = new Set<string>();
const brandSet = new Set<string>();
for (const row of productMeta ?? []) {
  if (row.category?.trim()) categorySet.add(row.category.trim());
  if (row.brand?.trim()) brandSet.add(row.brand.trim());
}
const categories = [...categorySet].sort((a, b) => a.localeCompare(b));
const brands = [...brandSet].sort((a, b) => a.localeCompare(b));
---

<TeamLayout title="Stock" activeNav="stock" plain wide fullBleed>
  <div
    class="stock-page"
    data-inventory-root
    data-is-manager={isManager ? "1" : "0"}
  >
    <TeamListLayout title="Stock" mainTitle="Your Products" sidebarTitle="Refine Your Search">
      <button slot="headerActions" class="team-list-layout__btn-secondary stock-page__scan-desktop" type="button" data-scan-open>
        Scan to check in
      </button>
      {
        isManager ? (
          <button slot="headerActions" class="team-list-layout__btn-primary" type="button" data-add-open>
            Add product
          </button>
        ) : null
      }

      <TeamListFilter slot="sidebarFilters" label="Category" count={categories.length} open={categories.length > 0}>
        {
          categories.length > 0 ? (
            <div class="team-list-layout__filter-options">
              <label class="team-list-layout__filter-option">
                <input type="radio" name="stock-category" value="" data-filter-category checked />
                <span>All categories</span>
              </label>
              {
                categories.map((category) => (
                  <label class="team-list-layout__filter-option">
                    <input type="radio" name="stock-category" value={category} data-filter-category />
                    <span>{category}</span>
                  </label>
                ))
              }
            </div>
          ) : (
            <p class="team-list-layout__filter-placeholder">No categories yet.</p>
          )
        }
      </TeamListFilter>

      <TeamListFilter slot="sidebarFilters" label="Brand" count={brands.length} open={brands.length > 0}>
        {
          brands.length > 0 ? (
            <div class="team-list-layout__filter-options">
              <label class="team-list-layout__filter-option">
                <input type="radio" name="stock-brand" value="" data-filter-brand checked />
                <span>All brands</span>
              </label>
              {
                brands.map((brand) => (
                  <label class="team-list-layout__filter-option">
                    <input type="radio" name="stock-brand" value={brand} data-filter-brand />
                    <span>{brand}</span>
                  </label>
                ))
              }
            </div>
          ) : (
            <p class="team-list-layout__filter-placeholder">No brands yet.</p>
          )
        }
      </TeamListFilter>

      <TeamListFilter slot="sidebarFilters" label="Stock level" open>
        <div class="team-list-layout__filter-options">
          <label class="team-list-layout__filter-option">
            <input type="radio" name="stock-level" value="" data-filter-stock checked />
            <span>All products</span>
          </label>
          <label class="team-list-layout__filter-option">
            <input type="radio" name="stock-level" value="in" data-filter-stock />
            <span>In stock</span>
          </label>
          <label class="team-list-layout__filter-option">
            <input type="radio" name="stock-level" value="low" data-filter-stock />
            <span>Low stock</span>
          </label>
          <label class="team-list-layout__filter-option">
            <input type="radio" name="stock-level" value="out" data-filter-stock />
            <span>Out of stock</span>
          </label>
        </div>
      </TeamListFilter>

      <TeamListFilter slot="sidebarFilters" label="Price range">
        <div class="team-list-layout__filter-options">
          <label class="team-list-layout__filter-option">
            <span>Min ($)</span>
            <input class="inventory-form-input" type="number" min="0" step="0.01" data-filter-min-price placeholder="0" />
          </label>
          <label class="team-list-layout__filter-option">
            <span>Max ($)</span>
            <input class="inventory-form-input" type="number" min="0" step="0.01" data-filter-max-price placeholder="Any" />
          </label>
        </div>
      </TeamListFilter>

      <TeamListExportButton slot="sidebarFooter" />

      <Fragment slot="stats">
        Total: <span data-total-count>—</span>
        · Low stock: <span data-low-stock-count>—</span>
        · <span data-filter-count>0</span> filters applied
      </Fragment>

      <p class="team-list-layout__notice team-list-layout__notice--banner" data-low-stock-banner hidden></p>

      <label slot="searchBar" class="team-list-layout__search">
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="none">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.75"></circle>
          <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
        </svg>
        <input
          class="team-list-layout__search-input"
          type="search"
          placeholder="Search by name, brand, barcode, SKU, or category"
          autocomplete="off"
          data-search
        />
      </label>

      <p class="team-list-layout__notice" data-status hidden aria-live="polite"></p>

      <div class="stock-page__list" data-product-list>
        <p class="stock-page__empty">Loading products…</p>
      </div>
    </TeamListLayout>

    <div class="stock-scan-bar">
      <button class="team-list-layout__btn-primary stock-scan-bar__btn" type="button" data-scan-open>
        Scan to check in
      </button>
    </div>
  </div>

  <!-- Scanner modal -->
  <div class="inventory-modal" data-scan-modal hidden>
    <div class="inventory-modal__backdrop" data-modal-close="scan"></div>
    <div class="inventory-modal__panel inventory-modal__panel--scanner" role="dialog" aria-modal="true" aria-labelledby="scan-title">
      <div class="inventory-modal__head">
        <h2 id="scan-title">Scan to check in</h2>
        <button class="inventory-modal__close" type="button" data-modal-close="scan" aria-label="Close">×</button>
      </div>
      <div class="inventory-scanner">
        <video class="inventory-scanner__video" data-scan-video playsinline muted autoplay></video>
        <p class="inventory-scanner__hint">
          Point your camera at a barcode (UPC/EAN) or QR code on the product
        </p>
        <p class="inventory-scanner__error" data-scan-error></p>
        <div class="inventory-scanner__manual">
          <label class="inventory-form-label">
            Or enter code manually
            <input class="inventory-form-input" type="text" data-manual-barcode placeholder="Barcode or QR value" />
          </label>
          <button class="team-list-layout__btn-secondary" type="button" data-manual-barcode-submit>
            Check in
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Transaction modal -->
  <div class="inventory-modal" data-tx-modal hidden>
    <div class="inventory-modal__backdrop" data-modal-close="tx"></div>
    <div class="inventory-modal__panel inventory-modal__panel--narrow" role="dialog" aria-modal="true" aria-labelledby="tx-title">
      <div class="inventory-modal__head">
        <h2 id="tx-title" data-tx-title>Log transaction</h2>
        <button class="inventory-modal__close" type="button" data-modal-close="tx" aria-label="Close">×</button>
      </div>
      <label class="inventory-form-label">
        Quantity
        <input class="inventory-form-input" type="number" step="any" min="0" data-tx-qty />
      </label>
      <label class="inventory-form-label">
        Notes (optional)
        <textarea class="inventory-form-input inventory-form-input--textarea" rows="2" data-tx-notes></textarea>
      </label>
      <button class="team-list-layout__btn-primary" type="button" data-tx-submit>Save</button>
    </div>
  </div>

  <!-- Add product modal (managers) -->
  {
    isManager ? (
      <div class="inventory-modal" data-add-modal hidden>
        <div class="inventory-modal__backdrop" data-modal-close="add" />
        <div
          class="inventory-modal__panel inventory-modal__panel--narrow"
          role="dialog"
          aria-modal="true"
          aria-labelledby="add-title"
        >
          <div class="inventory-modal__head">
            <h2 id="add-title">Add product</h2>
            <button
              class="inventory-modal__close"
              type="button"
              data-modal-close="add"
              aria-label="Close"
            >
              ×
            </button>
          </div>
          <form class="inventory-form-stack" data-add-form>
            <label class="inventory-form-label">
              Name
              <input class="inventory-form-input" name="name" required />
            </label>
            <label class="inventory-form-label">
              Barcode
              <input class="inventory-form-input" name="barcode" inputmode="numeric" />
            </label>
            <label class="inventory-form-label">
              Brand
              <input class="inventory-form-input" name="brand" />
            </label>
            <label class="inventory-form-label">
              Category
              <input
                class="inventory-form-input"
                name="category"
                placeholder="color, shampoo, developer…"
              />
            </label>
            <label class="inventory-form-label">
              Unit
              <input class="inventory-form-input" name="unit" value="each" />
            </label>
            <label class="inventory-form-label">
              Reorder threshold
              <span class="inventory-form-hint">
                When on-hand quantity is at or below this number, the product is flagged as low stock. Use 0 to disable alerts.
              </span>
              <input
                class="inventory-form-input"
                name="reorder_threshold"
                type="number"
                min="0"
                step="1"
                value="0"
              />
            </label>
            <label class="inventory-form-label">
              Image URL
              <span class="inventory-form-hint">
                Public URL (external link or Supabase Storage product-images bucket).
              </span>
              <input
                class="inventory-form-input"
                name="image_url"
                type="url"
                placeholder="https://…"
                inputmode="url"
              />
            </label>
            <label class="inventory-form-label">
              Initial quantity
              <input
                class="inventory-form-input"
                name="initial_quantity"
                type="number"
                min="0"
                step="any"
                value="0"
              />
            </label>
            <label class="inventory-form-label">
              Notes
              <textarea class="inventory-form-input inventory-form-input--textarea" name="notes" rows="2" />
            </label>
            <button class="team-list-layout__btn-primary" type="submit">
              Create product
            </button>
          </form>
        </div>
      </div>
    ) : null
  }

  <!-- Edit product modal (managers) -->
  {
    isManager ? (
      <div class="inventory-modal" data-edit-modal hidden>
        <div class="inventory-modal__backdrop" data-modal-close="edit" />
        <div
          class="inventory-modal__panel inventory-modal__panel--narrow"
          role="dialog"
          aria-modal="true"
          aria-labelledby="edit-title"
        >
          <div class="inventory-modal__head">
            <h2 id="edit-title">Edit product</h2>
            <button
              class="inventory-modal__close"
              type="button"
              data-modal-close="edit"
              aria-label="Close"
            >
              ×
            </button>
          </div>
          <form class="inventory-form-stack" data-edit-form>
            <label class="inventory-form-label">
              Name
              <input class="inventory-form-input" name="name" required />
            </label>
            <label class="inventory-form-label">
              Barcode
              <input class="inventory-form-input" name="barcode" inputmode="numeric" />
            </label>
            <label class="inventory-form-label">
              Category
              <input
                class="inventory-form-input"
                name="category"
                placeholder="color, shampoo, developer…"
              />
            </label>
            <label class="inventory-form-label">
              Reorder threshold
              <span class="inventory-form-hint">
                When on-hand quantity is at or below this number, the product is flagged as low stock. Use 0 to disable alerts.
              </span>
              <input
                class="inventory-form-input"
                name="reorder_threshold"
                type="number"
                min="0"
                step="1"
              />
            </label>
            <label class="inventory-form-label">
              Image URL
              <span class="inventory-form-hint">
                Public URL (external link or Supabase Storage product-images bucket).
              </span>
              <input
                class="inventory-form-input"
                name="image_url"
                type="url"
                placeholder="https://…"
                inputmode="url"
              />
            </label>
            <button class="team-list-layout__btn-primary" type="submit">
              Save changes
            </button>
          </form>
        </div>
      </div>
    ) : null
  }

  <div class="stock-toast" data-toast hidden role="status"></div>

  <script define:vars={{ apiBase: teamUrl("") }}>
    document.body.dataset.apiBase = apiBase;
  </script>
  <script src="../scripts/inventory.ts"></script>
</TeamLayout>

<style>
  .stock-page {
    padding-bottom: calc(5rem + env(safe-area-inset-bottom, 0px));
  }

  .stock-page__scan-desktop {
    display: none;
  }

  :global(.team-list-layout__notice--banner) {
    padding: 0.65rem 0.85rem;
    border: 1px solid #fcd34d;
    border-radius: 0.25rem;
    background: #fffbeb;
    color: #92400e;
  }

  :global(.team-list-layout__notice--banner.team-list-layout__notice--actionable) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
  }

  .stock-page__list {
    display: grid;
    gap: 1rem;
  }

  .stock-category__title {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    text-transform: capitalize;
  }

  .stock-category__count {
    font-weight: 400;
    color: #9ca3af;
  }

  .stock-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .stock-card {
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    overflow: hidden;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .stock-card:not(.stock-card--expanded):hover {
    border-color: var(--color-citrine);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .stock-card:hover {
    border-color: var(--color-stone-300);
  }

  .stock-card--expanded {
    grid-column: 1 / -1;
    border-color: var(--color-citrine);
    box-shadow: 0 2px 12px rgba(231, 172, 70, 0.15);
  }

  .stock-card--low {
    border-color: var(--color-dusty-rose);
  }

  .stock-card--low.stock-card--expanded {
    border-color: #c4847a;
  }

  .stock-card__header {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.3rem;
    width: 100%;
    padding: 0.35rem;
    border: none;
    background: transparent;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
  }

  .stock-card--expanded .stock-card__header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0.75rem;
  }

  .stock-card__header:focus-visible {
    outline: 2px solid var(--color-citrine);
    outline-offset: -2px;
  }

  .stock-card__thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
    background: var(--color-stone-100);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stock-card--expanded .stock-card__thumb {
    width: 3rem;
    height: 3rem;
    aspect-ratio: auto;
  }

  .stock-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .stock-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: #9ca3af;
  }

  .stock-card__placeholder svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .stock-card__badge {
    position: absolute;
    top: 0.15rem;
    right: 0.15rem;
    font-family: var(--font-sans);
    font-size: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 0.08rem 0.25rem;
    border-radius: 0.12rem;
    color: #991b1b;
    background: #fef2f2;
    border: 1px solid #fecaca;
  }

  .stock-card__summary {
    display: grid;
    gap: 0.1rem;
    min-width: 0;
  }

  .stock-card__name {
    font-size: 0.6875rem;
    font-weight: 600;
    color: #111827;
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .stock-card--expanded .stock-card__name {
    font-size: 0.875rem;
    -webkit-line-clamp: unset;
    display: block;
  }

  .stock-card__meta {
    font-size: 0.625rem;
    color: #6b7280;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .stock-card--expanded .stock-card__meta {
    font-size: 0.75rem;
  }

  .stock-card__chevron {
    display: none;
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
    color: #9ca3af;
    transition: transform 0.25s ease;
  }

  .stock-card--expanded .stock-card__chevron {
    display: block;
    transform: rotate(180deg);
  }

  .stock-card__expand {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }

  .stock-card--expanded .stock-card__expand {
    grid-template-rows: 1fr;
  }

  .stock-card__body {
    overflow: hidden;
  }

  .stock-card__body-inner {
    padding: 0 0.75rem 0.75rem;
    border-top: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .stock-card--expanded .stock-card__body-inner {
    border-top-color: #f3f4f6;
    padding-top: 0.75rem;
  }

  .stock-card__detail-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem 1rem;
    margin-bottom: 0.85rem;
  }

  .stock-card__detail-item {
    display: grid;
    gap: 0.1rem;
  }

  .stock-card__detail-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #9ca3af;
  }

  .stock-card__detail-value {
    font-size: 0.8125rem;
    color: #374151;
  }

  .stock-card__detail-value--qty {
    font-size: 1.05rem;
    font-weight: 600;
    color: #111827;
  }

  .stock-card__detail-value--qty-low {
    color: #991b1b;
  }

  .stock-card__notes {
    margin: 0 0 0.85rem;
    font-size: 0.8125rem;
    color: #6b7280;
    line-height: 1.45;
  }

  .stock-card__hero-img {
    width: 100%;
    max-height: 10rem;
    object-fit: contain;
    border-radius: 0.25rem;
    background: #f9fafb;
    margin-bottom: 0.85rem;
  }

  .stock-card__actions {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.45rem;
    margin-bottom: 0.85rem;
  }

  .stock-card__actions .team-list-layout__btn-secondary,
  .stock-card__actions .team-list-layout__btn-primary {
    padding: 0.45rem 0.65rem;
    font-size: 0.75rem;
    text-align: center;
  }

  .stock-card__actions .stock-card__edit-btn {
    grid-column: 1 / -1;
  }

  .stock-card__close {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.65rem;
    padding: 0;
    border: none;
    background: none;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: #6b7280;
    cursor: pointer;
  }

  .stock-card__close:hover,
  .stock-card__close:focus-visible {
    color: #374151;
    outline: none;
  }

  .stock-card__history-title {
    margin: 0 0 0.35rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #9ca3af;
  }

  .stock-card__history {
    display: grid;
    gap: 0.35rem;
  }

  .stock-card__history-row {
    display: grid;
    gap: 0.05rem;
    padding: 0.35rem 0;
    border-bottom: 1px solid #f3f4f6;
    font-size: 0.8125rem;
  }

  .stock-card__history-meta {
    font-size: 0.6875rem;
    color: #9ca3af;
  }

  .stock-card__history-loading {
    margin: 0;
    font-size: 0.8125rem;
    color: #9ca3af;
  }

  .stock-page__empty {
    margin: 1.5rem 0 0;
    text-align: center;
    font-size: 0.875rem;
    color: #9ca3af;
  }

  .stock-scan-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 200;
    padding: 0.75rem 1rem calc(0.75rem + env(safe-area-inset-bottom, 0px));
    background: #fff;
    border-top: 1px solid #e5e7eb;
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.08);
  }

  .stock-scan-bar__btn {
    width: 100%;
    min-height: 3rem;
    font-size: 1rem;
  }

  .stock-toast {
    position: fixed;
    left: 50%;
    bottom: calc(5rem + env(safe-area-inset-bottom, 0px));
    z-index: 400;
    transform: translateX(-50%);
    padding: 0.65rem 1rem;
    border-radius: 0.35rem;
    background: #111827;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .stock-toast[hidden] {
    display: none;
  }

  /* Modals */
  .inventory-modal {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0;
  }

  .inventory-modal[hidden] {
    display: none;
  }

  .inventory-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(17, 24, 39, 0.45);
  }

  .inventory-modal__panel {
    position: relative;
    z-index: 1;
