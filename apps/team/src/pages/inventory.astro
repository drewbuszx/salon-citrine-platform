---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamPage from "../components/TeamPage.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";

const { staff } = Astro.locals;
const isManager = isSalonManager(staff);
---

<TeamLayout title="Inventory" activeNav="sales" plain wide>
  <div
    class="inventory-page"
    data-inventory-root
    data-is-manager={isManager ? "1" : "0"}
  >
    <TeamPage
      title="Inventory"
      lead="Back-bar supplies — scan a barcode or QR code to check in received stock."
      toolbar
    >
      <div slot="actions" class="inventory-page__actions inventory-page__actions--desktop">
        <button class="btn-primary inventory-page__scan" type="button" data-scan-open>
          Scan to check in
        </button>
        {
          isManager ? (
            <button class="btn-secondary" type="button" data-add-open>
              Add product
            </button>
          ) : null
        }
      </div>

      <div slot="toolbar" class="inventory-toolbar">
        <label class="team-toolbar-field team-toolbar-field--grow">
          <span class="team-toolbar-label">Search</span>
          <input
            class="form-input"
            type="search"
            placeholder="Name, brand, barcode, SKU…"
            autocomplete="off"
            data-search
          />
        </label>
        <label class="inventory-filter">
          <input type="checkbox" data-low-stock-filter />
          Low stock only
        </label>
      </div>

      <p class="notice inventory-low-stock" data-low-stock-banner hidden></p>
      <p class="notice" data-status hidden></p>

      <div class="inventory-list" data-product-list>
        <p class="empty-state">Loading products…</p>
      </div>
    </TeamPage>

    <div class="inventory-scan-bar">
      <button class="btn-primary inventory-scan-bar__btn" type="button" data-scan-open>
        Scan to check in
      </button>
    </div>
  </div>

  <!-- Scanner modal -->
  <div class="inventory-modal" data-scan-modal hidden>
    <div class="inventory-modal__backdrop" data-modal-close="scan"></div>
    <div class="inventory-modal__panel inventory-modal__panel--scanner" role="dialog" aria-modal="true" aria-labelledby="scan-title">
      <div class="inventory-modal__head">
        <h2 id="scan-title">Scan to check in</h2>
        <button class="inventory-modal__close" type="button" data-modal-close="scan" aria-label="Close">×</button>
      </div>
      <div class="inventory-scanner">
        <video class="inventory-scanner__video" data-scan-video playsinline muted autoplay></video>
        <p class="inventory-scanner__hint">
          Point your camera at a barcode (UPC/EAN) or QR code on the product
        </p>
        <p class="notice notice--error inventory-scanner__error" data-scan-error></p>
        <div class="inventory-scanner__manual">
          <label class="form-label">
            Or enter code manually
            <input class="form-input" type="text" data-manual-barcode placeholder="Barcode or QR value" />
          </label>
          <button class="btn-secondary" type="button" data-manual-barcode-submit>
            Check in
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Product detail modal -->
  <div class="inventory-modal" data-detail-modal hidden>
    <div class="inventory-modal__backdrop" data-modal-close="detail"></div>
    <div class="inventory-modal__panel" role="dialog" aria-modal="true" aria-labelledby="detail-title">
      <div class="inventory-modal__head">
        <h2 id="detail-title" data-detail-title>Product</h2>
        <button class="inventory-modal__close" type="button" data-modal-close="detail" aria-label="Close">×</button>
      </div>
      <div class="inventory-detail__image-wrap" data-detail-image-wrap hidden>
        <img class="inventory-detail__image" data-detail-image alt="" />
      </div>
      <p class="inventory-detail__meta" data-detail-meta></p>
      <p class="inventory-detail__qty" data-detail-qty></p>
      <div class="inventory-detail__actions">
        <button class="btn-primary" type="button" data-tx-action="receive">Check in</button>
        <button class="btn-secondary" type="button" data-tx-action="use">Use</button>
        <button class="btn-secondary" type="button" data-tx-action="adjust">Adjust</button>
        <button class="btn-secondary" type="button" data-tx-action="count">Set count</button>
        {
          isManager ? (
            <button class="btn-secondary inventory-detail__edit" type="button" data-edit-open>
              Edit product
            </button>
          ) : null
        }
      </div>
      <h3 class="inventory-detail__history-title">Recent activity</h3>
      <div class="inventory-history" data-detail-history></div>
    </div>
  </div>

  <!-- Transaction modal -->
  <div class="inventory-modal" data-tx-modal hidden>
    <div class="inventory-modal__backdrop" data-modal-close="tx"></div>
    <div class="inventory-modal__panel inventory-modal__panel--narrow" role="dialog" aria-modal="true" aria-labelledby="tx-title">
      <div class="inventory-modal__head">
        <h2 id="tx-title" data-tx-title>Log transaction</h2>
        <button class="inventory-modal__close" type="button" data-modal-close="tx" aria-label="Close">×</button>
      </div>
      <label class="form-label">
        Quantity
        <input class="form-input" type="number" step="any" min="0" data-tx-qty />
      </label>
      <label class="form-label">
        Notes (optional)
        <textarea class="form-input form-input--textarea" rows="2" data-tx-notes></textarea>
      </label>
      <button class="btn-primary" type="button" data-tx-submit>Save</button>
    </div>
  </div>

  <!-- Add product modal (managers) -->
  {
    isManager ? (
      <div class="inventory-modal" data-add-modal hidden>
        <div class="inventory-modal__backdrop" data-modal-close="add" />
        <div
          class="inventory-modal__panel inventory-modal__panel--narrow"
          role="dialog"
          aria-modal="true"
          aria-labelledby="add-title"
        >
          <div class="inventory-modal__head">
            <h2 id="add-title">Add product</h2>
            <button
              class="inventory-modal__close"
              type="button"
              data-modal-close="add"
              aria-label="Close"
            >
              ×
            </button>
          </div>
          <form class="form-stack" data-add-form>
            <label class="form-label">
              Name
              <input class="form-input" name="name" required />
            </label>
            <label class="form-label">
              Barcode
              <input class="form-input" name="barcode" inputmode="numeric" />
            </label>
            <label class="form-label">
              Brand
              <input class="form-input" name="brand" />
            </label>
            <label class="form-label">
              Category
              <input
                class="form-input"
                name="category"
                placeholder="color, shampoo, developer…"
              />
            </label>
            <label class="form-label">
              Unit
              <input class="form-input" name="unit" value="each" />
            </label>
            <label class="form-label">
              Reorder threshold
              <span class="form-hint">
                When on-hand quantity is at or below this number, the product is flagged as low stock. Use 0 to disable alerts.
              </span>
              <input
                class="form-input"
                name="reorder_threshold"
                type="number"
                min="0"
                step="1"
                value="0"
              />
            </label>
            <label class="form-label">
              Image URL
              <span class="form-hint">
                Public URL (external link or Supabase Storage product-images bucket).
              </span>
              <input
                class="form-input"
                name="image_url"
                type="url"
                placeholder="https://…"
                inputmode="url"
              />
            </label>
            <label class="form-label">
              Initial quantity
              <input
                class="form-input"
                name="initial_quantity"
                type="number"
                min="0"
                step="any"
                value="0"
              />
            </label>
            <label class="form-label">
              Notes
              <textarea class="form-input form-input--textarea" name="notes" rows="2" />
            </label>
            <button class="btn-primary" type="submit">
              Create product
            </button>
          </form>
        </div>
      </div>
    ) : null
  }

  <!-- Edit product modal (managers) -->
  {
    isManager ? (
      <div class="inventory-modal" data-edit-modal hidden>
        <div class="inventory-modal__backdrop" data-modal-close="edit" />
        <div
          class="inventory-modal__panel inventory-modal__panel--narrow"
          role="dialog"
          aria-modal="true"
          aria-labelledby="edit-title"
        >
          <div class="inventory-modal__head">
            <h2 id="edit-title">Edit product</h2>
            <button
              class="inventory-modal__close"
              type="button"
              data-modal-close="edit"
              aria-label="Close"
            >
              ×
            </button>
          </div>
          <form class="form-stack" data-edit-form>
            <label class="form-label">
              Name
              <input class="form-input" name="name" required />
            </label>
            <label class="form-label">
              Barcode
              <input class="form-input" name="barcode" inputmode="numeric" />
            </label>
            <label class="form-label">
              Category
              <input
                class="form-input"
                name="category"
                placeholder="color, shampoo, developer…"
              />
            </label>
            <label class="form-label">
              Reorder threshold
              <span class="form-hint">
                When on-hand quantity is at or below this number, the product is flagged as low stock. Use 0 to disable alerts.
              </span>
              <input
                class="form-input"
                name="reorder_threshold"
                type="number"
                min="0"
                step="1"
              />
            </label>
            <label class="form-label">
              Image URL
              <span class="form-hint">
                Public URL (external link or Supabase Storage product-images bucket).
              </span>
              <input
                class="form-input"
                name="image_url"
                type="url"
                placeholder="https://…"
                inputmode="url"
              />
            </label>
            <button class="btn-primary" type="submit">
              Save changes
            </button>
          </form>
        </div>
      </div>
    ) : null
  }

  <script define:vars={{ apiBase: teamUrl("") }}>
    document.body.dataset.apiBase = apiBase;
  </script>
  <script src="../scripts/inventory.ts"></script>
</TeamLayout>

<style>
  .inventory-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    gap: 0.75rem 1rem;
    width: 100%;
  }

  .inventory-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .inventory-page__actions--desktop {
    display: none;
  }

  .inventory-scan-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 200;
    padding: 0.75rem 1rem calc(0.75rem + env(safe-area-inset-bottom, 0px));
    background: var(--color-booking-panel-bg);
    border-top: 1px solid var(--color-border);
    box-shadow: 0 -4px 24px var(--color-card-shadow);
  }

  .inventory-scan-bar__btn {
    width: 100%;
    min-height: 3rem;
    font-size: 1.05rem;
    background: var(--color-dusty-rose-dark, var(--color-charcoal));
  }

  .inventory-page {
    padding-bottom: calc(5rem + env(safe-area-inset-bottom, 0px));
  }

  .inventory-filter {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    white-space: nowrap;
    cursor: pointer;
  }

  .inventory-filter input {
    width: 1rem;
    height: 1rem;
    accent-color: var(--color-sage);
  }

  .inventory-low-stock {
    border-color: var(--color-citrine);
    background: rgba(231, 172, 70, 0.12);
  }

  .inventory-list {
    display: grid;
    gap: 1.75rem;
  }

  .inventory-category__title {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    font-size: 1.05rem;
    text-transform: capitalize;
  }

  .inventory-category__count {
    font-weight: 400;
  }

  .inventory-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .inventory-tile {
    display: grid;
    gap: 0.35rem;
    padding: 0;
    border: 1px solid var(--color-border);
    background: var(--color-booking-card-bg);
    text-align: left;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .inventory-tile:hover,
  .inventory-tile:focus-visible {
    border-color: var(--color-sage);
    outline: none;
  }

  .inventory-tile--low {
    border-color: #c44;
  }

  .inventory-tile__media {
    position: relative;
    aspect-ratio: 1;
    background: var(--color-booking-panel-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .inventory-tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .inventory-tile__placeholder {
    font-family: var(--font-sans);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-gray);
    opacity: 0.55;
  }

  .inventory-tile__badge {
    position: absolute;
    top: 0.35rem;
    right: 0.35rem;
  }

  .inventory-tile__name {
    padding: 0 0.5rem;
    font-size: 0.85rem;
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .inventory-tile__meta {
    padding: 0 0.5rem 0.5rem;
    font-size: 0.75rem;
  }

  .inventory-badge {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15rem 0.4rem;
    border: 1px solid currentColor;
  }

  .inventory-badge--low {
    color: #922;
    border-color: #c44;
    background: rgba(200, 60, 60, 0.08);
  }

  .inventory-modal {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0;
  }

  .inventory-modal[hidden] {
    display: none;
  }

  .inventory-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }

  .inventory-modal__panel {
    position: relative;
    z-index: 1;
    width: min(100%, 32rem);
    max-height: 90vh;
    overflow: auto;
    padding: 1.25rem;
    background: var(--color-booking-panel-bg);
    border: 1px solid var(--color-border);
    box-shadow: 0 12px 48px var(--color-card-shadow);
  }

  .inventory-modal__panel--narrow {
    width: min(100%, 24rem);
  }

  .inventory-modal__panel--scanner {
    width: min(100%, 28rem);
  }

  .inventory-modal__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .inventory-modal__head h2 {
    margin: 0;
    font-size: 1.15rem;
  }

  .inventory-modal__close {
    border: none;
    background: none;
    font-size: 1.75rem;
    line-height: 1;
    padding: 0.15rem 0.35rem;
    cursor: pointer;
  }

  .inventory-scanner__video {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background: #111;
    border: 1px solid var(--color-border);
  }

  .inventory-scanner__hint {
    margin: 0.65rem 0 0;
    font-size: 0.9rem;
    color: var(--color-gray);
  }

  .inventory-scanner__error:empty {
    display: none;
  }

  .inventory-scanner__manual {
    display: grid;
    gap: 0.65rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .inventory-detail__image-wrap {
    margin-bottom: 0.75rem;
  }

  .inventory-detail__image {
    width: 100%;
    max-height: 12rem;
    object-fit: contain;
    border: 1px solid var(--color-border);
    background: var(--color-booking-panel-bg);
  }

  .inventory-detail__meta {
    margin: 0 0 0.5rem;
    color: var(--color-gray);
    font-size: 0.9rem;
  }

  .inventory-detail__qty {
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 1.35rem;
    font-weight: 600;
  }

  .inventory-detail__qty--low {
    color: #922;
  }

  .inventory-detail__actions {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .inventory-detail__edit {
    grid-column: 1 / -1;
  }

  .form-hint {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    letter-spacing: normal;
    text-transform: none;
    color: var(--color-gray);
    line-height: 1.35;
  }

  .inventory-detail__history-title {
    font-size: 0.95rem;
    margin: 0 0 0.5rem;
  }

  .inventory-history {
    display: grid;
    gap: 0.5rem;
  }

  .inventory-history__row {
    display: grid;
    gap: 0.1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border-subtle);
    font-size: 0.9rem;
  }

  .inventory-history__loading {
    margin: 0;
    color: var(--color-gray);
    font-size: 0.9rem;
  }

  :global(body.inventory-modal-open) {
    overflow: hidden;
  }

  @media (min-width: 40rem) {
    .inventory-page__actions--desktop {
      display: flex;
    }

    .inventory-scan-bar {
      display: none;
    }

    .inventory-page {
      padding-bottom: 0;
    }

    .inventory-page__scan {
      background: var(--color-dusty-rose-dark, var(--color-charcoal));
    }

    .inventory-modal {
      align-items: center;
      padding: 1rem;
    }

    .inventory-detail__actions {
      grid-template-columns: repeat(4, 1fr);
    }

    .inventory-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
