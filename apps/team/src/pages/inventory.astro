---
import TeamLayout from "../layouts/TeamLayout.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";

const { staff } = Astro.locals;
const isManager = isSalonManager(staff);

const filterCategories = [
  "Category",
  "Brand",
  "Stock Level",
  "Low Stock",
  "Location",
  "Tags",
];
---

<TeamLayout title="Stock" activeNav="stock" plain wide fullBleed>
  <div
    class="stock-page"
    data-inventory-root
    data-is-manager={isManager ? "1" : "0"}
  >
    <header class="stock-page__subheader">
      <h1 class="stock-page__title">Stock</h1>
      <div class="stock-page__header-actions">
        <button class="stock-page__btn-secondary stock-page__scan-desktop" type="button" data-scan-open>
          Scan to check in
        </button>
        {
          isManager ? (
            <button class="stock-page__btn-primary" type="button" data-add-open>
              Add product
            </button>
          ) : null
        }
      </div>
    </header>

    <div class="stock-page__body">
      <aside class="stock-page__sidebar" aria-label="Refine your search">
        <h2 class="stock-page__sidebar-title">Refine Your Search</h2>
        <div class="stock-page__filters">
          {
            filterCategories.map((label) => (
              <details class="stock-filter">
                <summary class="stock-filter__trigger">
                  <span>{label}</span>
                  <svg class="stock-filter__chevron" viewBox="0 0 24 24" aria-hidden="true" fill="none">
                    <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </summary>
                <div class="stock-filter__body">
                  <p class="stock-filter__placeholder">Filter options coming soon.</p>
                </div>
              </details>
            ))
          }
        </div>
        <label class="stock-page__sidebar-filter">
          <input type="checkbox" data-low-stock-filter />
          Low stock only
        </label>
        <button class="stock-page__export" type="button" data-coming-soon>
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
            <path d="M12 3v12M7 10l5 5 5-5M5 21h14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          Export current list
        </button>
      </aside>

      <main class="stock-page__main">
        <h2 class="stock-page__main-title">Your Products</h2>
        <p class="stock-page__stats">
          Total: <span data-total-count>—</span>
          · Low stock: <span data-low-stock-count>—</span>
          · <span data-filter-count>0</span> filters applied
        </p>

        <p class="stock-page__notice stock-page__notice--banner" data-low-stock-banner hidden></p>

        <label class="stock-page__search">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.75"></circle>
            <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
          </svg>
          <input
            class="stock-page__search-input"
            type="search"
            placeholder="Search by name, brand, barcode, SKU, or category"
            autocomplete="off"
            data-search
          />
        </label>

        <p class="stock-page__notice" data-status hidden aria-live="polite"></p>

        <div class="stock-page__list" data-product-list>
          <p class="stock-page__empty">Loading products…</p>
        </div>
      </main>
    </div>

    <div class="stock-scan-bar">
      <button class="stock-page__btn-primary stock-scan-bar__btn" type="button" data-scan-open>
        Scan to check in
      </button>
    </div>
  </div>

  <!-- Scanner modal -->
  <div class="inventory-modal" data-scan-modal hidden>
    <div class="inventory-modal__backdrop" data-modal-close="scan"></div>
    <div class="inventory-modal__panel inventory-modal__panel--scanner" role="dialog" aria-modal="true" aria-labelledby="scan-title">
      <div class="inventory-modal__head">
        <h2 id="scan-title">Scan to check in</h2>
        <button class="inventory-modal__close" type="button" data-modal-close="scan" aria-label="Close">×</button>
      </div>
      <div class="inventory-scanner">
        <video class="inventory-scanner__video" data-scan-video playsinline muted autoplay></video>
        <p class="inventory-scanner__hint">
          Point your camera at a barcode (UPC/EAN) or QR code on the product
        </p>
        <p class="inventory-scanner__error" data-scan-error></p>
        <div class="inventory-scanner__manual">
          <label class="inventory-form-label">
            Or enter code manually
            <input class="inventory-form-input" type="text" data-manual-barcode placeholder="Barcode or QR value" />
          </label>
          <button class="stock-page__btn-secondary" type="button" data-manual-barcode-submit>
            Check in
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Transaction modal -->
  <div class="inventory-modal" data-tx-modal hidden>
    <div class="inventory-modal__backdrop" data-modal-close="tx"></div>
    <div class="inventory-modal__panel inventory-modal__panel--narrow" role="dialog" aria-modal="true" aria-labelledby="tx-title">
      <div class="inventory-modal__head">
        <h2 id="tx-title" data-tx-title>Log transaction</h2>
        <button class="inventory-modal__close" type="button" data-modal-close="tx" aria-label="Close">×</button>
      </div>
      <label class="inventory-form-label">
        Quantity
        <input class="inventory-form-input" type="number" step="any" min="0" data-tx-qty />
      </label>
      <label class="inventory-form-label">
        Notes (optional)
        <textarea class="inventory-form-input inventory-form-input--textarea" rows="2" data-tx-notes></textarea>
      </label>
      <button class="stock-page__btn-primary" type="button" data-tx-submit>Save</button>
    </div>
  </div>

  <!-- Add product modal (managers) -->
  {
    isManager ? (
      <div class="inventory-modal" data-add-modal hidden>
        <div class="inventory-modal__backdrop" data-modal-close="add" />
        <div
          class="inventory-modal__panel inventory-modal__panel--narrow"
          role="dialog"
          aria-modal="true"
          aria-labelledby="add-title"
        >
          <div class="inventory-modal__head">
            <h2 id="add-title">Add product</h2>
            <button
              class="inventory-modal__close"
              type="button"
              data-modal-close="add"
              aria-label="Close"
            >
              ×
            </button>
          </div>
          <form class="inventory-form-stack" data-add-form>
            <label class="inventory-form-label">
              Name
              <input class="inventory-form-input" name="name" required />
            </label>
            <label class="inventory-form-label">
              Barcode
              <input class="inventory-form-input" name="barcode" inputmode="numeric" />
            </label>
            <label class="inventory-form-label">
              Brand
              <input class="inventory-form-input" name="brand" />
            </label>
            <label class="inventory-form-label">
              Category
              <input
                class="inventory-form-input"
                name="category"
                placeholder="color, shampoo, developer…"
              />
            </label>
            <label class="inventory-form-label">
              Unit
              <input class="inventory-form-input" name="unit" value="each" />
            </label>
            <label class="inventory-form-label">
              Reorder threshold
              <span class="inventory-form-hint">
                When on-hand quantity is at or below this number, the product is flagged as low stock. Use 0 to disable alerts.
              </span>
              <input
                class="inventory-form-input"
                name="reorder_threshold"
                type="number"
                min="0"
                step="1"
                value="0"
              />
            </label>
            <label class="inventory-form-label">
              Image URL
              <span class="inventory-form-hint">
                Public URL (external link or Supabase Storage product-images bucket).
              </span>
              <input
                class="inventory-form-input"
                name="image_url"
                type="url"
                placeholder="https://…"
                inputmode="url"
              />
            </label>
            <label class="inventory-form-label">
              Initial quantity
              <input
                class="inventory-form-input"
                name="initial_quantity"
                type="number"
                min="0"
                step="any"
                value="0"
              />
            </label>
            <label class="inventory-form-label">
              Notes
              <textarea class="inventory-form-input inventory-form-input--textarea" name="notes" rows="2" />
            </label>
            <button class="stock-page__btn-primary" type="submit">
              Create product
            </button>
          </form>
        </div>
      </div>
    ) : null
  }

  <!-- Edit product modal (managers) -->
  {
    isManager ? (
      <div class="inventory-modal" data-edit-modal hidden>
        <div class="inventory-modal__backdrop" data-modal-close="edit" />
        <div
          class="inventory-modal__panel inventory-modal__panel--narrow"
          role="dialog"
          aria-modal="true"
          aria-labelledby="edit-title"
        >
          <div class="inventory-modal__head">
            <h2 id="edit-title">Edit product</h2>
            <button
              class="inventory-modal__close"
              type="button"
              data-modal-close="edit"
              aria-label="Close"
            >
              ×
            </button>
          </div>
          <form class="inventory-form-stack" data-edit-form>
            <label class="inventory-form-label">
              Name
              <input class="inventory-form-input" name="name" required />
            </label>
            <label class="inventory-form-label">
              Barcode
              <input class="inventory-form-input" name="barcode" inputmode="numeric" />
            </label>
            <label class="inventory-form-label">
              Category
              <input
                class="inventory-form-input"
                name="category"
                placeholder="color, shampoo, developer…"
              />
            </label>
            <label class="inventory-form-label">
              Reorder threshold
              <span class="inventory-form-hint">
                When on-hand quantity is at or below this number, the product is flagged as low stock. Use 0 to disable alerts.
              </span>
              <input
                class="inventory-form-input"
                name="reorder_threshold"
                type="number"
                min="0"
                step="1"
              />
            </label>
            <label class="inventory-form-label">
              Image URL
              <span class="inventory-form-hint">
                Public URL (external link or Supabase Storage product-images bucket).
              </span>
              <input
                class="inventory-form-input"
                name="image_url"
                type="url"
                placeholder="https://…"
                inputmode="url"
              />
            </label>
            <button class="stock-page__btn-primary" type="submit">
              Save changes
            </button>
          </form>
        </div>
      </div>
    ) : null
  }

  <div class="stock-toast" data-toast hidden role="status"></div>

  <script define:vars={{ apiBase: teamUrl("") }}>
    document.body.dataset.apiBase = apiBase;
  </script>
  <script src="../scripts/inventory.ts"></script>
</TeamLayout>

<style>
  .stock-page {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - var(--team-bar-height, 3.25rem));
    font-family: var(--font-sans);
    background: #fff;
    color: #111827;
    padding-bottom: calc(5rem + env(safe-area-inset-bottom, 0px));
  }

  .stock-page__subheader {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid #e5e7eb;
    background: #fff;
  }

  .stock-page__title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .stock-page__header-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .stock-page__btn-primary,
  .stock-page__btn-secondary {
    padding: 0.55rem 0.9rem;
    border-radius: 0.25rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .stock-page__btn-primary {
    border: none;
    background: #0096ff;
    color: #fff;
  }

  .stock-page__btn-primary:hover,
  .stock-page__btn-primary:focus-visible {
    background: #0084e0;
    outline: none;
  }

  .stock-page__btn-secondary {
    border: 1px solid #e5e7eb;
    background: #fff;
    color: #374151;
  }

  .stock-page__btn-secondary:hover,
  .stock-page__btn-secondary:focus-visible {
    background: #f9fafb;
    outline: none;
  }

  .stock-page__scan-desktop {
    display: none;
  }

  .stock-page__body {
    display: grid;
    grid-template-columns: minmax(220px, 23%) 1fr;
    flex: 1;
    min-height: 0;
  }

  .stock-page__sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem 0.85rem 1.25rem;
    border-right: 1px solid #e5e7eb;
    background: #f9fafb;
  }

  .stock-page__sidebar-title {
    margin: 0 0 0.35rem;
    padding: 0 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    color: #374151;
  }

  .stock-page__filters {
    display: grid;
    gap: 0;
    flex: 1;
    overflow-y: auto;
  }

  .stock-filter {
    border-bottom: 1px solid #e5e7eb;
  }

  .stock-filter__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.65rem 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: #374151;
    cursor: pointer;
    list-style: none;
  }

  .stock-filter__trigger::-webkit-details-marker {
    display: none;
  }

  .stock-filter__chevron {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: #9ca3af;
    transition: transform 0.15s ease;
  }

  .stock-filter[open] .stock-filter__chevron {
    transform: rotate(180deg);
  }

  .stock-filter__body {
    padding: 0 0.35rem 0.75rem;
  }

  .stock-filter__placeholder {
    margin: 0;
    font-size: 0.75rem;
    color: #9ca3af;
  }

  .stock-page__sidebar-filter {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: #374151;
    cursor: pointer;
  }

  .stock-page__sidebar-filter input {
    width: 1rem;
    height: 1rem;
    accent-color: #0096ff;
  }

  .stock-page__export {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    margin-top: auto;
    padding: 0.55rem 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.25rem;
    background: #fff;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: #374151;
    cursor: pointer;
  }

  .stock-page__export svg {
    width: 1rem;
    height: 1rem;
  }

  .stock-page__export:hover,
  .stock-page__export:focus-visible {
    background: #f3f4f6;
    outline: none;
  }

  .stock-page__main {
    padding: 1.25rem 1.5rem 2rem;
    background: #fff;
    min-width: 0;
  }

  .stock-page__main-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: #111827;
  }

  .stock-page__stats {
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: #6b7280;
  }

  .stock-page__search {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1rem;
    padding: 0.55rem 0.85rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.25rem;
    background: #fff;
  }

  .stock-page__search svg {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
    color: #9ca3af;
  }

  .stock-page__search-input {
    flex: 1;
    min-width: 0;
    border: none;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: #111827;
    outline: none;
  }

  .stock-page__search-input::placeholder {
    color: #9ca3af;
  }

  .stock-page__notice {
    margin: 0 0 0.75rem;
    font-size: 0.8125rem;
    color: #6b7280;
  }

  .stock-page__notice--error {
    color: #b91c1c;
  }

  .stock-page__notice--banner {
    padding: 0.65rem 0.85rem;
    border: 1px solid #fcd34d;
    border-radius: 0.25rem;
    background: #fffbeb;
    color: #92400e;
  }

  .stock-page__notice--banner.stock-page__notice--actionable {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
  }

  .stock-page__list {
    display: grid;
    gap: 1rem;
  }

  .stock-category__title {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    text-transform: capitalize;
  }

  .stock-category__count {
    font-weight: 400;
    color: #9ca3af;
  }

  .stock-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .stock-card {
    border: 1px solid #e5e7eb;
    border-radius: 0.3rem;
    background: #fff;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .stock-card:hover {
    border-color: #d1d5db;
  }

  .stock-card--expanded {
    grid-column: 1 / -1;
    border-color: #0096ff;
    box-shadow: 0 2px 12px rgba(0, 150, 255, 0.1);
  }

  .stock-card--low {
    border-color: #fca5a5;
  }

  .stock-card--low.stock-card--expanded {
    border-color: #f87171;
  }

  .stock-card__header {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.3rem;
    width: 100%;
    padding: 0.35rem;
    border: none;
    background: transparent;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
  }

  .stock-card--expanded .stock-card__header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0.75rem;
  }

  .stock-card__header:focus-visible {
    outline: 2px solid #0096ff;
    outline-offset: -2px;
  }

  .stock-card__thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    flex-shrink: 0;
    border-radius: 0.2rem;
    background: #f3f4f6;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stock-card--expanded .stock-card__thumb {
    width: 3rem;
    height: 3rem;
    aspect-ratio: auto;
  }

  .stock-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .stock-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: #9ca3af;
  }

  .stock-card__placeholder svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .stock-card__badge {
    position: absolute;
    top: 0.15rem;
    right: 0.15rem;
    font-family: var(--font-sans);
    font-size: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 0.08rem 0.25rem;
    border-radius: 0.12rem;
    color: #991b1b;
    background: #fef2f2;
    border: 1px solid #fecaca;
  }

  .stock-card__summary {
    display: grid;
    gap: 0.1rem;
    min-width: 0;
  }

  .stock-card__name {
    font-size: 0.6875rem;
    font-weight: 600;
    color: #111827;
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .stock-card--expanded .stock-card__name {
    font-size: 0.875rem;
    -webkit-line-clamp: unset;
    display: block;
  }

  .stock-card__meta {
    font-size: 0.625rem;
    color: #6b7280;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .stock-card--expanded .stock-card__meta {
    font-size: 0.75rem;
  }

  .stock-card__chevron {
    display: none;
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
    color: #9ca3af;
    transition: transform 0.25s ease;
  }

  .stock-card--expanded .stock-card__chevron {
    display: block;
    transform: rotate(180deg);
  }

  .stock-card__expand {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }

  .stock-card--expanded .stock-card__expand {
    grid-template-rows: 1fr;
  }

  .stock-card__body {
    overflow: hidden;
  }

  .stock-card__body-inner {
    padding: 0 0.75rem 0.75rem;
    border-top: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .stock-card--expanded .stock-card__body-inner {
    border-top-color: #f3f4f6;
    padding-top: 0.75rem;
  }

  .stock-card__detail-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem 1rem;
    margin-bottom: 0.85rem;
  }

  .stock-card__detail-item {
    display: grid;
    gap: 0.1rem;
  }

  .stock-card__detail-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #9ca3af;
  }

  .stock-card__detail-value {
    font-size: 0.8125rem;
    color: #374151;
  }

  .stock-card__detail-value--qty {
    font-size: 1.05rem;
    font-weight: 600;
    color: #111827;
  }

  .stock-card__detail-value--qty-low {
    color: #991b1b;
  }

