---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamListLayout from "../components/TeamListLayout.astro";
import UiScrollRow from "../components/ui/UiScrollRow.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";
import { defaultReportRangeDates } from "../lib/report-range";

const { staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

if (!isSalonManager(staff)) {
  return Astro.redirect(teamUrl("/"));
}

const { fromDate, toDate } = defaultReportRangeDates();

const NAV_SECTIONS = [
  { id: "reports-overview", label: "Overview", short: "Revenue", exportKey: "revenue" },
  { id: "reports-appointments", label: "Appointments", short: "Staff", exportKey: "appointments" },
  { id: "reports-cancellations", label: "Cancellations", short: "Cancels", exportKey: "cancellations" },
  { id: "reports-status", label: "Appointment status", short: "Status", exportKey: "cancellations" },
  { id: "reports-inventory", label: "Low stock", short: "Stock", exportKey: "inventory" },
];

const PRESETS = [
  { value: "today", label: "Today" },
  { value: "this-week", label: "This week" },
  { value: "last-week", label: "Last week" },
  { value: "this-month", label: "This month" },
  { value: "last-month", label: "Last month" },
  { value: "ytd", label: "YTD" },
  { value: "custom", label: "Custom" },
];
---

<TeamLayout title="Reports" activeNav="reports" plain wide fullBleed>
  <div
    class="reports-page"
    data-reports-app
    data-api-base={teamUrl("/api/reports")}
    data-inventory-url={teamUrl("/inventory")}
    data-from={fromDate}
    data-to={toDate}
  >
    <TeamListLayout title="Reports" mainTitle="Business summaries" sidebarTitle="Sections">
      <nav slot="sidebarExtra" class="team-list-layout__sidebar-nav reports-nav" aria-label="Report sections">
        {
          NAV_SECTIONS.map((section) => (
            <a
              class="team-list-layout__sidebar-link reports-nav__link"
              href={`#${section.id}`}
              data-nav-link={section.id}
            >
              {section.label}
            </a>
          ))
        }
      </nav>

      <Fragment slot="mainLead">Live salon data. Pick a range to update every section.</Fragment>

      <div class="reports-tabs" data-reports-tabs>
        <UiScrollRow label="Report sections">
          {
            NAV_SECTIONS.map((section, index) => (
              <button
                type="button"
                class:list={["reports-tabs__btn", { "is-active": index === 0 }]}
                data-report-tab={section.id}
                data-export-key={section.exportKey}
                aria-selected={index === 0 ? "true" : "false"}
              >
                <span class="reports-tabs__long">{section.label}</span>
                <span class="reports-tabs__short">{section.short}</span>
              </button>
            ))
          }
        </UiScrollRow>
      </div>

      <div slot="toolbar" class="reports-toolbar">
        <div class="reports-toolbar__presets-wrap">
          <UiScrollRow label="Date range presets">
            <div class="reports-toolbar__presets ui-segmented" role="group" aria-label="Date range presets">
              {
                PRESETS.map((preset) => (
                  <button
                    type="button"
                    class="ui-segmented__item reports-preset"
                    data-preset={preset.value}
                    aria-pressed="false"
                  >
                    {preset.label}
                  </button>
                ))
              }
            </div>
          </UiScrollRow>
        </div>

        <div class="reports-toolbar__custom" data-custom-range hidden>
          <label class="reports-toolbar__field">
            <span class="reports-toolbar__field-label">From</span>
            <span class="reports-toolbar__date">
              <input class="form-input reports-toolbar__date-input" type="date" data-range-from value={fromDate} />
            </span>
          </label>
          <label class="reports-toolbar__field">
            <span class="reports-toolbar__field-label">To</span>
            <span class="reports-toolbar__date">
              <input class="form-input reports-toolbar__date-input" type="date" data-range-to value={toDate} />
            </span>
          </label>
        </div>

        <div class="reports-toolbar__actions">
          <button class="ui-btn ui-btn--secondary ui-btn--compact reports-toolbar__refresh" type="button" data-range-apply>
            Refresh
          </button>

          <button
            class="ui-btn ui-btn--secondary ui-btn--compact reports-toolbar__export"
            type="button"
            data-export-btn
            disabled
            title="Export the visible report section as CSV"
          >
            Export revenue CSV
          </button>
        </div>

        <p class="reports-toolbar__meta">
          <span class="reports-toolbar__range" data-range-label aria-live="polite"></span>
          <span class="reports-toolbar__refreshed" data-refreshed-label></span>
        </p>
      </div>

      <p class="notice notice--error reports-error" data-reports-error hidden role="alert"></p>

      <section class="reports-section" id="reports-overview" aria-labelledby="reports-overview-title">
        <div class="reports-section__head">
          <h2 class="reports-section__title" id="reports-overview-title">Overview</h2>
        </div>
        <div class="reports-metrics" data-revenue-stats>
          <p class="empty-state">Loading reports…</p>
        </div>
      </section>

      <section class="team-panel reports-section" id="reports-appointments" aria-labelledby="reports-appointments-title">
        <h2 class="team-panel__title reports-section__title" id="reports-appointments-title">Appointments by staff</h2>
        <div class="team-data-table-wrap" data-staff-table>
          <p class="empty-state">Loading…</p>
        </div>
      </section>

      <section class="team-panel reports-section" id="reports-cancellations" aria-labelledby="reports-cancellations-title">
        <h2 class="team-panel__title reports-section__title" id="reports-cancellations-title">Cancellations &amp; no-shows</h2>
        <div data-cancel-stats>
          <p class="empty-state">Loading…</p>
        </div>
      </section>

      <section class="team-panel reports-section" id="reports-status" aria-labelledby="reports-status-title">
        <h2 class="team-panel__title reports-section__title" id="reports-status-title">Appointment status</h2>
        <div data-status-stats>
          <p class="empty-state">Loading…</p>
        </div>
      </section>

      <section class="team-panel reports-section" id="reports-inventory" aria-labelledby="reports-inventory-title">
        <h2 class="team-panel__title reports-section__title" id="reports-inventory-title">Low stock inventory</h2>
        <div data-inventory-stats>
          <p class="empty-state">Loading…</p>
        </div>
      </section>
    </TeamListLayout>
  </div>
</TeamLayout>

<script src="../scripts/reports.ts"></script>

<!--
  is:global — reports.ts injects section markup via innerHTML, so scoped
  selectors (with Astro's data-astro-cid attribute) would never match that DOM.
  Class names are page-unique (reports-*). Sidebar chrome: team-list-sidebar.css.
-->
<style is:global>
  .reports-page {
    min-width: 0;
    overflow-x: clip;
  }

  /* Toolbar --------------------------------------------------------------- */
  .reports-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--mobile-space-sm);
    width: 100%;
    min-width: 0;
  }

  .reports-toolbar__presets-wrap {
    flex: 1 1 100%;
    min-width: 0;
  }

  .reports-toolbar__presets {
    flex-wrap: nowrap;
    width: max-content;
    min-width: min(100%, max-content);
  }

  .reports-toolbar__presets .ui-segmented__item {
    flex: 0 0 auto;
    white-space: nowrap;
    padding-inline: 0.65rem;
  }

  .reports-preset[aria-pressed="true"] {
    background: var(--color-bg);
    color: var(--color-stone-800);
    box-shadow: inset 0 0 0 2px var(--color-selection-border);
  }

  .reports-toolbar__custom {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: var(--mobile-space-sm);
    flex: 1 1 100%;
  }

  .reports-toolbar__custom[hidden] {
    display: none;
  }

  .reports-toolbar__field {
    display: grid;
    gap: 0.25rem;
    flex: 1 1 8rem;
    min-width: 0;
  }

  .reports-toolbar__field-label {
    font-size: var(--ui-label-size, var(--text-xs));
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-400);
  }

  .reports-toolbar__date {
    display: block;
    min-width: 0;
  }

  .reports-toolbar__date-input {
    width: 100%;
    min-height: var(--touch-target-min);
  }

  .reports-toolbar__actions {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--mobile-space-xs);
    margin-left: auto;
  }

  .reports-toolbar__refresh,
  .reports-toolbar__export {
    min-height: var(--touch-target-min);
  }

  .reports-toolbar__export:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .reports-toolbar__meta {
    flex-basis: 100%;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.75rem;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-stone-500);
  }

  .reports-toolbar__range {
    font-weight: 600;
    color: var(--color-stone-700);
  }

  .reports-toolbar__refreshed {
    color: var(--color-stone-400);
  }

  .reports-error {
    margin: 0 0 1rem;
  }

  .reports-error[hidden] {
    display: none;
  }

  /* Mobile section tabs --------------------------------------------------- */
  .reports-tabs {
    display: none;
    margin: 0 0 var(--mobile-space-sm);
    min-width: 0;
  }

  .reports-tabs__btn {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-stone-200);
    border-radius: 999px;
    background: var(--color-bg);
    color: var(--color-stone-600);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    white-space: nowrap;
    cursor: pointer;
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .reports-tabs__btn:hover,
  .reports-tabs__btn:focus-visible {
    color: var(--color-text);
    border-color: var(--color-stone-300);
    outline: none;
  }

  .reports-tabs__btn.is-active,
  .reports-tabs__btn[aria-selected="true"] {
    color: var(--color-text);
    border-color: var(--color-sage);
    background: var(--color-selection-bg, rgba(141, 158, 136, 0.12));
    box-shadow: inset 0 0 0 1px var(--color-sage);
  }

  .reports-tabs__short {
    display: none;
  }

  .reports-revenue-def {
    margin: 0 0 0.75rem;
    grid-column: 1 / -1;
    font-size: var(--text-sm);
    color: var(--color-stone-500);
    line-height: var(--leading-normal);
  }

  /* Sections -------------------------------------------------------------- */
  .reports-section {
    margin-top: 1.25rem;
    scroll-margin-top: calc(var(--team-bar-height, 3.25rem) + 1rem);
  }

  .reports-section:first-of-type {
    margin-top: 0;
  }

  .reports-section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.65rem;
  }

  .reports-section__title {
    scroll-margin-top: calc(var(--team-bar-height, 3.25rem) + 1rem);
  }

  /* Compact metric cards -------------------------------------------------- */
  .reports-metrics {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
    gap: 0.75rem;
  }

  .reports-metric {
    display: grid;
    gap: 0.2rem;
    align-content: start;
    padding: 0.85rem 0.95rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
  }

  .reports-metric__label {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-400);
  }

  .reports-metric__value {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.1;
    color: var(--color-stone-800);
    font-variant-numeric: tabular-nums;
  }

  .reports-metric__meta {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

  /* Info tooltip glyph */
  .reports-info {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 0.95rem;
    height: 0.95rem;
    border-radius: 50%;
    border: 1px solid var(--color-stone-300);
    font-size: 0.6rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-stone-400);
    cursor: help;
  }

  /* Cancellations single-row panel --------------------------------------- */
  .reports-cancel-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: 0.5rem 1.5rem;
    padding: 0.35rem 0;
  }

  .reports-cancel-cell {
    display: grid;
    gap: 0.1rem;
  }

  .reports-cancel-cell__label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-400);
  }

  .reports-cancel-cell__value {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--color-stone-800);
    font-variant-numeric: tabular-nums;
  }

  .reports-cancel-cell__value--flag {
    color: var(--color-error);
  }

  .reports-cancel-cell__meta {
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

  /* Empty / status states ------------------------------------------------- */
  .reports-state.ui-empty {
    justify-items: center;
  }

  .reports-state.ui-empty--compact {
    padding: var(--mobile-space-md);
  }

  .reports-skeleton {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
    gap: 0.75rem;
  }

  .reports-skeleton__card {
    height: 4.75rem;
    border-radius: var(--radius-md);
    background: linear-gradient(
      90deg,
      var(--color-stone-100) 25%,
      var(--color-stone-50) 37%,
      var(--color-stone-100) 63%
    );
    background-size: 400% 100%;
    animation: reports-shimmer 1.4s ease infinite;
  }

  @keyframes reports-shimmer {
    0% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reports-skeleton__card {
      animation: none;
    }
  }

  /* Sidebar nav sits directly under the section title, no big gaps */
  .reports-nav {
    flex: 0 0 auto;
  }

  .reports-section.is-mobile-hidden {
    display: none;
  }

  @media (max-width: 900px) {
    .reports-tabs {
      display: block;
    }

    .reports-page :global(.team-list-layout__sidebar) {
      display: none;
    }

    .reports-page :global(.team-list-layout__main-lead) {
      display: none;
    }

    .reports-toolbar__actions {
      margin-left: 0;
      width: 100%;
    }

    .reports-toolbar__refresh,
    .reports-toolbar__export {
      flex: 1 1 calc(50% - 0.25rem);
    }
  }

  @media (max-width: 640px) {
    .reports-toolbar__field {
      flex-basis: 100%;
    }

    .reports-toolbar__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .reports-toolbar__refresh,
    .reports-toolbar__export {
      width: 100%;
    }
  }

  @media (max-width: 380px) {
    .reports-tabs__long {
      display: none;
    }

    .reports-tabs__short {
      display: inline;
    }

    .reports-tabs__btn {
      min-height: 2rem;
      padding-inline: 0.55rem;
      font-size: 0.75rem;
    }
  }
</style>
