---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamListLayout from "../components/TeamListLayout.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";
import { defaultReportRangeDates } from "../lib/report-range";

const { staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

if (!isSalonManager(staff)) {
  return Astro.redirect(teamUrl("/"));
}

const { fromDate, toDate } = defaultReportRangeDates();

const NAV_SECTIONS = [
  { id: "reports-overview", label: "Overview" },
  { id: "reports-appointments", label: "Appointments" },
  { id: "reports-cancellations", label: "Cancellations" },
  { id: "reports-status", label: "Appointment status" },
  { id: "reports-inventory", label: "Low stock" },
];

const PRESETS = [
  { value: "today", label: "Today" },
  { value: "this-week", label: "This week" },
  { value: "last-week", label: "Last week" },
  { value: "this-month", label: "This month" },
  { value: "last-month", label: "Last month" },
  { value: "ytd", label: "YTD" },
  { value: "custom", label: "Custom" },
];
---

<TeamLayout title="Reports" activeNav="reports" plain wide fullBleed>
  <div
    class="reports-page"
    data-reports-app
    data-api-base={teamUrl("/api/reports")}
    data-inventory-url={teamUrl("/inventory")}
    data-from={fromDate}
    data-to={toDate}
  >
    <TeamListLayout title="Reports" mainTitle="Business summaries" sidebarTitle="Sections">
      <nav slot="sidebarExtra" class="team-list-layout__sidebar-nav reports-nav" aria-label="Report sections">
        {
          NAV_SECTIONS.map((section) => (
            <a
              class="team-list-layout__sidebar-link reports-nav__link"
              href={`#${section.id}`}
              data-nav-link={section.id}
            >
              {section.label}
            </a>
          ))
        }
      </nav>

      <Fragment slot="mainLead">Live salon data. Pick a range to update every section.</Fragment>

      <div slot="toolbar" class="reports-toolbar">
        <div class="reports-toolbar__presets" role="group" aria-label="Date range presets">
          {
            PRESETS.map((preset) => (
              <button
                type="button"
                class="reports-preset"
                data-preset={preset.value}
                aria-pressed="false"
              >
                {preset.label}
              </button>
            ))
          }
        </div>

        <div class="reports-toolbar__custom" data-custom-range hidden>
          <label class="reports-toolbar__field">
            <span class="reports-toolbar__field-label">From</span>
            <input class="inventory-form-input" type="date" data-range-from value={fromDate} />
          </label>
          <label class="reports-toolbar__field">
            <span class="reports-toolbar__field-label">To</span>
            <input class="inventory-form-input" type="date" data-range-to value={toDate} />
          </label>
        </div>

        <div class="reports-toolbar__actions">
          <button class="team-list-layout__btn-secondary reports-toolbar__refresh" type="button" data-range-apply>
            Refresh
          </button>

          <div class="reports-export" data-export>
            <button
              class="team-list-layout__btn-secondary reports-export__trigger"
              type="button"
              data-export-trigger
              aria-haspopup="true"
              aria-expanded="false"
            >
              Export
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </button>
            <div class="reports-export__menu" data-export-menu hidden role="menu">
              <button type="button" role="menuitem" data-export-section="all">Full report (CSV)</button>
              <button type="button" role="menuitem" data-export-section="revenue">Revenue summary</button>
              <button type="button" role="menuitem" data-export-section="appointments">Appointments by staff</button>
              <button type="button" role="menuitem" data-export-section="cancellations">Cancellations &amp; no-shows</button>
              <button type="button" role="menuitem" data-export-section="inventory">Low stock inventory</button>
            </div>
          </div>
        </div>

        <p class="reports-toolbar__meta">
          <span class="reports-toolbar__range" data-range-label aria-live="polite"></span>
          <span class="reports-toolbar__refreshed" data-refreshed-label></span>
        </p>
      </div>

      <p class="notice notice--error reports-error" data-reports-error hidden role="alert"></p>

      <section class="reports-section" id="reports-overview" aria-labelledby="reports-overview-title">
        <div class="reports-section__head">
          <h2 class="reports-section__title" id="reports-overview-title">Overview</h2>
        </div>
        <div class="reports-metrics" data-revenue-stats>
          <p class="empty-state">Loading reports…</p>
        </div>
      </section>

      <section class="team-panel reports-section" id="reports-appointments" aria-labelledby="reports-appointments-title">
        <h2 class="team-panel__title reports-section__title" id="reports-appointments-title">Appointments by staff</h2>
        <div class="team-data-table-wrap" data-staff-table>
          <p class="empty-state">Loading…</p>
        </div>
      </section>

      <section class="team-panel reports-section" id="reports-cancellations" aria-labelledby="reports-cancellations-title">
        <h2 class="team-panel__title reports-section__title" id="reports-cancellations-title">Cancellations &amp; no-shows</h2>
        <div data-cancel-stats>
          <p class="empty-state">Loading…</p>
        </div>
      </section>

      <section class="team-panel reports-section" id="reports-status" aria-labelledby="reports-status-title">
        <h2 class="team-panel__title reports-section__title" id="reports-status-title">Appointment status</h2>
        <div data-status-stats>
          <p class="empty-state">Loading…</p>
        </div>
      </section>

      <section class="team-panel reports-section" id="reports-inventory" aria-labelledby="reports-inventory-title">
        <h2 class="team-panel__title reports-section__title" id="reports-inventory-title">Low stock inventory</h2>
        <div data-inventory-stats>
          <p class="empty-state">Loading…</p>
        </div>
      </section>
    </TeamListLayout>
  </div>
</TeamLayout>

<script src="../scripts/reports.ts"></script>

<!--
  is:global — reports.ts injects section markup via innerHTML, so scoped
  selectors (with Astro's data-astro-cid attribute) would never match that DOM.
  Class names are page-unique (reports-*). Sidebar chrome: team-list-sidebar.css.
-->
<style is:global>
  .reports-page {
    min-width: 0;
    overflow-x: clip;
  }

  /* Toolbar --------------------------------------------------------------- */
  .reports-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
    width: 100%;
  }

  .reports-toolbar__presets {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    padding: 0.2rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-stone-50);
  }

  .reports-preset {
    padding: 0.35rem 0.7rem;
    border: none;
    border-radius: var(--radius-sm);
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-stone-600);
    cursor: pointer;
    transition:
      background var(--transition-fast),
      color var(--transition-fast);
  }

  .reports-preset:hover,
  .reports-preset:focus-visible {
    background: var(--color-stone-100);
    color: var(--color-stone-800);
    outline: none;
  }

  .reports-preset[aria-pressed="true"] {
    background: var(--color-citrine);
    color: var(--color-black);
    font-weight: 600;
  }

  .reports-toolbar__custom {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .reports-toolbar__custom[hidden] {
    display: none;
  }

  .reports-toolbar__field {
    display: grid;
    gap: 0.25rem;
  }

  .reports-toolbar__field-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-400);
  }

  .reports-toolbar__custom .inventory-form-input {
    height: 2.35rem;
  }

  .reports-toolbar__actions {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  .reports-toolbar__refresh {
    height: 2.35rem;
  }

  /* Export dropdown ------------------------------------------------------- */
  .reports-export {
    position: relative;
  }

  .reports-export__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    height: 2.35rem;
  }

  .reports-export__menu {
    position: absolute;
    top: calc(100% + 0.3rem);
    right: 0;
    z-index: 30;
    display: grid;
    min-width: 14rem;
    padding: 0.3rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-lg);
  }

  .reports-export__menu[hidden] {
    display: none;
  }

  .reports-export__menu button {
    padding: 0.5rem 0.6rem;
    border: none;
    border-radius: var(--radius-sm);
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-stone-700);
    text-align: left;
    cursor: pointer;
  }

  .reports-export__menu button:hover,
  .reports-export__menu button:focus-visible {
    background: var(--color-citrine-muted);
    color: var(--color-citrine-dark);
    outline: none;
  }

  .reports-toolbar__meta {
    flex-basis: 100%;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.75rem;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-stone-500);
  }

  .reports-toolbar__range {
    font-weight: 600;
    color: var(--color-stone-700);
  }

  .reports-toolbar__refreshed {
    color: var(--color-stone-400);
  }

  .reports-error {
    margin: 0 0 1rem;
  }

  .reports-error[hidden] {
    display: none;
  }

  /* Sections -------------------------------------------------------------- */
  .reports-section {
    margin-top: 1.25rem;
    scroll-margin-top: calc(var(--team-bar-height, 3.25rem) + 1rem);
  }

  .reports-section:first-of-type {
    margin-top: 0;
  }

  .reports-section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.65rem;
  }

  .reports-section__title {
    scroll-margin-top: calc(var(--team-bar-height, 3.25rem) + 1rem);
  }

  /* Compact metric cards -------------------------------------------------- */
  .reports-metrics {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
    gap: 0.75rem;
  }

  .reports-metric {
    display: grid;
    gap: 0.2rem;
    align-content: start;
    padding: 0.85rem 0.95rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
  }

  .reports-metric__label {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-400);
  }

  .reports-metric__value {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.1;
    color: var(--color-stone-800);
    font-variant-numeric: tabular-nums;
  }

  .reports-metric__meta {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

  /* Info tooltip glyph */
  .reports-info {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 0.95rem;
    height: 0.95rem;
    border-radius: 50%;
    border: 1px solid var(--color-stone-300);
    font-size: 0.6rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-stone-400);
    cursor: help;
  }

  /* Cancellations single-row panel --------------------------------------- */
  .reports-cancel-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: 0.5rem 1.5rem;
    padding: 0.35rem 0;
  }

  .reports-cancel-cell {
    display: grid;
    gap: 0.1rem;
  }

  .reports-cancel-cell__label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-400);
  }

  .reports-cancel-cell__value {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--color-stone-800);
    font-variant-numeric: tabular-nums;
  }

  .reports-cancel-cell__value--flag {
    color: var(--color-error);
  }

  .reports-cancel-cell__meta {
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

  /* Empty / status states ------------------------------------------------- */
  .reports-state {
    display: grid;
    justify-items: center;
    gap: 0.4rem;
    margin: 0;
    padding: 1.5rem 1rem;
    text-align: center;
  }

  .reports-state__title {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-stone-600);
  }

  .reports-state__hint {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--color-stone-400);
  }

  .reports-state--error .reports-state__title {
    color: var(--color-error);
  }

  .reports-skeleton {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
    gap: 0.75rem;
  }

  .reports-skeleton__card {
    height: 4.75rem;
    border-radius: var(--radius-md);
    background: linear-gradient(
      90deg,
      var(--color-stone-100) 25%,
      var(--color-stone-50) 37%,
      var(--color-stone-100) 63%
    );
    background-size: 400% 100%;
    animation: reports-shimmer 1.4s ease infinite;
  }

  @keyframes reports-shimmer {
    0% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reports-skeleton__card {
      animation: none;
    }
  }

  /* Sidebar nav sits directly under the section title, no big gaps */
  .reports-nav {
    flex: 0 0 auto;
  }

  @media (max-width: 900px) {
    .reports-toolbar__actions {
      margin-left: 0;
    }

    .reports-toolbar__presets {
      width: 100%;
    }
  }
</style>
