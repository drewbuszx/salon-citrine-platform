---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamListLayout from "../components/TeamListLayout.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";

const { staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

if (!isSalonManager(staff)) {
  return Astro.redirect(teamUrl("/"));
}

const today = new Date();
const fromDefault = new Date(today);
fromDefault.setDate(fromDefault.getDate() - 30);
const toValue = today.toISOString().slice(0, 10);
const fromValue = fromDefault.toISOString().slice(0, 10);
---

<TeamLayout title="Reports" activeNav="reports" plain wide fullBleed>
  <div
    class="reports-page"
    data-reports-app
    data-api-base={teamUrl("/api/reports")}
    data-from={fromValue}
    data-to={toValue}
  >
    <TeamListLayout title="Reports" mainTitle="Business summaries" sidebarTitle="Report options">
      <button slot="headerActions" class="team-list-layout__btn-secondary" type="button" data-export-csv>
        Export CSV
      </button>

      <div slot="sidebarFilters" class="reports-sidebar">
        <label class="reports-sidebar__field">
          <span class="reports-sidebar__label">From</span>
          <input class="inventory-form-input" type="date" data-range-from value={fromValue} />
        </label>
        <label class="reports-sidebar__field">
          <span class="reports-sidebar__label">To</span>
          <input class="inventory-form-input" type="date" data-range-to value={toValue} />
        </label>
        <button class="team-list-layout__btn-primary reports-sidebar__apply" type="button" data-range-apply>
          Apply range
        </button>
        <p class="team-list-layout__filter-placeholder" data-range-label aria-live="polite"></p>
      </div>

      <nav slot="sidebarExtra" class="team-list-layout__sidebar-nav" aria-label="Report sections">
        <a class="team-list-layout__sidebar-link" href="#reports-revenue">Revenue summary</a>
        <a class="team-list-layout__sidebar-link" href="#reports-staff-title">Appointments by staff</a>
        <a class="team-list-layout__sidebar-link" href="#reports-cancel-title">Cancellations</a>
        <a class="team-list-layout__sidebar-link" href="#reports-inventory-title">Low stock</a>
      </nav>

      <Fragment slot="mainLead">Business summaries from live salon data.</Fragment>

      <p class="notice notice--error" data-reports-error hidden role="alert"></p>

      <div class="team-stat-grid" id="reports-revenue" data-revenue-stats>
        <p class="empty-state">Loading reports…</p>
      </div>

      <section class="team-panel reports-section" aria-labelledby="reports-staff-title">
        <h2 class="team-panel__title" id="reports-staff-title">Appointments by staff</h2>
        <div class="team-data-table-wrap" data-staff-table>
          <p class="empty-state">Loading…</p>
        </div>
      </section>

      <section class="team-panel reports-section" aria-labelledby="reports-cancel-title">
        <h2 class="team-panel__title" id="reports-cancel-title">Cancellations & no-shows</h2>
        <div data-cancel-stats>
          <p class="empty-state">Loading…</p>
        </div>
      </section>

      <section class="team-panel reports-section" aria-labelledby="reports-inventory-title">
        <h2 class="team-panel__title" id="reports-inventory-title">Low stock inventory</h2>
        <div data-inventory-stats>
          <p class="empty-state">Loading…</p>
        </div>
      </section>
    </TeamListLayout>
  </div>
</TeamLayout>

<script src="../scripts/reports.ts"></script>

<style>
  .reports-sidebar {
    display: grid;
    gap: 0.65rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .reports-sidebar__field {
    display: grid;
    gap: 0.35rem;
    padding: 0 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: #374151;
  }

  .reports-sidebar__label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #9ca3af;
  }

  .reports-sidebar__apply {
    margin: 0 0.35rem;
    width: calc(100% - 0.7rem);
  }

  .reports-section {
    margin-top: 1.25rem;
  }

  .reports-cancel-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    margin-bottom: 1rem;
  }
</style>
