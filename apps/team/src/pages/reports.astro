---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamListLayout from "../components/TeamListLayout.astro";
import UiScrollRow from "../components/ui/UiScrollRow.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";
import { defaultReportRangeDates } from "../lib/report-range";
import { reportNavGroups } from "../lib/report-metrics";

const { staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

if (!isSalonManager(staff)) {
  return Astro.redirect(teamUrl("/"));
}

const { fromDate, toDate } = defaultReportRangeDates();
const navGroups = reportNavGroups();

const PRESETS = [
  { value: "today", label: "Today" },
  { value: "this-week", label: "This week" },
  { value: "last-week", label: "Last week" },
  { value: "this-month", label: "This month" },
  { value: "last-month", label: "Last month" },
  { value: "ytd", label: "YTD" },
  { value: "custom", label: "Custom" },
];

const COMPARE_OPTIONS = [
  { value: "none", label: "No comparison" },
  { value: "previous", label: "Previous period" },
  { value: "previous-month", label: "Previous month" },
  { value: "last-year", label: "Same period last year" },
];
---

<TeamLayout title="Reports" activeNav="reports" plain wide fullBleed>
  <div
    class="reports-page"
    data-reports-app
    data-api-base={teamUrl("/api/reports")}
    data-inventory-url={teamUrl("/inventory")}
    data-from={fromDate}
    data-to={toDate}
  >
    <TeamListLayout title="Reports" mainTitle="Business summaries" sidebarTitle="Sections">
      <nav slot="sidebarExtra" class="team-list-layout__sidebar-nav reports-nav" aria-label="Report sections">
        {
          navGroups.map((group) => (
            <div class="reports-nav__group">
              <p class="reports-nav__heading">{group.group}</p>
              {group.sections.map((section) => (
                <a
                  class="team-list-layout__sidebar-link reports-nav__link"
                  href={`#${section.id}`}
                  data-nav-link={section.id}
                >
                  {section.label}
                </a>
              ))}
            </div>
          ))
        }
      </nav>

      <Fragment slot="mainLead">Live salon data. Pick a range to update every section.</Fragment>

      <div class="reports-tabs" data-reports-tabs>
        <UiScrollRow label="Report sections">
          {
            navGroups.flatMap((g) => g.sections).map((section, index) => (
              <button
                type="button"
                class:list={["reports-tabs__btn", { "is-active": index === 0 }]}
                data-report-tab={section.id}
                data-export-key={section.exportKey}
                aria-selected={index === 0 ? "true" : "false"}
              >
                <span class="reports-tabs__long">{section.label}</span>
                <span class="reports-tabs__short">{section.short}</span>
              </button>
            ))
          }
        </UiScrollRow>
      </div>

      <div slot="toolbar" class="reports-toolbar" data-reports-toolbar>
        <div class="reports-toolbar__row reports-toolbar__row--primary">
          <div class="reports-toolbar__presets-wrap">
            <UiScrollRow label="Date range presets">
              <div class="reports-toolbar__presets ui-segmented" role="group" aria-label="Date range presets">
                {
                  PRESETS.map((preset) => (
                    <button
                      type="button"
                      class="ui-segmented__item reports-preset"
                      data-preset={preset.value}
                      aria-pressed="false"
                    >
                      {preset.label}
                    </button>
                  ))
                }
              </div>
            </UiScrollRow>
          </div>

          <div class="reports-toolbar__actions">
            <label class="reports-toolbar__compare">
              <span class="reports-toolbar__compare-label">Compare</span>
              <select class="form-input reports-toolbar__compare-select" data-compare-mode>
                {
                  COMPARE_OPTIONS.map((opt) => (
                    <option value={opt.value} selected={opt.value === "previous"}>
                      {opt.label}
                    </option>
                  ))
                }
              </select>
            </label>

            <button
              class="ui-btn ui-btn--secondary ui-btn--compact reports-toolbar__refresh"
              type="button"
              data-range-apply
            >
              Refresh
            </button>

            <details class="reports-export-menu" data-export-menu>
              <summary class="ui-btn ui-btn--secondary ui-btn--compact reports-export-menu__trigger" data-export-trigger>
                Export
              </summary>
              <div class="reports-export-menu__panel" role="menu">
                <p class="reports-export-menu__hint" data-export-hint>Choose a section to export as CSV.</p>
                <button type="button" class="reports-export-menu__item" data-export-section="overview" role="menuitem">
                  Overview
                </button>
                <button type="button" class="reports-export-menu__item" data-export-section="revenue" role="menuitem">
                  Revenue
                </button>
                <button type="button" class="reports-export-menu__item" data-export-section="appointments" role="menuitem">
                  Appointments by staff
                </button>
                <button type="button" class="reports-export-menu__item" data-export-section="cancellations" role="menuitem">
                  Cancellations &amp; no-shows
                </button>
                <button type="button" class="reports-export-menu__item" data-export-section="status" role="menuitem">
                  Appointment status
                </button>
                <button type="button" class="reports-export-menu__item" data-export-section="inventory" role="menuitem">
                  Low stock
                </button>
                <button type="button" class="reports-export-menu__item" data-export-section="all" role="menuitem">
                  Full report
                </button>
              </div>
            </details>
          </div>
        </div>

        <div class="reports-toolbar__custom" data-custom-range hidden>
          <label class="reports-toolbar__field">
            <span class="reports-toolbar__field-label">From</span>
            <span class="reports-toolbar__date">
              <input class="form-input reports-toolbar__date-input" type="date" data-range-from value={fromDate} />
            </span>
          </label>
          <label class="reports-toolbar__field">
            <span class="reports-toolbar__field-label">To</span>
            <span class="reports-toolbar__date">
              <input class="form-input reports-toolbar__date-input" type="date" data-range-to value={toDate} />
            </span>
          </label>
        </div>

        <p class="reports-toolbar__meta">
          <span class="reports-toolbar__range" data-range-label aria-live="polite"></span>
          <span class="reports-toolbar__refreshed" data-refreshed-label></span>
        </p>
      </div>

      <p class="notice notice--error reports-error" data-reports-error hidden role="alert"></p>

      <div class="reports-workspace">
        <section class="reports-section" id="reports-overview" aria-labelledby="reports-overview-title">
          <header class="reports-section__head">
            <div>
              <h2 class="reports-section__title" id="reports-overview-title">Overview</h2>
              <p class="reports-section__desc">Key metrics for the selected range.</p>
            </div>
          </header>
          <div class="reports-section__body" data-overview-body>
            <p class="empty-state">Loading reports…</p>
          </div>
        </section>

        <section class="reports-section" id="reports-revenue" aria-labelledby="reports-revenue-title">
          <header class="reports-section__head">
            <div>
              <h2 class="reports-section__title" id="reports-revenue-title">Revenue</h2>
              <p class="reports-section__desc">Completed checkout totals for this range.</p>
            </div>
          </header>
          <div class="reports-section__body" data-revenue-body>
            <p class="empty-state">Loading…</p>
          </div>
        </section>

        <section class="reports-section" id="reports-appointments" aria-labelledby="reports-appointments-title">
          <header class="reports-section__head">
            <div>
              <h2 class="reports-section__title" id="reports-appointments-title">Appointments by staff</h2>
              <p class="reports-section__desc">Scheduled and completed work by provider.</p>
            </div>
          </header>
          <div class="reports-section__body" data-staff-body>
            <p class="empty-state">Loading…</p>
          </div>
        </section>

        <section class="reports-section" id="reports-status" aria-labelledby="reports-status-title">
          <header class="reports-section__head">
            <div>
              <h2 class="reports-section__title" id="reports-status-title">Appointment status</h2>
              <p class="reports-section__desc">How appointments in this range resolved.</p>
            </div>
          </header>
          <div class="reports-section__body" data-status-body>
            <p class="empty-state">Loading…</p>
          </div>
        </section>

        <section class="reports-section" id="reports-cancellations" aria-labelledby="reports-cancellations-title">
          <header class="reports-section__head">
            <div>
              <h2 class="reports-section__title" id="reports-cancellations-title">Cancellations &amp; no-shows</h2>
              <p class="reports-section__desc">Lost appointments and fees collected.</p>
            </div>
          </header>
          <div class="reports-section__body" data-cancel-body>
            <p class="empty-state">Loading…</p>
          </div>
        </section>

        <section class="reports-section" id="reports-inventory" aria-labelledby="reports-inventory-title">
          <header class="reports-section__head">
            <div>
              <h2 class="reports-section__title" id="reports-inventory-title">Low stock inventory</h2>
              <p class="reports-section__desc">Products at or below their reorder point.</p>
            </div>
          </header>
          <div class="reports-section__body" data-inventory-body>
            <p class="empty-state">Loading…</p>
          </div>
        </section>
      </div>

      <aside
        class="reports-detail"
        data-detail-panel
        hidden
        role="dialog"
        aria-modal="true"
        aria-labelledby="reports-detail-title"
      >
        <div class="reports-detail__body" data-detail-body></div>
      </aside>
    </TeamListLayout>
  </div>
</TeamLayout>

<script src="../scripts/reports.ts"></script>

<!--
  is:global — reports.ts injects section markup via innerHTML, so scoped
  selectors would never match that DOM. Class names are page-unique (reports-*).
-->
<style is:global>
  .reports-page {
    min-width: 0;
    overflow-x: clip;
  }

  .reports-page .team-list-layout__main {
    max-width: 92rem;
  }

  /* Sticky toolbar beneath global nav ------------------------------------ */
  .reports-page .team-list-layout__toolbar {
    position: sticky;
    top: var(--team-bar-height, 3.25rem);
    z-index: 12;
    margin: 0 calc(-1 * var(--space-6)) 1rem;
    padding: 0.75rem var(--space-6);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-stone-200);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.04);
  }

  .reports-toolbar {
    display: grid;
    gap: 0.65rem;
    width: 100%;
    min-width: 0;
  }

  .reports-toolbar__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--mobile-space-sm);
    min-width: 0;
  }

  .reports-toolbar__row--primary {
    justify-content: space-between;
  }

  .reports-toolbar__presets-wrap {
    flex: 1 1 18rem;
    min-width: 0;
  }

  .reports-toolbar__presets {
    flex-wrap: nowrap;
    width: max-content;
    min-width: min(100%, max-content);
  }

  .reports-toolbar__presets .ui-segmented__item {
    flex: 0 0 auto;
    white-space: nowrap;
    padding-inline: 0.65rem;
  }

  .reports-preset[aria-pressed="true"],
  .reports-preset.is-active {
    background: var(--color-citrine-muted, var(--color-selection-bg));
    color: var(--color-stone-800);
    box-shadow: inset 0 0 0 2px var(--color-citrine, var(--color-selection-border));
  }

  .reports-toolbar__actions {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--mobile-space-xs);
    flex: 0 0 auto;
  }

  .reports-toolbar__compare {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: var(--touch-target-min);
  }

  .reports-toolbar__compare-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-400);
    white-space: nowrap;
  }

  .reports-toolbar__compare-select {
    min-height: 2.25rem;
    padding: 0.25rem 0.5rem;
    font-size: var(--text-xs);
  }

  .reports-toolbar__custom {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: var(--mobile-space-sm);
  }

  .reports-toolbar__custom[hidden] {
    display: none;
  }

  .reports-toolbar__field {
    display: grid;
    gap: 0.25rem;
    flex: 1 1 8rem;
    min-width: 0;
  }

  .reports-toolbar__field-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-400);
  }

  .reports-toolbar__date-input {
    width: 100%;
    min-height: var(--touch-target-min);
  }

  .reports-toolbar__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.75rem;
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-stone-500);
  }

  .reports-toolbar__range {
    font-weight: 600;
    color: var(--color-stone-700);
  }

  .reports-toolbar__refreshed::before {
    content: "· ";
    color: var(--color-stone-300);
  }

  /* Export menu ------------------------------------------------------------ */
  .reports-export-menu {
    position: relative;
  }

  .reports-export-menu__trigger {
    list-style: none;
    cursor: pointer;
  }

  .reports-export-menu__trigger::-webkit-details-marker {
    display: none;
  }

  .reports-export-menu__panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.35rem);
    z-index: 30;
    min-width: 14rem;
    padding: 0.5rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-md);
  }

  .reports-export-menu__hint {
    margin: 0 0 0.35rem;
    padding: 0.35rem 0.5rem;
    font-size: var(--text-xs);
    color: var(--color-stone-500);
    line-height: 1.35;
  }

  .reports-export-menu__item {
    display: block;
    width: 100%;
    padding: 0.45rem 0.55rem;
    border: none;
    border-radius: var(--radius-sm);
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    text-align: left;
    color: var(--color-stone-700);
    cursor: pointer;
  }

  .reports-export-menu__item:hover,
  .reports-export-menu__item:focus-visible {
    background: var(--color-stone-100);
    outline: none;
  }

  .reports-export-menu__item:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Nav groups ------------------------------------------------------------- */
  .reports-nav__group + .reports-nav__group {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-stone-200);
  }

  .reports-nav__heading {
    margin: 0;
    padding: 0.35rem var(--team-sidebar-inset-x) 0.15rem;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-stone-400);
  }

  /* Workspace + sections --------------------------------------------------- */
  .reports-workspace {
    display: grid;
    gap: 1rem;
  }

  .reports-section {
    padding: 1rem 1.1rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    scroll-margin-top: calc(var(--team-bar-height, 3.25rem) + 7rem);
  }

  .reports-section__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .reports-section__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-stone-800);
  }

  .reports-section__desc {
    margin: 0.2rem 0 0;
    font-size: var(--text-sm);
    color: var(--color-stone-500);
  }

  .reports-section-lead {
    margin: 0 0 0.75rem;
    font-size: var(--text-sm);
    color: var(--color-stone-600);
  }

  /* KPI grid --------------------------------------------------------------- */
  .reports-kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10.5rem, 1fr));
    gap: 0.65rem;
    margin-bottom: 1rem;
  }

  .reports-kpi {
    display: grid;
    gap: 0.15rem;
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-stone-50);
    cursor: default;
  }

  .reports-kpi[role="button"] {
    cursor: pointer;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .reports-kpi[role="button"]:hover,
  .reports-kpi[role="button"]:focus-visible {
    border-color: var(--color-citrine);
    box-shadow: 0 0 0 2px var(--color-focus-ring);
    outline: none;
  }

  .reports-kpi__label {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin: 0;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-stone-400);
  }

  .reports-kpi__value {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    line-height: 1.1;
    color: var(--color-stone-800);
    font-variant-numeric: tabular-nums;
  }

  .reports-kpi__cmp {
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

  .reports-kpi__cmp--up {
    color: var(--color-stone-600);
  }

  .reports-kpi__cmp--down {
    color: var(--color-stone-600);
  }

  /* Banners + alerts ------------------------------------------------------- */
  .reports-banner {
    margin: 0 0 0.85rem;
    padding: 0.75rem 0.9rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-stone-200);
    background: var(--color-stone-50);
  }

  .reports-banner--info {
    border-color: rgba(141, 158, 136, 0.35);
    background: var(--color-sage-muted, rgba(141, 158, 136, 0.08));
  }

  .reports-banner__title {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-stone-800);
  }

  .reports-banner__hint {
    margin: 0.25rem 0 0;
    font-size: var(--text-sm);
    color: var(--color-stone-600);
    line-height: 1.4;
  }

  .reports-inv-alert {
    margin: 0 0 0.75rem;
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .reports-inv-alert a {
    color: var(--color-link);
    text-decoration: none;
  }

  .reports-inv-alert a:hover {
    text-decoration: underline;
  }

  /* Trend chart ------------------------------------------------------------ */
  .reports-trend {
    margin-top: 0.25rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--color-stone-200);
  }

  .reports-trend__head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .reports-trend__title {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-stone-700);
  }

  .reports-trend__controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .reports-trend__metric {
    min-height: 2rem;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--color-stone-200);
    border-radius: 999px;
    background: var(--color-bg);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-stone-600);
    cursor: pointer;
  }

  .reports-trend__metric.is-active,
  .reports-trend__metric[aria-pressed="true"] {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted);
    color: var(--color-stone-800);
  }

  .reports-trend__summary {
    margin: 0 0 0.5rem;
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

  .reports-trend__chart {
    display: flex;
    align-items: flex-end;
    gap: 0.25rem;
    min-height: 7rem;
    padding: 0.5rem 0;
    overflow-x: auto;
  }

  .reports-trend__bar-wrap {
    display: flex;
    flex: 1 1 0;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    min-width: 1.75rem;
  }

  .reports-trend__bar {
    width: 100%;
    max-width: 2rem;
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    background: var(--color-citrine);
    min-height: 2px;
  }

  .reports-trend__bar-label {
    font-size: 0.5625rem;
    color: var(--color-stone-400);
    white-space: nowrap;
    transform: rotate(-35deg);
    transform-origin: top center;
  }

  /* Tables ----------------------------------------------------------------- */
  .reports-table-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .reports-table-search {
    flex: 1 1 12rem;
    min-width: 0;
  }

  .reports-table-search__input {
    width: 100%;
    min-height: 2.25rem;
    font-size: var(--text-sm);
  }

  .reports-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
  }

  .reports-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .reports-table th,
  .reports-table td {
    padding: 0.55rem 0.7rem;
    border-bottom: 1px solid var(--color-stone-200);
    text-align: left;
    vertical-align: middle;
  }

  .reports-table th {
    position: sticky;
    top: 0;
    z-index: 1;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-500);
    background: var(--color-stone-50);
    white-space: nowrap;
    cursor: pointer;
    user-select: none;
  }

  .reports-table th.num,
  .reports-table td.num {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .reports-table tbody tr:last-child td {
    border-bottom: none;
  }

  .reports-table tbody tr[role="button"] {
    cursor: pointer;
  }

  .reports-table tbody tr[role="button"]:hover td,
  .reports-table tbody tr[role="button"]:focus-visible td {
    background: var(--color-sage-muted);
  }

  .reports-table-foot {
    margin: 0.5rem 0 0;
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

