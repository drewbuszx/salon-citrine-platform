---
import DayCalendar from "../components/DayCalendar.astro";
import TeamLayout from "../layouts/TeamLayout.astro";
import { isSalonManager } from "../lib/auth";
import {
  formatDayParam,
  loadCalendarData,
  loadStaffServicesByStaff,
  parseDayParam,
  sortStaffWithCurrentFirst,
} from "../lib/calendar";
import { teamUrl } from "../lib/supabase-server";

const { supabase, staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

const selectedDay = parseDayParam(
  Astro.url.searchParams.get("day") ?? Astro.url.searchParams.get("week"),
);
const dayParam = formatDayParam(selectedDay);
const managerView = isSalonManager(staff);

let calendar;
let servicesByStaff: Record<
  string,
  Array<{ id: string; name: string; durationMinutes: number }>
> = {};

try {
  const loaded = await loadCalendarData(supabase, {
    selectedDay,
    staffFilterIds: managerView ? null : [staff.id],
  });
  calendar = {
    ...loaded,
    staff: sortStaffWithCurrentFirst(loaded.staff, staff.id),
  };
  servicesByStaff = await loadStaffServicesByStaff(
    supabase,
    calendar.staff.map((member) => member.id),
  );
} catch (error) {
  console.error("Failed to load calendar", error);
  calendar = {
    staff: [],
    appointments: [],
    blockedTimes: [],
    timeOff: [],
    staffSchedules: {},
  };
}

let waitlistCountQuery = supabase
  .from("waitlist_entries")
  .select("*", { count: "exact", head: true })
  .eq("status", "active");

if (!managerView) {
  waitlistCountQuery = waitlistCountQuery.or(
    `staff_id.eq.${staff.id},staff_id.is.null`,
  );
}

const { count: waitlistCount } = await waitlistCountQuery;
---

<TeamLayout title="Book" activeNav="book" fullBleed>
  <DayCalendar
    selectedDay={selectedDay}
    dayParam={dayParam}
    staff={calendar.staff}
    appointments={calendar.appointments}
    blockedTimes={calendar.blockedTimes}
    timeOff={calendar.timeOff ?? []}
    staffSchedules={calendar.staffSchedules ?? {}}
    servicesByStaff={servicesByStaff}
    currentStaffId={staff.id}
    managerView={managerView}
    waitlistCount={waitlistCount ?? 0}
  />
</TeamLayout>
