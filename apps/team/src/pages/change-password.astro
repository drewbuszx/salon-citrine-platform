---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamPage from "../components/TeamPage.astro";
import { teamUrl } from "../lib/supabase-server";

const error = Astro.url.searchParams.get("error");
const message =
  error === "current"
    ? "Current password is incorrect."
    : error === "mismatch"
      ? "New passwords do not match."
      : error === "weak"
        ? "New password must be at least 8 characters."
        : error === "update"
          ? "Could not update password. Try again."
          : error === "invalid"
            ? "Fill in all fields correctly."
            : null;
---

<TeamLayout title="Change password" loginPage plain>
  <TeamPage
    title="Set a new password"
    lead="Your account uses a temporary password. Enter that temporary password as the current password, then choose a new one."
  >
  <section class="form-stack form-stack--narrow">
    {message ? <p class="notice notice--error" role="alert">{message}</p> : null}

    <form
      class="form-stack"
      method="post"
      action={teamUrl("/api/auth/change-password")}
    >
      <label class="form-label">
        Current password (temporary password from setup)
        <input
          class="form-input"
          name="current_password"
          type="password"
          autocomplete="current-password"
          required
        />
      </label>
      <label class="form-label">
        New password
        <input
          class="form-input"
          name="new_password"
          type="password"
          autocomplete="new-password"
          minlength="8"
          required
        />
      </label>
      <label class="form-label">
        Confirm new password
        <input
          class="form-input"
          name="confirm_password"
          type="password"
          autocomplete="new-password"
          minlength="8"
          required
        />
      </label>
      <button class="btn-primary" type="submit">Save password</button>
    </form>
  </section>
  </TeamPage>
</TeamLayout>
