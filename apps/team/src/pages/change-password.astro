---
import TeamLayout from "../layouts/TeamLayout.astro";
import { teamUrl } from "../lib/supabase-server";

const error = Astro.url.searchParams.get("error");
const message =
  error === "current"
    ? "Current password is incorrect."
    : error === "mismatch"
      ? "New passwords do not match."
      : error === "weak"
        ? "New password must be at least 8 characters."
        : error === "update"
          ? "Could not update password. Try again."
          : error === "invalid"
            ? "Fill in all fields correctly."
            : null;
---

<TeamLayout title="Change password">
  <section class="change-password">
    <h1>Set a new password</h1>
    <p class="change-password__lead">
      Your account uses a temporary password. Choose a new one to continue.
    </p>

    {message ? <p class="change-password__error" role="alert">{message}</p> : null}

    <form
      class="change-password__form"
      method="post"
      action={teamUrl("/api/auth/change-password")}
    >
      <label>
        Current password
        <input
          name="current_password"
          type="password"
          autocomplete="current-password"
          required
        />
      </label>
      <label>
        New password
        <input
          name="new_password"
          type="password"
          autocomplete="new-password"
          minlength="8"
          required
        />
      </label>
      <label>
        Confirm new password
        <input
          name="confirm_password"
          type="password"
          autocomplete="new-password"
          minlength="8"
          required
        />
      </label>
      <button type="submit">Save password</button>
    </form>
  </section>
</TeamLayout>

<style>
  .change-password {
    max-width: 24rem;
    margin: 2rem auto;
  }

  h1 {
    font-size: 1.75rem;
  }

  .change-password__lead {
    color: var(--color-gray);
  }

  .change-password__error {
    padding: 0.65rem 0.75rem;
    border: 1px solid #c44;
    background: rgba(200, 60, 60, 0.08);
    color: #922;
    font-size: 0.9rem;
  }

  .change-password__form {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  label {
    display: grid;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  input {
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    text-transform: none;
    letter-spacing: normal;
    font-size: 1rem;
  }

  button {
    padding: 0.7rem 1rem;
    border: none;
    background: var(--color-charcoal);
    color: var(--color-white);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
</style>
