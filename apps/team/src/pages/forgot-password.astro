---
import TeamLayout from "../layouts/TeamLayout.astro";
import { BUSINESS } from "@saloncitrine/shared";
import { withBase } from "../lib/paths";
import { teamUrl } from "../lib/supabase-server";

const sent = Astro.url.searchParams.get("sent") === "1";
const error = Astro.url.searchParams.get("error");
const message =
  sent
    ? "If an account exists for that email, we sent a reset link. Check your inbox."
    : error === "missing"
      ? "Enter your work email address."
      : error === "send"
        ? "We could not send a reset email. Try again or contact support."
        : error === "connection"
          ? "We could not reach the sign-in service. Check your connection and try again."
          : null;

const logoMobileLightSrc = withBase("images/salon-citrine-wordmark-mobile.png");
const logoMobileDarkSrc = withBase("images/salon-citrine-wordmark-rev.png");
---

<TeamLayout title="Reset password" loginPage plain>
  <section class="login-split login-split--compact">
    <div class="login-split__panel login-split__panel--solo">
      <a class="login-split__mobile-logo" href={teamUrl("/login")} aria-label={BUSINESS.name}>
        <img
          class="login-split__mobile-logo-img login-split__mobile-logo-img--light"
          src={logoMobileLightSrc}
          alt={BUSINESS.name}
          width="240"
          height="90"
          loading="eager"
        />
        <img
          class="login-split__mobile-logo-img login-split__mobile-logo-img--dark"
          src={logoMobileDarkSrc}
          alt=""
          width="240"
          height="90"
          loading="eager"
          aria-hidden="true"
        />
      </a>

      <div class="login-split__form-wrap">
        <div class="login-card">
          <header class="login-card__heading">
            <p class="login-card__kicker">Staff portal</p>
            <h1 class="login-card__title">Reset password</h1>
            <p class="login-card__lead">
              Enter your work email and we will send a link to choose a new password.
            </p>
          </header>

          {
            message ? (
              <p
                class:list={["login-alert", sent ? "login-alert--success" : "login-alert--error"]}
                role="alert"
              >
                {message}
              </p>
            ) : null
          }

          {
            !sent ? (
              <form class="login-form" method="post" action={teamUrl("/api/auth/forgot-password")}>
                <div class="login-field" data-field>
                  <label class="login-field__label" for="forgot-email">Email</label>
                  <input
                    class="login-field__input"
                    id="forgot-email"
                    name="email"
                    type="email"
                    autocomplete="username"
                    required
                  />
                </div>
                <button class="login-submit" type="submit">Send reset link</button>
              </form>
            ) : null
          }

          <p class="login-card__meta">
            <a class="login-link" href={teamUrl("/login")}>Back to sign in</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</TeamLayout>
