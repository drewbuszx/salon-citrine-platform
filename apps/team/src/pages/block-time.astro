---
import TeamLayout from "../layouts/TeamLayout.astro";
import TeamPage from "../components/TeamPage.astro";
import { isSalonManager } from "../lib/auth";
import { teamUrl } from "../lib/supabase-server";

const { supabase, staff } = Astro.locals;

if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

const managerView = isSalonManager(staff);

let staffOptions: Array<{ id: string; name: string }> = [];
if (managerView) {
  const { data } = await supabase
    .from("staff")
    .select("id, name")
    .order("name");
  staffOptions = data ?? [];
}

const saved = Astro.url.searchParams.get("saved") === "1";
const error = Astro.url.searchParams.get("error");
---

<TeamLayout title="Block time" activeNav="book" plain>
  <TeamPage
    title="Block time"
    lead={managerView ? "Block calendar time for any provider." : "Block time on your schedule."}
  >
    <a slot="actions" class="btn-secondary" href={teamUrl("/book")}>← Book</a>

  {saved ? <p class="notice notice--success">Blocked time saved.</p> : null}
  {
    error === "invalid" ? (
      <p class="notice notice--error" role="alert">
        Could not save — check dates and try again.
      </p>
    ) : null
  }

  <form class="form-stack form-stack--medium" method="post" action={teamUrl("/api/block-time")}>
    {
      managerView ? (
        <label class="form-label">
          Provider
          <select class="form-input" name="staff_id" required>
            {
              staffOptions.map((member) => (
                <option value={member.id}>{member.name}</option>
              ))
            }
          </select>
        </label>
      ) : (
        <input type="hidden" name="staff_id" value={staff.id} />
      )
    }

    <label class="form-label">
      Starts
      <input class="form-input" name="starts_at" type="datetime-local" required />
    </label>

    <label class="form-label">
      Ends
      <input class="form-input" name="ends_at" type="datetime-local" required />
    </label>

    <label class="form-label">
      Reason (optional)
      <input
        class="form-input"
        name="reason"
        type="text"
        maxlength="200"
        placeholder="Lunch, meeting…"
      />
    </label>

    <button class="btn-primary" type="submit">Save block</button>
  </form>
  </TeamPage>
</TeamLayout>
