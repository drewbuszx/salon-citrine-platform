---
export const prerender = false;

import TeamLayout from "../../layouts/TeamLayout.astro";
import TeamListLayout from "../../components/TeamListLayout.astro";
import { teamUrl } from "../../lib/supabase-server";
import {
  INTAKE_REFERRAL_SOURCES,
  PREFERRED_CONTACT_LABELS,
  PREFERRED_CONTACT_METHODS,
} from "@saloncitrine/shared";

const { staff } = Astro.locals;
if (!staff) {
  return Astro.redirect(`${import.meta.env.BASE_URL}login?error=unlinked`);
}

const clientId = Astro.params.id;
if (!clientId) {
  return Astro.redirect(teamUrl("/clients"));
}
---

<TeamLayout title="Client profile" activeNav="clients" plain wide fullBleed>
  <div
    class="client-profile"
    data-client-profile
    data-client-id={clientId}
    data-api-url={teamUrl(`/api/clients/${clientId}`)}
    data-notes-api-url={teamUrl(`/api/clients/${clientId}/notes`)}
    data-book-url={import.meta.env.PUBLIC_BOOK_URL ?? "https://saloncitrineindy.com/book"}
  >
    <div class="client-profile__skeleton" data-loading>
      <div class="skeleton skeleton--block" style="height:2rem;max-width:14rem;margin-bottom:1rem"></div>
      <div class="skeleton skeleton--line" style="max-width:100%"></div>
      <div class="skeleton skeleton--line" style="max-width:90%"></div>
      <div class="skeleton skeleton--line" style="max-width:75%"></div>
      <div class="skeleton skeleton--block" style="height:6rem;margin-top:1.5rem"></div>
    </div>
    <p class="notice notice--error" data-error hidden></p>

    <div data-profile-content hidden>
      <TeamListLayout title="Client profile" sidebarTitle="Sections">
        <a slot="headerActions" class="team-list-layout__btn-secondary" href={teamUrl("/clients")}>← All clients</a>
        <a slot="headerActions" class="team-list-layout__btn-primary" data-book-again href="#" hidden>Book again</a>

        <nav slot="sidebarFilters" class="team-list-layout__sidebar-nav" aria-label="Client sections">
          <a class="team-list-layout__sidebar-link" href="#client-contact">Contact</a>
          <a class="team-list-layout__sidebar-link" href="#client-intake">Intake profile</a>
          <a class="team-list-layout__sidebar-link" href="#client-notes">Preferences & notes</a>
          <a class="team-list-layout__sidebar-link" href="#client-timeline">Visit timeline</a>
          <a class="team-list-layout__sidebar-link" href="#client-notes-timeline">Notes timeline</a>
        </nav>

        <div class="client-profile__intro">
          <h2 class="client-profile__name" data-client-name></h2>
          <p class="client-profile__stats" data-client-stats></p>
        </div>

        <div class="client-profile__layout">
          <aside class="client-profile__sidebar">
            <section class="team-panel" id="client-contact">
              <h2 class="team-panel__title">Contact</h2>
              <form class="client-form" data-contact-form>
                <label class="form-label">First name<input class="form-input" name="firstName" required /></label>
                <label class="form-label">Last name<input class="form-input" name="lastName" required /></label>
                <label class="form-label">Email<input class="form-input" name="email" type="email" /></label>
                <label class="form-label">Phone<input class="form-input" name="phone" type="tel" /></label>
                <label class="checkbox-row">
                  <input type="checkbox" name="smsOptIn" />
                  SMS reminders
                </label>
                <label class="checkbox-row">
                  <input type="checkbox" name="emailOptIn" />
                  Email marketing
                </label>
                <button type="submit" class="btn-primary">Save contact</button>
              </form>
            </section>

            <section class="team-panel" id="client-intake">
              <h2 class="team-panel__title">Intake profile</h2>
              <form class="client-form" data-intake-form>
                <label class="form-label">
                  Birthday
                  <input class="form-input" name="birthday" type="date" />
                </label>
                <label class="form-label">
                  Street address
                  <input class="form-input" name="addressLine1" autocomplete="address-line1" />
                </label>
                <label class="form-label">
                  Address line 2
                  <input class="form-input" name="addressLine2" autocomplete="address-line2" />
                </label>
                <div class="client-form__row">
                  <label class="form-label">
                    City
                    <input class="form-input" name="addressCity" autocomplete="address-level2" />
                  </label>
                  <label class="form-label">
                    State
                    <input class="form-input" name="addressState" maxlength="2" autocomplete="address-level1" />
                  </label>
                  <label class="form-label">
                    ZIP
                    <input class="form-input" name="addressZip" inputmode="numeric" autocomplete="postal-code" />
                  </label>
                </div>
                <label class="form-label">
                  Preferred contact
                  <select class="form-input" name="preferredContactMethod">
                    <option value="">—</option>
                    {
                      PREFERRED_CONTACT_METHODS.map((method) => (
                        <option value={method}>{PREFERRED_CONTACT_LABELS[method]}</option>
                      ))
                    }
                  </select>
                </label>
                <fieldset class="client-form__fieldset">
                  <legend class="form-label">How they heard about us</legend>
                  <div class="client-form__checks">
                    {
                      INTAKE_REFERRAL_SOURCES.map((source) => (
                        <label class="checkbox-row">
                          <input type="checkbox" name="referralSources" value={source} />
                          {source}
                        </label>
                      ))
                    }
                  </div>
                </fieldset>
                <button type="submit" class="btn-primary">Save intake</button>
              </form>
            </section>

            <section class="team-panel" id="client-notes">
              <h2 class="team-panel__title">Preferences & notes</h2>
              <form class="client-form" data-notes-form>
                <label class="form-label">Client preferences<textarea class="form-input form-input--textarea" name="bookingPreferences" rows="2"></textarea></label>
                <label class="form-label">Intake notes<textarea class="form-input form-input--textarea" name="intakeNotes" rows="2"></textarea></label>
                <label class="form-label">Formula notes<textarea class="form-input form-input--textarea" name="formulaNotes" rows="3"></textarea></label>
                <label class="form-label">Staff notes<textarea class="form-input form-input--textarea" name="staffNotes" rows="3"></textarea></label>
                <label class="form-label">Tags (comma-separated)<input class="form-input" name="tags" placeholder="vip, balayage, sensitive scalp" /></label>
                <button type="submit" class="btn-primary">Save notes</button>
              </form>
            </section>
          </aside>

          <div class="client-profile__main">
            <section class="team-panel" id="client-timeline">
              <h2 class="team-panel__title">Visit timeline</h2>
              <ul class="client-timeline" data-timeline></ul>
            </section>

            <section class="team-panel" id="client-notes-timeline">
              <h2 class="team-panel__title">Notes timeline</h2>
              <form class="client-note-add" data-add-note-form>
                <label class="form-label">
                  Add note
                  <select class="form-input" name="noteType">
                    <option value="general">General</option>
                    <option value="formula">Formula</option>
                    <option value="preference">Preference</option>
                  </select>
                </label>
                <label class="form-label">
                  <textarea class="form-input form-input--textarea" name="body" rows="2" required placeholder="Note for the team…"></textarea>
                </label>
                <button type="submit" class="btn-secondary">Add note</button>
              </form>
              <ul class="client-notes" data-notes-list></ul>
            </section>
          </div>
        </div>
      </TeamListLayout>
    </div>
  </div>
</TeamLayout>

<script src="../../scripts/client-profile.ts"></script>

<style>
  .client-profile__intro {
    margin-bottom: 1rem;
  }

  .client-profile__name {
    margin: 0.15rem 0 0;
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    font-weight: 600;
  }

  .client-profile__stats {
    margin: 0.35rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-gray);
  }

  .client-profile__layout {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 960px) {
    .client-profile__layout {
      grid-template-columns: minmax(16rem, 22rem) 1fr;
      align-items: start;
    }
  }

  .client-profile__sidebar,
  .client-profile__main {
    display: grid;
    gap: 1rem;
  }

  .client-form,
  .client-note-add {
    display: grid;
    gap: 0.75rem;
  }

  .client-form__row {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 2fr 1fr 1fr;
  }

  @media (max-width: 720px) {
    .client-form__row {
      grid-template-columns: 1fr;
    }
  }

  .client-form__fieldset {
    margin: 0;
    padding: 0;
    border: 0;
  }

  .client-form__checks {
    display: grid;
    gap: 0.35rem;
  }

  .checkbox-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.88rem;
  }

  .client-timeline,
  .client-notes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .client-timeline__item,
  .client-notes__item {
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--color-border-subtle);
    background: var(--color-booking-panel-bg);
  }

  .client-timeline__meta,
  .client-notes__meta {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: var(--color-gray);
    margin-bottom: 0.25rem;
  }

  .client-timeline__status {
    display: inline-block;
    margin-top: 0.35rem;
    padding: 0.1rem 0.45rem;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: rgba(231, 172, 70, 0.2);
  }
</style>
