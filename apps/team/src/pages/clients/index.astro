---
import TeamLayout from "../../layouts/TeamLayout.astro";
import TeamPage from "../../components/TeamPage.astro";
import { teamUrl } from "../../lib/supabase-server";

const { staff } = Astro.locals;
if (!staff) {
  return Astro.redirect(`${import.meta.env.BASE_URL}login?error=unlinked`);
}

const initialQuery = Astro.url.searchParams.get("q") ?? "";
---

<TeamLayout title="Clients" activeNav="clients" plain wide>
  <div class="clients-page" data-clients-search>
    <TeamPage
      title="Clients"
      lead="Search by name, email, or phone to open a client chart."
      toolbar
    >
      <label slot="toolbar" class="team-toolbar-field team-toolbar-field--grow">
        <span class="team-toolbar-label">Search clients</span>
        <input
          class="form-input"
          type="search"
          name="q"
          value={initialQuery}
          placeholder="Start typing…"
          autocomplete="off"
          data-search-input
          autofocus
        />
      </label>

      <p class="notice" data-status hidden aria-live="polite"></p>
      <ul class="team-list" data-results role="listbox" aria-label="Search results"></ul>
    </TeamPage>
  </div>
</TeamLayout>

<script
  define:vars={{
    searchApi: teamUrl("/api/clients/search"),
    clientsBase: teamUrl("/clients"),
    initialQuery,
  }}
>
  const root = document.querySelector("[data-clients-search]");
  const input = root?.querySelector("[data-search-input]");
  const results = root?.querySelector("[data-results]");
  const status = root?.querySelector("[data-status]");
  let debounce = null;

  function showStatus(message, isError = false) {
    if (!status) return;
    status.textContent = message;
    status.hidden = !message;
    status.classList.toggle("notice--error", isError);
  }

  function renderResults(clients) {
    if (!results) return;
    results.innerHTML = "";

    if (clients.length === 0) {
      showStatus("No clients found.");
      return;
    }

    showStatus("");

    for (const client of clients) {
      const li = document.createElement("li");
      const link = document.createElement("a");
      link.className = "team-list__link";
      link.href = `${clientsBase}/${client.id}`;
      link.innerHTML = `
        <span class="team-list__primary">${client.fullName}</span>
        <span class="team-list__secondary">${[client.phone, client.email].filter(Boolean).join(" · ") || "No contact on file"}</span>
      `;
      li.appendChild(link);
      results.appendChild(li);
    }
  }

  async function search(term) {
    if (term.length < 2) {
      renderResults([]);
      showStatus(term.length === 0 ? "" : "Type at least 2 characters.");
      return;
    }

    showStatus("Searching…");
    try {
      const res = await fetch(`${searchApi}?q=${encodeURIComponent(term)}`);
      const body = await res.json();
      if (!res.ok) throw new Error(body.error || "Search failed");
      renderResults(body.clients ?? []);
      if ((body.clients ?? []).length > 0) showStatus("");
    } catch (err) {
      showStatus(err instanceof Error ? err.message : "Search failed", true);
      renderResults([]);
    }
  }

  input?.addEventListener("input", () => {
    const term = input.value.trim();
    if (debounce) clearTimeout(debounce);
    debounce = setTimeout(() => search(term), 250);
  });

  if (initialQuery.length >= 2) {
    search(initialQuery);
  }
</script>
