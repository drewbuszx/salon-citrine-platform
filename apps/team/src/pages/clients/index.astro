---
import TeamLayout from "../../layouts/TeamLayout.astro";
import TeamListLayout from "../../components/TeamListLayout.astro";
import TeamListFilter from "../../components/TeamListFilter.astro";
import TeamListExportButton from "../../components/TeamListExportButton.astro";
import { teamUrl } from "../../lib/supabase-server";

const { staff, supabase } = Astro.locals;
if (!staff) {
  return Astro.redirect(`${import.meta.env.BASE_URL}login?error=unlinked`);
}

const initialQuery = Astro.url.searchParams.get("q") ?? "";

const { count: totalCount, error: countError } = await supabase
  .from("clients")
  .select("*", { count: "exact", head: true });

let initialClients: Array<{
  id: string;
  firstName: string;
  lastName: string;
  phone: string | null;
  email: string | null;
}> = [];

if (!countError) {
  let listQuery = supabase
    .from("clients")
    .select("id, first_name, last_name, phone, email")
    .order("last_name")
    .order("first_name");

  const term = initialQuery.replace(/,/g, " ").trim();
  if (term.length >= 2) {
    listQuery = listQuery.or(
      `first_name.ilike.%${term}%,last_name.ilike.%${term}%,email.ilike.%${term}%,phone.ilike.%${term}%`,
    );
  }

  const { data } = await listQuery.limit(term.length >= 2 ? 50 : 100);
  initialClients = (data ?? []).map((row) => ({
    id: row.id,
    firstName: row.first_name,
    lastName: row.last_name,
    phone: row.phone,
    email: row.email,
  }));
}

const filterCategories = [
  "Saved Audiences",
  "Locations",
  "Primary Locations",
  "Purchased",
  "Provider",
  "First Appointment",
  "Last Appointment",
  "Tags",
  "Referral Source",
  "Blocked",
];
---

<TeamLayout title="Clients" activeNav="clients" plain wide fullBleed>
  <div class="clients-page" data-clients-root>
  <TeamListLayout title="Clients" mainTitle="Your Clients">
    <button slot="headerActions" class="team-list-layout__btn-secondary" type="button" data-coming-soon>
      Merge Clients
    </button>
    <button slot="headerActions" class="team-list-layout__btn-primary" type="button" data-add-open>
      Add New Client
    </button>

    {
      filterCategories.map((label) => (
        <TeamListFilter slot="sidebarFilters" label={label} />
      ))
    }

    <TeamListExportButton slot="sidebarFooter" />

    <Fragment slot="stats">
      Total: <span data-total-count>{countError ? "—" : (totalCount ?? initialClients.length)}</span>
      | <span data-filter-count>0</span> filters applied
    </Fragment>

    <label slot="searchBar" class="team-list-layout__search">
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.75"></circle>
        <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
      </svg>
      <input
        class="team-list-layout__search-input"
        type="search"
        name="q"
        value={initialQuery}
        placeholder="Search by name, phone number, or email"
        autocomplete="off"
        data-search-input
      />
    </label>

    <p class="team-list-layout__notice" data-status hidden aria-live="polite"></p>

    <div class="clients-page__table-wrap">
      <table class="clients-table">
        <thead>
          <tr>
            <th scope="col">First Name</th>
            <th scope="col">Last Name</th>
            <th scope="col">Mobile</th>
            <th scope="col">Email</th>
          </tr>
        </thead>
        <tbody data-results></tbody>
      </table>
      <p class="clients-page__empty" data-empty hidden>No clients found.</p>
    </div>
  </TeamListLayout>
  </div>

  <div class="clients-modal" data-add-modal hidden>
    <div class="clients-modal__backdrop" data-modal-close></div>
    <div class="clients-modal__panel" role="dialog" aria-modal="true" aria-labelledby="add-client-title">
      <div class="clients-modal__head">
        <h2 id="add-client-title">Add New Client</h2>
        <button class="clients-modal__close" type="button" data-modal-close aria-label="Close">×</button>
      </div>
      <form class="clients-modal__form" data-add-form>
        <label class="clients-modal__label">
          First name
          <input class="clients-modal__input" name="firstName" required autocomplete="given-name" />
        </label>
        <label class="clients-modal__label">
          Last name
          <input class="clients-modal__input" name="lastName" required autocomplete="family-name" />
        </label>
        <label class="clients-modal__label">
          Mobile
          <input class="clients-modal__input" name="phone" type="tel" autocomplete="tel" />
        </label>
        <label class="clients-modal__label">
          Email
          <input class="clients-modal__input" name="email" type="email" autocomplete="email" />
        </label>
        <p class="team-list-layout__notice team-list-layout__notice--error" data-add-error hidden></p>
        <div class="clients-modal__actions">
          <button class="team-list-layout__btn-secondary" type="button" data-modal-close>Cancel</button>
          <button class="team-list-layout__btn-primary" type="submit">Create client</button>
        </div>
      </form>
    </div>
  </div>

  <div class="clients-toast" data-toast hidden role="status"></div>
</TeamLayout>

<script
  define:vars={{
    searchApi: teamUrl("/api/clients/search"),
    createApi: teamUrl("/api/clients"),
    clientsBase: teamUrl("/clients"),
    initialQuery,
    initialClients,
    initialTotal: countError ? null : (totalCount ?? initialClients.length),
  }}
>
  const root = document.querySelector("[data-clients-root]");
  const input = root?.querySelector("[data-search-input]");
  const tbody = root?.querySelector("[data-results]");
  const status = root?.querySelector("[data-status]");
  const emptyState = root?.querySelector("[data-empty]");
  const totalEl = root?.querySelector("[data-total-count]");
  const toast = document.querySelector("[data-toast]");
  const addModal = document.querySelector("[data-add-modal]");
  const addForm = document.querySelector("[data-add-form]");
  const addError = document.querySelector("[data-add-error]");
  let debounce = null;
  let toastTimer = null;

  function formatPhone(value) {
    return value?.trim() || "—";
  }

  function formatEmail(value) {
    return value?.trim() || "—";
  }

  function showStatus(message, isError = false) {
    if (!status) return;
    status.textContent = message;
    status.hidden = !message;
    status.classList.toggle("team-list-layout__notice--error", isError);
  }

  function showToast(message) {
    if (!toast) return;
    toast.textContent = message;
    toast.hidden = false;
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(() => {
      toast.hidden = true;
    }, 2800);
  }

  function renderResults(clients) {
    if (!tbody || !emptyState) return;
    tbody.innerHTML = "";

    if (clients.length === 0) {
      emptyState.hidden = false;
      return;
    }

    emptyState.hidden = true;

    for (const client of clients) {
      const tr = document.createElement("tr");
      const linkBase = `${clientsBase}/${client.id}`;
      tr.innerHTML = `
        <td><a class="clients-table__link" href="${linkBase}">${client.firstName || "—"}</a></td>
        <td><a class="clients-table__link" href="${linkBase}">${client.lastName || "—"}</a></td>
        <td>${formatPhone(client.phone)}</td>
        <td>${formatEmail(client.email)}</td>
      `;
      tbody.appendChild(tr);
    }
  }

  async function loadClients(term) {
    const query = term.trim();
    if (query.length === 1) {
      renderResults([]);
      showStatus("Type at least 2 characters to search.");
      return;
    }

    if (query.length >= 2) {
      showStatus("Searching…");
    } else {
      showStatus("");
    }

    try {
      const url =
        query.length >= 2
          ? `${searchApi}?q=${encodeURIComponent(query)}`
          : searchApi;
      const res = await fetch(url);
      const body = await res.json();
      if (!res.ok) throw new Error(body.error || "Failed to load clients");

      renderResults(body.clients ?? []);
      if (totalEl && typeof body.total === "number") {
        totalEl.textContent = String(body.total);
      }
      showStatus("");
    } catch (err) {
      showStatus(err instanceof Error ? err.message : "Failed to load clients", true);
      renderResults([]);
    }
  }

  input?.addEventListener("input", () => {
    const term = input.value.trim();
    if (debounce) clearTimeout(debounce);
    debounce = setTimeout(() => loadClients(term), 250);
  });

  function openAddModal() {
    addModal?.removeAttribute("hidden");
    addForm?.reset();
    if (addError) addError.hidden = true;
    addForm?.querySelector("input")?.focus();
  }

  function closeAddModal() {
    addModal?.setAttribute("hidden", "");
  }

  root?.querySelector("[data-add-open]")?.addEventListener("click", openAddModal);
  document.querySelectorAll("[data-modal-close]").forEach((el) => {
    el.addEventListener("click", closeAddModal);
  });

  document.querySelectorAll("[data-coming-soon]").forEach((el) => {
    el.addEventListener("click", () => showToast("Coming soon"));
  });

  addForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!(addForm instanceof HTMLFormElement)) return;

    const formData = new FormData(addForm);
    const payload = {
      firstName: String(formData.get("firstName") ?? "").trim(),
      lastName: String(formData.get("lastName") ?? "").trim(),
      phone: String(formData.get("phone") ?? "").trim(),
      email: String(formData.get("email") ?? "").trim(),
    };

    if (addError) addError.hidden = true;

    try {
      const res = await fetch(createApi, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const body = await res.json();
      if (!res.ok) throw new Error(body.error || "Failed to create client");

      const clientId = body.client?.id;
      if (clientId) {
        window.location.href = `${clientsBase}/${clientId}`;
        return;
      }
      closeAddModal();
      loadClients("");
    } catch (err) {
      if (addError) {
        addError.textContent = err instanceof Error ? err.message : "Failed to create client";
        addError.hidden = false;
      }
    }
  });

  renderResults(initialClients);
  if (initialTotal !== null && totalEl) {
    totalEl.textContent = String(initialTotal);
  }
  if (initialQuery.trim().length === 1) {
    showStatus("Type at least 2 characters to search.");
  }
</script>

<style>
  .clients-page__table-wrap {
    overflow-x: auto;
  }

  .clients-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }

  .clients-table th {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e5e7eb;
    font-size: 0.75rem;
    font-weight: 600;
    text-align: left;
    color: #6b7280;
    background: #fff;
  }

  .clients-table td {
    padding: 0.95rem 1rem;
    border-bottom: 1px solid #e5e7eb;
    color: #374151;
    vertical-align: middle;
  }

  .clients-table tbody tr:hover td {
    background: #f9fafb;
  }

  .clients-table__link {
    color: #0096ff;
    text-decoration: none;
  }

  .clients-table__link:hover,
  .clients-table__link:focus-visible {
    text-decoration: underline;
    outline: none;
  }

  .clients-page__empty {
    margin: 1.5rem 0 0;
    text-align: center;
    font-size: 0.875rem;
    color: #9ca3af;
  }

  .clients-modal[hidden] {
    display: none;
  }

  .clients-modal {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: grid;
    place-items: center;
    padding: 1rem;
  }

  .clients-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(17, 24, 39, 0.45);
  }

  .clients-modal__panel {
    position: relative;
    z-index: 1;
    width: min(100%, 28rem);
    padding: 1.25rem;
    border-radius: 0.35rem;
    background: #fff;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.18);
  }

  .clients-modal__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .clients-modal__head h2 {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 600;
  }

  .clients-modal__close {
    border: none;
    background: none;
    font-size: 1.5rem;
    line-height: 1;
    color: #6b7280;
    cursor: pointer;
  }

  .clients-modal__form {
    display: grid;
    gap: 0.85rem;
  }

  .clients-modal__label {
    display: grid;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: #374151;
  }

  .clients-modal__input {
    padding: 0.55rem 0.65rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.25rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: #111827;
  }

  .clients-modal__input:focus-visible {
    outline: none;
    border-color: #0096ff;
    box-shadow: 0 0 0 2px rgba(0, 150, 255, 0.2);
  }

  .clients-modal__actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .clients-toast {
    position: fixed;
    left: 50%;
    bottom: 1.5rem;
    z-index: 400;
    transform: translateX(-50%);
    padding: 0.65rem 1rem;
    border-radius: 0.35rem;
    background: #111827;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .clients-toast[hidden] {
    display: none;
  }

  @media (max-width: 640px) {
    .clients-table th,
    .clients-table td {
      padding-inline: 0.65rem;
    }
  }
</style>
