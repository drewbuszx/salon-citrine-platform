---
import TeamLayout from "../../layouts/TeamLayout.astro";
import TeamListLayout from "../../components/TeamListLayout.astro";
import TeamListFilter from "../../components/TeamListFilter.astro";
import TeamListExportButton from "../../components/TeamListExportButton.astro";
import { teamUrl } from "../../lib/supabase-server";

const { staff, supabase } = Astro.locals;
if (!staff) {
  return Astro.redirect(`${import.meta.env.BASE_URL}login?error=unlinked`);
}

const initialQuery = Astro.url.searchParams.get("q") ?? "";

const [
  { count: totalCount, error: countError },
  { data: tagRows },
  { data: referralRows },
  { data: staffRows },
  { data: locationRows },
] = await Promise.all([
  supabase.from("clients").select("*", { count: "exact", head: true }),
  supabase.from("clients").select("tags"),
  supabase.from("clients").select("referral_sources"),
  supabase.from("staff").select("id, name").in("role", ["owner", "stylist", "esthetician"]).order("name"),
  supabase.from("locations").select("id, name").eq("is_active", true).order("name"),
]);

const tagSet = new Set<string>();
for (const row of tagRows ?? []) {
  for (const tag of row.tags ?? []) {
    if (tag?.trim()) tagSet.add(tag.trim());
  }
}
const tags = [...tagSet].sort((a, b) => a.localeCompare(b));

const referralSet = new Set<string>();
for (const row of referralRows ?? []) {
  for (const source of row.referral_sources ?? []) {
    if (source?.trim()) referralSet.add(source.trim());
  }
}
const referralSources = [...referralSet].sort((a, b) => a.localeCompare(b));

const providers = staffRows ?? [];
const locations = locationRows ?? [];

let initialClients: Array<{
  id: string;
  firstName: string;
  lastName: string;
  phone: string | null;
  email: string | null;
}> = [];

if (!countError) {
  let listQuery = supabase
    .from("clients")
    .select("id, first_name, last_name, phone, email")
    .order("last_name")
    .order("first_name");

  const term = initialQuery.replace(/,/g, " ").trim();
  if (term.length >= 2) {
    listQuery = listQuery.or(
      `first_name.ilike.%${term}%,last_name.ilike.%${term}%,email.ilike.%${term}%,phone.ilike.%${term}%`,
    );
  }

  const { data } = await listQuery.limit(term.length >= 2 ? 50 : 100);
  initialClients = (data ?? []).map((row) => ({
    id: row.id,
    firstName: row.first_name,
    lastName: row.last_name,
    phone: row.phone,
    email: row.email,
  }));
}
---

<TeamLayout title="Clients" activeNav="clients" plain wide fullBleed>
  <div class="clients-page" data-clients-root>
  <TeamListLayout title="Clients" mainTitle="Your Clients" sidebarTitle="Refine Your Search">
    <button slot="headerActions" class="team-list-layout__btn-secondary" type="button" data-coming-soon>
      Merge Clients
    </button>
    <button slot="headerActions" class="team-list-layout__btn-primary" type="button" data-add-open>
      Add New Client
    </button>

    <TeamListFilter slot="sidebarFilters" label="Saved Audiences" count={0} placeholder="No saved audiences yet." open={false}>
      <p class="clients-filter-empty">
        <span class="clients-filter-empty__icon" aria-hidden="true">◎</span>
        Save filtered lists here soon — for now, use Tags or Referral below.
      </p>
    </TeamListFilter>

    <TeamListFilter slot="sidebarFilters" label="Locations" count={locations.length} open={locations.length > 0}>
      {
        locations.length > 0 ? (
          <div class="team-list-layout__filter-options">
            {
              locations.map((loc) => (
                <label class="team-list-layout__filter-option">
                  <input type="radio" name="client-location" value={loc.id} data-filter-location disabled />
                  <span>{loc.name}</span>
                </label>
              ))
            }
          </div>
        ) : (
          <p class="team-list-layout__filter-placeholder">Single-location salon — all clients.</p>
        )
      }
    </TeamListFilter>

    <TeamListFilter slot="sidebarFilters" label="Primary Locations" count={locations.length}>
      <p class="team-list-layout__filter-placeholder">Primary location tracking coming soon.</p>
    </TeamListFilter>

    <TeamListFilter slot="sidebarFilters" label="Purchased">
      <label class="team-list-layout__filter-option">
        <input type="checkbox" data-filter-purchased />
        <span>Has purchase history</span>
      </label>
      <label class="team-list-layout__filter-option">
        <input type="checkbox" data-filter-has-visits />
        <span>Has at least one visit</span>
      </label>
    </TeamListFilter>

    <TeamListFilter slot="sidebarFilters" label="Provider" count={providers.length} open={providers.length > 0}>
      {
        providers.length > 0 ? (
          <div class="team-list-layout__filter-options">
            <label class="team-list-layout__filter-option">
              <input type="radio" name="client-provider" value="" data-filter-provider checked />
              <span>All providers</span>
            </label>
            {
              providers.map((member) => (
                <label class="team-list-layout__filter-option">
                  <input type="radio" name="client-provider" value={member.id} data-filter-provider />
                  <span>{member.name}</span>
                </label>
              ))
            }
          </div>
        ) : (
          <p class="team-list-layout__filter-placeholder">No providers found.</p>
        )
      }
    </TeamListFilter>

    <TeamListFilter slot="sidebarFilters" label="First Appointment">
      <p class="clients-filter-empty clients-filter-empty--compact">Date range filter coming soon — use search or tags for now.</p>
    </TeamListFilter>

    <TeamListFilter slot="sidebarFilters" label="Last Appointment">
      <p class="clients-filter-empty clients-filter-empty--compact">Date range filter coming soon — sort by visit timeline on a profile.</p>
    </TeamListFilter>

    <TeamListFilter slot="sidebarFilters" label="Tags" count={tags.length} open={tags.length > 0}>
      {
        tags.length > 0 ? (
          <div class="team-list-layout__filter-options">
            <label class="team-list-layout__filter-option">
              <input type="radio" name="client-tag" value="" data-filter-tag checked />
              <span>All tags</span>
            </label>
            {
              tags.map((tag) => (
                <label class="team-list-layout__filter-option">
                  <input type="radio" name="client-tag" value={tag} data-filter-tag />
                  <span>{tag}</span>
                </label>
              ))
            }
          </div>
        ) : (
          <p class="team-list-layout__filter-placeholder">No client tags yet.</p>
        )
      }
    </TeamListFilter>

    <TeamListFilter slot="sidebarFilters" label="Referral Source" count={referralSources.length} open={referralSources.length > 0}>
      {
        referralSources.length > 0 ? (
          <div class="team-list-layout__filter-options">
            <label class="team-list-layout__filter-option">
              <input type="radio" name="client-referral" value="" data-filter-referral checked />
              <span>All sources</span>
            </label>
            {
              referralSources.map((source) => (
                <label class="team-list-layout__filter-option">
                  <input type="radio" name="client-referral" value={source} data-filter-referral />
                  <span>{source}</span>
                </label>
              ))
            }
          </div>
        ) : (
          <p class="team-list-layout__filter-placeholder">No referral sources recorded.</p>
        )
      }
    </TeamListFilter>

    <TeamListFilter slot="sidebarFilters" label="Blocked">
      <p class="clients-filter-empty clients-filter-empty--compact">No blocked clients — blocking will appear here when enabled.</p>
    </TeamListFilter>

    <TeamListExportButton slot="sidebarFooter" />

    <Fragment slot="stats">
      Total: <span data-total-count>{countError ? "—" : (totalCount ?? initialClients.length)}</span>
      | <span data-filter-count>0</span> filters applied
    </Fragment>

    <label slot="searchBar" class="team-list-layout__search clients-page__search" data-search-wrap>
      <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="none" data-search-icon>
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.75"></circle>
        <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
      </svg>
      <span class="clients-page__search-spinner" data-search-spinner hidden aria-hidden="true"></span>
      <input
        class="team-list-layout__search-input"
        type="search"
        name="q"
        value={initialQuery}
        placeholder="Search by name, phone number, or email"
        autocomplete="off"
        data-search-input
      />
    </label>

    <p class="team-list-layout__notice" data-status hidden aria-live="polite"></p>

    <div class="team-list-layout__table-wrap">
      <table class="team-list-layout__data-table clients-table">
        <thead>
          <tr>
            <th scope="col">First Name</th>
            <th scope="col">Last Name</th>
            <th scope="col">Mobile</th>
            <th scope="col">Email</th>
          </tr>
        </thead>
        <tbody data-results></tbody>
      </table>
      <p class="clients-page__empty" data-empty hidden>
        <span class="clients-page__empty-icon" aria-hidden="true">👤</span>
        <strong data-empty-title>No clients found</strong>
        <span class="clients-page__empty-hint" data-empty-hint>Try a different search or clear filters.</span>
      </p>
    </div>
  </TeamListLayout>
  </div>

  <div class="clients-modal" data-add-modal hidden>
    <div class="clients-modal__backdrop" data-modal-close></div>
    <div class="clients-modal__panel" role="dialog" aria-modal="true" aria-labelledby="add-client-title">
      <div class="clients-modal__head">
        <div>
          <h2 id="add-client-title">Add New Client</h2>
          <p class="clients-modal__lead">Quick add — full profile opens after save.</p>
        </div>
        <button class="clients-modal__close" type="button" data-modal-close aria-label="Close">×</button>
      </div>
      <form class="clients-modal__form" data-add-form>
        <div class="clients-modal__row">
          <label class="clients-modal__label">
            First name
            <input class="clients-modal__input" name="firstName" required autocomplete="given-name" />
          </label>
          <label class="clients-modal__label">
            Last name
            <input class="clients-modal__input" name="lastName" required autocomplete="family-name" />
          </label>
        </div>
        <label class="clients-modal__label">
          Mobile
          <input class="clients-modal__input" name="phone" type="tel" autocomplete="tel" placeholder="(317) 555-0100" />
        </label>
        <label class="clients-modal__label">
          Email
          <input class="clients-modal__input" name="email" type="email" autocomplete="email" placeholder="name@email.com" />
        </label>
        <p class="team-list-layout__notice team-list-layout__notice--error" data-add-error hidden></p>
        <div class="clients-modal__actions">
          <button class="team-list-layout__btn-secondary" type="button" data-modal-close>Cancel</button>
          <button class="team-list-layout__btn-primary" type="submit" data-add-submit>Create client</button>
        </div>
      </form>
    </div>
  </div>

  <div class="clients-toast" data-toast hidden role="status"></div>
</TeamLayout>

<script
  define:vars={{
    searchApi: teamUrl("/api/clients/search"),
    createApi: teamUrl("/api/clients"),
    clientsBase: teamUrl("/clients"),
    initialQuery,
    initialClients,
    initialTotal: countError ? null : (totalCount ?? initialClients.length),
  }}
>
  const root = document.querySelector("[data-clients-root]");
  const input = root?.querySelector("[data-search-input]");
  const tbody = root?.querySelector("[data-results]");
  const status = root?.querySelector("[data-status]");
  const emptyState = root?.querySelector("[data-empty]");
  const totalEl = root?.querySelector("[data-total-count]");
  const filterCountEl = root?.querySelector("[data-filter-count]");
  const toast = document.querySelector("[data-toast]");
  const addModal = document.querySelector("[data-add-modal]");
  const addForm = document.querySelector("[data-add-form]");
  const addError = document.querySelector("[data-add-error]");
  const addSubmit = document.querySelector("[data-add-submit]");
  const searchWrap = root?.querySelector("[data-search-wrap]");
  const searchSpinner = root?.querySelector("[data-search-spinner]");
  const searchIcon = root?.querySelector("[data-search-icon]");
  const emptyTitle = root?.querySelector("[data-empty-title]");
  const emptyHint = root?.querySelector("[data-empty-hint]");
  let debounce = null;
  let toastTimer = null;
  let loadingCount = 0;

  function getFilters() {
    const provider =
      root?.querySelector("[data-filter-provider]:checked")?.value?.trim() ?? "";
    const tag = root?.querySelector("[data-filter-tag]:checked")?.value?.trim() ?? "";
    const referral =
      root?.querySelector("[data-filter-referral]:checked")?.value?.trim() ?? "";
    const purchased = Boolean(root?.querySelector("[data-filter-purchased]")?.checked);
    const hasVisits = Boolean(root?.querySelector("[data-filter-has-visits]")?.checked);
    return { provider, tag, referral, purchased, hasVisits };
  }

  function formatPhone(value) {
    return value?.trim() || "—";
  }

  function formatEmail(value) {
    return value?.trim() || "—";
  }

  function showStatus(message, isError = false) {
    if (!status) return;
    status.textContent = message;
    status.hidden = !message;
    status.classList.toggle("team-list-layout__notice--error", isError);
  }

  function showToast(message) {
    if (!toast) return;
    toast.textContent = message;
    toast.hidden = false;
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(() => {
      toast.hidden = true;
    }, 2800);
  }

  function setSearchLoading(active) {
    loadingCount += active ? 1 : -1;
    if (loadingCount < 0) loadingCount = 0;
    const isLoading = loadingCount > 0;
    searchWrap?.classList.toggle("clients-page__search--loading", isLoading);
    if (searchSpinner instanceof HTMLElement) searchSpinner.hidden = !isLoading;
    if (searchIcon instanceof HTMLElement) searchIcon.hidden = isLoading;
    input?.setAttribute("aria-busy", isLoading ? "true" : "false");
  }

  function navigateToClient(href) {
    window.location.href = href;
  }

  function bindClientRow(tr, linkBase) {
    tr.className = "clients-table__row";
    tr.tabIndex = 0;
    tr.setAttribute("role", "link");
    tr.setAttribute("aria-label", `View ${tr.querySelector("td")?.textContent?.trim() ?? "client"} profile`);
    tr.addEventListener("click", (event) => {
      if (event.target instanceof HTMLAnchorElement) return;
      navigateToClient(linkBase);
    });
    tr.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        navigateToClient(linkBase);
      }
    });
  }

  function renderResults(clients) {
    if (!tbody || !emptyState) return;
    tbody.innerHTML = "";

    if (clients.length === 0) {
      emptyState.hidden = false;
      const filters = getFilters();
      const hasFilters =
        filters.provider ||
        filters.tag ||
        filters.referral ||
        filters.purchased ||
        filters.hasVisits;
      const term = input?.value.trim() ?? "";
      if (emptyTitle) {
        emptyTitle.textContent = hasFilters
          ? "No clients match filters"
          : term.length >= 2
            ? "No clients match search"
            : "No clients yet";
      }
      if (emptyHint) {
        emptyHint.textContent = hasFilters
          ? "Try clearing a sidebar filter or broadening your search."
          : term.length >= 2
            ? "Check spelling or search by phone or email."
            : "Add your first client with the button above.";
      }
      return;
    }

    emptyState.hidden = true;

    for (const client of clients) {
      const tr = document.createElement("tr");
      const linkBase = `${clientsBase}/${client.id}`;
      tr.dataset.clientHref = linkBase;
      tr.innerHTML = `
        <td><a class="team-list-layout__data-table__link" href="${linkBase}">${client.firstName || "—"}</a></td>
        <td><a class="team-list-layout__data-table__link" href="${linkBase}">${client.lastName || "—"}</a></td>
        <td>${formatPhone(client.phone)}</td>
        <td>${formatEmail(client.email)}</td>
      `;
      bindClientRow(tr, linkBase);
      tbody.appendChild(tr);
    }
  }

  function renderSkeletonRows() {
    if (!tbody) return;
    emptyState.hidden = true;
    tbody.innerHTML = Array.from({ length: 6 }, () =>
      `<tr class="clients-table__skeleton-row">
        <td><span class="skeleton skeleton--line"></span></td>
        <td><span class="skeleton skeleton--line"></span></td>
        <td><span class="skeleton skeleton--line"></span></td>
        <td><span class="skeleton skeleton--line"></span></td>
      </tr>`,
    ).join("");
  }

  async function loadClients(term) {
    const query = term.trim();
    if (query.length === 1) {
      setSearchLoading(false);
      renderResults([]);
      showStatus("Type at least 2 characters to search.");
      return;
    }

    renderSkeletonRows();
    setSearchLoading(true);
    showStatus("");

    const filters = getFilters();
    const params = new URLSearchParams();
    if (query.length >= 2) params.set("q", query);
    if (filters.provider) params.set("provider", filters.provider);
    if (filters.tag) params.set("tag", filters.tag);
    if (filters.referral) params.set("referral", filters.referral);
    if (filters.purchased) params.set("purchased", "1");
    if (filters.hasVisits) params.set("hasVisits", "1");

    try {
      const url = `${searchApi}?${params.toString()}`;
      const res = await fetch(url);
      const body = await res.json();
      if (!res.ok) throw new Error(body.error || "Failed to load clients");

      renderResults(body.clients ?? []);
      if (totalEl && typeof body.total === "number") {
        totalEl.textContent = String(body.total);
      }
      if (filterCountEl && typeof body.filtersApplied === "number") {
        filterCountEl.textContent = String(body.filtersApplied);
      }
      showStatus("");
    } catch (err) {
      showStatus(err instanceof Error ? err.message : "Failed to load clients", true);
      renderResults([]);
    } finally {
      setSearchLoading(false);
    }
  }

  function scheduleLoad() {
    const term = input?.value.trim() ?? "";
    if (debounce) clearTimeout(debounce);
    debounce = setTimeout(() => loadClients(term), 250);
  }

  input?.addEventListener("input", scheduleLoad);

  root?.querySelectorAll("[data-filter-provider], [data-filter-tag], [data-filter-referral]").forEach((el) => {
    el.addEventListener("change", () => {
      showToast("Filters updated");
      scheduleLoad();
    });
  });
  root?.querySelector("[data-filter-purchased]")?.addEventListener("change", () => {
    showToast("Filters updated");
    scheduleLoad();
  });
  root?.querySelector("[data-filter-has-visits]")?.addEventListener("change", () => {
    showToast("Filters updated");
    scheduleLoad();
  });

  function openAddModal() {
    addModal?.removeAttribute("hidden");
    addForm?.reset();
    if (addError) addError.hidden = true;
    if (addSubmit instanceof HTMLButtonElement) {
      addSubmit.disabled = false;
      addSubmit.removeAttribute("aria-busy");
      addSubmit.textContent = "Create client";
    }
    addForm?.querySelector("input")?.focus();
  }

  function closeAddModal() {
    addModal?.setAttribute("hidden", "");
  }

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && addModal && !addModal.hasAttribute("hidden")) {
      closeAddModal();
    }
  });

  root?.querySelector("[data-add-open]")?.addEventListener("click", openAddModal);
  document.querySelectorAll("[data-modal-close]").forEach((el) => {
    el.addEventListener("click", closeAddModal);
  });

  document.querySelectorAll("[data-coming-soon]").forEach((el) => {
    el.addEventListener("click", () => showToast("Coming soon"));
  });

  addForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!(addForm instanceof HTMLFormElement)) return;

    const formData = new FormData(addForm);
    const payload = {
      firstName: String(formData.get("firstName") ?? "").trim(),
      lastName: String(formData.get("lastName") ?? "").trim(),
      phone: String(formData.get("phone") ?? "").trim(),
      email: String(formData.get("email") ?? "").trim(),
    };

    if (addError) addError.hidden = true;
    if (addSubmit instanceof HTMLButtonElement) {
      addSubmit.disabled = true;
      addSubmit.setAttribute("aria-busy", "true");
      addSubmit.textContent = "Creating…";
    }

    try {
      const res = await fetch(createApi, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const body = await res.json();
      if (!res.ok) throw new Error(body.error || "Failed to create client");

      const clientId = body.client?.id;
      if (clientId) {
        window.location.href = `${clientsBase}/${clientId}`;
        return;
      }
      closeAddModal();
      loadClients("");
    } catch (err) {
      if (addError) {
        addError.textContent = err instanceof Error ? err.message : "Failed to create client";
        addError.hidden = false;
      }
      if (addSubmit instanceof HTMLButtonElement) {
        addSubmit.disabled = false;
        addSubmit.removeAttribute("aria-busy");
        addSubmit.textContent = "Create client";
      }
    }
  });

  renderResults(initialClients);
  if (initialTotal !== null && totalEl) {
    totalEl.textContent = String(initialTotal);
  }
  if (initialQuery.trim().length === 1) {
    showStatus("Type at least 2 characters to search.");
  }
</script>

<style>
  .clients-filter-empty {
    margin: 0;
    padding: 0.5rem 0 0;
    display: grid;
    gap: 0.35rem;
    font-size: var(--text-xs);
    line-height: var(--leading-normal);
    color: var(--color-stone-500);
  }

  .clients-filter-empty--compact {
    padding: 0;
  }

  .clients-filter-empty__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--color-stone-100);
    font-size: 0.75rem;
    color: var(--color-stone-500);
  }

  .clients-page__search {
    position: relative;
  }

  .clients-page__search-spinner {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    border: 2px solid var(--color-stone-200);
    border-top-color: var(--color-citrine);
    border-radius: 50%;
    animation: clients-search-spin 0.65s linear infinite;
  }

  .clients-page__search-spinner[hidden] {
    display: none;
  }

  .clients-page__search--loading .team-list-layout__search-input {
    color: var(--color-stone-500);
  }

  @keyframes clients-search-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .clients-page :global(.clients-table__row:focus-visible) {
    outline: 2px solid var(--color-citrine);
    outline-offset: -2px;
  }

  .clients-table__skeleton-row .skeleton--line {
    display: block;
    width: 80%;
    max-width: 10rem;
    height: 0.75rem;
  }

  .clients-page__empty {
    display: grid;
    gap: 0.35rem;
    justify-items: center;
    margin: 2.5rem auto 0;
    max-width: 20rem;
    padding: 2rem 1rem;
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-stone-500);
  }

  .clients-page__empty[hidden] {
    display: none;
  }

  .clients-page__empty-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--color-stone-100);
    font-size: 1.35rem;
    line-height: 1;
    margin-bottom: 0.35rem;
  }

  .clients-page__empty strong {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-stone-700);
  }

  .clients-page__empty-hint {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-stone-500);
  }

  .clients-modal[hidden] {
