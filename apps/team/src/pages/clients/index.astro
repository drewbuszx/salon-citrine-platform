---
import TeamLayout from "../../layouts/TeamLayout.astro";
import TeamListLayout from "../../components/TeamListLayout.astro";
import TeamListFilter from "../../components/TeamListFilter.astro";
import ClientsAddModal from "../../components/clients/ClientsAddModal.astro";
import ClientsPreviewDrawer from "../../components/clients/ClientsPreviewDrawer.astro";
import { teamUrl } from "../../lib/supabase-server";
import {
  clientInitials,
  formatLtvDisplay,
  formatPhoneDisplay,
  preferredNameFromPreferences,
} from "../../lib/client-format";

const { staff, supabase } = Astro.locals;
if (!staff) {
  return Astro.redirect(teamUrl("/login?error=unlinked"));
}

const initialQuery = Astro.url.searchParams.get("q") ?? "";
const bookUrl = teamUrl("/book");

const [
  { count: totalCount, error: countError },
  { data: tagRows },
  { data: referralRows },
  { data: staffRows },
] = await Promise.all([
  supabase.from("clients").select("*", { count: "exact", head: true }),
  supabase.from("clients").select("tags"),
  supabase.from("clients").select("referral_sources"),
  supabase.from("staff").select("id, name").in("role", ["owner", "stylist", "esthetician"]).order("name"),
]);

const tagSet = new Set<string>();
for (const row of tagRows ?? []) {
  for (const tag of row.tags ?? []) {
    if (tag?.trim()) tagSet.add(tag.trim());
  }
}
const tags = [...tagSet].sort((a, b) => a.localeCompare(b));

const referralSet = new Set<string>();
for (const row of referralRows ?? []) {
  for (const source of row.referral_sources ?? []) {
    if (source?.trim()) referralSet.add(source.trim());
  }
}
const referralSources = [...referralSet].sort((a, b) => a.localeCompare(b));

const providers = staffRows ?? [];

function formatVisitDate(iso: string | null | undefined) {
  if (!iso) return null;
  return new Intl.DateTimeFormat("en-US", {
    timeZone: "America/Indiana/Indianapolis",
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(iso));
}

let initialClients: Array<Record<string, unknown>> = [];

if (!countError) {
  let listQuery = supabase
    .from("clients")
    .select(
      "id, first_name, last_name, phone, email, tags, visit_count, lifetime_value_cents, last_visit_at, booking_preferences",
    )
    .order("last_name")
    .order("first_name");

  const term = initialQuery.replace(/,/g, " ").trim();
  if (term.length >= 2) {
    listQuery = listQuery.or(
      `first_name.ilike.%${term}%,last_name.ilike.%${term}%,email.ilike.%${term}%,phone.ilike.%${term}%`,
    );
  }

  const { data } = await listQuery.limit(term.length >= 2 ? 50 : 25);
  initialClients = (data ?? []).map((row) => {
    const tagList = (row.tags ?? []).filter(Boolean);
    const visitCount = row.visit_count ?? 0;
    const ltv = formatLtvDisplay(row.lifetime_value_cents, visitCount);
    return {
      id: row.id,
      firstName: row.first_name,
      lastName: row.last_name,
      fullName: `${row.first_name} ${row.last_name}`.trim(),
      preferredName: preferredNameFromPreferences(row.first_name, row.booking_preferences),
      phone: row.phone,
      email: row.email,
      phoneDisplay: formatPhoneDisplay(row.phone),
      emailDisplay: row.email?.trim() || null,
      tags: tagList,
      tagLabels: tagList.slice(0, 3),
      visitCount,
      ltvCents: row.lifetime_value_cents ?? 0,
      ltvLabel: ltv.label,
      ltvTitle: ltv.title,
      ltvKind: ltv.kind,
      lastVisitLabel: formatVisitDate(row.last_visit_at),
      providerName: null,
      upcomingLabel: null,
      upcomingAt: null,
      initials: clientInitials(row.first_name, row.last_name),
    };
  });
}

const initialTotal = countError ? null : (totalCount ?? initialClients.length);
---

<TeamLayout title="Clients" activeNav="clients" plain wide fullBleed>
  <div
    class="clients-page"
    data-clients-root
    data-client-api={teamUrl("/api/clients/:id")}
  >
    <TeamListLayout
      title="Clients"
      mainTitle="Your Clients"
      sidebarTitle="Refine your search"
      rootClass="clients-list-layout"
      filterKey="clients"
    >
      <Fragment slot="toolbar">
        <div class="clients-page__toolbar">
          <div class="clients-page__toolbar-main">
            <h2 class="clients-page__heading">
              <span class="clients-page__heading-title">Your Clients</span>
              <span
                class="clients-page__heading-count"
                data-client-count
                aria-label={initialTotal === 1 ? "1 client" : `${initialTotal ?? 0} clients`}
              >{initialTotal ?? "—"}</span>
            </h2>
            <div class="clients-page__search-block">
              <label class="clients-page__search" data-search-wrap>
                <span class="clients-page__search-label">Search by name, phone, or email</span>
                <span class="clients-page__search-field">
                  <svg class="clients-page__search-icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="none" data-search-icon>
                    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.75"></circle>
                    <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
                  </svg>
                  <span class="clients-page__search-spinner" data-search-spinner hidden aria-hidden="true"></span>
                  <input
                    class="clients-page__search-input"
                    type="search"
                    name="q"
                    value={initialQuery}
                    placeholder="Search by name, phone, or email"
                    autocomplete="off"
                    data-search-input
                    aria-label="Search by name, phone, or email"
                  />
                  <button class="clients-page__search-clear" type="button" data-search-clear hidden aria-label="Clear search">×</button>
                </span>
              </label>
              <span class="clients-page__result-count" data-result-count hidden></span>
            </div>
          </div>
          <div class="clients-page__toolbar-actions">
            <div class="clients-page__sort">
              <label class="clients-page__sort-inline">
                <span class="clients-page__sort-prefix">Sort:</span>
                <select class="clients-page__sort-select" data-sort-select aria-label="Sort clients by">
                  <option value="name">Name (A–Z)</option>
                  <option value="recently_added">Recently added</option>
                  <option value="last_visit">Last visit</option>
                  <option value="next_appointment">Next appointment</option>
                  <option value="visits">Most visits</option>
                  <option value="ltv">Highest lifetime value</option>
                </select>
              </label>
            </div>
            <details class="clients-page__columns">
              <summary class="clients-page__columns-trigger" aria-label="Choose columns">
                <svg width="15" height="15" viewBox="0 0 24 24" aria-hidden="true" fill="none">
                  <path d="M4 5h16M4 12h16M4 19h16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
                </svg>
                <span>Columns</span>
              </summary>
              <div class="clients-page__columns-panel">
                <label class="clients-page__columns-option"><input type="checkbox" data-column-toggle="client" checked /> Client</label>
                <label class="clients-page__columns-option"><input type="checkbox" data-column-toggle="contact" checked /> Contact</label>
                <label class="clients-page__columns-option"><input type="checkbox" data-column-toggle="provider" checked /> Provider</label>
                <label class="clients-page__columns-option"><input type="checkbox" data-column-toggle="lastVisit" checked /> Last visit</label>
                <label class="clients-page__columns-option"><input type="checkbox" data-column-toggle="nextAppt" checked /> Next appointment</label>
                <label class="clients-page__columns-option"><input type="checkbox" data-column-toggle="visits" checked /> Visits</label>
                <label class="clients-page__columns-option"><input type="checkbox" data-column-toggle="ltv" checked /> Lifetime value</label>
              </div>
            </details>
            <button class="clients-page__btn-primary" type="button" data-add-open>Add client</button>
          </div>
        </div>
      </Fragment>

      <div slot="stats" class="clients-page__summary" data-summary-strip role="group" aria-label="Client directory summary">
        <div class="clients-page__summary-item clients-page__summary-item--static">
          <span class="clients-page__summary-value" data-summary-total>{initialTotal ?? "—"}</span>
          <span class="clients-page__summary-label">Total clients</span>
        </div>
        <div class="clients-page__summary-item clients-page__summary-item--static">
          <span class="clients-page__summary-value" data-summary-new>—</span>
          <span class="clients-page__summary-label">New this month</span>
        </div>
        <button
          type="button"
          class="clients-page__summary-item clients-page__summary-item--action"
          data-summary-filter="upcoming"
          aria-pressed="false"
        >
          <span class="clients-page__summary-value" data-summary-upcoming>—</span>
          <span class="clients-page__summary-label">Upcoming appointments</span>
        </button>
        <button
          type="button"
          class="clients-page__summary-item clients-page__summary-item--action"
          data-summary-filter="noUpcoming"
          aria-pressed="false"
        >
          <span class="clients-page__summary-value" data-summary-no-booking>—</span>
          <span class="clients-page__summary-label">No future appointment</span>
        </button>
      </div>

      <TeamListFilter slot="sidebarFilters" label="Saved audiences" open={false}>
        <p class="clients-filter-empty">
          <span class="clients-filter-empty__icon" aria-hidden="true">◎</span>
          Saved segments are not available yet. Use tags or referral filters below.
        </p>
      </TeamListFilter>

      <TeamListFilter slot="sidebarFilters" label="Purchase history">
        <div class="team-list-layout__filter-options">
          <label class="team-list-layout__filter-option clients-page__filter-option">
            <input type="checkbox" data-filter-purchased />
            <span>Has completed sales</span>
          </label>
          <label class="team-list-layout__filter-option clients-page__filter-option">
            <input type="checkbox" data-filter-has-visits />
            <span>Has at least one visit</span>
          </label>
        </div>
      </TeamListFilter>

      <TeamListFilter slot="sidebarFilters" label="Provider" count={providers.length} open={providers.length > 0}>
        {
          providers.length > 0 ? (
            <div class="clients-page__provider-filter">
              <p class="clients-page__filter-hint">Matches clients with any appointment (past or upcoming) with this provider.</p>
              <div class="team-list-layout__filter-options clients-page__provider-list">
                <label class="team-list-layout__filter-option clients-page__filter-option">
                  <input type="radio" name="client-provider" value="" data-filter-provider checked />
                  <span>All providers</span>
                </label>
                {
                  providers.map((member) => (
                    <label class="team-list-layout__filter-option clients-page__filter-option">
                      <input type="radio" name="client-provider" value={member.id} data-filter-provider />
                      <span>{member.name}</span>
                    </label>
                  ))
                }
              </div>
            </div>
          ) : (
            <p class="team-list-layout__filter-placeholder">No providers found.</p>
          )
        }
      </TeamListFilter>

      <TeamListFilter slot="sidebarFilters" label="Tags" count={tags.length} open={tags.length > 0}>
        {
          tags.length > 0 ? (
            <div class="team-list-layout__filter-options">
              <label class="team-list-layout__filter-option clients-page__filter-option">
                <input type="radio" name="client-tag" value="" data-filter-tag checked />
                <span>All tags</span>
              </label>
              {
                tags.map((tag) => (
                  <label class="team-list-layout__filter-option clients-page__filter-option">
                    <input type="radio" name="client-tag" value={tag} data-filter-tag />
                    <span>{tag}</span>
                  </label>
                ))
              }
            </div>
          ) : (
            <p class="clients-filter-empty clients-filter-empty--compact">No tags yet — add tags on a client profile.</p>
          )
        }
      </TeamListFilter>

      <TeamListFilter slot="sidebarFilters" label="Referral source" count={referralSources.length} open={referralSources.length > 0}>
        {
          referralSources.length > 0 ? (
            <div class="team-list-layout__filter-options">
              <label class="team-list-layout__filter-option clients-page__filter-option">
                <input type="radio" name="client-referral" value="" data-filter-referral checked />
                <span>All sources</span>
              </label>
              {
                referralSources.map((source) => (
                  <label class="team-list-layout__filter-option clients-page__filter-option">
                    <input type="radio" name="client-referral" value={source} data-filter-referral />
                    <span>{source}</span>
                  </label>
                ))
              }
            </div>
          ) : (
            <p class="clients-filter-empty clients-filter-empty--compact">No referral sources recorded yet.</p>
          )
        }
      </TeamListFilter>

      <div class="clients-page__filter-bar" data-filter-bar hidden>
        <span class="clients-page__filter-bar-label">Filters:</span>
        <div class="clients-page__active-filters" data-active-filters></div>
        <button class="clients-page__clear-filters" type="button" data-filter-clear-all>Clear all</button>
      </div>

      <p class="clients-page__notice" data-status hidden aria-live="polite"></p>
      <p class="clients-page__sr-live" data-sr-live aria-live="polite" aria-atomic="true"></p>

      <div class="clients-page__table-wrap" data-results-wrap>
        <table class="clients-table clients-page__table" aria-label="Clients">
          <thead>
            <tr>
              <th scope="col" data-col="client">Client</th>
              <th scope="col" data-col="contact">Contact</th>
              <th scope="col" data-col="provider">Recent provider</th>
              <th scope="col" data-col="lastVisit">Last visit</th>
              <th scope="col" data-col="nextAppt">Next appointment</th>
              <th scope="col" data-col="visits" class="clients-table__num">Visits</th>
              <th scope="col" data-col="ltv" class="clients-table__num">
                <abbr title="Lifetime value from completed sales">Lifetime value</abbr>
              </th>
              <th scope="col" data-col="actions" class="clients-table__actions-head"><span class="clients-page__sr-only">Actions</span></th>
            </tr>
          </thead>
          <tbody data-results></tbody>
        </table>

        <ul class="clients-page__cards" data-card-results aria-label="Clients"></ul>

        <div class="clients-page__empty" data-empty hidden>
          <span class="clients-page__empty-icon" aria-hidden="true">👤</span>
          <strong data-empty-title>No clients found</strong>
          <span class="clients-page__empty-hint" data-empty-hint>Try a different search or clear filters.</span>
          <button type="button" class="clients-page__btn-secondary clients-page__empty-action" data-empty-clear hidden>
            Clear filters
          </button>
        </div>

        <footer class="clients-page__footer" data-footer hidden>
          <span class="clients-page__footer-range" data-page-range aria-live="polite"></span>
          <span class="clients-page__footer-sep" data-footer-sep aria-hidden="true">·</span>
          <label class="clients-page__per-page">
            <span>Rows per page:</span>
            <select data-per-page aria-label="Rows per page">
              <option value="25" selected>25</option>
              <option value="50">50</option>
              <option value="100">100</option>
            </select>
          </label>
          <div class="clients-page__page-buttons" data-page-buttons hidden>
            <span class="clients-page__footer-sep" aria-hidden="true">·</span>
            <button type="button" class="clients-page__page-btn" data-pagination-prev>Previous</button>
            <button type="button" class="clients-page__page-btn" data-pagination-next>Next</button>
          </div>
        </footer>
      </div>
    </TeamListLayout>
  </div>

  <ClientsAddModal />
  <ClientsPreviewDrawer />

  <div class="clients-toast" data-toast hidden role="status"></div>
</TeamLayout>

<script
  define:vars={{
    searchApi: teamUrl("/api/clients/search"),
    createApi: teamUrl("/api/clients"),
    clientApi: teamUrl("/api/clients/:id"),
    clientsBase: teamUrl("/clients"),
    bookUrl,
    initialQuery,
    initialClients,
    initialTotal,
  }}
>
  window.__clientsDirectoryConfig = {
    searchApi,
    createApi,
    clientApi,
    clientsBase,
    bookUrl,
    initialQuery,
    initialClients,
    initialTotal,
  };
</script>
<script src="../../scripts/clients-directory.ts"></script>

<style>
  .clients-page__sr-only,
  .clients-page :global(.clients-page__sr-only) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .clients-page__sr-live {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Guard: page-scoped display rules must not override the hidden attribute. */
  .clients-page [hidden] {
    display: none !important;
  }

  .clients-page :global(.clients-list-layout .team-list-layout__main-title) {
    display: none;
  }

  .clients-page :global(.clients-list-layout .team-list-layout__main) {
    max-width: 92rem;
    padding: var(--space-3) var(--space-5) var(--space-6);
  }

  .clients-page :global(.clients-list-layout .team-list-layout__subheader) {
    margin-bottom: 0.15rem;
    padding-block: 0.35rem;
  }

  .clients-page :global(.clients-list-layout .team-list-layout__stats) {
    margin: 0 0 0.5rem;
  }

  .clients-page :global(.clients-list-layout .team-list-layout__main-lead) {
    margin: 0;
  }

  .clients-page :global(.clients-list-layout .team-list-layout__toolbar) {
    margin-bottom: 0.5rem;
  }

  @media (min-width: 901px) {
    .clients-page :global(.clients-list-layout .team-list-layout__body) {
      grid-template-columns: minmax(240px, 260px) minmax(0, 1fr);
    }

    .clients-page :global(.clients-list-layout .team-list-layout__sidebar) {
      position: sticky;
      top: var(--team-bar-height, 3.25rem);
      align-self: start;
      max-height: calc(100vh - var(--team-bar-height, 3.25rem));
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .clients-page :global(.clients-list-layout .team-list-layout__filters) {
      flex: 1 1 auto;
      min-height: 0;
      overflow-y: auto;
      overscroll-behavior: contain;
    }
  }

  /* Provider clipping fix (approach A): the option group grows naturally and
     the sidebar filters column owns the single scroll. No nested scrollbox. */
  .clients-page__provider-list {
    padding-bottom: 0.25rem;
  }

  .clients-page__filter-hint {
    margin: 0 0 0.4rem;
    font-size: var(--text-xs);
    line-height: var(--leading-normal);
    color: var(--color-stone-500);
  }

  .clients-page__filter-option {
    min-height: var(--touch-target-min, 2.75rem);
    padding-block: 0.35rem;
  }

  .clients-filter-empty {
    margin: 0;
    padding: 0.5rem 0 0;
    display: grid;
    gap: 0.35rem;
    font-size: var(--text-xs);
    line-height: var(--leading-normal);
    color: var(--color-stone-500);
  }

  .clients-filter-empty--compact {
    padding: 0;
  }

  .clients-filter-empty__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--color-stone-100);
    font-size: 0.75rem;
    color: var(--color-stone-500);
  }

  .clients-page__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-3);
    width: 100%;
  }

  .clients-page__toolbar-main {
    display: grid;
    gap: 0.5rem;
    flex: 1 1 18rem;
    min-width: 0;
    max-width: 36rem;
  }

  .clients-page__heading {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
  }

  .clients-page__heading-title {
    font-family: var(--font-display, var(--font-body));
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-stone-800);
    letter-spacing: var(--tracking-tight, normal);
  }

  .clients-page__heading-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.6rem;
    height: 1.4rem;
    padding: 0 0.45rem;
    border-radius: 999px;
    background: var(--color-stone-100);
    font-size: var(--text-xs);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--color-stone-600);
  }

  .clients-page__search-block {
    display: grid;
    gap: 0.25rem;
    min-width: 0;
  }

  .clients-page__search {
    display: grid;
    gap: 0.25rem;
  }

  .clients-page__search-label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  .clients-page__search-field {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.65rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    min-height: var(--touch-target-min, 2.75rem);
  }

  .clients-page__search-icon {
    flex-shrink: 0;
    color: var(--color-stone-400);
  }

  .clients-page__search-input {
    flex: 1;
    min-width: 0;
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-stone-800);
    outline: none;
  }

  .clients-page__search-input::placeholder {
    color: var(--color-stone-400);
  }

  .clients-page__search-clear {
    border: none;
    background: none;
    color: var(--color-stone-500);
    font-size: 1.15rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.15rem 0.35rem;
    border-radius: var(--radius-sm);
  }

  .clients-page__search-spinner {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    border: 2px solid var(--color-stone-200);
    border-top-color: var(--color-citrine);
    border-radius: 50%;
    animation: clients-search-spin 0.65s linear infinite;
  }

  .clients-page__search--loading .clients-page__search-input {
    color: var(--color-stone-500);
  }

  @keyframes clients-search-spin {
    to { transform: rotate(360deg); }
  }

  .clients-page__result-count {
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

  .clients-page__toolbar-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .clients-page__sort-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: var(--touch-target-min, 2.75rem);
    padding: 0 0.6rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
  }

  .clients-page__sort-prefix {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-stone-500);
    white-space: nowrap;
  }

  .clients-page__sort-select {
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-stone-800);
    cursor: pointer;
    padding: 0.35rem 0.15rem;
    outline: none;
  }

  .clients-page__columns {
    position: relative;
  }

  .clients-page__columns-trigger {
    list-style: none;
    cursor: pointer;
    min-height: var(--touch-target-min, 2.75rem);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0 0.65rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-stone-600);
  }

  .clients-page__columns-trigger svg {
    color: var(--color-stone-400);
  }

  .clients-page__columns-trigger:hover,
  .clients-page__columns[open] .clients-page__columns-trigger {
    border-color: var(--color-stone-300);
    color: var(--color-stone-800);
  }

  .clients-page__columns-trigger::-webkit-details-marker {
    display: none;
  }

  .clients-page__columns-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.25rem);
    z-index: 20;
    min-width: 11rem;
    padding: 0.5rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    box-shadow: var(--shadow-md);
    display: grid;
    gap: 0.25rem;
  }

  .clients-page__columns-option {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: var(--text-sm);
    min-height: 2rem;
    cursor: pointer;
  }

  .clients-page__btn-primary,
  .clients-page__btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--touch-target-min, 2.75rem);
    padding: 0.45rem 0.9rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .clients-page__btn-primary {
    background: var(--color-citrine);
    color: var(--color-stone-900);
    border-color: var(--color-citrine);
  }

  .clients-page__btn-primary:hover,
  .clients-page__btn-primary:focus-visible {
    background: var(--color-citrine-dark);
    outline: none;
    box-shadow: 0 0 0 3px var(--color-focus-ring);
  }

  .clients-page__btn-secondary {
    background: var(--color-bg);
    color: var(--color-stone-700);
    border-color: var(--color-stone-200);
  }

  .clients-page__btn-secondary:hover:not(:disabled),
  .clients-page__btn-secondary:focus-visible:not(:disabled) {
    border-color: var(--color-stone-300);
    outline: none;
    box-shadow: 0 0 0 3px var(--color-focus-ring);
  }

  .clients-page__btn-secondary:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .clients-page__summary {
    display: grid;
    grid-template-columns: repeat(4, minmax(8rem, 1fr));
    gap: 0.5rem;
    margin: 0;
    max-width: 46rem;
  }

  .clients-page__summary-item {
    display: grid;
    gap: 0.15rem;
    align-content: start;
    padding: 0.55rem 0.8rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-stone-50);
    text-align: left;
  }

  .clients-page__summary-item--static {
    cursor: default;
  }

  .clients-page__summary-item--action {
    cursor: pointer;
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }

  .clients-page__summary-item--action:hover,
  .clients-page__summary-item--action:focus-visible {
    border-color: var(--color-stone-300);
    background: var(--color-bg);
    outline: none;
    box-shadow: 0 0 0 3px var(--color-focus-ring);
  }

  .clients-page__summary-item--action[aria-pressed="true"] {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted);
    box-shadow: inset 0 0 0 1px var(--color-citrine);
  }

  .clients-page__summary-value {
    font-size: var(--text-xl, 1.25rem);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1.1;
    color: var(--color-stone-800);
  }

  .clients-page__summary-label {
    font-size: var(--text-xs);
    line-height: var(--leading-snug, 1.3);
    color: var(--color-stone-500);
  }

  .clients-page__filter-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.5rem;
    margin: 0 0 0.65rem;
  }

  .clients-page__filter-bar-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  .clients-page__active-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .clients-page__filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    min-height: 2rem;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--color-stone-200);
    border-radius: 999px;
    background: var(--color-bg);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-stone-700);
    cursor: pointer;
  }

  .clients-page__clear-filters {
    border: none;
    background: none;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
    min-height: var(--touch-target-min, 2.75rem);
    padding: 0 0.35rem;
  }

  .clients-page__notice {
    margin: 0 0 0.65rem;
    font-size: var(--text-sm);
    color: var(--color-stone-600);
  }

  .clients-page__notice--error {
    color: var(--color-error);
  }

  .clients-page__table-wrap {
    min-width: 0;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg);
  }

  .clients-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body);
    font-size: var(--text-sm);
  }

  .clients-table th,
  .clients-table td {
    padding: 0.7rem 0.85rem;
    border-bottom: 1px solid var(--color-stone-200);
    vertical-align: middle;
    text-align: left;
  }

  .clients-table tbody tr:last-child td {
    border-bottom: none;
  }

  .clients-table th.clients-table__num,
  .clients-table td.clients-table__num {
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .clients-table th.clients-table__actions-head,
  .clients-table td.clients-table__actions-col {
    width: 3rem;
    min-width: 3rem;
    text-align: right;
    padding-right: 0.6rem;
  }

  .clients-table th {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-500);
    background: var(--color-stone-50);
  }

  .clients-table th abbr {
    text-decoration: none;
    cursor: help;
  }

  .clients-page :global(.clients-table__row) {
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .clients-page :global(.clients-table__row:hover) {
    background: var(--color-citrine-muted);
  }

  .clients-page :global(.clients-table__row:focus-visible) {
    outline: 2px solid var(--color-citrine);
    outline-offset: -2px;
  }

  .clients-page :global(.clients-table__client) {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
  }

  .clients-page :global(.clients-table__avatar) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(141, 158, 136, 0.18);
    border: 1px solid rgba(141, 158, 136, 0.35);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-stone-700);
    flex-shrink: 0;
  }

  .clients-page :global(.clients-table__client-text) {
    display: grid;
    gap: 0.1rem;
    min-width: 0;
  }

  .clients-page :global(.clients-table__name) {
    font-weight: 600;
    color: var(--color-stone-800);
  }

  .clients-page :global(.clients-table__preferred) {
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

  .clients-page :global(.clients-table__tag-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .clients-page :global(.clients-table__tag) {
    display: inline-flex;
    padding: 0.05rem 0.4rem;
    border-radius: 999px;
    background: var(--color-stone-100);
    font-size: 0.65rem;
    color: var(--color-stone-600);
  }

  .clients-page :global(.clients-table__contact) {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }

  .clients-page :global(.clients-table__contact-line) {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    min-width: 0;
  }

  .clients-page :global(.clients-table__contact-icon) {
    flex-shrink: 0;
    width: 0.9rem;
    color: var(--color-stone-400);
    font-size: 0.72rem;
    text-align: center;
  }

  .clients-page :global(.clients-table__contact-link) {
    color: var(--color-stone-700);
    text-decoration: none;
    word-break: break-word;
  }

  .clients-page :global(.clients-table__contact-link:hover),
  .clients-page :global(.clients-table__contact-link:focus-visible) {
    text-decoration: underline;
    text-underline-offset: 2px;
    color: var(--color-stone-900);
  }

  .clients-page :global(.clients-table__muted) {
    color: var(--color-stone-400);
    font-style: italic;
  }

  .clients-page :global(.clients-table__ltv) {
    font-weight: 600;
    color: var(--color-stone-700);
  }

  .clients-page :global(.clients-table__soft) {
    color: var(--color-stone-400);
  }

  .clients-page :global(.clients-table__actions) {
    position: relative;
    display: flex;
    justify-content: flex-end;
  }

  .clients-page :global(.clients-table__menu-btn) {
    border: none;
    background: none;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-sm);
    color: var(--color-stone-500);
    cursor: pointer;
    font-size: 1.1rem;
    line-height: 1;
  }

  .clients-page :global(.clients-table__menu-btn:hover),
  .clients-page :global(.clients-table__menu-btn:focus-visible) {
    background: var(--color-stone-100);
    color: var(--color-stone-800);
    outline: none;
    box-shadow: 0 0 0 3px var(--color-focus-ring);
  }

  /* Row action menu is positioned via fixed coordinates by JS (popover).
     The hidden guard MUST be :global — the menu is injected by JS and never
     carries the Astro scope hash, so a scoped [hidden] guard would not match
     it and the display:grid below would keep it permanently visible. */
  .clients-page :global(.clients-table__menu[hidden]) {
    display: none !important;
  }

  .clients-page :global(.clients-table__menu) {
    position: fixed;
    z-index: 320;
    min-width: 11rem;
    max-width: 15rem;
    padding: 0.35rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    box-shadow: var(--shadow-lg);
    display: grid;
    gap: 0.05rem;
  }

  .clients-page :global(.clients-table__menu a) {
    display: block;
    padding: 0.5rem 0.6rem;
    border-radius: var(--radius-sm);
    color: var(--color-stone-700);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .clients-page :global(.clients-table__menu a:hover),
  .clients-page :global(.clients-table__menu a:focus-visible) {
    background: var(--color-citrine-muted);
    color: var(--color-stone-900);
    outline: none;
  }

  .clients-page__cards {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--mobile-space-sm, 0.75rem);
  }

  .clients-page :global(.clients-card) {
    display: grid;
    gap: 0.65rem;
    padding: var(--mobile-space-md, 1rem);
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-sm);
  }

  .clients-page :global(.clients-card__open) {
    display: grid;
    gap: 0.55rem;
    width: 100%;
    border: none;
    background: none;
    padding: 0;
    text-align: left;
    cursor: pointer;
    font: inherit;
    color: inherit;
  }

  .clients-page :global(.clients-card__head) {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
  }

  .clients-page :global(.clients-card__avatar) {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(141, 158, 136, 0.18);
    font-size: var(--text-xs);
    font-weight: 600;
    flex-shrink: 0;
  }

  .clients-page :global(.clients-card__name) {
    margin: 0;
    font-size: var(--text-base);
    font-weight: 600;
  }

  .clients-page :global(.clients-card__meta) {
    display: flex;
    gap: 0.75rem;
    font-size: var(--text-sm);
    color: var(--color-stone-600);
  }

  .clients-page__empty {
    display: grid;
    gap: 0.4rem;
    justify-items: center;
    margin: 0;
    padding: 2.5rem 1.25rem;
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-stone-500);
  }

  .clients-page__empty-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--color-stone-100);
    font-size: 1.35rem;
    margin-bottom: 0.25rem;
  }

  .clients-page__empty strong {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-stone-700);
  }

  .clients-page__empty-action {
    margin-top: 0.5rem;
  }

  .clients-page__results--empty .clients-table,
  .clients-page__results--empty .clients-page__cards,
  .clients-page__results--empty .clients-page__footer {
    display: none;
  }

  /* Cohesive table footer inside the table container. */
  .clients-page__footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.85rem;
    border-top: 1px solid var(--color-stone-200);
    background: var(--color-stone-50);
    font-size: var(--text-sm);
    color: var(--color-stone-600);
  }

  .clients-page__footer-range {
    font-variant-numeric: tabular-nums;
  }

  .clients-page__footer-sep {
    color: var(--color-stone-300);
    user-select: none;
  }

  .clients-page__page-buttons {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .clients-page__page-btn {
    border: none;
    background: none;
    padding: 0.2rem 0.35rem;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-link);
    cursor: pointer;
    border-radius: var(--radius-sm);
  }

  .clients-page__page-btn:hover:not(:disabled),
  .clients-page__page-btn:focus-visible:not(:disabled) {
    text-decoration: underline;
    outline: none;
  }

  .clients-page__page-btn:disabled {
    color: var(--color-stone-400);
    cursor: not-allowed;
  }

  .clients-page__per-page {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .clients-page__per-page select {
    min-height: 2rem;
    padding: 0.15rem 0.4rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    font-size: var(--text-sm);
  }

  .clients-modal[hidden],
  .clients-drawer[hidden],
  .clients-toast[hidden] {
    display: none;
  }

  .clients-modal {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: grid;
    place-items: center;
    padding: 1rem;
  }

  .clients-modal__backdrop,
  .clients-drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(47, 42, 40, 0.45);
  }

  .clients-modal__panel {
    position: relative;
    z-index: 1;
    width: min(100%, 30rem);
    max-height: 90vh;
    overflow: auto;
    padding: var(--space-5);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    border: 1px solid var(--color-stone-200);
    box-shadow: var(--shadow-lg);
  }

  .clients-modal__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .clients-modal__head h2 {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 600;
  }

  .clients-modal__lead {
    margin: 0.25rem 0 0;
    font-size: var(--text-sm);
    color: var(--color-stone-500);
  }

  .clients-modal__close,
  .clients-drawer__close {
    border: none;
    background: none;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-stone-500);
    cursor: pointer;
    padding: 0.15rem;
    border-radius: var(--radius-sm);
  }

  .clients-modal__form {
    display: grid;
    gap: var(--space-3);
  }

  .clients-modal__row {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr 1fr;
  }

  .clients-modal__label {
    display: grid;
    gap: 0.35rem;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  .clients-modal__input {
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    text-transform: none;
    letter-spacing: normal;
    font-weight: 400;
    background: var(--color-bg);
  }

  .clients-modal__input:focus-visible {
    outline: none;
    border-color: var(--color-citrine);
    box-shadow: 0 0 0 3px var(--color-focus-ring);
  }

  .clients-modal__duplicate {
    padding: 0.65rem 0.75rem;
    border: 1px solid rgba(180, 35, 24, 0.25);
    border-radius: var(--radius-sm);
    background: rgba(180, 35, 24, 0.06);
    font-size: var(--text-sm);
  }

  .clients-modal__duplicate-list {
    margin: 0.35rem 0;
    padding-left: 1.1rem;
  }

  .clients-modal__actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-2);
  }

  .clients-drawer {
    position: fixed;
    inset: 0;
    z-index: 250;
    pointer-events: none;
  }

  .clients-drawer:not([hidden]) {
    pointer-events: auto;
  }

  .clients-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(100%, 24rem);
    z-index: 1;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border-left: 1px solid var(--color-stone-200);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .clients-drawer__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem 1rem 0.75rem;
    border-bottom: 1px solid var(--color-stone-200);
  }

  .clients-drawer__head-main {
    display: flex;
    gap: 0.65rem;
    min-width: 0;
  }

  .clients-drawer__avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(141, 158, 136, 0.18);
    font-weight: 600;
    flex-shrink: 0;
  }

  .clients-drawer__title {
    margin: 0;
    font-size: var(--text-base);
    font-weight: 600;
  }

  .clients-drawer__preferred {
    margin: 0.15rem 0 0;
    font-size: var(--text-xs);
    color: var(--color-stone-500);
  }

  .clients-drawer__loading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem;
    font-size: var(--text-sm);
    color: var(--color-stone-500);
  }

  .clients-drawer__spinner {
    width: 1rem;
    height: 1rem;
    border: 2px solid var(--color-stone-200);
    border-top-color: var(--color-citrine);
    border-radius: 50%;
    animation: clients-search-spin 0.65s linear infinite;
  }

  .clients-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 0.85rem 1rem 1rem;
    display: grid;
    gap: 0.85rem;
  }

  .clients-drawer__facts {
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }

