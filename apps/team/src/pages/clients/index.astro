---
import TeamLayout from "../layouts/TeamLayout.astro";
import { teamUrl } from "../lib/supabase-server";

const { staff } = Astro.locals;
if (!staff) {
  return Astro.redirect(`${import.meta.env.BASE_URL}login?error=unlinked`);
}

const initialQuery = Astro.url.searchParams.get("q") ?? "";
---

<TeamLayout title="Clients" activeNav="clients" wide>
  <div class="clients-page" data-clients-search>
    <header class="clients-page__header">
      <h1 class="page-title">Clients</h1>
      <p class="page-lead">Search by name, email, or phone to open a client chart.</p>
    </header>

    <label class="form-label clients-page__search">
      Search clients
      <input
        class="form-input"
        type="search"
        name="q"
        value={initialQuery}
        placeholder="Start typing…"
        autocomplete="off"
        data-search-input
        autofocus
      />
    </label>

    <p class="notice" data-status hidden aria-live="polite"></p>

    <ul class="clients-results" data-results role="listbox" aria-label="Search results"></ul>
  </div>
</TeamLayout>

<script
  define:vars={{
    searchApi: teamUrl("/api/clients/search"),
    clientsBase: teamUrl("/clients"),
    initialQuery,
  }}
>
  const root = document.querySelector("[data-clients-search]");
  const input = root?.querySelector("[data-search-input]");
  const results = root?.querySelector("[data-results]");
  const status = root?.querySelector("[data-status]");
  let debounce = null;

  function showStatus(message, isError = false) {
    if (!status) return;
    status.textContent = message;
    status.hidden = !message;
    status.classList.toggle("notice--error", isError);
  }

  function renderResults(clients) {
    if (!results) return;
    results.innerHTML = "";

    if (clients.length === 0) {
      showStatus("No clients found.");
      return;
    }

    showStatus("");

    for (const client of clients) {
      const li = document.createElement("li");
      li.className = "clients-results__item";
      const link = document.createElement("a");
      link.className = "clients-results__link";
      link.href = `${clientsBase}/${client.id}`;
      link.innerHTML = `
        <span class="clients-results__name">${client.fullName}</span>
        <span class="clients-results__meta">${[client.phone, client.email].filter(Boolean).join(" · ") || "No contact on file"}</span>
      `;
      li.appendChild(link);
      results.appendChild(li);
    }
  }

  async function search(term) {
    if (term.length < 2) {
      renderResults([]);
      showStatus(term.length === 0 ? "" : "Type at least 2 characters.");
      return;
    }

    showStatus("Searching…");
    try {
      const res = await fetch(`${searchApi}?q=${encodeURIComponent(term)}`);
      const body = await res.json();
      if (!res.ok) throw new Error(body.error || "Search failed");
      renderResults(body.clients ?? []);
      if ((body.clients ?? []).length > 0) showStatus("");
    } catch (err) {
      showStatus(err instanceof Error ? err.message : "Search failed", true);
      renderResults([]);
    }
  }

  input?.addEventListener("input", () => {
    const term = input.value.trim();
    if (debounce) clearTimeout(debounce);
    debounce = setTimeout(() => search(term), 250);
  });

  if (initialQuery.length >= 2) {
    search(initialQuery);
  }
</script>

<style>
  .clients-page__header {
    margin-bottom: 1.25rem;
  }

  .clients-page__search {
    max-width: 32rem;
    margin-bottom: 1rem;
  }

  .clients-results {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .clients-results__link {
    display: grid;
    gap: 0.2rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease;
  }

  .clients-results__link:hover,
  .clients-results__link:focus-visible {
    border-color: var(--color-citrine);
    outline: none;
  }

  .clients-results__name {
    font-weight: 600;
    font-size: 1.05rem;
  }

  .clients-results__meta {
    font-size: 0.9rem;
    color: var(--color-gray);
  }
</style>
