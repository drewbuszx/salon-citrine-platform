---
import { teamUrl } from "../lib/supabase-server";
import { pulseHint, revenuePaceHint, type TeamPulseMetrics } from "../lib/team-pulse";

interface Props {
  metrics: TeamPulseMetrics;
}

const { metrics } = Astro.props;

const apptHint = pulseHint("appointments", metrics.todayAppointments, metrics.scope);
const waitlistHint = pulseHint("waitlist", metrics.waitlistActive);
const stockHint = pulseHint("stock", metrics.lowStock);
const revenueHint = revenuePaceHint(metrics);

const waitlistHot = metrics.waitlistActive >= 3;
const stockAlert = metrics.lowStock > 0;
---

<section
  class="team-pulse"
  aria-label="Team pulse — today's salon snapshot"
  data-loaded={metrics.loaded ? "true" : "false"}
>
  <header class="team-pulse__head">
    <div class="team-pulse__title-row">
      <span class="team-pulse__live" aria-hidden="true" />
      <h2 class="team-pulse__title">Team Pulse</h2>
    </div>
    <p class="team-pulse__subtitle">
      {metrics.scope === "salon" ? "Salon-wide · today" : "Your book · today"}
    </p>
  </header>

  {
    revenueHint && (
      <a class="team-pulse__revenue" href={teamUrl("/reports")}>
        <span class="team-pulse__revenue-label">Revenue pace</span>
        <span class="team-pulse__revenue-value">{revenueHint}</span>
      </a>
    )
  }

  <div class="team-pulse__grid">
    <a
      class="team-pulse__metric"
      href={teamUrl("/book")}
      aria-label={`${metrics.todayAppointments} appointments today. Open book.`}
    >
      <span class="team-pulse__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <rect x="4" y="5" width="16" height="15" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 3v4M16 3v4M4 10h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="team-pulse__value">{metrics.todayAppointments}</span>
      <span class="team-pulse__label">Today's book</span>
      <span class="team-pulse__hint">{apptHint}</span>
      <span class="team-pulse__go" aria-hidden="true">Open book →</span>
    </a>

    <a
      class:list={["team-pulse__metric", waitlistHot && "team-pulse__metric--hot"]}
      href={teamUrl("/waitlist")}
      aria-label={`${metrics.waitlistActive} on waitlist. View waitlist.`}
    >
      <span class="team-pulse__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M12 6v6l3.5 2M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="team-pulse__value">{metrics.waitlistActive}</span>
      <span class="team-pulse__label">Waitlist queue</span>
      <span class="team-pulse__hint">{waitlistHint}</span>
      <span class="team-pulse__go" aria-hidden="true">View waitlist →</span>
    </a>

    <a
      class:list={["team-pulse__metric", stockAlert && "team-pulse__metric--alert"]}
      href={teamUrl("/inventory")}
      aria-label={`${metrics.lowStock} low stock items. View inventory.`}
    >
      <span class="team-pulse__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M12 12l8-4.5M12 12v9M12 12L4 7.5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="team-pulse__value">{metrics.lowStock}</span>
      <span class="team-pulse__label">Stock alerts</span>
      <span class="team-pulse__hint">{stockHint}</span>
      <span class="team-pulse__go" aria-hidden="true">View stock →</span>
    </a>
  </div>
</section>

<style>
  .team-pulse {
    margin-bottom: 1.75rem;
    padding: 1rem 1rem 1.1rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-lg);
    background: var(--color-stone-50);
    box-shadow: var(--shadow-sm);
  }

  .team-pulse__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
    padding: 0 0.15rem;
  }

  .team-pulse__title-row {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .team-pulse__live {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--color-citrine);
    box-shadow: 0 0 0 0 rgba(231, 172, 70, 0.45);
    animation: team-pulse-live 2.4s ease-in-out infinite;
  }

  @keyframes team-pulse-live {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(231, 172, 70, 0.45);
    }
    50% {
      box-shadow: 0 0 0 5px rgba(231, 172, 70, 0);
    }
  }

  .team-pulse__title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-stone-700);
  }

  .team-pulse__subtitle {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  .team-pulse__revenue {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: inherit;
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .team-pulse__revenue:hover,
  .team-pulse__revenue:focus-visible {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted);
    outline: none;
  }

  .team-pulse__revenue-label {
    flex: 0 0 auto;
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-citrine-dark);
  }

  .team-pulse__revenue-value {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    line-height: 1.35;
    color: var(--color-stone-700);
    text-align: right;
  }

  .team-pulse__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .team-pulse__metric {
    display: grid;
    grid-template-rows: auto auto auto auto auto;
    justify-items: center;
    gap: 0.15rem;
    padding: 0.75rem 0.4rem 0.65rem;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    text-align: center;
    color: inherit;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast),
      background var(--transition-fast);
  }

  .team-pulse__metric:hover,
  .team-pulse__metric:focus-visible {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
    outline: none;
  }

  .team-pulse__metric--hot,
  .team-pulse__metric--alert {
    border-color: var(--color-stone-200);
    background: var(--color-bg);
  }

  .team-pulse__metric--hot:hover,
  .team-pulse__metric--hot:focus-visible,
  .team-pulse__metric--alert:hover,
  .team-pulse__metric--alert:focus-visible {
    border-color: var(--color-citrine);
    background: var(--color-citrine-muted);
  }

  .team-pulse__icon {
    display: inline-flex;
    width: 1.15rem;
    height: 1.15rem;
    color: var(--color-stone-500);
    transition: color var(--transition-fast);
  }

  .team-pulse__icon svg {
    width: 100%;
    height: 100%;
  }

  .team-pulse__metric:hover .team-pulse__icon,
  .team-pulse__metric:focus-visible .team-pulse__icon {
    color: var(--color-citrine-dark);
  }

  .team-pulse__value {
    font-family: var(--font-display);
    font-size: 1.85rem;
    font-weight: 500;
    line-height: 1;
    color: var(--color-stone-800);
  }

  .team-pulse__label {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-stone-700);
  }

  .team-pulse__hint {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    line-height: 1.25;
    color: var(--color-stone-500);
    max-width: 6.75rem;
  }

  .team-pulse__go {
    margin-top: 0.1rem;
    font-family: var(--font-sans);
    font-size: 0.56rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-citrine-dark);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .team-pulse__metric:hover .team-pulse__go,
  .team-pulse__metric:focus-visible .team-pulse__go {
    opacity: 1;
  }

  :global([data-theme="dark"]) .team-pulse {
    background: var(--color-stone-100);
    border-color: var(--color-stone-200);
  }

  :global([data-theme="dark"]) .team-pulse__metric {
    background: var(--color-stone-50);
    border-color: var(--color-stone-200);
  }

  :global([data-theme="dark"]) .team-pulse__value {
    color: var(--color-text);
  }

  :global([data-theme="dark"]) .team-pulse__title,
  :global([data-theme="dark"]) .team-pulse__label,
  :global([data-theme="dark"]) .team-pulse__revenue-value {
    color: var(--color-stone-800);
  }

  :global([data-theme="dark"]) .team-pulse__subtitle,
  :global([data-theme="dark"]) .team-pulse__hint {
    color: var(--color-stone-500);
  }

  :global([data-theme="dark"]) .team-pulse__revenue-label {
    color: var(--color-citrine-light);
  }

  @media (max-width: 420px) {
    .team-pulse__head {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .team-pulse__value {
      font-size: 1.55rem;
    }
  }

  /* Desktop: fills the dashboard main column; grid gap owns spacing. */
  @media (min-width: 1100px) {
    .team-pulse {
      margin-bottom: 0;
      padding: 1.25rem 1.35rem 1.4rem;
    }

    .team-pulse__grid {
      gap: 0.75rem;
    }

    .team-pulse__metric {
      padding: 1rem 0.65rem 0.9rem;
    }
  }
</style>
