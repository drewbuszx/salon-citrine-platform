  <div class="day-cal__toast" id="day-cal-toast" hidden role="status" aria-live="polite">
    <span class="day-cal__toast-message" id="day-cal-toast-message"></span>
    <button type="button" class="day-cal__toast-undo" id="day-cal-toast-undo" hidden>
      Undo
    </button>
  </div>

  <div
    class="day-cal__shortcuts-help"
    data-cal-shortcuts-help
    hidden
    aria-hidden="true"
  >
    <button
      type="button"
      class="day-cal__shortcuts-help-backdrop"
      data-cal-shortcuts-close
      tabindex="-1"
      aria-label="Close keyboard shortcuts"
    ></button>
    <div
      class="day-cal__shortcuts-help-panel"
      data-cal-shortcuts-panel
      role="dialog"
      aria-labelledby="day-cal-shortcuts-title"
    >
      <header class="day-cal__shortcuts-help-header">
        <h2 class="day-cal__shortcuts-help-title" id="day-cal-shortcuts-title">
          Keyboard shortcuts
        </h2>
        <button
          type="button"
          class="day-cal__shortcuts-help-close"
          data-cal-shortcuts-close
          aria-label="Close"
        >
          ×
        </button>
