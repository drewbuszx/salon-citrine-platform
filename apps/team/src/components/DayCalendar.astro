      <dl class="day-cal__shortcuts-list">
        <div class="day-cal__shortcuts-row">
          <dt><kbd>T</kbd></dt>
          <dd>Jump to today</dd>
        </div>
        <div class="day-cal__shortcuts-row">
          <dt><kbd>N</kbd></dt>
          <dd>New appointment</dd>
        </div>
        <div class="day-cal__shortcuts-row">
          <dt><kbd>←</kbd> <kbd>→</kbd></dt>
          <dd>Previous / next day</dd>
        </div>
        <div class="day-cal__shortcuts-row">
          <dt><kbd>/</kbd></dt>
          <dd>Focus client search</dd>
        </div>
        <div class="day-cal__shortcuts-row">
          <dt><kbd>Esc</kbd></dt>
          <dd>Close panel or menu</dd>
        </div>
        <div class="day-cal__shortcuts-row">
          <dt><kbd>?</kbd></dt>
          <dd>Show this help</dd>
