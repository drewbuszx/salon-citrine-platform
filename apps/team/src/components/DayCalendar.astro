---
import type {
  CalendarAppointment,
  CalendarBlockedTime,
  CalendarStaff,
  CalendarTimeOff,
  StaffSchedule,
  StaffServiceOption,
} from "../lib/calendar";
import {
  CALENDAR_ROW_HEIGHT_REM,
  CALENDAR_SLOT_MINUTES,
  CALENDAR_START_HOUR,
  STAFF_HEADER_HEIGHT_REM,
  calendarGridHeightRem,
  calendarTimeSlots,
  currentTimeLineTopRem,
  defaultCalendarScrollTopRem,
  eventBlockStyle,
  formatDayLabel,
  formatDayParam,
  formatCompactTimeRangeInSalon,
  formatNowLabel,
  formatSlotHourLabel,
  formatSlotMinuteLabel,
  formatSlotTimeLabel,
  isSalonClosedOnDay,
  isSlotWithinStaffSchedule,
  staffAccentColor,
  staffColumnWidthRem,
  staffShiftStatus,
  isTodayInSalon,
  shiftDay,
  slotStartsAtIso,
  staffEventsForDay,
  timeOffForDay,
  layoutOverlappingEvents,
  findNextOpenGap,
} from "../lib/calendar";
import {
  appointmentStatusMeta,
  formatServiceDisplayName,
  serviceCategoryColor,
} from "../lib/appointment-ui";
import { teamUrl } from "../lib/supabase-server";

interface Props {
  selectedDay: Date;
  dayParam: string;
  staff: CalendarStaff[];
  appointments: CalendarAppointment[];
  blockedTimes: CalendarBlockedTime[];
  timeOff?: CalendarTimeOff[];
  staffSchedules: Record<string, StaffSchedule[]>;
  servicesByStaff: Record<string, StaffServiceOption[]>;
  currentStaffId: string;
  managerView: boolean;
  waitlistCount?: number;
}

const {
  selectedDay,
  dayParam,
  staff,
  appointments,
  blockedTimes,
  timeOff = [],
  staffSchedules,
  servicesByStaff,
  currentStaffId,
  managerView,
  waitlistCount = 0,
} = Astro.props;

const prevDay = formatDayParam(shiftDay(selectedDay, -1));
const nextDay = formatDayParam(shiftDay(selectedDay, 1));
const todayParam = formatDayParam(new Date());
const timeSlots = calendarTimeSlots();
const gridHeight = calendarGridHeightRem();
const isToday = isTodayInSalon(selectedDay);
const nowLineTop = isToday ? currentTimeLineTopRem() : null;
const nowLabel = isToday && nowLineTop !== null ? formatNowLabel() : null;
const salonClosed = isSalonClosedOnDay(dayParam);
const staffColWidthRem = staffColumnWidthRem(staff);
const defaultScrollTopRem = defaultCalendarScrollTopRem(dayParam, {
  appointments,
  staffIds: staff.map((member) => member.id),
  staffSchedules,
});
const nextOpenGap = findNextOpenGap(
  selectedDay,
  dayParam,
  staff,
  appointments,
  blockedTimes,
  staffSchedules,
  60,
  timeOff,
);

const weekStart = shiftDay(selectedDay, -selectedDay.getDay());
const weekDays = Array.from({ length: 7 }, (_, index) => {
  const day = shiftDay(weekStart, index);
  const param = formatDayParam(day);
  const count = appointments.filter((appt) =>
    isSameDayInSalon(appt.startsAt, day),
  ).length;
  return {
    param,
    label: new Intl.DateTimeFormat("en-US", { weekday: "short" }).format(day),
    dayNum: day.getDate(),
    isSelected: param === dayParam,
    isToday: isTodayInSalon(day),
    count,
  };
});

function isSameDayInSalon(iso: string, day: Date): boolean {
  return formatDayParam(day) === formatDayParam(new Date(iso));
}

function staffPhotoUrl(member: CalendarStaff) {
  if (member.photoUrl) {
    return member.photoUrl.startsWith("/")
      ? teamUrl(member.photoUrl)
      : member.photoUrl;
  }
  return teamUrl(`/images/${member.slug}.jpg`);
}

const calendarConfig = {
  dayParam,
  dayLabel: formatDayLabel(selectedDay),
  slotMinutes: CALENDAR_SLOT_MINUTES,
  managerView,
  currentStaffId,
  canMoveAppointments: managerView,
  staff,
  servicesByStaff,
  appointments,
  blockedTimes,
  staffSchedules,
  nextOpenGap,
  api: {
    appointments: teamUrl("/api/appointments"),
    blockedTimes: teamUrl("/api/blocked-times"),
    clientsSearch: teamUrl("/api/clients/search"),
    clientProfile: teamUrl("/api/clients"),
    clientsPage: teamUrl("/clients"),
    checkout: teamUrl("/checkout"),
    findOpenings: teamUrl("/api/calendar/find-openings"),
    waitlist: teamUrl("/api/waitlist"),
    waitlistPage: teamUrl("/waitlist"),
  },
  reloadUrl: `${teamUrl("/book")}?day=${dayParam}`,
  weekUrl: teamUrl("/week"),
  staffIds: staff.map((member) => member.id),
  defaultScrollTopRem,
  calendarStartHour: CALENDAR_START_HOUR,
};
---

<section
  class="day-cal"
  aria-label="Day calendar"
  style={`--day-staff-width: ${staffColWidthRem}rem; --day-header-height: ${STAFF_HEADER_HEIGHT_REM}rem`}
>
  <header class="day-cal__header" data-sticky-header>
    <div class="day-cal__toolbar-primary">
      <nav class="day-cal__date-nav" aria-label="Day navigation">
        <a
          class="day-cal__subbar-btn day-cal__subbar-btn--icon"
          href={`${teamUrl("/book")}?day=${prevDay}`}
          aria-label="Previous day"
        >
          ‹
        </a>
        <label class="day-cal__date-picker">
          <span class="day-cal__date-label">{formatDayLabel(selectedDay)}</span>
          <input
            type="date"
            class="day-cal__date-input"
            value={dayParam}
            data-date-picker
            aria-label={`Jump to date, currently ${formatDayLabel(selectedDay)}`}
          />
        </label>
        <a
          class="day-cal__subbar-btn day-cal__subbar-btn--icon"
          href={`${teamUrl("/book")}?day=${nextDay}`}
          aria-label="Next day"
        >
          ›
        </a>
        <a
          class:list={[
            "day-cal__subbar-btn",
            "day-cal__subbar-btn--today",
            isToday && "day-cal__subbar-btn--today-active",
          ]}
          href={`${teamUrl("/book")}?day=${todayParam}`}
          aria-current={isToday ? "date" : undefined}
        >
          Today
        </a>
      </nav>

      <div class="day-cal__toolbar-primary-actions">
        <span class="day-cal__view-pill" aria-current="true">Day</span>
        <a
          class="day-cal__subbar-btn day-cal__subbar-btn--ghost"
          href={teamUrl(`/week?week=${dayParam}`)}
          data-week-link
        >
          Week
        </a>
        <button
          type="button"
          class="day-cal__subbar-btn day-cal__subbar-btn--ghost"
          data-find-opening
        >
          Find opening
        </button>
        <button
          type="button"
          class:list={[
            "day-cal__subbar-btn",
            "day-cal__subbar-btn--ghost",
            "day-cal__subbar-btn--waitlist",
            waitlistCount > 0 && "day-cal__subbar-btn--waitlist-hot",
          ]}
          data-waitlist-drawer
        >
          Waitlist
          <span
            class:list={[
              "day-cal__waitlist-badge",
              waitlistCount > 0 && "day-cal__waitlist-badge--active",
            ]}
            data-waitlist-badge
            aria-label={`${waitlistCount} on waitlist`}
          >
            {waitlistCount}
          </span>
        </button>
        <button type="button" class="day-cal__subbar-btn day-cal__subbar-btn--primary" data-new-appointment>
          New appointment
        </button>
      </div>
    </div>

    {
      (nextOpenGap || waitlistCount > 0) && (
        <p class="day-cal__gap-hint" role="status" aria-live="polite">
          {
            waitlistCount > 0 && (
              <>
                <button
                  type="button"
                  class="day-cal__gap-hint-btn day-cal__gap-hint-waitlist"
                  data-waitlist-drawer
                >
                  <strong data-waitlist-count-inline>{waitlistCount}</strong> on waitlist
                </button>
                {nextOpenGap && <span class="day-cal__gap-hint-sep" aria-hidden="true">·</span>}
              </>
            )
          }
          {
            nextOpenGap && (
              <button
                type="button"
                class="day-cal__gap-hint-btn"
                data-gap-book
                data-staff-id={nextOpenGap.staffId}
                data-starts-at={nextOpenGap.startsAt}
                aria-label={`Book next open slot: ${nextOpenGap.label}`}
              >
                <span class="day-cal__gap-hint-slot">
                  Next open <span class="day-cal__gap-hint-sep" aria-hidden="true">·</span>{" "}
                  <strong>{nextOpenGap.label}</strong>
                </span>
                <span class="day-cal__gap-hint-cta">Book slot</span>
              </button>
            )
          }
        </p>
      )
    }

    {
      staff.length > 0 && (
        <div class="day-cal__toolbar-secondary">
          <nav class="day-cal__week-strip" aria-label="Week">
            {
              weekDays.map((day) => (
                <a
                  class:list={[
                    "day-cal__week-day",
                    day.isSelected && "day-cal__week-day--selected",
                    day.isToday && "day-cal__week-day--today",
                  ]}
                  href={`${teamUrl("/book")}?day=${day.param}`}
                  aria-current={day.isSelected ? "date" : undefined}
                >
                  <span class="day-cal__week-day-label">{day.label}</span>
                  <span class="day-cal__week-day-num">{day.dayNum}</span>
                  {day.count > 0 && (
                    <span class="day-cal__week-day-dot" aria-label={`${day.count} appointments`} />
                  )}
                </a>
              ))
            }
          </nav>

          <div
            class="day-cal__staff-filter"
            data-staff-filter
            role="group"
            aria-label="Show or hide staff columns"
          >
            <span class="day-cal__staff-filter-label" aria-hidden="true">
              Columns
            </span>
            <button
              type="button"
              class="day-cal__staff-chip day-cal__staff-chip--all is-active"
              data-staff-filter-all
              aria-pressed="true"
            >
              All staff
            </button>
            {staff.map((member) => (
              <button
                type="button"
                class:list={[
                  "day-cal__staff-chip",
                  member.id === currentStaffId && "day-cal__staff-chip--self",
                ]}
                data-staff-filter-id={member.id}
                aria-pressed="true"
                title={`Show or hide ${member.name}'s column`}
              >
                <img
                  class="day-cal__staff-chip-photo"
                  src={staffPhotoUrl(member)}
                  alt=""
                  width="22"
                  height="22"
                  loading="lazy"
                />
                <span class="day-cal__staff-chip-name">{member.name.split(" ")[0]}</span>
              </button>
            ))}
            <span class="visually-hidden" role="status" aria-live="polite" data-staff-filter-status></span>
          </div>
        </div>
      )
    }
  </header>

  {
    staff.length > 1 && (
      <div class="day-cal__mobile-bar" data-mobile-staff-bar>
        <button
          type="button"
          class="day-cal__mobile-staff-btn"
          data-mobile-staff-prev
          aria-label="Previous provider"
        >
          ‹
        </button>
        <label class="day-cal__mobile-staff-select-wrap">
          <span class="visually-hidden">Provider</span>
          <select class="day-cal__mobile-staff-select" data-mobile-staff-select>
            {staff.map((member) => (
              <option value={member.id} selected={member.id === currentStaffId}>
                {member.name}
              </option>
            ))}
          </select>
        </label>
        <button
          type="button"
          class="day-cal__mobile-staff-btn"
          data-mobile-staff-next
          aria-label="Next provider"
        >
          ›
        </button>
      </div>
    )
  }

  <div class="day-cal__compact-subbar" data-compact-subbar aria-hidden="true">
    <span class="day-cal__compact-date" data-compact-date>{formatDayLabel(selectedDay)}</span>
    <span class="day-cal__compact-staff" data-compact-staff />
  </div>

  <div class="day-cal__frame">
    <div class="day-cal__viewport" data-calendar-viewport>
      <div class="day-cal__time-axis" aria-hidden="true">
        <div class="day-cal__time-spacer">
          {
            nowLabel ? (
              <span class="day-cal__now-label day-cal__now-label--rail">{nowLabel}</span>
            ) : null
          }
        </div>
        <div class="day-cal__time-rail" style={`height: ${gridHeight}rem`}>
          {
            timeSlots.map((minutes) => {
              const hourLabel = formatSlotHourLabel(minutes);
              const minuteLabel = formatSlotMinuteLabel(minutes);
              const isHour = minutes % 60 === 0;
              return (
                <div
                  class:list={[
                    "day-cal__time-label",
                    isHour && "day-cal__time-label--hour",
                    minuteLabel && "day-cal__time-label--minute",
                  ]}
                  style={`height: ${CALENDAR_ROW_HEIGHT_REM}rem`}
                >
                  {hourLabel || minuteLabel}
                </div>
              );
            })
          }
          {
            nowLineTop !== null ? (
              <div
                class="day-cal__now-marker"
                style={`top: ${nowLineTop}rem`}
                aria-hidden="true"
              />
            ) : null
          }
        </div>
      </div>

      <div
        class="day-cal__schedule"
        style={`--day-staff-count: ${staff.length}`}
        data-staff-columns
      >
        <div class="day-cal__staff-row">
          {
            staff.map((member) => {
              const accent = staffAccentColor(member.id);
              const memberSchedules = staffSchedules[member.id] ?? [];
              const shiftStatus = staffShiftStatus(memberSchedules, dayParam);
              return (
                <header
                  class="day-cal__staff-header"
                  data-staff-header-column={member.id}
                >
                  <img
                    class="day-cal__avatar"
                    src={staffPhotoUrl(member)}
                    alt=""
                    width="28"
                    height="28"
                    loading="lazy"
                    style={`border-color: ${accent}`}
                  />
                  <div class="day-cal__staff-heading">
                    <span class="day-cal__staff-name">{member.name.split(" ")[0]}</span>
                    <span
                      class:list={[
                        "day-cal__staff-shift",
                        `day-cal__staff-shift--${shiftStatus.kind}`,
                      ]}
                      title={shiftStatus.label}
                    >
                      {shiftStatus.shortLabel}
                    </span>
                  </div>
                </header>
              );
            })
          }
        </div>

        <div class="day-cal__columns">
          {
            isToday && nowLineTop !== null ? (
              <div
                class="day-cal__now-line"
                style={`top: ${nowLineTop}rem`}
                aria-hidden="true"
              />
            ) : null
          }
          {
            staff.map((member) => {
              const events = staffEventsForDay(
                member.id,
                selectedDay,
                appointments,
                blockedTimes,
              );
              const accent = staffAccentColor(member.id);
              const memberSchedules = staffSchedules[member.id] ?? [];
              // Cancelled appointments render hidden (see .day-cal__appt-card--cancelled),
              // so they shouldn't claim a column in the overlap layout of visible cards.
              const visibleEvents = events.filter(
                (item) => !(item.kind === "appointment" && item.status === "cancelled"),
              );
              const visibleLayouts = layoutOverlappingEvents(visibleEvents);
              const eventLayoutById = new Map(
                visibleEvents.map((item, index) => [item.id, visibleLayouts[index]]),
              );

              return (
                <div
                  class="day-cal__column"
                  data-staff-column={member.id}
                  style={`--staff-accent: ${accent}`}
                >
                  <div
                    class="day-cal__grid"
                    style={`height: ${gridHeight}rem; --staff-accent: ${accent}`}
                  >
                  {
                    timeSlots.map((minutes) => {
                      const inShift =
                        !salonClosed &&
                        isSlotWithinStaffSchedule(
                          minutes,
                          memberSchedules,
                          dayParam,
                        );
                      return (
                        <button
                          type="button"
                          class:list={[
                            "day-cal__slot",
                            salonClosed && "day-cal__slot--salon-closed",
                            !salonClosed && inShift && "day-cal__slot--shift",
                            !salonClosed && !inShift && "day-cal__slot--off",
                          ]}
                          style={`height: ${CALENDAR_ROW_HEIGHT_REM}rem`}
                          data-staff-id={member.id}
                          data-starts-at={slotStartsAtIso(selectedDay, minutes)}
                          data-slot-minutes={CALENDAR_SLOT_MINUTES}
                          aria-label={`${inShift ? "Book" : "Unavailable"} · ${member.name} · ${formatSlotTimeLabel(minutes)}`}
                        />
                      );
                    })
                  }

                  {
                    events.map((event) => {
                      const style = eventBlockStyle(event.startsAt, event.endsAt);
                      const isBlocked = event.kind === "blocked";
                      const apptStatus =
                        event.kind === "appointment" ? event.status : null;
                      const statusMeta = apptStatus
                        ? appointmentStatusMeta(apptStatus)
                        : null;
                      const blockAccent = isBlocked
                        ? null
                        : serviceCategoryColor(
                            event.kind === "appointment"
                              ? event.serviceCategory
                              : null,
                          );
                      const timeRange = formatCompactTimeRangeInSalon(
                        event.startsAt,
                        event.endsAt,
                      );
                      const serviceDisplay =
                        event.kind === "appointment" && event.serviceLabel
                          ? formatServiceDisplayName(event.serviceLabel)
                          : null;

                      const durationMinutes = Math.round(
                        (new Date(event.endsAt).getTime() -
                          new Date(event.startsAt).getTime()) /
                          60000,
                      );

                      const layout = eventLayoutById.get(event.id) ?? {
                        columnIndex: 0,
                        columnCount: 1,
                      };
                      const hasConflict = layout.columnCount > 1;
                      const overlapInsetStyle = hasConflict
                        ? (() => {
                            const leftRem = 0.3;
                            const rightRem = 0.42;
                            const gapRem = 0.14;
                            const { columnCount: count, columnIndex: index } = layout;
                            const available = `(100% - ${leftRem}rem - ${rightRem}rem - ${gapRem * (count - 1)}rem)`;
                            const width = `calc(${available} / ${count})`;
                            const left = `calc(${leftRem}rem + (${available} / ${count} + ${gapRem}rem) * ${index})`;
                            return `; left: ${left}; width: ${width}`;
                          })()
                        : "";

                      return (
                        <button
                          type="button"
                          class:list={[
                            "day-cal__block",
                            "day-cal__appt-card",
                            isBlocked && "day-cal__block--blocked",
                            !isBlocked && (managerView || member.id === currentStaffId) && "day-cal__appt-card--draggable",
                            apptStatus && `day-cal__appt-card--${apptStatus}`,
                            hasConflict && "day-cal__appt-card--conflict",
                          ]}
                          style={`${Object.entries(style).map(([k, v]) => `${k}: ${v}`).join("; ")}${blockAccent ? `; --block-accent: ${blockAccent}` : ""}${overlapInsetStyle}`}
                          data-kind={event.kind}
                          data-id={event.id}
                          data-staff-id={event.staffId}
                          data-starts-at={event.startsAt}
                          data-ends-at={event.endsAt}
                          data-duration-minutes={isBlocked ? undefined : durationMinutes}
                          aria-label={
                            isBlocked
                              ? `${event.label}, ${timeRange}${hasConflict ? ", overlaps another appointment" : ""}`
                              : `${event.clientFullName}, ${serviceDisplay ?? "appointment"}, ${statusMeta?.label ?? apptStatus}, ${timeRange}${hasConflict ? ", overlaps another appointment" : ""}`
                          }
                        >
                          {
                            isBlocked ? (
                              <>
                                <span class="day-cal__appt-card-time">{timeRange}</span>
                                <span class="day-cal__appt-card-client">{event.label}</span>
                              </>
                            ) : (
                              <>
                                <div class="day-cal__appt-card-head">
                                  <span class="day-cal__appt-card-time">{timeRange}</span>
                                  {
                                    statusMeta ? (
                                      <span
                                        class:list={[
                                          "day-cal__appt-status",
                                          apptStatus && `day-cal__appt-status--${apptStatus}`,
                                        ]}
                                        title={statusMeta.label}
                                      >
                                        <span class="day-cal__appt-status-icon" aria-hidden="true">
                                          {statusMeta.icon}
                                        </span>
                                        <span class="day-cal__appt-status-label">
                                          {statusMeta.shortLabel}
                                        </span>
                                      </span>
                                    ) : null
                                  }
                                  <span
                                    class="day-cal__appt-card-menu-btn"
                                    data-appt-menu-btn
                                    data-id={event.id}
                                    role="button"
                                    tabindex="0"
                                    aria-label={`More options for ${event.clientFullName}`}
                                    aria-haspopup="menu"
                                  >
                                    <span aria-hidden="true">⋮</span>
                                  </span>
                                </div>
                                <span class="day-cal__appt-card-client">
                                  {event.clientFullName}
                                </span>
                                {
                                  serviceDisplay ? (
                                    <span class="day-cal__appt-card-service">
                                      {serviceDisplay}
                                    </span>
                                  ) : event.serviceCount > 0 ? (
                                    <span class="day-cal__appt-card-service">
                                      {event.serviceCount}{" "}
                                      {event.serviceCount === 1 ? "service" : "services"}
                                    </span>
                                  ) : null
                                }
                                {
                                  event.serviceCount > 1 ? (
                                    <span class="day-cal__appt-card-more">
                                      +{event.serviceCount - 1} more
                                    </span>
                                  ) : null
                                }
                                <div class="day-cal__appt-card-indicators">
                                  {
                                    event.hasNotes ? (
                                      <span class="day-cal__appt-indicator" title="Has internal note" aria-label="Has note">
                                        note
                                      </span>
                                    ) : null
                                  }
                                  {
                                    hasConflict ? (
                                      <span
                                        class="day-cal__appt-indicator day-cal__appt-indicator--conflict"
                                        title="Overlaps another appointment"
                                        aria-label="Overlaps another appointment"
                                      >
                                        ⚠ conflict
                                      </span>
                                    ) : null
                                  }
                                </div>
                              </>
                            )
                          }
                          {
                            !isBlocked && (managerView || member.id === currentStaffId) ? (
                              <span
                                class="day-cal__appt-resize-handle"
                                data-resize-handle
                                aria-hidden="true"
                                tabindex="-1"
                              ></span>
                            ) : null
                          }
                        </button>
                      );
                    })
                  }

                  {
                    timeOffForDay(member.id, selectedDay, timeOff).map((off) => {
                      const offStyle = eventBlockStyle(off.startsAt, off.endsAt);
                      const offRange = off.allDay
                        ? "All day"
                        : formatCompactTimeRangeInSalon(off.startsAt, off.endsAt);
                      return (
                        <div
                          class="day-cal__block day-cal__block--time-off"
                          style={Object.entries(offStyle)
                            .map(([k, v]) => `${k}: ${v}`)
                            .join("; ")}
                          data-kind="time_off"
                          data-id={off.id}
                          aria-label={`Time off: ${off.label}, ${offRange}`}
                        >
                          <span class="day-cal__block-time">{offRange}</span>
                          <span class="day-cal__block-title">{off.label}</span>
                        </div>
                      );
                    })
                  }

                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>

  <div class="day-cal__sheet" id="day-cal-selection" hidden aria-hidden="true">
    <div class="day-cal__sheet-backdrop" data-close-selection tabindex="-1"></div>
    <div
      class="day-cal__sheet-panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="day-cal-selection-title"
    >
      <header class="day-cal__sheet-header">
        <h3 class="day-cal__sheet-title" id="day-cal-selection-title">Selected time</h3>
      </header>
      <div class="day-cal__sheet-body">
        <p class="day-cal__selection-summary" id="day-cal-selection-summary"></p>
        <div class="day-cal__sheet-actions" role="menu">
          <button
            type="button"
            class="day-cal__sheet-action day-cal__sheet-action--primary"
            data-action="block-bulk"
            role="menuitem"
          >
            Block time (bulk)
          </button>
          <button type="button" class="day-cal__sheet-action" data-action="appointment-bulk" role="menuitem">
            New appointment
          </button>
          <button
            type="button"
            class="day-cal__sheet-action day-cal__sheet-action--muted"
