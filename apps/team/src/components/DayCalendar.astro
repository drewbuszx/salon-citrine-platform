        <div class="day-cal__drawer-heading">
          <h2 class="day-cal__drawer-title" id="day-cal-drawer-title"></h2>
          <p class="day-cal__drawer-subtitle" id="day-cal-drawer-subtitle"></p>
        </div>
        <button
          type="button"
          class="day-cal__drawer-close"
          data-close-drawer
          aria-label="Close panel"
