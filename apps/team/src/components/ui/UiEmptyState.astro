---
interface Props {
  title: string;
  hint?: string;
  icon?: string;
  compact?: boolean;
  class?: string;
}

const { title, hint, icon, compact = false, class: className } = Astro.props;
const hasActions = Astro.slots.has("actions");
---

<div class:list={["ui-empty", compact && "ui-empty--compact", className]}>
  {icon ? <span class="ui-empty__icon" aria-hidden="true">{icon}</span> : null}
  <p class="ui-empty__title">{title}</p>
  {hint ? <p class="ui-empty__hint">{hint}</p> : null}
  {
    hasActions ? (
      <div class="ui-empty__actions">
        <slot name="actions" />
      </div>
    ) : null
  }
</div>
