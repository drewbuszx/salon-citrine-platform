---
import { STAFF_MEMBERS } from "@saloncitrine/shared";

const DAYS = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
const HOURS = ["10 AM", "12 PM", "2 PM", "4 PM", "6 PM", "8 PM"];

const today = new Date();
const weekStart = new Date(today);
weekStart.setDate(today.getDate() - today.getDay() + 1);

const weekDates = Array.from({ length: 7 }, (_, i) => {
  const d = new Date(weekStart);
  d.setDate(weekStart.getDate() + i);
  return d;
});

const placeholderAppointments = [
  {
    staffSlug: "lily-gleitsman",
    dayIndex: 1,
    hourIndex: 1,
    label: "Haircut · Alex M.",
  },
  {
    staffSlug: "shelby-craft",
    dayIndex: 2,
    hourIndex: 2,
    label: "Vivid consult · Jordan K.",
  },
  {
    staffSlug: "julie-powers",
    dayIndex: 3,
    hourIndex: 3,
    label: "Korean facial · Sam T.",
  },
];
---

<section class="calendar" aria-label="Week calendar">
  <header class="calendar__toolbar">
    <h2 class="calendar__title">Week of {weekDates[0].toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}</h2>
    <div class="calendar__actions">
      <button type="button" disabled>← Prev</button>
      <button type="button" disabled>Today</button>
      <button type="button" disabled>Next →</button>
    </div>
  </header>

  <div class="calendar__scroll">
    <table class="calendar__grid">
      <thead>
        <tr>
          <th class="calendar__corner">Staff</th>
          {
            weekDates.map((date, i) => (
              <th>
                <span class="calendar__day">{DAYS[date.getDay()]}</span>
                <span class="calendar__date">{date.getDate()}</span>
              </th>
            ))
          }
        </tr>
      </thead>
      <tbody>
        {
          STAFF_MEMBERS.map((member) => (
            <tr>
              <th scope="row" class="calendar__staff">
                {member.name}
              </th>
              {
                weekDates.map((_, dayIndex) => (
                  <td class="calendar__cell">
                    {
                      placeholderAppointments
                        .filter(
                          (a) =>
                            a.staffSlug === member.slug && a.dayIndex === dayIndex,
                        )
                        .map((a) => (
                          <div class="calendar__appt">{a.label}</div>
                        ))
                    }
                  </td>
                ))
              }
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <p class="calendar__note">
    Placeholder week view — drag-drop, blocked time, and Supabase Auth login
    ship in Phase 1.
  </p>
</section>

<style>
  .calendar__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .calendar__title {
    font-size: 1.25rem;
  }

  .calendar__actions {
    display: flex;
    gap: 0.5rem;
  }

  .calendar__actions button {
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: not-allowed;
    opacity: 0.55;
  }

  .calendar__scroll {
    overflow-x: auto;
    border: 1px solid var(--color-border);
  }

  .calendar__grid {
    width: 100%;
    min-width: 48rem;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .calendar__grid th,
  .calendar__grid td {
    border: 1px solid var(--color-border);
    padding: 0.5rem;
    vertical-align: top;
  }

  .calendar__corner {
    width: 8rem;
    background: var(--color-light);
  }

  .calendar__grid thead th {
    background: var(--color-light);
    text-align: center;
  }

  .calendar__day {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .calendar__date {
    display: block;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .calendar__staff {
    text-align: left;
    background: var(--color-light);
    font-weight: 500;
    white-space: nowrap;
  }

  .calendar__cell {
    min-height: 3rem;
    min-width: 6rem;
    background: var(--color-bg);
  }

  .calendar__appt {
    padding: 0.35rem 0.45rem;
    margin-bottom: 0.25rem;
    background: var(--color-citrine);
    color: var(--color-black);
    font-size: 0.75rem;
    line-height: 1.3;
    border-radius: 2px;
  }

  .calendar__note {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--color-gray);
  }
</style>
