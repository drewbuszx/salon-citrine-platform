---
import type {
  CalendarAppointment,
  CalendarBlockedTime,
  CalendarStaff,
  StaffSchedule,
} from "../lib/calendar";
import {
  CALENDAR_ROW_HEIGHT_REM,
  STAFF_HEADER_HEIGHT_REM,
  calendarGridHeightRem,
  calendarTimeSlots,
  currentTimeLineTopRem,
  defaultCalendarScrollTopRem,
  eventBlockStyle,
  formatCompactTimeRangeInSalon,
  formatDayLabel,
  formatDayParam,
  formatNowLabel,
  formatSlotHourLabel,
  formatSlotMinuteLabel,
  formatSlotTimeLabel,
  isSalonClosedOnDay,
  isSameDayInSalon,
  isSlotWithinStaffSchedule,
  isTodayInSalon,
  shiftDay,
  staffEventsForDay,
  staffShiftStatus,
} from "../lib/calendar";
import {
  appointmentStatusMeta,
  formatServiceDisplayName,
  serviceCategoryColor,
} from "../lib/appointment-ui";
import { teamUrl } from "../lib/supabase-server";

interface Props {
  weekStart: Date;
  weekParam: string;
  staff: CalendarStaff;
  staffOptions: CalendarStaff[];
  appointments: CalendarAppointment[];
  blockedTimes: CalendarBlockedTime[];
  staffSchedules: StaffSchedule[];
  currentStaffId: string;
  managerView: boolean;
}

const {
  weekStart,
  weekParam,
  staff: selectedStaff,
  staffOptions,
  appointments,
  blockedTimes,
  staffSchedules,
  currentStaffId,
  managerView,
} = Astro.props;

const prevWeek = formatDayParam(shiftDay(weekStart, -7));
const nextWeek = formatDayParam(shiftDay(weekStart, 7));
const todayWeek = formatDayParam(shiftDay(new Date(), -new Date().getDay()));
const timeSlots = calendarTimeSlots();
const gridHeight = calendarGridHeightRem();

const weekDays = Array.from({ length: 7 }, (_, index) => {
  const day = shiftDay(weekStart, index);
  const param = formatDayParam(day);
  const count = appointments.filter((appt) =>
    isSameDayInSalon(appt.startsAt, day),
  ).length;
  return {
    day,
    param,
    label: new Intl.DateTimeFormat("en-US", { weekday: "short" }).format(day),
    dayNum: day.getDate(),
    isToday: isTodayInSalon(day),
    count,
    closed: isSalonClosedOnDay(param),
  };
});

const isTodayWeek = weekDays.some((day) => day.isToday);
const nowLineTop = isTodayWeek ? currentTimeLineTopRem() : null;
const nowLabel = nowLineTop !== null ? formatNowLabel() : null;

/* Anchor default scroll on today when this week contains it. */
const scrollAnchorParam =
  weekDays.find((day) => day.isToday)?.param ?? weekParam;
const defaultScrollTopRem = defaultCalendarScrollTopRem(scrollAnchorParam, {
  appointments,
  staffIds: [selectedStaff.id],
  staffSchedules: { [selectedStaff.id]: staffSchedules },
});

function staffPhotoUrl(member: CalendarStaff) {
  if (member.photoUrl) {
    return member.photoUrl.startsWith("/")
      ? teamUrl(member.photoUrl)
      : member.photoUrl;
  }
  return teamUrl(`/images/${member.slug}.jpg`);
}

const isViewingSelf = selectedStaff.id === currentStaffId;
---

<section
  class="week-cal"
  aria-label={`Week calendar for ${selectedStaff.name}`}
  style={`--week-header-height: ${STAFF_HEADER_HEIGHT_REM}rem`}
>
  <header class="week-cal__header">
    <div class="week-cal__toolbar">
      <nav class="week-cal__nav" aria-label="Week navigation">
        <a
          class="week-cal__btn week-cal__btn--icon"
          href={`${teamUrl("/week")}?week=${prevWeek}&staff=${selectedStaff.id}`}
          aria-label="Previous week"
        >
          ‹
        </a>
        <span class="week-cal__range">
          {formatDayLabel(weekStart)} – {formatDayLabel(shiftDay(weekStart, 6))}
        </span>
        <a
          class="week-cal__btn week-cal__btn--icon"
          href={`${teamUrl("/week")}?week=${nextWeek}&staff=${selectedStaff.id}`}
          aria-label="Next week"
        >
          ›
        </a>
        <a
          class:list={[
            "week-cal__btn",
            isTodayWeek && "week-cal__btn--today-active",
          ]}
          href={`${teamUrl("/week")}?week=${todayWeek}&staff=${selectedStaff.id}`}
          aria-current={isTodayWeek ? "date" : undefined}
        >
          This week
        </a>
      </nav>

      <div class="week-cal__toolbar-actions">
        <a
          class="week-cal__view-pill"
          href={teamUrl(`/book?day=${scrollAnchorParam}`)}
        >
          Day
        </a>
        <span class="week-cal__view-pill week-cal__view-pill--active" aria-current="true">
          Week
        </span>
        <span class="week-cal__staff">
          <img
            class="week-cal__staff-photo"
            src={staffPhotoUrl(selectedStaff)}
            alt=""
            width="24"
            height="24"
            loading="lazy"
          />
          {
            managerView && staffOptions.length > 1 ? (
              <label class="week-cal__staff-select">
                <span class="visually-hidden">Provider</span>
                <select data-week-staff-select>
                  {staffOptions.map((member) => (
                    <option value={member.id} selected={member.id === selectedStaff.id}>
                      {member.name}
                      {member.id === currentStaffId ? " (you)" : ""}
                    </option>
                  ))}
                </select>
              </label>
            ) : (
              <span class="week-cal__staff-name">
                {isViewingSelf ? "My week" : selectedStaff.name}
              </span>
            )
          }
        </span>
      </div>
    </div>
  </header>

  <div class="week-cal__frame">
    <div class="week-cal__viewport" data-week-viewport>
      <div class="week-cal__time-axis" aria-hidden="true">
        <div class="week-cal__time-spacer">
          {nowLabel ? <span class="week-cal__now-label">{nowLabel}</span> : null}
        </div>
        <div class="week-cal__time-rail" style={`height: ${gridHeight}rem`}>
          {
            timeSlots.map((minutes) => {
              const hourLabel = formatSlotHourLabel(minutes);
              const minuteLabel = formatSlotMinuteLabel(minutes);
              return (
                <div
                  class:list={[
                    "week-cal__time-label",
                    minutes % 60 === 0 && "week-cal__time-label--hour",
                    minuteLabel && "week-cal__time-label--minute",
                  ]}
                  style={`height: ${CALENDAR_ROW_HEIGHT_REM}rem`}
                >
                  {hourLabel || minuteLabel}
                </div>
              );
            })
          }
          {
            nowLineTop !== null ? (
              <div class="week-cal__now-marker" style={`top: ${nowLineTop}rem`} aria-hidden="true" />
            ) : null
          }
        </div>
      </div>

      <div class="week-cal__schedule">
        <div class="week-cal__day-row">
          {
            weekDays.map((dayInfo) => {
              const shiftStatus = staffShiftStatus(staffSchedules, dayInfo.param);
              return (
                <header
                  class:list={[
                    "week-cal__day-header",
                    dayInfo.isToday && "week-cal__day-header--today",
                  ]}
                >
                  <a
                    class="week-cal__day-heading"
                    href={`${teamUrl("/book")}?day=${dayInfo.param}`}
                    aria-label={`Open day view for ${formatDayLabel(dayInfo.day)}`}
                  >
                    <span class="week-cal__day-label">{dayInfo.label}</span>
                    <span class="week-cal__day-num">{dayInfo.dayNum}</span>
                    {dayInfo.count > 0 && (
                      <span
                        class="week-cal__day-dot"
                        aria-label={`${dayInfo.count} appointments`}
                      />
                    )}
                  </a>
                  <span
                    class:list={[
                      "week-cal__day-shift",
                      `week-cal__day-shift--${shiftStatus.kind}`,
                    ]}
                    title={shiftStatus.label}
                  >
                    {shiftStatus.shortLabel}
                  </span>
                </header>
              );
            })
          }
        </div>

        <div class="week-cal__columns">
          {
            nowLineTop !== null ? (
              <div
                class="week-cal__now-line"
                style={`top: ${nowLineTop}rem`}
                aria-hidden="true"
              />
            ) : null
          }
          {
            weekDays.map((dayInfo) => {
              const events = staffEventsForDay(
                selectedStaff.id,
                dayInfo.day,
                appointments,
                blockedTimes,
              );

              return (
                <div class="week-cal__column" data-day-column={dayInfo.param}>
                  <div class="week-cal__grid" style={`height: ${gridHeight}rem`}>
                    {
                      timeSlots.map((minutes) => {
                        const inShift =
                          !dayInfo.closed &&
                          isSlotWithinStaffSchedule(minutes, staffSchedules, dayInfo.param);
                        return (
                          <a
                            class:list={[
                              "week-cal__slot",
                              dayInfo.closed && "week-cal__slot--closed",
                              !dayInfo.closed && inShift && "week-cal__slot--shift",
                              !dayInfo.closed && !inShift && "week-cal__slot--off",
                            ]}
                            style={`height: ${CALENDAR_ROW_HEIGHT_REM}rem`}
                            href={`${teamUrl("/book")}?day=${dayInfo.param}`}
                            aria-label={`Open ${dayInfo.label} in day view at ${formatSlotTimeLabel(minutes)}`}
                          />
                        );
                      })
                    }

                    {
                      events.map((event) => {
                        const style = eventBlockStyle(event.startsAt, event.endsAt);
                        const isBlocked = event.kind === "blocked";
                        const apptStatus =
                          event.kind === "appointment" ? event.status : null;
                        const statusMeta = apptStatus
                          ? appointmentStatusMeta(apptStatus)
                          : null;
                        const blockAccent = isBlocked
                          ? null
                          : serviceCategoryColor(
                              event.kind === "appointment"
                                ? event.serviceCategory
                                : null,
                            );
                        const serviceDisplay =
                          event.kind === "appointment" && event.serviceLabel
                            ? formatServiceDisplayName(event.serviceLabel)
                            : null;
                        const timeRange = formatCompactTimeRangeInSalon(
                          event.startsAt,
                          event.endsAt,
                        );

                        return (
                          <a
                            class:list={[
                              "week-cal__block",
                              isBlocked && "week-cal__block--blocked",
                            ]}
                            style={`${Object.entries(style).map(([k, v]) => `${k}: ${v}`).join("; ")}${blockAccent ? `; --block-accent: ${blockAccent}` : ""}`}
                            href={`${teamUrl("/book")}?day=${dayInfo.param}`}
                          >
                            <span class="week-cal__block-time">{timeRange}</span>
                            <span class="week-cal__block-label">
                              {isBlocked ? event.label : event.clientFullName}
                            </span>
                            {
                              serviceDisplay ? (
                                <span class="week-cal__block-service">{serviceDisplay}</span>
                              ) : null
                            }
                            {
                              statusMeta ? (
                                <span class="week-cal__block-status">{statusMeta.shortLabel}</span>
                              ) : null
                            }
                          </a>
                        );
                      })
                    }
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ defaultScrollTopRem }}>
    (function () {
      const root = document.querySelector(".week-cal");
      if (!root) return;
      const viewport = root.querySelector("[data-week-viewport]");
      const scrollTopRem = Number(defaultScrollTopRem);
      if (viewport instanceof HTMLElement && scrollTopRem > 0) {
        const remPx = parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
        viewport.scrollTop = scrollTopRem * remPx;
      }
      root.querySelector("[data-week-staff-select]")?.addEventListener("change", (event) => {
        const select = event.target;
        if (!(select instanceof HTMLSelectElement)) return;
        const url = new URL(window.location.href);
        url.searchParams.set("staff", select.value);
        window.location.href = url.toString();
      });
    })();
  </script>
</section>

<style>
  .week-cal {
    --week-day-width: 9rem;
    --week-time-width: 3rem;
    --week-header-height: 2.75rem;
    --week-day-count: 7;
    /* Structural grid hairlines — shared with the day view's column model. */
    --week-divider: rgba(0, 0, 0, 0.12);
    --week-divider-strong: rgba(0, 0, 0, 0.18);
    --week-header-bg: var(--color-light);
    display: flex;
    flex-direction: column;
    width: 100%;
    height: calc(100vh - var(--team-bar-height, 3.25rem));
    min-height: 0;
    background: var(--color-bg);
    color: var(--color-text);
  }

  [data-theme="dark"] .week-cal {
    --week-divider: rgba(255, 255, 255, 0.14);
    --week-divider-strong: rgba(255, 255, 255, 0.22);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .week-cal__header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 0.4rem clamp(0.75rem, 2vw, 1.25rem);
    border-bottom: 1px solid var(--week-divider-strong);
    background: var(--color-bg);
  }

  .week-cal__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .week-cal__nav {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .week-cal__range {
    font-size: 0.82rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .week-cal__btn {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.65rem;
    border: 1px solid var(--color-border);
    border-radius: 0.35rem;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.72rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .week-cal__btn--icon {
    width: 2rem;
    justify-content: center;
    padding: 0;
    font-size: 1.1rem;
  }

  .week-cal__btn--today-active {
    border-color: var(--color-citrine);
    background: rgba(231, 172, 70, 0.18);
  }

  .week-cal__toolbar-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  .week-cal__view-pill {
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: inherit;
  }

  .week-cal__view-pill--active {
    border-color: var(--color-citrine);
    background: rgba(231, 172, 70, 0.18);
  }

  .week-cal__staff {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .week-cal__staff-photo {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--color-border);
  }

  .week-cal__staff-select select {
    font-size: 0.78rem;
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.35rem;
    background: var(--color-light);
    color: var(--color-text);
  }

  .week-cal__staff-name {
    font-size: 0.78rem;
    font-weight: 600;
  }

  .week-cal__frame {
    flex: 1;
    min-height: 0;
    display: flex;
    background: var(--color-bg);
    overflow: hidden;
    width: 100%;
  }

  .week-cal__viewport {
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: flex-start;
    width: 100%;
    overflow: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    scrollbar-gutter: stable both-edges;
    background: var(--color-bg);
    position: relative;
  }

  .week-cal__time-axis {
    flex: 0 0 var(--week-time-width);
    align-self: flex-start;
    position: sticky;
    left: 0;
    z-index: 5;
    border-right: 1px solid var(--week-divider);
    background: var(--color-bg);
  }

  .week-cal__time-spacer {
    height: var(--week-header-height);
    flex-shrink: 0;
    border-bottom: 1px solid var(--week-divider-strong);
    background: var(--week-header-bg);
    position: sticky;
    top: 0;
    z-index: 6;
    display: flex;
    align-items: flex-end;
    padding: 0 0.15rem 0.2rem;
  }

  .week-cal__now-label {
    font-family: var(--font-sans);
    font-size: 0.52rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #c44;
    white-space: nowrap;
  }

  .week-cal__time-rail {
    position: relative;
  }

  .week-cal__time-label {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 0.15rem 0.2rem 0 0.15rem;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.02em;
    color: var(--color-gray);
    border-bottom: 1px solid var(--color-border-subtle);
    background: var(--color-bg);
  }

  .week-cal__time-label--hour {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-text);
    border-bottom-color: var(--color-border);
  }

  .week-cal__time-label--minute {
    font-size: 0.5rem;
    color: var(--color-gray);
    opacity: 0.7;
    border-bottom-color: transparent;
  }

  .week-cal__now-marker {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 4;
    height: 2px;
    background: #c44;
    pointer-events: none;
  }

  .week-cal__now-marker::before {
    content: "";
    position: absolute;
    right: -0.2rem;
    top: 50%;
    transform: translateY(-50%);
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: #c44;
  }

  /* Shared sticky header + column model (mirrors the day view's schedule). */
  .week-cal__schedule {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    align-self: flex-start;
    min-width: max-content;
    width: max-content;
    position: relative;
    --week-columns-template: repeat(
      var(--week-day-count),
      minmax(var(--week-day-width), 1fr)
    );
    background: var(--color-bg);
  }

  .week-cal__day-row {
    position: sticky;
    top: 0;
    z-index: 36;
    display: grid;
    grid-template-columns: var(--week-columns-template);
    background: var(--week-header-bg);
    border-bottom: 1px solid var(--week-divider-strong);
    box-shadow: 0 2px 3px rgba(0, 0, 0, 0.05);
    isolation: isolate;
  }

  .week-cal__day-row::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background-image: repeating-linear-gradient(
      to right,
      transparent,
      transparent calc(100% / var(--week-day-count) - 1px),
      var(--week-divider) calc(100% / var(--week-day-count) - 1px),
      var(--week-divider) calc(100% / var(--week-day-count))
    );
  }

  .week-cal__day-header {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.05rem;
    box-sizing: border-box;
    height: var(--week-header-height);
    min-height: var(--week-header-height);
    max-height: var(--week-header-height);
    padding: 0 0.45rem;
    background: var(--week-header-bg);
    color: var(--color-text);
    overflow: hidden;
    position: relative;
    z-index: 2;
  }

  .week-cal__day-header--today {
    box-shadow: inset 0 -2px 0 var(--color-citrine);
  }

  .week-cal__day-heading {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .week-cal__day-header--today .week-cal__day-num {
    color: var(--color-citrine-dark, #c9952e);
  }

  .week-cal__day-label {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray);
  }

  .week-cal__day-num {
    font-size: 0.85rem;
    font-weight: 700;
  }

  .week-cal__day-dot {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--color-citrine);
    align-self: center;
  }

  .week-cal__day-shift {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.52rem;
    color: var(--color-gray);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .week-cal__day-shift--closed,
  .week-cal__day-shift--off {
    opacity: 0.75;
  }

  .week-cal__columns {
    position: relative;
    display: grid;
    grid-template-columns: var(--week-columns-template);
    flex: 1 1 auto;
    min-width: 0;
    width: 100%;
    background: var(--color-bg);
    isolation: isolate;
  }

  .week-cal__columns::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background-image: repeating-linear-gradient(
      to right,
      transparent,
      transparent calc(100% / var(--week-day-count) - 1px),
      var(--week-divider) calc(100% / var(--week-day-count) - 1px),
      var(--week-divider) calc(100% / var(--week-day-count))
    );
  }

  .week-cal__now-line {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 3;
    height: 2px;
    background: #c44;
    pointer-events: none;
  }

  .week-cal__column {
    position: relative;
    min-width: 0;
    background: var(--color-bg);
  }

  .week-cal__grid {
    position: relative;
  }

  .week-cal__slot {
    display: block;
    width: 100%;
    border: none;
    border-bottom: 1px solid var(--color-border-subtle);
    text-decoration: none;
  }

  .week-cal__slot--shift {
    background: rgba(141, 158, 136, 0.1);
  }

  .week-cal__slot--off {
    background: repeating-linear-gradient(
      -45deg,
      var(--color-bg),
      var(--color-bg) 4px,
      rgba(0, 0, 0, 0.04) 4px,
      rgba(0, 0, 0, 0.04) 8px
    );
    opacity: 0.72;
  }

  .week-cal__slot--closed {
    opacity: 0.5;
    background: rgba(0, 0, 0, 0.04);
  }

  .week-cal__block {
    position: absolute;
    left: 0.12rem;
    right: 0.12rem;
    z-index: 2;
    display: grid;
    gap: 0.05rem;
    padding: 0.2rem 0.35rem;
    border-left: 3px solid var(--block-accent, var(--color-citrine));
    border-radius: 3px;
    background: color-mix(in srgb, var(--block-accent, var(--color-citrine)) 88%, #fff 12%);
    color: #1a1a1a;
    font-size: 0.58rem;
    text-decoration: none;
    overflow: hidden;
  }

  .week-cal__block--blocked {
    background: #c8c8c8;
    border-left-color: #9a9a9a;
    color: #3a3a3a;
