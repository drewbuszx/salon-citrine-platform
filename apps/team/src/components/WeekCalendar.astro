---
import type {
  CalendarAppointment,
  CalendarBlockedTime,
  CalendarStaff,
} from "../lib/calendar";
import {
  eventDayIndex,
  formatTimeInSalon,
  formatWeekParam,
  shiftWeek,
  weekDates,
} from "../lib/calendar";
import { teamUrl } from "../lib/supabase-server";

interface Props {
  weekStart: Date;
  staff: CalendarStaff[];
  appointments: CalendarAppointment[];
  blockedTimes: CalendarBlockedTime[];
  singleColumn?: boolean;
}

const { weekStart, staff, appointments, blockedTimes, singleColumn = false } =
  Astro.props;

const dates = weekDates(weekStart);
const prevWeek = formatWeekParam(shiftWeek(weekStart, -1));
const nextWeek = formatWeekParam(shiftWeek(weekStart, 1));
const todayWeek = formatWeekParam(new Date());

const DAY_LABELS = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];

function cellEvents(staffId: string, dayIndex: number) {
  const appts = appointments
    .filter(
      (item) =>
        item.staffId === staffId && eventDayIndex(item.startsAt, weekStart) === dayIndex,
    )
    .map((item) => ({
      kind: "appointment" as const,
      label: item.serviceLabel
        ? `${item.serviceLabel} · ${item.clientLabel}`
        : item.clientLabel,
      time: formatTimeInSalon(item.startsAt),
      status: item.status,
    }));

  const blocks = blockedTimes
    .filter(
      (item) =>
        item.staffId === staffId && eventDayIndex(item.startsAt, weekStart) === dayIndex,
    )
    .map((item) => ({
      kind: "blocked" as const,
      label: item.reason || "Blocked",
      time: formatTimeInSalon(item.startsAt),
      status: "blocked",
    }));

  return [...appts, ...blocks].sort((a, b) => a.time.localeCompare(b.time));
}
---

<section class="calendar" aria-label="Week calendar">
  <header class="calendar__toolbar">
    <h2 class="calendar__title">
      Week of {
        dates[0]?.toLocaleDateString("en-US", {
          month: "long",
          day: "numeric",
          year: "numeric",
        })
      }
    </h2>
    <div class="calendar__actions">
      <a class="calendar__btn" href={`${teamUrl("/")}?week=${prevWeek}`}>← Prev</a>
      <a class="calendar__btn" href={`${teamUrl("/")}?week=${todayWeek}`}>Today</a>
      <a class="calendar__btn" href={`${teamUrl("/")}?week=${nextWeek}`}>Next →</a>
    </div>
  </header>

  {
    singleColumn ? (
      <div class="calendar__single">
        {
          dates.map((date, dayIndex) => (
            <article class="calendar__day-card">
              <h3>
                {DAY_LABELS[dayIndex]} {date.getDate()}
              </h3>
              <ul>
                {
                  cellEvents(staff[0]?.id ?? "", dayIndex).map((event) => (
                    <li class:list={["calendar__event", `calendar__event--${event.kind}`]}>
                      <span class="calendar__event-time">{event.time}</span>
                      <span>{event.label}</span>
                    </li>
                  ))
                }
                {cellEvents(staff[0]?.id ?? "", dayIndex).length === 0 ? (
                  <li class="calendar__empty">No appointments</li>
                ) : null}
              </ul>
            </article>
          ))
        }
      </div>
    ) : (
      <div class="calendar__scroll">
        <table class="calendar__grid">
          <thead>
            <tr>
              <th class="calendar__corner">Staff</th>
              {
                dates.map((date, index) => (
                  <th>
                    <span class="calendar__day">{DAY_LABELS[index]}</span>
                    <span class="calendar__date">{date.getDate()}</span>
                  </th>
                ))
              }
            </tr>
          </thead>
          <tbody>
            {
              staff.map((member) => (
                <tr>
                  <th scope="row" class="calendar__staff">
                    {member.name}
                  </th>
                  {
                    dates.map((_, dayIndex) => (
                      <td class="calendar__cell">
                        {
                          cellEvents(member.id, dayIndex).map((event) => (
                            <div
                              class:list={[
                                "calendar__appt",
                                event.kind === "blocked" && "calendar__appt--blocked",
                              ]}
                            >
                              <span class="calendar__appt-time">{event.time}</span>
                              {event.label}
                            </div>
                          ))
                        }
                      </td>
                    ))
                  }
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    )
  }
</section>

<style>
  .calendar__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .calendar__title {
    font-size: 1.25rem;
  }

  .calendar__actions {
    display: flex;
    gap: 0.5rem;
  }

  .calendar__btn {
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-booking-card-bg);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;
  }

  .calendar__btn:hover,
  .calendar__btn:focus-visible {
    opacity: 0.75;
    outline: none;
  }

  .calendar__scroll {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    background: var(--color-booking-card-bg);
  }

  .calendar__grid {
    width: 100%;
    min-width: 48rem;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .calendar__grid th,
  .calendar__grid td {
    border: 1px solid var(--color-border);
    padding: 0.5rem;
    vertical-align: top;
  }

  .calendar__corner,
  .calendar__staff {
    background: var(--color-light);
  }

  .calendar__corner {
    width: 8rem;
  }

  .calendar__grid thead th {
    background: var(--color-light);
    text-align: center;
  }

  .calendar__day {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .calendar__date {
    display: block;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .calendar__staff {
    text-align: left;
    font-weight: 500;
    white-space: nowrap;
  }

  .calendar__cell {
    min-height: 3rem;
    min-width: 6rem;
    background: var(--color-booking-card-bg);
  }

  .calendar__appt {
    padding: 0.35rem 0.45rem;
    margin-bottom: 0.25rem;
    background: var(--color-citrine);
    color: var(--color-black);
    font-size: 0.75rem;
    line-height: 1.3;
    border-radius: 2px;
  }

  .calendar__appt--blocked {
    background: rgba(120, 120, 120, 0.25);
    color: var(--color-text);
  }

  .calendar__appt-time {
    display: block;
    font-size: 0.65rem;
    opacity: 0.85;
  }

  .calendar__single {
    display: grid;
    gap: 0.75rem;
  }

  .calendar__day-card {
    border: 1px solid var(--color-border);
    padding: 0.75rem;
    background: var(--color-booking-card-bg);
  }

  .calendar__day-card h3 {
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }

  .calendar__day-card ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.35rem;
  }

  .calendar__event {
    display: grid;
    gap: 0.15rem;
    padding: 0.45rem 0.55rem;
    background: var(--color-citrine);
    color: var(--color-black);
    font-size: 0.82rem;
  }

  .calendar__event--blocked {
    background: rgba(120, 120, 120, 0.25);
    color: var(--color-text);
  }

  .calendar__event-time {
    font-size: 0.72rem;
    opacity: 0.85;
  }

  .calendar__empty {
    color: var(--color-gray);
    font-size: 0.85rem;
  }
</style>
