---
import { MANAGE_NAV, type ManageSection } from "../lib/manage-nav";

interface Props {
  title: string;
  activeSection?: ManageSection;
  rootClass?: string;
}

const { title, activeSection = "hub", rootClass = "" } = Astro.props;
const hasHeaderActions = Astro.slots.has("headerActions");
---

<div class:list={["team-manage-layout", rootClass]}>
  <header class="team-manage-layout__subheader">
    <h1 class="team-manage-layout__title">{title}</h1>
    {
      hasHeaderActions ? (
        <div class="team-manage-layout__header-actions">
          <slot name="headerActions" />
        </div>
      ) : null
    }
  </header>

  <div class="team-manage-layout__body">
    <aside class="team-manage-layout__sidebar" aria-label="Manage business">
      <h2 class="team-manage-layout__sidebar-title">Manage Business</h2>
      <nav class="team-manage-layout__nav" aria-label="Business settings">
        {
          MANAGE_NAV.map((item) =>
            item.disabled ? (
              <span class="team-manage-layout__nav-link team-manage-layout__nav-link--disabled">
                <span>{item.label}</span>
                <span class="team-manage-layout__soon-badge">Soon</span>
              </span>
            ) : (
              <a
                class:list={[
                  "team-manage-layout__nav-link",
                  { "is-active": activeSection === item.id },
                ]}
                href={item.href}
                aria-current={activeSection === item.id ? "page" : undefined}
              >
                {item.label}
              </a>
            ),
          )
        }
      </nav>
    </aside>

    <main class="team-manage-layout__main">
      <slot />
    </main>
  </div>
</div>

<style>
  .team-manage-layout {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - var(--team-bar-height, 3.25rem));
    font-family: var(--font-body);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .team-manage-layout__subheader {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--color-stone-200);
    background: var(--color-bg);
  }

  .team-manage-layout__title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .team-manage-layout__header-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .team-manage-layout__body {
    display: grid;
    grid-template-columns: minmax(200px, 220px) 1fr;
    flex: 1;
    min-height: 0;
  }

  .team-manage-layout__sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 0;
    border-right: 1px solid var(--color-stone-200);
    background: var(--team-sidebar-bg);
  }

  .team-manage-layout__sidebar-title {
    margin: 0 0 0.5rem;
    padding: 0 1rem;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-400);
  }

  .team-manage-layout__nav {
    display: grid;
    gap: 0;
  }

  .team-manage-layout__nav-link {
    display: block;
    padding: 0.6rem 1rem;
    border-left: 3px solid transparent;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-stone-700);
    text-decoration: none;
    transition:
      color var(--transition-fast),
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .team-manage-layout__nav-link:hover,
  .team-manage-layout__nav-link:focus-visible {
    color: var(--color-citrine-dark);
    background: var(--color-citrine-muted);
    outline: none;
  }

  .team-manage-layout__nav-link.is-active {
    border-left-color: var(--team-sidebar-active-border);
    color: var(--color-stone-800);
    background: var(--team-sidebar-active-bg);
    font-weight: 600;
  }

  .team-manage-layout__nav-link--disabled {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    border-left: 3px solid transparent;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-stone-600);
    cursor: not-allowed;
  }

  :global(.team-manage-layout__soon-badge) {
    display: inline-flex;
    flex-shrink: 0;
    padding: 0.15rem 0.4rem;
    border: 1px solid var(--color-stone-300);
    border-radius: var(--radius-sm);
    background: var(--color-stone-100);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-stone-600);
    line-height: 1.2;
  }

  .team-manage-layout__main {
    padding: 1.25rem 1.5rem 2rem;
    background: #fff;
    min-width: 0;
  }

  :global(.team-manage-layout__hub-list) {
    display: grid;
    gap: 0;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  :global(.team-manage-layout__hub-row) {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.15rem;
    border-bottom: 1px solid var(--color-stone-200);
    background: var(--color-bg);
  }

  :global(.team-manage-layout__hub-row:last-child) {
    border-bottom: none;
  }

  :global(.team-manage-layout__hub-row--disabled) {
    background: var(--color-stone-50);
  }

  :global(.team-manage-layout__hub-row--disabled .team-manage-layout__hub-icon) {
    background: var(--color-stone-100);
    color: var(--color-stone-400);
  }

  :global(.team-manage-layout__hub-row--disabled .team-manage-layout__hub-title) {
    color: var(--color-stone-500);
  }

  :global(.team-manage-layout__hub-row--disabled .team-manage-layout__hub-desc) {
    color: var(--color-stone-400);
  }

  :global(.team-manage-layout__hub-icon) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-sm);
    background: var(--color-stone-100);
    color: var(--color-stone-500);
    flex-shrink: 0;
  }

  :global(.team-manage-layout__hub-icon svg) {
    width: 1.1rem;
    height: 1.1rem;
  }

  :global(.team-manage-layout__hub-copy) {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }

  :global(.team-manage-layout__hub-title) {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-stone-800);
  }

  :global(.team-manage-layout__hub-desc) {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-stone-500);
    line-height: var(--leading-normal);
  }

  @media (max-width: 900px) {
    .team-manage-layout__body {
      grid-template-columns: 1fr;
    }

    .team-manage-layout__sidebar {
      border-right: none;
      border-bottom: 1px solid var(--color-stone-200);
      padding-bottom: 0.75rem;
    }

    .team-manage-layout__nav {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      padding: 0 0.75rem;
    }

    .team-manage-layout__nav-link,
    .team-manage-layout__nav-link--disabled {
      border-left: none;
      border-radius: 0.25rem;
      padding: 0.45rem 0.65rem;
    }

    .team-manage-layout__nav-link.is-active {
      border-left: none;
      box-shadow: inset 0 0 0 2px var(--color-citrine);
    }
  }
</style>
