---
import PageContextHeader from "./PageContextHeader.astro";
import { MANAGE_NAV, type ManageSection } from "../lib/manage-nav";
import { isManageSectionEnabled } from "../lib/modules";

interface Props {
  title: string;
  contextTitle?: string;
  contextSubtitle?: string;
  contextEyebrow?: string;
  contextDensity?: "compact" | "standard";
  activeSection?: ManageSection;
  rootClass?: string;
  managerView?: boolean;
  hideContextHeader?: boolean;
  contentWidth?: "operational" | "reading" | "default";
}

const {
  title,
  contextTitle,
  contextSubtitle = "",
  contextEyebrow = "",
  contextDensity = "standard",
  activeSection = "hub",
  rootClass = "",
  managerView = true,
  hideContextHeader = false,
  contentWidth = "default",
} = Astro.props;

const hasHeaderActions = Astro.slots.has("headerActions");
const resolvedContextTitle = contextTitle ?? title;
const showContextHeader = !hideContextHeader && Boolean(resolvedContextTitle);

const navItems = MANAGE_NAV.filter((item) => {
  // Hide sections whose module is set aside (see lib/modules.ts).
  if (!isManageSectionEnabled(item.id)) return false;
  if (item.id === "services" || item.id === "booking-policy" || item.id === "staff" || item.id === "business" || item.id === "activity" || item.id === "roles") {
    return managerView;
  }
  return true;
});
---

<div class:list={["team-manage-layout", rootClass]}>
  <div class="team-manage-layout__body">
    <aside class="team-manage-layout__sidebar" aria-label="Manage business">
      <h2 class="team-manage-layout__sidebar-title">Manage Business</h2>
      <nav class="team-manage-layout__nav" aria-label="Business settings">
        {
          navItems.map((item) =>
            item.disabled ? (
              <span
                class="team-manage-layout__nav-link team-manage-layout__nav-link--disabled"
                aria-disabled="true"
              >
                <span>{item.label}</span>
                <span class="ui-badge ui-badge--info team-manage-layout__soon-badge">Soon</span>
              </span>
            ) : (
              <a
                class:list={[
                  "team-manage-layout__nav-link",
                  { "is-active": activeSection === item.id },
                ]}
                href={item.href}
                aria-current={activeSection === item.id ? "page" : undefined}
              >
                {item.label}
              </a>
            ),
          )
        }
      </nav>
    </aside>

    <div
      class:list={[
        "team-manage-layout__main",
        contentWidth === "reading" && "team-main--content-reading",
      ]}
    >
      {
        showContextHeader ? (
          <PageContextHeader
            title={resolvedContextTitle}
            subtitle={contextSubtitle}
            eyebrow={contextEyebrow}
            density={contextDensity}
            headingLevel={1}
          >
            {
              hasHeaderActions ? (
                <Fragment slot="primaryAction">
                  <slot name="headerActions" />
                </Fragment>
              ) : null
            }
          </PageContextHeader>
        ) : null
      }
      <slot />
    </div>
  </div>
</div>

<style>
  .team-manage-layout {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - var(--team-bar-height, 3.25rem));
    font-family: var(--font-body);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .team-manage-layout__body {
    display: grid;
    grid-template-columns: minmax(200px, 220px) 1fr;
    flex: 1;
    min-height: 0;
  }

  .team-manage-layout__sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.75rem 0 1rem;
    border-right: 1px solid var(--color-stone-200);
    background: var(--team-sidebar-bg);
  }

  .team-manage-layout__sidebar-title {
    margin: 0 0 0.5rem;
    padding: 0 var(--team-sidebar-inset-x);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-400);
  }

  .team-manage-layout__nav {
    display: grid;
    gap: 0;
  }

  .team-manage-layout__nav-link {
    display: block;
    padding: 0.5rem var(--team-sidebar-inset-x);
    border-left: 3px solid transparent;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-stone-700);
    text-decoration: none;
    transition:
      color var(--transition-fast),
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .team-manage-layout__nav-link:hover,
  .team-manage-layout__nav-link:focus-visible {
    color: var(--color-citrine-dark);
    background: var(--color-citrine-muted);
    outline: none;
  }

  .team-manage-layout__nav-link.is-active {
    border-left-color: var(--team-sidebar-active-border);
    color: var(--color-stone-800);
    background: var(--team-sidebar-active-bg);
    font-weight: 600;
  }

  .team-manage-layout__nav-link--disabled {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.5rem var(--team-sidebar-inset-x);
    border-left: 3px solid transparent;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-stone-500);
    cursor: not-allowed;
    pointer-events: none;
  }

  .team-manage-layout__nav-link--disabled:hover {
    color: var(--color-stone-500);
    background: transparent;
  }

  :global(.team-manage-layout__soon-badge) {
    display: inline-flex;
    flex-shrink: 0;
    padding: 0.15rem 0.4rem;
    border: 1px solid var(--color-stone-300);
    border-radius: var(--radius-sm);
    background: var(--color-stone-100);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-stone-600);
    line-height: 1.2;
  }

  .team-manage-layout__main {
    padding: var(--shell-main-padding-top) var(--shell-main-padding-x) var(--shell-main-padding-bottom);
    background: var(--color-bg);
    min-width: 0;
  }

  :global(.team-manage-layout__hub-list) {
    display: grid;
    gap: 0;
    border: 1px solid var(--color-stone-200);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  :global(.team-manage-layout__hub-row) {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem var(--team-sidebar-inset-x);
    border-bottom: 1px solid var(--color-stone-200);
    background: var(--color-bg);
  }

  :global(.team-manage-layout__hub-row:last-child) {
    border-bottom: none;
  }

  :global(.team-manage-layout__hub-row--disabled) {
    background: var(--color-stone-50);
    pointer-events: none;
    cursor: not-allowed;
  }

  :global(.team-manage-layout__hub-row--disabled:hover) {
    background: var(--color-stone-50);
  }

  :global(.team-manage-layout__hub-row--disabled .team-manage-layout__hub-icon) {
    background: var(--color-stone-100);
    color: var(--color-stone-400);
  }

  :global(.team-manage-layout__hub-row--disabled .team-manage-layout__hub-title) {
    color: var(--color-stone-500);
  }

  :global(.team-manage-layout__hub-row--disabled .team-manage-layout__hub-desc) {
    color: var(--color-stone-400);
  }

  :global(.team-manage-layout__hub-icon) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: var(--radius-sm);
    background: var(--color-stone-100);
    color: var(--color-stone-500);
    flex-shrink: 0;
  }

  :global(.team-manage-layout__hub-icon svg) {
    display: block;
    width: var(--team-sidebar-icon-size, 1rem);
    height: var(--team-sidebar-icon-size, 1rem);
  }

  :global(.team-manage-layout__hub-copy) {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }

  :global(.team-manage-layout__hub-title) {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-stone-800);
  }

  :global(.team-manage-layout__hub-desc) {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-stone-500);
    line-height: var(--leading-normal);
  }

  @media (max-width: 900px) {
    .team-manage-layout__body {
      grid-template-columns: 1fr;
    }

    .team-manage-layout__sidebar {
      display: none;
    }

    .team-manage-layout__main {
      padding: var(--mobile-space-md);
      padding-bottom: calc(var(--mobile-space-xl) + env(safe-area-inset-bottom, 0px));
    }

    :global(.team-manage-layout__hub-row) {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
      gap: 0.5rem 0.75rem;
      padding: var(--mobile-space-md);
    }

    :global(.team-manage-layout__hub-row .ui-btn),
    :global(.team-manage-layout__hub-row .team-manage-layout__soon-badge) {
      grid-column: 1 / -1;
      justify-self: start;
    }
  }
</style>
