---
import { BUSINESS } from "@saloncitrine/shared";
import type { StaffProfile } from "../env.d.ts";
import StaffAvatar from "./StaffAvatar.astro";
import { staffInitials, staffPhotoSrc } from "../lib/staff-display";
import { normalizePhotoCrop, parsePhotoCrop } from "../lib/staff-photo";
import { withBase } from "../lib/paths";
import { teamUrl } from "../lib/supabase-server";

/** Boulevard-style top bar sections mapped to team routes */
export type TeamActiveNav =
  | "dashboard"
  | "book"
  | "tasks"
  | "stock"
  | "clients"
  | "docs"
  | "events"
  | "reports"
  | "manage"
  | "account";

interface Props {
  activeNav?: TeamActiveNav;
  staff?: StaffProfile | null;
  isAuthenticated?: boolean;
  pageTitle?: string;
}

const { activeNav, staff = null, isAuthenticated = false, pageTitle = "" } = Astro.props;

const marketingOrigin = `https://${BUSINESS.domain}`;
/** Light theme: white wordmark on dark team bar; compact PNG is invert-filter fallback */
const logoLightSrc = withBase("images/salon-citrine-primary-white.png");
const logoFallbackSrc = withBase("images/salon-citrine-logo-compact.png");
/** Dark theme: HorizRev horizontal logo on #1a1a1a team bar */
const logoDarkSrc = withBase("images/logo-horiz-rev-dark.png");
const profileMenuId = "team-profile-menu";

const navTabs: {
  id: TeamActiveNav;
  label: string;
  href: string;
  disabled?: boolean;
}[] = [
  { id: "dashboard", label: "Dashboard", href: teamUrl("/") },
  { id: "book", label: "Book", href: teamUrl("/book") },
  { id: "tasks", label: "Tasks", href: teamUrl("/tasks") },
  { id: "stock", label: "Stock", href: teamUrl("/inventory") },
  { id: "clients", label: "Clients", href: teamUrl("/clients") },
  { id: "docs", label: "Docs", href: teamUrl("/docs") },
  { id: "events", label: "Events", href: teamUrl("/events") },
  { id: "reports", label: "Reports", href: teamUrl("/reports") },
  { id: "manage", label: "Manage", href: teamUrl("/manage") },
];

const photoSrc = staff ? staffPhotoSrc(staff.photo_url, staff.slug) : null;
const photoCrop = staff ? normalizePhotoCrop(parsePhotoCrop(staff.photo_crop)) : null;
const initials = staff ? staffInitials(staff.name) : "";
---

<header class="team-bar">
  <div class="team-bar__inner">
    <div class="team-bar__brand">
      <a class="team-bar__logo" href={isAuthenticated ? teamUrl("/") : marketingOrigin} aria-label={BUSINESS.name}>
        <img
          class="team-bar__logo-img team-bar__logo-img--light"
          src={logoLightSrc}
          data-fallback-src={logoFallbackSrc}
          alt=""
          width="200"
          height="40"
          loading="eager"
        />
        <img
          class="team-bar__logo-img team-bar__logo-img--dark"
          src={logoDarkSrc}
          alt=""
          width="200"
          height="40"
          loading="eager"
          aria-hidden="true"
        />
        <span class="team-bar__logo-wordmark">{BUSINESS.name}</span>
      </a>
      {
        pageTitle ? (
          <span class="team-bar__page-title" data-page-title hidden>
            {pageTitle}
          </span>
        ) : null
      }
    </div>

    {
      isAuthenticated ? (
        <>
          <div class="team-bar__nav-wrap">
            <nav class="team-bar__nav" aria-label="Team">
              {navTabs.map((item) => (
                <a
                  class:list={[
                    "team-bar__tab",
                    { "team-bar__tab--active": activeNav === item.id },
                  ]}
                  href={item.href}
                  aria-current={activeNav === item.id ? "page" : undefined}
                >
                  {item.label}
                </a>
              ))}
            </nav>
          </div>

          <div class="team-bar__utilities">
            <button
              type="button"
              class="team-bar__icon-btn team-bar__icon-btn--muted"
              aria-label="Notifications"
              title="Notifications unavailable"
              disabled
            >
              <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
                <path
                  d="M18 8a6 6 0 10-12 0c0 7-3 7-3 7h18s-3 0-3-7M13.73 21a2 2 0 01-3.46 0"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>

            <div class="team-bar__profile team-bar__profile--desktop" data-profile-dropdown>
              <button
                class="team-bar__profile-btn"
                type="button"
                aria-expanded="false"
                aria-haspopup="menu"
                aria-controls={profileMenuId}
                data-profile-trigger
                aria-label={`Open account menu${staff?.name ? ` for ${staff.name}` : ""}`}
              >
                {
                  photoSrc ? (
                    <StaffAvatar
                      src={photoSrc}
                      crop={photoCrop}
                      size="header"
                      class="team-bar__avatar-wrap"
                    />
                  ) : (
                    <span class="team-bar__avatar team-bar__avatar--initials" aria-hidden="true">
                      {initials}
                    </span>
                  )}
                <svg class="team-bar__profile-chevron" viewBox="0 0 24 24" aria-hidden="true" fill="none">
                  <path
                    d="M6 9l6 6 6-6"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </button>
              <ul
                id={profileMenuId}
                class="team-bar__profile-menu"
                role="menu"
                aria-label="Account menu"
                data-profile-menu
                hidden
              >
                <li role="none">
                  <span class="team-bar__profile-label" role="presentation">{staff?.name}</span>
                </li>
                <li role="none">
                  <a class="team-bar__profile-item" href={teamUrl("/account")} role="menuitem">
                    Account settings
                  </a>
                </li>
                <li role="none">
                  <a class="team-bar__profile-item" href={teamUrl("/my-book")} role="menuitem">
                    My book
                  </a>
                </li>
                <li class="team-bar__profile-divider" role="separator" aria-hidden="true"></li>
                <li role="none">
                  <button
                    type="button"
                    class="team-bar__profile-item team-bar__profile-item--button"
                    role="menuitem"
                    data-theme-toggle
                  >
                    Change appearance
                  </button>
                </li>
                <li class="team-bar__profile-divider" role="separator" aria-hidden="true"></li>
                <li role="none">
                  <form method="post" action={teamUrl("/api/auth/logout")} role="none">
                    <button
                      class="team-bar__profile-item team-bar__profile-item--button team-bar__profile-item--logout"
                      type="submit"
                      role="menuitem"
                    >
                      Log out
                    </button>
                  </form>
                </li>
              </ul>
            </div>

            <button
              type="button"
              class="team-bar__mobile-menu-btn"
              data-mobile-menu-open
              aria-expanded="false"
              aria-controls="team-mobile-drawer"
              aria-label={`Open menu${staff?.name ? ` for ${staff.name}` : ""}`}
            >
              {
                photoSrc ? (
                  <StaffAvatar src={photoSrc} crop={photoCrop} size="header" class="team-bar__avatar-wrap" />
                ) : (
                  <span class="team-bar__avatar team-bar__avatar--initials" aria-hidden="true">
                    {initials}
                  </span>
                )}
            </button>
          </div>

          <div class="team-bar__drawer-backdrop" data-drawer-backdrop hidden></div>
          <aside
            id="team-mobile-drawer"
            class="team-bar__drawer"
            data-mobile-drawer
            inert
            aria-label="Account and navigation"
          >
            <header class="team-bar__drawer-head">
              <div class="team-bar__drawer-user">
                {
                  photoSrc ? (
                    <StaffAvatar src={photoSrc} crop={photoCrop} size="header" class="team-bar__avatar-wrap" />
                  ) : (
                    <span class="team-bar__avatar team-bar__avatar--initials" aria-hidden="true">
                      {initials}
                    </span>
                  )}
                <p class="team-bar__drawer-name">{staff?.name}</p>
              </div>
              <button type="button" class="team-bar__drawer-close ui-btn ui-btn--secondary ui-btn--compact" data-drawer-close aria-label="Close menu">
                Done
              </button>
            </header>

            <nav class="team-bar__drawer-section" aria-label="Navigation">
              <h2 class="team-bar__drawer-label">Navigation</h2>
              <ul class="team-bar__drawer-list">
                {
                  navTabs.map((item) => (
                    <li>
                      <a
                        class:list={[
                          "team-bar__drawer-link",
                          { "team-bar__drawer-link--active": activeNav === item.id },
                        ]}
                        href={item.href}
                        aria-current={activeNav === item.id ? "page" : undefined}
                      >
                        <span>{item.label}</span>
                        {activeNav === item.id ? (
                          <span class="team-bar__drawer-check" aria-hidden="true">✓</span>
                        ) : null}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </nav>

            <div class="team-bar__drawer-section">
              <h2 class="team-bar__drawer-label">Account</h2>
              <ul class="team-bar__drawer-list">
                <li>
                  <a class="team-bar__drawer-link" href={teamUrl("/account")}>Account settings</a>
                </li>
                <li>
                  <a class="team-bar__drawer-link" href={teamUrl("/my-book")}>My book</a>
                </li>
              </ul>
            </div>

            <div class="team-bar__drawer-section">
              <h2 class="team-bar__drawer-label">Appearance</h2>
              <button type="button" class="team-bar__drawer-link team-bar__drawer-link--button" data-theme-toggle>
                Change appearance
              </button>
            </div>

            <footer class="team-bar__drawer-footer">
              <form method="post" action={teamUrl("/api/auth/logout")}>
                <button type="submit" class="team-bar__drawer-logout">Log out</button>
              </form>
            </footer>
          </aside>
        </>
      ) : (
        <div class="team-bar__guest" aria-hidden="true"></div>
      )
    }
  </div>
</header>

<style>
  .team-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 120;
    height: var(--team-bar-height, 3.25rem);
    background: var(--team-bar-bg, #2f2a28);
    border-bottom: 1px solid var(--team-bar-border, rgba(255, 255, 255, 0.08));
    color: var(--team-bar-text, rgba(255, 255, 255, 0.92));
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.12);
  }

  .team-bar__inner {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    height: 100%;
    max-width: 100%;
    padding: 0 var(--space-3) 0 var(--space-4);
  }

  .team-bar__brand {
    flex: 0 1 auto;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
  }

  .team-bar__page-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--team-bar-text, rgba(255, 255, 255, 0.92));
  }

  .team-bar__page-title[hidden] {
    display: none;
  }

  @media (max-width: 1100px) {
    :global(.team-shell.is-page-scrolled) .team-bar__page-title:not([hidden]) {
      display: block;
    }
  }

  .team-bar__logo {
    display: flex;
    align-items: center;
    line-height: 0;
  }

  .team-bar__logo-img {
    display: block;
    height: calc(var(--team-bar-height, 3.25rem) - 0.75rem);
    max-height: calc(var(--team-bar-height, 3.25rem) - 0.75rem);
    width: auto;
    max-width: 12rem;
    object-fit: contain;
    object-position: left center;
    opacity: 0.96;
    transition: opacity var(--transition-fast);
  }

  .team-bar__logo-img--dark {
    display: none;
  }

  [data-theme="dark"] .team-bar__logo-img--light {
    display: none;
  }

  [data-theme="dark"] .team-bar__logo-img--dark {
    display: block;
  }

  .team-bar__logo:hover .team-bar__logo-img,
  .team-bar__logo:focus-visible .team-bar__logo-img {
    opacity: 1;
  }

  .team-bar__logo-img--fallback {
    height: calc(var(--team-bar-height, 3.25rem) - 1.15rem);
    max-height: calc(var(--team-bar-height, 3.25rem) - 1.15rem);
    max-width: 7rem;
    filter: brightness(0) invert(1);
  }

  .team-bar__logo-wordmark {
    display: none;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--team-bar-text, rgba(255, 255, 255, 0.92));
    white-space: nowrap;
  }

  .team-bar__logo.is-wordmark .team-bar__logo-img--light,
  .team-bar__logo.is-wordmark .team-bar__logo-img--dark {
    display: none;
  }

  .team-bar__logo.is-wordmark .team-bar__logo-wordmark {
    display: block;
  }

  .team-bar__nav-wrap {
    position: relative;
    flex: 1 1 auto;
    min-width: 0;
  }

  .team-bar__nav-wrap::before,
  .team-bar__nav-wrap::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: var(--ui-scroll-fade-width, 1.25rem);
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .team-bar__nav-wrap::before {
    left: 0;
    background: linear-gradient(to right, var(--team-bar-bg, #2f2a28), transparent);
  }

  .team-bar__nav-wrap::after {
    right: 0;
    background: linear-gradient(to left, var(--team-bar-bg, #2f2a28), transparent);
  }

  .team-bar__nav-wrap.is-scrollable-start::before,
  .team-bar__nav-wrap.is-scrollable-end::after {
    opacity: 1;
  }

  .team-bar__nav {
    display: flex;
    align-items: stretch;
    gap: 0.1rem;
    flex: 1 1 auto;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: 0 0.15rem;
  }

  .team-bar__nav::-webkit-scrollbar {
    display: none;
  }

  .team-bar__tab {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    position: relative;
    padding: 0.5rem 0.7rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--team-bar-tab, rgba(255, 255, 255, 0.62));
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .team-bar__tab:hover,
  .team-bar__tab:focus-visible {
    color: var(--team-bar-tab-hover, rgba(255, 255, 255, 0.95));
    background: var(--team-bar-tab-hover-bg, rgba(255, 255, 255, 0.06));
    outline: none;
  }

  .team-bar__tab--active {
    color: var(--color-citrine);
    background: var(--team-bar-tab-active-bg, rgba(231, 172, 70, 0.1));
    box-shadow: inset 0 -2px 0 var(--color-citrine);
  }

  .team-bar__utilities {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 0 0 auto;
    margin-left: auto;
  }

  .team-bar__icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--touch-target-min, 2.75rem);
    height: var(--touch-target-min, 2.75rem);
    padding: 0;
    border: none;
    border-radius: 0.35rem;
    background: transparent;
    color: var(--team-bar-utility, rgba(255, 255, 255, 0.8));
    cursor: pointer;
    text-decoration: none;
  }

  .team-bar__icon-btn:disabled,
  .team-bar__icon-btn--muted {
    opacity: 0.28;
    cursor: default;
    pointer-events: none;
  }

  .team-bar__icon-btn:not(:disabled):hover,
  .team-bar__icon-btn:focus-visible {
    background: var(--team-bar-utility-hover-bg, rgba(255, 255, 255, 0.1));
    color: var(--team-bar-text, #fff);
    outline: none;
  }

  .team-bar__icon-btn svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .team-bar__profile {
    position: relative;
  }

  .team-bar__profile-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.12rem 0.2rem 0.12rem 0.12rem;
    border: 1px solid transparent;
    background: none;
    cursor: pointer;
    border-radius: 999px;
    color: var(--team-bar-profile, rgba(255, 255, 255, 0.88));
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .team-bar__profile-btn:hover,
  .team-bar__profile-btn:focus-visible {
    background: var(--team-bar-profile-hover-bg, rgba(255, 255, 255, 0.1));
    border-color: var(--team-bar-profile-hover-border, rgba(255, 255, 255, 0.18));
    outline: none;
  }

  .team-bar__profile-chevron {
    width: 0.85rem;
    height: 0.85rem;
    flex-shrink: 0;
    opacity: 0.72;
    transition: transform var(--transition-fast);
  }

  .team-bar__profile.is-open .team-bar__profile-chevron {
    transform: rotate(180deg);
  }

  .team-bar__avatar,
  .team-bar__avatar-wrap {
    width: 1.85rem;
    height: 1.85rem;
    border: 2px solid rgba(231, 172, 70, 0.45);
    border-radius: 50%;
    box-shadow: 0 0 0 2px rgba(47, 42, 40, 0.25);
  }

  .team-bar__avatar--initials {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-dusty-rose);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
  }

  .team-bar__profile-menu {
    position: absolute;
    top: calc(100% + 0.35rem);
    right: 0;
    z-index: 130;
    min-width: 11.5rem;
    margin: 0;
    padding: 0.35rem 0;
    list-style: none;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-bg);
    color: var(--color-text);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.18);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      visibility 0.15s;
  }

  .team-bar__profile-menu[hidden] {
    display: block;
  }

  .team-bar__profile.is-open .team-bar__profile-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .team-bar__profile.is-open .team-bar__profile-menu[hidden] {
    display: block;
  }

  .team-bar__profile-label {
    display: block;
    padding: 0.45rem 0.85rem 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .team-bar__profile-item {
    display: block;
    width: 100%;
    padding: 0.55rem 0.85rem;
    border: none;
    background: none;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    text-align: left;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .team-bar__profile-item:hover,
  .team-bar__profile-item:focus-visible {
    background: var(--color-light);
    outline: none;
  }

  .team-bar__profile-divider {
    height: 1px;
    margin: 0.25rem 0;
    background: var(--color-border);
  }

  .team-bar__profile-item--logout {
    color: var(--color-stone-600);
  }

  .team-bar__profile-item--logout:hover,
  .team-bar__profile-item--logout:focus-visible {
    color: var(--color-error);
    background: rgba(180, 35, 24, 0.06);
  }

  .team-bar__mobile-menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    min-width: var(--touch-target-min, 2.75rem);
    min-height: var(--touch-target-min, 2.75rem);
    padding: 0.12rem;
    border: 1px solid var(--team-bar-mobile-btn-border, rgba(255, 255, 255, 0.18));
    border-radius: 999px;
    background: var(--team-bar-mobile-btn-bg, rgba(255, 255, 255, 0.06));
    cursor: pointer;
  }

  .team-bar__mobile-menu-btn:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(231, 172, 70, 0.45);
  }

  .team-bar__drawer-backdrop {
    display: none;
  }

  .team-bar__drawer {
    display: none;
  }

  .team-bar__drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--mobile-space-sm, 0.75rem);
    padding: var(--mobile-space-md, 1rem);
    border-bottom: 1px solid var(--color-stone-200);
  }

  .team-bar__drawer-user {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
  }

  .team-bar__drawer-name {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-stone-800);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .team-bar__drawer-section {
    padding: 0.65rem var(--mobile-space-md, 1rem);
    border-bottom: 1px solid var(--color-stone-200);
  }

  .team-bar__drawer-label {
    margin: 0 0 0.35rem;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-stone-500);
  }

  .team-bar__drawer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.15rem;
  }

  .team-bar__drawer-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    min-height: var(--touch-target-min, 2.75rem);
    padding: 0.45rem 0.55rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-stone-800);
    text-decoration: none;
    background: transparent;
    border: none;
    width: 100%;
    text-align: left;
    cursor: pointer;
  }

  .team-bar__drawer-link:hover,
  .team-bar__drawer-link:focus-visible {
    background: var(--color-stone-100);
    outline: none;
  }

