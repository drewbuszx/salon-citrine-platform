---
import { teamUrl } from "../lib/supabase-server";

interface Props {
  activeNav: "calendar" | "block-time" | "services" | "my-services";
  staffName: string;
  staffRole: string;
}

const { activeNav, staffName, staffRole } = Astro.props;

const navItems = [
  { id: "calendar" as const, label: "Calendar", href: teamUrl("/") },
  { id: "block-time" as const, label: "Block time", href: teamUrl("/block-time") },
];

if (staffRole === "owner" || staffRole === "front_desk") {
  navItems.push({
    id: "services" as const,
    label: "Services",
    href: teamUrl("/services"),
  });
} else if (staffRole === "stylist" || staffRole === "esthetician") {
  navItems.push({
    id: "my-services" as const,
    label: "My services",
    href: teamUrl("/my-services"),
  });
}
---

<nav class="team-subnav" aria-label="Team">
  <div class="team-subnav__inner">
    <div class="team-subnav__links">
      {
        navItems.map((item) => (
          <a
            class:list={[
              "team-subnav__link",
              { "team-subnav__link--active": activeNav === item.id },
            ]}
            href={item.href}
            aria-current={activeNav === item.id ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <div class="team-subnav__actions">
      <span class="team-subnav__user">{staffName}</span>
      <form method="post" action={teamUrl("/api/auth/logout")}>
        <button class="team-subnav__logout" type="submit">Sign out</button>
      </form>
    </div>
  </div>
</nav>
