---
interface Props {
  title: string;
  mainTitle?: string;
  sidebarTitle?: string;
  showSidebar?: boolean;
  rootClass?: string;
  rootId?: string;
}

const {
  title,
  mainTitle,
  sidebarTitle = "",
  showSidebar = true,
  rootClass = "",
  rootId,
} = Astro.props;

const hasHeaderActions = Astro.slots.has("headerActions");
const hasSidebarFilters = Astro.slots.has("sidebarFilters");
const hasSidebarExtra = Astro.slots.has("sidebarExtra");
const hasSidebarFooter = Astro.slots.has("sidebarFooter");
const hasStats = Astro.slots.has("stats");
const hasSearchBar = Astro.slots.has("searchBar");
const hasMainLead = Astro.slots.has("mainLead");
const hasToolbar = Astro.slots.has("toolbar");
---

<div class:list={["team-list-layout", rootClass]} id={rootId}>
  <header class="team-list-layout__subheader">
    <h1 class="team-list-layout__title">{title}</h1>
    {
      hasHeaderActions ? (
        <div class="team-list-layout__header-actions">
          <slot name="headerActions" />
        </div>
      ) : null
    }
  </header>

  <div class="team-list-layout__body">
    {
      showSidebar ? (
        <aside class="team-list-layout__sidebar" aria-label="Page options">
          {sidebarTitle ? <h2 class="team-list-layout__sidebar-title">{sidebarTitle}</h2> : null}
          {
            hasSidebarFilters ? (
              <div class="team-list-layout__filters">
                <slot name="sidebarFilters" />
              </div>
            ) : null
          }
          {hasSidebarExtra ? <slot name="sidebarExtra" /> : null}
          {hasSidebarFooter ? <slot name="sidebarFooter" /> : null}
        </aside>
      ) : null
    }

    <main class="team-list-layout__main">
      {mainTitle ? <h2 class="team-list-layout__main-title">{mainTitle}</h2> : null}
      {hasMainLead ? <p class="team-list-layout__main-lead"><slot name="mainLead" /></p> : null}
      {hasStats ? <p class="team-list-layout__stats"><slot name="stats" /></p> : null}
      {hasToolbar ? <div class="team-list-layout__toolbar"><slot name="toolbar" /></div> : null}
      {hasSearchBar ? <slot name="searchBar" /> : null}
      <slot />
    </main>
  </div>
</div>

<style>
  .team-list-layout {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - var(--team-bar-height, 3.25rem));
    font-family: var(--font-sans);
    background: #fff;
    color: #111827;
  }

  .team-list-layout__subheader {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid #e5e7eb;
    background: #fff;
  }

  .team-list-layout__title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .team-list-layout__header-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .team-list-layout__body {
    display: grid;
    grid-template-columns: minmax(200px, 220px) 1fr;
    flex: 1;
    min-height: 0;
  }

  .team-list-layout:not(:has(.team-list-layout__sidebar)) .team-list-layout__body {
    grid-template-columns: 1fr;
  }

  .team-list-layout__sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 0;
    border-right: 1px solid #e5e7eb;
    background: #fafafa;
  }

  .team-list-layout__main {
    padding: 1.25rem 1.5rem 2rem;
    background: #fff;
    min-width: 0;
  }

  .team-list-layout__main-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: #111827;
  }

  .team-list-layout__main-lead {
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.45;
    color: #6b7280;
  }

  .team-list-layout__stats {
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: #6b7280;
  }

  .team-list-layout__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    width: 100%;
  }

  :global(.team-list-layout__data-table) {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }

  :global(.team-list-layout__data-table th) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e5e7eb;
    font-size: 0.75rem;
    font-weight: 600;
    text-align: left;
    color: #6b7280;
    background: #fff;
  }

  :global(.team-list-layout__data-table td) {
    padding: 0.95rem 1rem;
    border-bottom: 1px solid #e5e7eb;
    color: #374151;
    vertical-align: middle;
  }

  :global(.team-list-layout__data-table tbody tr:nth-child(even) td) {
    background: #f9fafb;
  }

  :global(.team-list-layout__data-table tbody tr:hover td) {
    background: #f3f4f6;
  }

  :global(.team-list-layout__data-table__link) {
    color: #0096ff;
    text-decoration: none;
  }

  :global(.team-list-layout__data-table__link:hover),
  :global(.team-list-layout__data-table__link:focus-visible) {
    text-decoration: underline;
    outline: none;
  }

  :global(.team-list-layout__table-wrap) {
    overflow-x: auto;
  }

  :global(.team-list-layout__btn-primary),
  :global(.team-list-layout__btn-secondary) {
    padding: 0.55rem 0.9rem;
    border-radius: 0.25rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  :global(.team-list-layout__btn-primary) {
    border: none;
    background: #0096ff;
    color: #fff;
  }

  :global(.team-list-layout__btn-primary:hover),
  :global(.team-list-layout__btn-primary:focus-visible) {
    background: #0084e0;
    outline: none;
  }

  :global(.team-list-layout__btn-accent) {
    padding: 0.55rem 0.9rem;
    border: none;
    border-radius: 0.25rem;
    background: #7c3aed;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    cursor: pointer;
    transition: background 0.15s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  :global(.team-list-layout__btn-accent:hover),
  :global(.team-list-layout__btn-accent:focus-visible) {
    background: #6d28d9;
    outline: none;
  }

  :global(.team-list-layout__btn-secondary) {
    border: 1px solid #e5e7eb;
    background: #fff;
    color: #374151;
  }

  :global(.team-list-layout__btn-secondary:hover),
  :global(.team-list-layout__btn-secondary:focus-visible) {
    background: #f9fafb;
    outline: none;
  }

  @media (max-width: 900px) {
    .team-list-layout__body {
      grid-template-columns: 1fr;
    }

    .team-list-layout__sidebar {
      border-right: none;
      border-bottom: 1px solid #e5e7eb;
      max-height: 16rem;
      padding-bottom: 0.75rem;
    }
  }

  @media (max-width: 640px) {
    .team-list-layout__subheader {
      padding-inline: 1rem;
    }

    .team-list-layout__main {
      padding-inline: 1rem;
    }
  }
</style>
