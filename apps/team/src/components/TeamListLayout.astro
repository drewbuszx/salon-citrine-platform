---
interface Props {
  title: string;
  mainTitle?: string;
  sidebarTitle?: string;
  showSidebar?: boolean;
  rootClass?: string;
  rootId?: string;
}

const {
  title,
  mainTitle,
  sidebarTitle = "",
  showSidebar = true,
  rootClass = "",
  rootId,
} = Astro.props;

const hasHeaderActions = Astro.slots.has("headerActions");
const hasSidebarFilters = Astro.slots.has("sidebarFilters");
const hasSidebarExtra = Astro.slots.has("sidebarExtra");
const hasSidebarFooter = Astro.slots.has("sidebarFooter");
const hasStats = Astro.slots.has("stats");
const hasSearchBar = Astro.slots.has("searchBar");
const hasMainLead = Astro.slots.has("mainLead");
const hasToolbar = Astro.slots.has("toolbar");
---

<div class:list={["team-list-layout", rootClass]} id={rootId}>
  <header class="team-list-layout__subheader">
    <h1 class="team-list-layout__title">{title}</h1>
    {
      hasHeaderActions ? (
        <div class="team-list-layout__header-actions">
          <slot name="headerActions" />
        </div>
      ) : null
    }
  </header>

  <div class="team-list-layout__body">
    {
      showSidebar ? (
        <aside class="team-list-layout__sidebar" aria-label="Page options">
          {sidebarTitle ? <h2 class="team-list-layout__sidebar-title">{sidebarTitle}</h2> : null}
          {
            hasSidebarFilters ? (
              <div class="team-list-layout__filters">
                <slot name="sidebarFilters" />
              </div>
            ) : null
          }
          {hasSidebarExtra ? <slot name="sidebarExtra" /> : null}
          {hasSidebarFooter ? <slot name="sidebarFooter" /> : null}
        </aside>
      ) : null
    }

    <main class="team-list-layout__main">
      {mainTitle ? <h2 class="team-list-layout__main-title">{mainTitle}</h2> : null}
      {hasMainLead ? <p class="team-list-layout__main-lead"><slot name="mainLead" /></p> : null}
      {hasStats ? <p class="team-list-layout__stats"><slot name="stats" /></p> : null}
      {hasToolbar ? <div class="team-list-layout__toolbar"><slot name="toolbar" /></div> : null}
      {hasSearchBar ? <slot name="searchBar" /> : null}
      <slot />
    </main>
  </div>
</div>

<style>
  .team-list-layout {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - var(--team-bar-height, 3.25rem));
    font-family: var(--font-body);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .team-list-layout__subheader {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3) var(--space-4);
    min-height: 3.25rem;
    padding: var(--space-3) var(--space-5);
    border-bottom: 1px solid var(--color-stone-200);
    background: var(--color-bg);
  }

  .team-list-layout__title {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
  }

  .team-list-layout__header-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .team-list-layout__body {
    display: grid;
    grid-template-columns: minmax(200px, 220px) 1fr;
    flex: 1;
    min-height: 0;
  }

  .team-list-layout:not(:has(.team-list-layout__sidebar)) .team-list-layout__body {
    grid-template-columns: 1fr;
  }

  .team-list-layout__sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 0;
    border-right: 1px solid var(--color-stone-200);
    background: var(--team-sidebar-bg);
  }

  .team-list-layout__main {
    padding: var(--space-5) var(--space-6) var(--space-8);
    background: var(--color-bg);
    min-width: 0;
  }

  .team-list-layout__main-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
  }

  .team-list-layout__main-lead {
    margin: 0 0 1rem;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-stone-500);
  }

  .team-list-layout__stats {
    margin: 0 0 1rem;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-stone-500);
  }

  .team-list-layout__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: 1rem;
    width: 100%;
  }

  @media (max-width: 900px) {
    .team-list-layout__body {
      grid-template-columns: 1fr;
    }

    .team-list-layout__sidebar {
      border-right: none;
      border-bottom: 1px solid var(--color-stone-200);
      max-height: 16rem;
      padding-bottom: 0.75rem;
    }
  }

  @media (max-width: 640px) {
    .team-list-layout__subheader {
      padding-inline: var(--space-4);
    }

    .team-list-layout__main {
      padding-inline: var(--space-4);
    }
  }
</style>
