---
interface Props {
  title: string;
  mainTitle?: string;
  sidebarTitle?: string;
  showSidebar?: boolean;
  rootClass?: string;
  rootId?: string;
  filterKey?: string;
}

const {
  title,
  mainTitle,
  sidebarTitle = "",
  showSidebar = true,
  rootClass = "",
  rootId,
  filterKey,
} = Astro.props;

const hasHeaderActions = Astro.slots.has("headerActions");
const hasSidebarFilters = Astro.slots.has("sidebarFilters");
const hasSidebarExtra = Astro.slots.has("sidebarExtra");
const hasSidebarFooter = Astro.slots.has("sidebarFooter");
const hasStats = Astro.slots.has("stats");
const hasSearchBar = Astro.slots.has("searchBar");
const hasMainLead = Astro.slots.has("mainLead");
const hasToolbar = Astro.slots.has("toolbar");

const resolvedFilterKey = filterKey ?? rootId ?? title.toLowerCase().replace(/\s+/g, "-");
const mobileFilters = showSidebar && (hasSidebarFilters || hasSidebarExtra || hasSidebarFooter);
---

<div
  class:list={["team-list-layout", rootClass]}
  id={rootId}
  data-list-filters={mobileFilters ? "" : undefined}
  data-filter-key={mobileFilters ? resolvedFilterKey : undefined}
>
  <header class="team-list-layout__subheader">
    <h1 class="team-list-layout__title">{title}</h1>
    {
      hasHeaderActions ? (
        <div class="team-list-layout__header-actions">
          <slot name="headerActions" />
        </div>
      ) : null
    }
  </header>

  {
    mobileFilters ? (
      <div class="team-list-layout__filter-backdrop" data-filter-backdrop hidden />
    ) : null
  }

  <div class="team-list-layout__body">
    <main class="team-list-layout__main">
      {
        mobileFilters ? (
          <div class="team-list-layout__mobile-filter-bar">
            <div class="team-list-layout__filter-chips ui-filter-chips" data-filter-chips />
            <button
              type="button"
              class="ui-filter-trigger team-list-layout__filter-open"
              data-filter-open
              aria-expanded="false"
              aria-controls="team-filter-panel"
            >
              Filters
              <span class="ui-filter-trigger__count" data-filter-badge hidden>
                0
              </span>
            </button>
          </div>
        ) : null
      }

      {mainTitle ? <h2 class="team-list-layout__main-title">{mainTitle}</h2> : null}
      {hasMainLead ? <p class="team-list-layout__main-lead"><slot name="mainLead" /></p> : null}
      {hasStats ? <p class="team-list-layout__stats"><slot name="stats" /></p> : null}
      {hasToolbar ? <div class="team-list-layout__toolbar"><slot name="toolbar" /></div> : null}
      {hasSearchBar ? <slot name="searchBar" /> : null}
      <slot />
    </main>

    {
      showSidebar ? (
        <aside
          id="team-filter-panel"
          class="team-list-layout__sidebar"
          data-filter-panel
          aria-label="Filters and options"
        >
          {
            mobileFilters ? (
              <div class="team-list-layout__sheet-head">
                <h2 class="team-list-layout__sheet-title">
                  {sidebarTitle || "Filters"}
                </h2>
                <button
                  type="button"
                  class="team-list-layout__sheet-done ui-btn ui-btn--secondary ui-btn--compact"
                  data-filter-close
                >
                  Done
                </button>
              </div>
            ) : null
          }
          {sidebarTitle && !mobileFilters ? (
            <h2 class="team-list-layout__sidebar-title">{sidebarTitle}</h2>
          ) : null}
          {
            hasSidebarFilters ? (
              <div class="team-list-layout__filters">
                <slot name="sidebarFilters" />
              </div>
            ) : null
          }
          {hasSidebarExtra ? <slot name="sidebarExtra" /> : null}
          {hasSidebarFooter ? <slot name="sidebarFooter" /> : null}
        </aside>
      ) : null
    }
  </div>
</div>

<script>
  import "../scripts/list-filters.ts";
</script>

<style>
  /* Mobile filter sheet — layout shell lives in team-list-sidebar.css (global). */

  .team-list-layout__mobile-filter-bar {
    display: none;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--mobile-space-sm, 0.75rem);
    margin-bottom: var(--mobile-space-md, 1rem);
    min-width: 0;
  }

  .team-list-layout__filter-chips {
    flex: 1 1 auto;
    min-width: 0;
  }

  .team-list-layout__filter-open {
    flex: 0 0 auto;
  }

  .team-list-layout__sheet-head {
    display: none;
    align-items: center;
    justify-content: space-between;
    gap: var(--mobile-space-sm, 0.75rem);
    padding: 0 var(--team-sidebar-inset-x) 0.65rem;
    border-bottom: 1px solid var(--color-stone-200);
    margin-bottom: 0.35rem;
  }

  .team-list-layout__sheet-title {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
  }

  .team-list-layout__filter-backdrop {
    display: none;
  }

  @media (max-width: 900px) {
    .team-list-layout[data-list-filters] .team-list-layout__mobile-filter-bar {
      display: flex;
    }

    .team-list-layout[data-list-filters] .team-list-layout__sheet-head {
      display: flex;
    }

    .team-list-layout[data-list-filters] .team-list-layout__sidebar-title {
      display: none;
    }

    .team-list-layout[data-list-filters] .team-list-layout__sidebar {
      position: fixed;
      inset: auto 0 0 0;
      z-index: 200;
      max-height: min(85vh, 32rem);
      padding-top: 0.75rem;
      padding-bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));
      border-right: none;
      border-top: 1px solid var(--color-stone-200);
      border-radius: var(--radius-xl) var(--radius-xl) 0 0;
      box-shadow: var(--shadow-lg);
      transform: translateY(110%);
      visibility: hidden;
      transition:
        transform var(--transition-base),
        visibility var(--transition-base);
      overflow: hidden;
    }

    .team-list-layout[data-list-filters] .team-list-layout__sidebar.is-sheet-open {
      transform: translateY(0);
      visibility: visible;
    }

    .team-list-layout[data-list-filters] .team-list-layout__filters,
    .team-list-layout[data-list-filters] .team-list-layout__sidebar-nav,
    .team-list-layout[data-list-filters] .events-sidebar-nav,
    .team-list-layout[data-list-filters] .reports-sidebar {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      overscroll-behavior: contain;
      -webkit-overflow-scrolling: touch;
    }

    .team-list-layout__filter-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 199;
      background: rgba(10, 10, 10, 0.45);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition:
        opacity var(--transition-base),
        visibility var(--transition-base);
    }

    .team-list-layout.is-filter-open .team-list-layout__filter-backdrop {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
  }

  @media (min-width: 901px) {
    .team-list-layout__mobile-filter-bar,
    .team-list-layout__filter-backdrop,
    .team-list-layout__sheet-head {
      display: none !important;
    }
  }
</style>
