---
/**
 * Team alerts panel — dropdown feed for the header notification bell.
 *
 * Minimal client-populated shell: the markup here is the container, states
 * (loading / empty / error) and the list region. `team-header.ts` fetches
 * `/api/alerts`, renders items into `[data-alerts-list]`, and toggles states.
 *
 * NOTE (Agent 3): created inline by Agent 4 to unblock header wiring. Reconcile
 * item template / dismiss behaviour with the richer panel when ready.
 */
interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div class="team-alerts" data-alerts-panel role="region" aria-label="Notifications">
  <div id={id} class="team-alerts__panel" data-alerts-menu hidden>
    <header class="team-alerts__head">
      <h2 class="team-alerts__title">Notifications</h2>
    </header>

    <div class="team-alerts__body">
      <p class="team-alerts__state" data-alerts-loading>Loading…</p>
      <p class="team-alerts__state" data-alerts-empty hidden>You're all caught up.</p>
      <p class="team-alerts__state team-alerts__state--error" data-alerts-error hidden>
        Couldn't load notifications.
      </p>
      <ul class="team-alerts__list" data-alerts-list role="list" hidden></ul>
    </div>
  </div>
</div>

<template data-alerts-item-template>
  <li class="team-alerts__item" role="listitem">
    <a class="team-alerts__link" data-alerts-item-link href="#">
      <span class="team-alerts__dot" data-alerts-item-dot aria-hidden="true"></span>
      <span class="team-alerts__text">
        <span class="team-alerts__item-title" data-alerts-item-title></span>
        <span class="team-alerts__item-message" data-alerts-item-message></span>
      </span>
    </a>
  </li>
</template>

<style>
  .team-alerts {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .team-alerts__panel {
    position: absolute;
    top: calc(100% + 0.4rem);
    right: 0;
    z-index: 130;
    width: min(20rem, calc(100vw - 1.5rem));
    max-height: min(28rem, calc(100vh - var(--team-bar-height, 3.25rem) - 1.5rem));
    display: flex;
    flex-direction: column;
    overflow: hidden;
    margin: 0;
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background: var(--color-bg);
    color: var(--color-text);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.2);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    pointer-events: auto;
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      visibility 0.15s;
  }

  .team-alerts__panel[hidden] {
    display: flex;
  }

  :global(.team-bar__alerts.is-open) .team-alerts__panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .team-alerts__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--color-border);
  }

  .team-alerts__title {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
  }

  .team-alerts__body {
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .team-alerts__state {
    margin: 0;
    padding: 1.1rem 0.95rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-gray);
    text-align: center;
  }

  .team-alerts__state--error {
    color: var(--color-error);
  }

  .team-alerts__list {
    margin: 0;
    padding: 0.3rem;
    list-style: none;
    display: grid;
    gap: 0.15rem;
  }

  .team-alerts__link {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.6rem 0.65rem;
    border-radius: 0.45rem;
    text-decoration: none;
    color: inherit;
  }

  .team-alerts__link:hover,
  .team-alerts__link:focus-visible {
    background: var(--color-light);
    outline: none;
  }

  .team-alerts__dot {
    flex-shrink: 0;
    width: 0.55rem;
    height: 0.55rem;
    margin-top: 0.3rem;
    border-radius: 50%;
    background: var(--color-gray);
  }

  .team-alerts__dot[data-severity="warning"] {
    background: var(--color-citrine, #e7ac46);
  }

  .team-alerts__dot[data-severity="urgent"] {
    background: var(--color-error, #b42318);
  }

  .team-alerts__text {
    display: grid;
    gap: 0.1rem;
    min-width: 0;
  }

  .team-alerts__item-title {
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .team-alerts__item-message {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-gray);
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
