---
import { teamUrl } from "../lib/supabase-server";

interface Props {
  panelId?: string;
}

const { panelId = "team-alerts-panel" } = Astro.props;
const alertsApiUrl = teamUrl("/api/alerts");
const teamBase = teamUrl("");
---

<div
  class="team-alerts"
  data-team-alerts
  data-alerts-api={alertsApiUrl}
  data-team-base={teamBase}
  data-unread-count="0"
>
  <div
    id={panelId}
    class="team-alerts__panel"
    role="menu"
    aria-label="Alerts"
    data-alerts-panel
    hidden
  >
    <header class="team-alerts__header">
      <h2 class="team-alerts__title">Alerts</h2>
      <button
        type="button"
        class="team-alerts__mark-all"
        data-alerts-mark-all
        hidden
      >
        Mark all read
      </button>
    </header>

    <div class="team-alerts__body">
      <div class="team-alerts__loading" data-alerts-loading hidden>
        <ul class="team-alerts__list" role="list" aria-busy="true">
          <li class="team-alerts__skeleton" aria-hidden="true">
            <span class="team-alerts__skeleton-icon"></span>
            <span class="team-alerts__skeleton-copy">
              <span class="team-alerts__skeleton-line team-alerts__skeleton-line--wide"></span>
              <span class="team-alerts__skeleton-line team-alerts__skeleton-line--medium"></span>
            </span>
          </li>
        </ul>
      </div>

      <div class="team-alerts__error" data-alerts-error hidden role="alert">
        <p class="team-alerts__error-title">Couldn&apos;t load alerts</p>
        <p class="team-alerts__error-hint" data-alerts-error-hint>
          Check your connection and try again.
        </p>
        <button type="button" class="team-alerts__retry ui-btn ui-btn--secondary ui-btn--compact" data-alerts-retry>
          Try again
        </button>
      </div>

      <ul class="team-alerts__list" role="list" data-alerts-list hidden></ul>

      <div class="team-alerts__empty" data-alerts-empty hidden>
        <p class="team-alerts__empty-title">You&apos;re all caught up</p>
        <p class="team-alerts__empty-copy">No waitlist, stock, or task alerts right now.</p>
      </div>
    </div>
  </div>
</div>

<script>
  import { initTeamAlerts } from "../scripts/team-alerts";

  initTeamAlerts();
</script>

<style>
  .team-alerts {
    position: relative;
  }

  .team-alerts__panel {
    position: absolute;
    top: calc(100% + 0.35rem);
    right: 0;
    z-index: 130;
    display: flex;
    flex-direction: column;
    width: min(22rem, calc(100vw - 2rem));
    max-height: min(24rem, calc(100vh - var(--team-bar-height, 3.25rem) - 2rem));
    margin: 0;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-bg);
    color: var(--color-text);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.18);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      visibility 0.15s;
    overflow: hidden;
  }

  .team-alerts__panel[hidden] {
    display: flex;
  }

  :global([data-alerts-dropdown].is-open) .team-alerts__panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  :global([data-alerts-dropdown].is-open) .team-alerts__panel[hidden] {
    display: flex;
  }

  .team-alerts__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding: 0.55rem 0.75rem 0.45rem;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .team-alerts__title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .team-alerts__mark-all {
    padding: 0.2rem 0.35rem;
    border: none;
    border-radius: var(--radius-sm);
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-link);
    cursor: pointer;
  }

  .team-alerts__mark-all:hover,
  .team-alerts__mark-all:focus-visible {
    background: var(--color-light);
    outline: none;
  }

  .team-alerts__body {
    flex: 1 1 auto;
    min-height: 0;
    overflow: auto;
    -webkit-overflow-scrolling: touch;
  }

  .team-alerts__list {
    list-style: none;
    margin: 0;
    padding: 0.25rem 0;
  }

  .team-alerts__item {
    margin: 0;
  }

  .team-alerts__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: start;
    gap: 0.55rem;
    padding: 0.55rem 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: background var(--transition-fast);
  }

  .team-alerts__row:hover,
  .team-alerts__row:focus-visible {
    background: var(--color-light);
    outline: none;
  }

  .team-alerts__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.65rem;
    height: 1.65rem;
    margin-top: 0.05rem;
    border-radius: 999px;
    flex-shrink: 0;
  }

  .team-alerts__icon svg {
    width: 0.95rem;
    height: 0.95rem;
  }

  .team-alerts__row--info .team-alerts__icon {
    background: var(--color-sage-muted);
    color: var(--color-sage-dark);
  }

  .team-alerts__row--warning .team-alerts__icon {
    background: var(--color-citrine-muted);
    color: var(--color-citrine-dark);
  }

  .team-alerts__row--urgent .team-alerts__icon {
    background: var(--color-error-muted);
    color: var(--color-error);
  }

  .team-alerts__copy {
    display: grid;
    gap: 0.12rem;
    min-width: 0;
  }

  .team-alerts__row-title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .team-alerts__row-body {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    line-height: 1.35;
    color: var(--color-stone-600);
  }

  .team-alerts__row-time {
    font-family: var(--font-body);
    font-size: 0.62rem;
    color: var(--color-stone-500);
  }

  .team-alerts__chevron {
    display: inline-flex;
    align-items: center;
    margin-top: 0.2rem;
    color: var(--color-stone-400);
    opacity: 0.65;
    transition: opacity var(--transition-fast);
  }

  .team-alerts__chevron svg {
    width: 0.85rem;
    height: 0.85rem;
  }

  .team-alerts__row:hover .team-alerts__chevron,
  .team-alerts__row:focus-visible .team-alerts__chevron {
    opacity: 1;
  }

  .team-alerts__empty,
  .team-alerts__error,
  .team-alerts__loading {
    padding: 1rem 0.85rem 1.1rem;
  }

  .team-alerts__empty-title {
    margin: 0 0 0.25rem;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-stone-800);
  }

  .team-alerts__empty-copy {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    line-height: var(--leading-relaxed);
    color: var(--color-stone-500);
  }

  .team-alerts__error-title {
    margin: 0 0 0.2rem;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-error);
  }

  .team-alerts__error-hint {
    margin: 0 0 0.65rem;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-stone-600);
  }

  .team-alerts__skeleton {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.55rem;
    padding: 0.55rem 0.75rem;
  }

  .team-alerts__skeleton-icon,
  .team-alerts__skeleton-line {
    border-radius: var(--radius-sm);
    background: linear-gradient(
      90deg,
      var(--color-stone-100) 0%,
      var(--color-stone-200) 50%,
      var(--color-stone-100) 100%
    );
    background-size: 200% 100%;
    animation: team-alerts-shimmer 1.4s ease infinite;
  }

  .team-alerts__skeleton-icon {
    width: 1.65rem;
    height: 1.65rem;
    border-radius: 999px;
  }

  .team-alerts__skeleton-copy {
    display: grid;
    gap: 0.35rem;
    padding-top: 0.15rem;
  }

  .team-alerts__skeleton-line {
    height: 0.55rem;
  }

  .team-alerts__skeleton-line--wide {
    width: 88%;
  }

  .team-alerts__skeleton-line--medium {
    width: 62%;
  }

  @keyframes team-alerts-shimmer {
    0% {
      background-position: 100% 0;
    }
    100% {
      background-position: -100% 0;
    }
  }

  :global([data-theme="dark"]) .team-alerts__panel {
    border-color: var(--color-border);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.45);
  }

  :global([data-theme="dark"]) .team-alerts__row:hover,
  :global([data-theme="dark"]) .team-alerts__row:focus-visible {
    background: var(--color-stone-100);
  }

  :global([data-theme="dark"]) .team-alerts__row-title {
    color: var(--color-text);
  }

  :global([data-theme="dark"]) .team-alerts__row-body {
    color: var(--color-stone-600);
  }

  :global([data-theme="dark"]) .team-alerts__empty-title {
    color: var(--color-stone-800);
  }

  :global([data-theme="dark"]) .team-alerts__mark-all:hover,
  :global([data-theme="dark"]) .team-alerts__mark-all:focus-visible {
    background: var(--color-stone-100);
  }

  :global([data-theme="dark"]) .team-alerts__skeleton-icon,
  :global([data-theme="dark"]) .team-alerts__skeleton-line {
    background: linear-gradient(
      90deg,
      var(--color-stone-100) 0%,
      var(--color-stone-200) 50%,
      var(--color-stone-100) 100%
    );
    background-size: 200% 100%;
  }

  @media (max-width: 1100px) {
    .team-alerts__panel {
      right: -0.35rem;
      width: min(20rem, calc(100vw - 1.25rem));
    }
  }
</style>
