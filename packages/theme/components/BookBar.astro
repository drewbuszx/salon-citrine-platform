---
/**
 * Stub — Salon Citrine book bar.
 * The signature citrine bottom CTA bar from the marketing site.
 */
interface Props {
  href?: string;
  label?: string;
}

const { href = "/book", label = "Book Now" } = Astro.props;
---

<div class="sc-book-bar">
  <a class="sc-book-bar__link" href={href}>{label}</a>
</div>

<style>
  .sc-book-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 200;
    height: var(--book-bar-height);
    background: var(--color-book-bar-bg);
    border-top: 1px solid var(--color-text);
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .sc-book-bar__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--color-book-bar-text);
    font-family: var(--font-basic-title);
    font-size: clamp(1.3rem, 2.5vw, 1.4rem);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .sc-book-bar:has(.sc-book-bar__link:hover),
  .sc-book-bar:has(.sc-book-bar__link:focus-visible) {
    background: var(--color-book-bar-hover-bg);
    border-top-color: var(--color-book-bar-hover-text);
  }

  .sc-book-bar__link:hover,
  .sc-book-bar__link:focus-visible {
    color: var(--color-book-bar-hover-text);
  }
</style>
