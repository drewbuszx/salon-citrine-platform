# Supabase — Postgres, staff auth (team.saloncitrineindy.com), Edge Functions
SUPABASE_URL=https://kkhdkmplbxzsckjhpsgf.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Server-side Astro pages (apps/web, apps/team) read SUPABASE_URL + SUPABASE_ANON_KEY from repo root .env.
# For client-side Supabase (islands, browser JS), duplicate with the PUBLIC_ prefix:
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Stripe — all service payments (card-on-file, deposits, fees). Never store raw card numbers.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Astro exposes public env vars with PUBLIC_ prefix when wiring Stripe Elements:
# PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Twilio — client SMS (confirmations, reminders, opt-in marketing)
# Production: complete Twilio 10DLC brand/campaign registration before sending at scale.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=  # E.164 sender (+13175551234) or Messaging Service SID (MG...)

# Resend — all automated transactional email
RESEND_API_KEY=
RESEND_FROM_EMAIL=bookings@saloncitrineindy.com  # or onboarding@resend.dev for dev

# Shopify — retail + gift cards (balance lookup/redemption in Phase 2)
SHOPIFY_STORE_URL=
SHOPIFY_ACCESS_TOKEN=

# App
APP_URL=https://saloncitrineindy.com
TZ=America/Indiana/Indianapolis
